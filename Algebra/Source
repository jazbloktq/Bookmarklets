  // ── Reciprocal & exponent-sign post-processing ──

  // Convert a simplified result string so all exponents match the requested sign.
  // Strategy:
  //   positive-only: move every negative-exponent factor to denominator with positive exp
  //   negative-only: move every positive-exponent factor (and coeff) to denominator with negative exp
  function applyExpSignFilter(raw, mode) {
    if(mode==="any") return {result:raw, note:null};

    // Parse the result as a flat monomial: coeff × var^e × ...
    // We only handle simple monomial results (what simplify/indexForm produce).
    // For anything complex (contains +, -, spaces) we skip silently.
    const s = raw.replace(/\s/g,"");
    if(/[+\-]/.test(s.replace(/^\-/,""))) return {result:raw, note:null};

    // Extract coefficient and variable powers
    let work = s;
    let sign = 1;
    if(work.startsWith("-")){sign=-1; work=work.slice(1);}

    // Pull leading coefficient fraction like 5/2
    let numCoeff=1, denCoeff=1;
    const fracM = work.match(/^\((\d+)\/(\d+)\)/);
    const intM  = work.match(/^(\d+\.?\d*)/);
    if(fracM){ numCoeff=parseInt(fracM[1]); denCoeff=parseInt(fracM[2]); work=work.slice(fracM[0].length);}
    else if(intM){ numCoeff=parseFloat(intM[1]); work=work.slice(intM[0].length);}

    // Pull all variable^exp
    const varRegex=/([a-zA-Z])\^?(-?\d+)?/g;
    let m;
    const varPowers={};
    while((m=varRegex.exec(work))!==null){
      const v=m[1], e=m[2]!==undefined?parseInt(m[2]):1;
      varPowers[v]=(varPowers[v]||0)+e;
    }

    // Build numerator vars and denominator vars based on mode
    const numVars={}, denVars={};
    if(mode==="positive"){
      // Negative exponents move to denominator as positive
      for(const[v,e] of Object.entries(varPowers)){
        if(e>0) numVars[v]=e;
        else if(e<0) denVars[v]=-e;
        // e===0 means it cancels, skip
      }
    } else { // negative
      // Positive exponents move to denominator and become negative (shown as x^-n in den)
      // Equivalently: represent as 1/x^n in numerator with negative exponent form
      // But "negative exponents only" means we want all vars as negative exponents in the top.
      // So positive-exp vars become negative: x^3 → x^-3, x^-2 stays x^-2
      // Coeff stays in numerator; we just negate all positive exponents
      for(const[v,e] of Object.entries(varPowers)){
        if(e>0) numVars[v]=-e;       // flip to negative
        else if(e<0) numVars[v]=e;   // already negative
      }
    }

    // Reconstruct
    function buildMonomialStr(c, dc, vars){
      let s="";
      const signStr = sign===-1?"-":"";
      // coefficient
      let coeffStr="";
      if(dc!==1){
        coeffStr=fmtNum(c/dc);
        if(coeffStr.includes("/")) coeffStr="("+coeffStr+")";
      } else {
        coeffStr = c===1?"":fmtNum(c);
      }
      s += signStr;
      s += coeffStr;
      const entries=Object.entries(vars).sort((a,b)=>a[0].localeCompare(b[0]));
      for(const[v,e] of entries){
        s+=v;
        if(e!==1) s+="^"+e;
      }
      return s||fmtNum(sign*c/dc);
    }

    let result, note;
    if(mode==="positive"){
      const denEntries=Object.entries(denVars);
      if(denEntries.length===0){
        // No negative exponents — already fine, but double-check
        result = raw;
        note = null;
      } else {
        // Build numerator
        const numStr = buildMonomialStr(numCoeff,denCoeff,numVars);
        // Build denominator
        let dStr="";
        denEntries.sort((a,b)=>a[0].localeCompare(b[0])).forEach(([v,e])=>{dStr+=v+(e!==1?"^"+e:"");});
        result = (numStr==="1"||numStr===""?"1":numStr)+"/"+dStr;
        note = "Negative exponents moved to denominator (positive exponents only)";
      }
    } else {
      // negative mode: every var now has negative exponent in numVars; coeff stays
      const hasPositive = Object.values(numVars).some(e=>e>0);
      if(hasPositive){
        // Shouldn't happen with our logic but fall back
        result = raw; note=null;
      } else {
        result = buildMonomialStr(numCoeff, denCoeff, numVars);
        note = "Positive exponents converted to negative form (negative exponents only)";
      }
    }
    return {result, note};
  }

  // ── Run ──
  function run(){
    let raw=getRawMath();
    const mode=document.getElementById("__at-mode__").value;
    const reciprocal=document.getElementById("__at-recip__").checked;
    const expSign=document.getElementById("__at-exp-sign__").value;
    const solveFor=(document.getElementById("__at-solvefor__").value||"").trim().slice(0,4)||null;
    if(!raw){resultDiv.innerHTML='<span style="color:#ccc;">Enter an expression above…</span>';resultDiv.style.cssText="min-height:52px;padding:12px;border:1px solid #e8e8e8;border-radius:8px;background:#fafafa;font-size:13px;position:relative;";return;}
    try{
      // Apply reciprocal: wrap input as 1/(expr)
      if(reciprocal){
        const stripped=raw.replace(/^\(|\)$/g,"");
        raw="1/("+stripped+")";
      }

      let res;
      if(mode==="simplify")      res=doSimplify(raw);
      else if(mode==="expand")   res=doExpand(raw);
      else if(mode==="index")    res=doIndexForm(raw);
      else if(mode==="factorise")res=doFactorise(raw);
      else if(mode==="binomial") res=doBinomial(raw);
      else if(mode==="hcflcm")   res=doHcfLcm(raw);
      else if(mode==="excluded") res=doExcludedClean(raw);
      else                       res=doSolve(raw, solveFor);

      // Apply exponent-sign filter to result
      if(expSign!=="any"){
        const filtered=applyExpSignFilter(res.result, expSign);
        if(filtered.result!==res.result){
          res.steps.push({text:"Rewrite using "+(expSign==="positive"?"positive":"negative")+" exponents only: "+filtered.result, rule:expSign+" exponents"});
          res.result=filtered.result;
        }
      }

      const{result:val,steps}=res;

      const modeLabels={simplify:"Simplified",expand:"Expanded",index:"Index form",
        factorise:"Factorised",binomial:"Binomial Expansion",hcflcm:"HCF / LCM",
        excluded:"Excluded values",solve:"Solution"};
      const label=modeLabels[mode]||mode;

      // Split multiple results on the "  or  " separator used by doSolve / doExcluded
      const resultParts=val.split(/\s{2}or\s{2}/).map(s=>s.trim()).filter(Boolean);
      const multiResult=resultParts.length>1;

      function buildResultHtml(idx){
        const current=resultParts[idx];
        const latexResult=rawToLatex(current);
        let html='<button class="__at-copy-btn__" id="__at-copy-result__" title="Copy result as LaTeX">LaTeX ⎘</button>';
        html+='<div style="font-size:10px;color:#999;text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px;">'+label+'</div>';

        // Result display with optional prev/next switcher
        html+='<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-right:60px;">';
        html+='<div style="font-size:21px;font-weight:600;font-family:Georgia,serif;color:#111;flex:1;">'+renderMath(current)+'</div>';
        if(multiResult){
          html+='<div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">';
          html+='<button id="__at-prev-result__" style="width:26px;height:26px;border:1.5px solid #b0c8f8;border-radius:50%;background:'+(idx>0?"#1a5abf":"#e8e8e8")+';color:'+(idx>0?"#fff":"#bbb")+';font-size:14px;cursor:'+(idx>0?"pointer":"default")+';display:flex;align-items:center;justify-content:center;line-height:1;" '+(idx===0?'disabled':'')+'>‹</button>';
          html+='<span style="font-size:11px;color:#777;font-family:monospace;min-width:32px;text-align:center;">'+(idx+1)+' / '+resultParts.length+'</span>';
          html+='<button id="__at-next-result__" style="width:26px;height:26px;border:1.5px solid #b0c8f8;border-radius:50%;background:'+(idx<resultParts.length-1?"#1a5abf":"#e8e8e8")+';color:'+(idx<resultParts.length-1?"#fff":"#bbb")+';font-size:14px;cursor:'+(idx<resultParts.length-1?"pointer":"default")+';display:flex;align-items:center;justify-content:center;line-height:1;" '+(idx===resultParts.length-1?'disabled':'')+'>›</button>';
          html+='</div>';
        }
        html+='</div>';

        html+='<div style="border-top:1px solid #ececec;padding-top:8px;">';
        steps.forEach((step,i)=>{
          const text=typeof step==="string"?step:step.text;
          const rule=typeof step==="object"&&step.rule?step.rule:null;
          html+='<div style="display:flex;gap:8px;margin-bottom:6px;line-height:1.5;align-items:flex-start;">'+
            '<span style="min-width:17px;height:17px;border-radius:50%;background:#ebebeb;font-size:10px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;color:#777;">'+(i+1)+'</span>'+
            '<span style="color:#444;font-size:12px;font-family:Georgia,serif;">'+renderMath(text)+(rule?'<span class="__at-rule-badge__">'+escHtml(rule)+'</span>':"")+'</span>'+
            '</div>';
        });
        html+='</div>';
        return{html,latexResult};
      }

      function renderAtIdx(idx){
        const{html,latexResult}=buildResultHtml(idx);
        resultDiv.style.cssText="min-height:52px;padding:12px;border:1px solid #d0e4ff;border-radius:8px;background:#f5f9ff;font-size:13px;position:relative;";
        resultDiv.innerHTML=html;

        // Copy button
        const copyBtn=document.getElementById("__at-copy-result__");
        if(copyBtn){
          copyBtn._latex=latexResult;
          copyBtn.onclick=function(){
            navigator.clipboard.writeText(this._latex).then(()=>{
              this.textContent="Copied ✓";this.classList.add("copied");
              setTimeout(()=>{this.textContent="LaTeX ⎘";this.classList.remove("copied");},2000);
            }).catch(()=>{
              const ta=document.createElement("textarea");ta.value=this._latex;document.body.appendChild(ta);ta.select();document.execCommand("copy");document.body.removeChild(ta);
              this.textContent="Copied ✓";this.classList.add("copied");
              setTimeout(()=>{this.textContent="LaTeX ⎘";this.classList.remove("copied");},2000);
            });
          };
        }

        // Switcher buttons
        if(multiResult){
          const prevBtn=document.getElementById("__at-prev-result__");
          const nextBtn=document.getElementById("__at-next-result__");
          if(prevBtn)prevBtn.onclick=()=>{if(idx>0)renderAtIdx(idx-1);};
          if(nextBtn)nextBtn.onclick=()=>{if(idx<resultParts.length-1)renderAtIdx(idx+1);};
        }
      }

      renderAtIdx(0);
      pushHistory(raw,mode,val);

    } catch(err){
      resultDiv.style.cssText="min-height:52px;padding:12px;border:1px solid #ffcccc;border-radius:8px;background:#fff5f5;font-size:13px;position:relative;";
      resultDiv.innerHTML='<span style="color:#c00;font-weight:600;">Error:</span> <span style="color:#c00;">'+escHtml(err.message)+'</span>';
    }
  }

  // ── Close & drag ──
  document.getElementById("__at-x__").onclick=()=>overlay.remove();
  let dragging=false,dx=0,dy=0;
  document.getElementById("__at-hdr__").addEventListener("mousedown",e=>{
    dragging=true;const r=overlay.getBoundingClientRect();dx=e.clientX-r.left;dy=e.clientY-r.top;
  });
  document.addEventListener("mousemove",e=>{
    if(!dragging)return;
    overlay.style.left=(e.clientX-dx)+"px";overlay.style.top=(e.clientY-dy)+"px";overlay.style.right="auto";
  });
  document.addEventListener("mouseup",()=>{dragging=false;});

  document.getElementById("__at-go__").onclick=run;

  // Show/hide "Solve for" row based on mode
  const modeEl=document.getElementById("__at-mode__");
  const solveForRow=document.getElementById("__at-solvefor-row__");
  function updateSolveForVisibility(){
    solveForRow.style.display=modeEl.value==="solve"?"flex":"none";
  }
  modeEl.addEventListener("change",updateSolveForVisibility);
  updateSolveForVisibility();
  console.log("%c Algebra Tool loaded!", "color:#1a5abf;font-weight:bold;font-size:14px;");
  console.log("Modes: simplify · expand · index · factorise · binomial · hcf/lcm · excluded · solve");
  console.log("Run the script again to close the panel.");
})();
