// ============================================================
//  ALGEBRA EXPRESSION TOOL — paste into browser console
//
//  Input modes:
//    • Rich editor: ^ = power, / = ÷, * = ×, ? = fraction
//    • LaTeX: paste  p^5\times \left(p^2\right)^3
//             and it auto-converts to the visual rich format
//    • Plain math: paste  3x^5 * 4x^6  etc.
//
//  Keyboard shortcuts (in main editor):
//    ^  or  Shift+digit/letter  → superscript exponent
//    ArrowLeft/Right at edge of sup → exit sup
//    ArrowDown anywhere in sup → exit sup
//    Escape → exit sup
//    ?  or  Shift+/  → fraction widget
//    Tab (inside fraction) → numerator → denominator → after
//
//  Modes: Simplify · Expand · Index Form · Excluded Values ·
//         Solve · Factorise · Binomial Expand · HCF/LCM
// ============================================================

(function () {
  const existing = document.getElementById("__algebra-tool__");
  if (existing) { existing.remove(); return; }

  // ══════════════════════════════════════════════════════════
  //  LaTeX ↔ raw-math converters
  // ══════════════════════════════════════════════════════════
  function latexToRaw(latex) {
    let s = latex.trim();
    s = s.replace(/^\$\$([\s\S]*)\$\$$/, (_,x)=>x);
    s = s.replace(/^\$|\$$/g, "");
    s = s.replace(/^\\\[|\\\]$/g, "");
    s = s.replace(/^\\\(|\\\)$/g, "");
    s = s.replace(/^\\begin\{[^}]*\}|\\end\{[^}]*\}$/g, "");
    s = s.trim();
    s = s.replace(/\\left\s*\(/g,"(").replace(/\\right\s*\)/g,")");
    s = s.replace(/\\left\s*\[/g,"(").replace(/\\right\s*\]/g,")");
    s = s.replace(/\\left\s*\{/g,"(").replace(/\\right\s*\}/g,")");
    s = s.replace(/\\left\s*\|/g,"|").replace(/\\right\s*\|/g,"|");
    s = s.replace(/\\left\s*\./g,"").replace(/\\right\s*\./g,"");
    s = expandLatexCmd(s,"frac",  2,a=>"("+a[0]+")/("+a[1]+")");
    s = expandLatexCmd(s,"dfrac", 2,a=>"("+a[0]+")/("+a[1]+")");
    s = expandLatexCmd(s,"tfrac", 2,a=>"("+a[0]+")/("+a[1]+")");
    s = s.replace(/\\sqrt\s*\[([^\]]+)\]\s*\{([^}]*)\}/g,"($2)^(1/$1)");
    s = expandLatexCmd(s,"sqrt",1,a=>"sqrt("+a[0]+")");
    s = s.replace(/\\cdot\b/g,"*").replace(/\\times\b/g,"*")
         .replace(/\\div\b/g,"/").replace(/\\pm\b/g,"±");
    ["sin","cos","tan","cot","sec","csc","arcsin","arccos","arctan",
     "ln","log","exp","abs","min","max","gcd","lcm"].forEach(fn=>{
      s = s.replace(new RegExp("\\\\"+fn+"\\b","g"),fn);
    });
    const greek={alpha:"α",beta:"β",gamma:"γ",delta:"δ",epsilon:"ε",
      zeta:"ζ",eta:"η",theta:"θ",iota:"ι",kappa:"κ",lambda:"λ",
      mu:"μ",nu:"ν",xi:"ξ",pi:"π",rho:"ρ",sigma:"σ",tau:"τ",
      upsilon:"υ",phi:"φ",chi:"χ",psi:"ψ",omega:"ω",
      Gamma:"Γ",Delta:"Δ",Theta:"Θ",Lambda:"Λ",Xi:"Ξ",
      Pi:"Π",Sigma:"Σ",Upsilon:"Υ",Phi:"Φ",Psi:"Ψ",Omega:"Ω",infty:"∞"};
    Object.entries(greek).forEach(([k,v])=>{
      s = s.replace(new RegExp("\\\\"+k+"\\b","g"),v);
    });
    ["text","mathrm","mathbf","mathit","mathbb","operatorname"].forEach(cmd=>{
      s = expandLatexCmd(s,cmd,1,a=>a[0]);
    });
    s = s.replace(/\^\s*\{/g,"^(");
    s = s.replace(/_\s*\{([^}]*)\}/g,"").replace(/_[a-zA-Z0-9]/g,"");
    s = s.replace(/\{/g,"(").replace(/\}/g,")");
    s = s.replace(/\s+/g,"");
    s = s.replace(/\\[a-zA-Z]+\s*/g,"");
    s = s.replace(/\(\)/g,"");
    return s;
  }

  // Convert a result back to LaTeX for clipboard copy
  function rawToLatex(s) {
    if (!s) return s;
    let t = s;
    // fractions  a/b or (a)/(b)
    t = t.replace(/\(([^()]+)\)\/\(([^()]+)\)/g, (_,n,d)=>`\\frac{${n}}{${d}}`);
    t = t.replace(/(-?\w+)\/(\d+)/g, (_,n,d)=>`\\frac{${n}}{${d}}`);
    // exponents
    t = t.replace(/\^(-?\d+)/g, (_,e)=>`^{${e}}`);
    // multiplication dot
    t = t.replace(/×/g,"\\times ");
    // ÷
    t = t.replace(/÷/g,"\\div ");
    // ± 
    t = t.replace(/±/g,"\\pm ");
    // ≠
    t = t.replace(/≠/g,"\\neq ");
    // "or" stays as text
    t = t.replace(/ or /g,"\\text{ or }");
    return t;
  }

  function expandLatexCmd(s,cmd,numArgs,replacer) {
    const tag="\\"+cmd; let result="",i=0;
    while(i<s.length){
      const idx=s.indexOf(tag,i);
      if(idx===-1){result+=s.slice(i);break;}
      const after=s[idx+tag.length];
      if(after&&/[a-zA-Z]/.test(after)){result+=s.slice(i,idx+1);i=idx+1;continue;}
      result+=s.slice(i,idx);
      let pos=idx+tag.length;
      while(pos<s.length&&s[pos]===" ")pos++;
      const args=[];
      for(let a=0;a<numArgs;a++){
        while(pos<s.length&&s[pos]===" ")pos++;
        if(s[pos]==="{"){
          const end=findMatchingBrace(s,pos);
          args.push(s.slice(pos+1,end));pos=end+1;
        } else {args.push(s[pos]||"");pos++;}
      }
      result+=replacer(args);i=pos;
    }
    return result;
  }

  function findMatchingBrace(s,open) {
    let depth=0;
    for(let i=open;i<s.length;i++){
      if(s[i]==="{")depth++;
      else if(s[i]==="}"){depth--;if(depth===0)return i;}
    }
    return s.length-1;
  }

  function findMatchingParen(s,open) {
    let depth=0;
    for(let i=open;i<s.length;i++){
      if(s[i]==="(")depth++;
      else if(s[i]===")"){depth--;if(depth===0)return i;}
    }
    return s.length-1;
  }

  function looksLikeLatex(s) {
    return /\\[a-zA-Z]/.test(s)||/\\\(|\\\[/.test(s)||(/\$/.test(s)&&/[a-zA-Z^_{}\\]/.test(s));
  }

  // ══════════════════════════════════════════════════════════
  //  Math helpers
  // ══════════════════════════════════════════════════════════
  function fmtNum(n) {
    const r=parseFloat(n.toFixed(9));
    if(Number.isInteger(r))return String(r);
    for(let d=2;d<=200;d++){
      const num=Math.round(r*d);
      if(Math.abs(num/d-r)<1e-9)return num+"/"+d;
    }
    return r.toFixed(4).replace(/\.?0+$/,"");
  }

  function normalise(s) {
    return s.replace(/\s+/g,"").replace(/[÷]/g,"/").replace(/[×·]/g,"*");
  }

  function gcd(a,b) {
    a=Math.abs(Math.round(a));b=Math.abs(Math.round(b));
    while(b){const t=b;b=a%b;a=t;}return a;
  }
  function lcm(a,b){return Math.abs(a*b)/gcd(a,b);}

  function tokeniseTopLevel(s) {
    const tokens=[];let depth=0,cur="";
    for(let i=0;i<s.length;i++){
      const c=s[i];
      if(c==="("){depth++;cur+=c;}
      else if(c===")"){depth--;cur+=c;}
      else if((c==="*"||c==="/")&&depth===0){if(cur)tokens.push(cur);tokens.push(c);cur="";}
      else cur+=c;
    }
    if(cur)tokens.push(cur);return tokens;
  }

  // Handles multi-variable like 2xy^3, leading + sign
  function parseMonomial(s) {
    s=s.replace(/^\(+|\)+$/g,"");
    let sign=1;
    if(s.startsWith("-")){sign=-1;s=s.slice(1);}
    else if(s.startsWith("+"))s=s.slice(1);
    const nm=s.match(/^(\d+\.?\d*)/);
    let coeff=nm?parseFloat(nm[1]):1;
    const rest=nm?s.slice(nm[0].length):s;
    const vars={};
    const vr=/([a-zA-Z])(?:\^(-?\d+))?/g;
    let m;
    while((m=vr.exec(rest))!==null)
      vars[m[1]]=(vars[m[1]]||0)+(m[2]!==undefined?parseInt(m[2]):1);
    return {coeff:sign*coeff,vars};
  }

  function parsePowerToken(t) {
    const m=t.match(/^(-?)\((.+)\)\^(-?\d+)$/);
    if(m)return{sign:m[1]==="-"?-1:1,inner:m[2],outerExp:parseInt(m[3])};
    return null;
  }

  function parseMonomialWithOuterPow(t) {
    const pow=parsePowerToken(t);
    if(pow){
      const inner=parseMonomial(pow.inner);
      const n=pow.outerExp;
      const nc=Math.pow(inner.coeff,n);
      const newVars={};
      for(const[v,e]of Object.entries(inner.vars))newVars[v]=e*n;
      return{coeff:nc,vars:newVars};
    }
    return parseMonomial(t);
  }

  function formatMonomial(coeff,vars) {
    const r=parseFloat(coeff.toFixed(9));let s="";
    const entries=Object.entries(vars).filter(([,e])=>e!==0).sort((a,b)=>a[0].localeCompare(b[0]));
    if(entries.length===0)return fmtNum(r);
    if(r===-1)s="-";else if(r!==1){const fn=fmtNum(r);s=(fn.includes("/")&&entries.length>0)?"("+fn+")":fn;}
    for(const[v,e]of entries){s+=v;if(e!==1)s+="^"+e;}
    return s||"1";
  }

  function tryParseNumber(s){s=s.replace(/^\(+|\)+$/g,"");const n=parseFloat(s);return isNaN(n)?null:n;}

  function tryParseMonomial(s) {
    s=s.replace(/^\(+|\)+$/g,"");
    // handles e.g. 3x^2, -x, 2x, x^3
    const m=s.match(/^(-?\d*\.?\d*)([a-zA-Z])(?:\^(-?\d+))?$/);
    if(!m)return null;
    const coeff=m[1]?(m[1]==="-"?-1:parseFloat(m[1])):1;
    return{coeff,varName:m[2],exp:m[3]?parseInt(m[3]):1};
  }

  function parsePolynomial(s) {
    // Use splitTopLevelAdd so nested parens are respected
    s=s.replace(/^\(+|\)+$/g,"");
    const terms=splitTopLevelAdd(s);
    let a=0,b=0,c=0,varName=null;
    for(const t of terms){
      const m=parseMonomial(t);
      const v=Object.keys(m.vars)[0];
      if(!varName&&v)varName=v;
      const exp=v?m.vars[v]:0;
      if(exp===2)a+=m.coeff;
      else if(exp===1)b+=m.coeff;
      else c+=m.coeff;
    }
    return{a,b,c,varName:varName||"x"};
  }

  function fmtPoly(a,b,c,v) {
    let s="";
    if(a){s+=(a===1?"":(a===-1?"-":a))+v+"²";}
    if(b){s+=(b>0&&s?" + ":b<0?" − ":"")+( Math.abs(b)===1?"":Math.abs(b))+v;}
    if(c){s+=(c>0&&s?" + ":c<0?" − ":"")+Math.abs(c);}
    return s||"0";
  }

  function findTopLevelSlash(s) {
    let depth=0;
    for(let i=0;i<s.length;i++){
      if(s[i]==="(")depth++;else if(s[i]===")")depth--;
      else if(s[i]==="/"&&depth===0)return i;
    }
    return -1;
  }

  function solveForZero(expr,steps) {
    expr=expr.replace(/^\(+|\)+$/g,"");const zeros=[];
    const linM=expr.match(/^(-?\d*\.?\d*)([a-zA-Z])([+-]\d+\.?\d*)?$/);
    if(linM){
      const a=linM[1]?(linM[1]==="-"?-1:parseFloat(linM[1])):1;
      const b=linM[3]?parseFloat(linM[3]):0;const z=-b/a;
      steps.push("Solve: "+(a!==1?a:"")+linM[2]+(b>=0?"+":"")+b+" = 0  →  "+linM[2]+" = "+fmtNum(z));
      zeros.push(fmtNum(z));return zeros;
    }
    const qM=expr.match(/^(-?\d*\.?\d*)[a-zA-Z]\^2([+-]\d*\.?\d*[a-zA-Z])?([+-]\d+\.?\d*)?$/);
    if(qM){
      const a=qM[1]?(qM[1]==="-"?-1:parseFloat(qM[1])):1;
      const bv=qM[2]?parseFloat(qM[2].replace(/[a-zA-Z]/g,"")):0;
      const cv=qM[3]?parseFloat(qM[3]):0;const disc=bv*bv-4*a*cv;
      if(disc<0){steps.push("Discriminant < 0, no real zeros");return[];}
      const r1=(-bv+Math.sqrt(disc))/(2*a),r2=(-bv-Math.sqrt(disc))/(2*a);
      steps.push("Quadratic formula: x = "+fmtNum(r1)+(Math.abs(disc)>1e-9?", x = "+fmtNum(r2):""));
      zeros.push(fmtNum(r1));if(Math.abs(disc)>1e-9)zeros.push(fmtNum(r2));return zeros;
    }
    if(/^[a-zA-Z](\^\d+)?$/.test(expr)){steps.push("Variable = 0");zeros.push("0");return zeros;}
    throw new Error("Could not find zeros of: "+expr);
  }

  // ══════════════════════════════════════════════════════════
  //  SIMPLIFY
  // ══════════════════════════════════════════════════════════
  function doSimplify(raw) {
    const s=normalise(raw);const steps=[];
    const tokens=tokeniseTopLevel(s);let coeff=1,vars={},curDen=false;
    steps.push({text:"Original: "+s.replace(/\*/g," × ").replace(/\//g," ÷ ")});
    steps.push({text:"Apply product/quotient of powers (add exponents for ×, subtract for ÷):",rule:"index law"});
    for(const t of tokens){
      if(t==="*"){curDen=false;continue;}if(t==="/"){curDen=true;continue;}
      const m=parseMonomialWithOuterPow(t);
      if(curDen){
        coeff/=m.coeff;
        for(const[v,e]of Object.entries(m.vars))vars[v]=(vars[v]||0)-e;
        steps.push({text:"  ÷ "+t+" → ÷"+fmtNum(m.coeff)+", "+Object.entries(m.vars).map(([v,e])=>v+"^(−"+e+")").join(" "),rule:"quotient law"});
      } else {
        coeff*=m.coeff;
        for(const[v,e]of Object.entries(m.vars))vars[v]=(vars[v]||0)+e;
        steps.push({text:"  × "+t+" → ×"+fmtNum(m.coeff)+", "+Object.entries(m.vars).map(([v,e])=>v+"^(+"+e+")").join(" "),rule:"product law"});
      }
    }
    const result=formatMonomial(coeff,vars);
    steps.push({text:"Result: "+result});
    return{result,steps};
  }

  // ══════════════════════════════════════════════════════════
  //  EXCLUDED VALUES
  // ══════════════════════════════════════════════════════════
  function doExcluded(raw) {
    const s=normalise(raw);const steps=[];
    const si=findTopLevelSlash(s);
    if(si===-1)throw new Error("No division found. Enter a fraction like 5/(x−3).");
    const den=s.slice(si+1).replace(/^\(|\)$/g,"");
    steps.push({text:"Denominator: "+den});
    steps.push({text:"Set denominator = 0: "+den+" = 0",rule:"excluded values"});
    const zeros=solveForZero(den,steps.map(s=>s).reduce((a,s)=>{a.push(s.text);return a;},[]).reduce((_,__)=>__));
    // re-run cleanly
    const stepsClean=[];
    stepsClean.push({text:"Denominator: "+den});
    stepsClean.push({text:"Set denominator = 0: "+den+" = 0",rule:"excluded values"});
    const zeros2=solveForZero(den,stepsClean.map(()=>""));
    // just collect zeros directly
    const zs=[];
    solveForZero(den,zs);
    stepsClean.push(...zs.map(z=>({text:"Solution: x = "+z,rule:"solve"})));
    const result=zs.length?zs.map(z=>"x ≠ "+z).join(",  "):"No excluded values";
    return{result,steps:stepsClean};
  }

  function doExcludedClean(raw) {
    const s=normalise(raw);const steps=[];
    const si=findTopLevelSlash(s);
    if(si===-1)throw new Error("No division found. Enter a fraction like 5/(x−3).");
    const den=s.slice(si+1).replace(/^\(|\)$/g,"");
    steps.push({text:"Denominator: "+den});
    steps.push({text:"Set denominator = 0: "+den+" = 0",rule:"excluded values"});
    const zeroSteps=[];
    const zeros=solveForZero(den,zeroSteps);
    zeroSteps.forEach(t=>steps.push({text:t,rule:"solve"}));
    const result=zeros.length?zeros.map(z=>"x ≠ "+z).join(",  "):"No excluded values";
    return{result,steps};
  }

  // ══════════════════════════════════════════════════════════
  //  SOLVE
  // ══════════════════════════════════════════════════════════
  // ══════════════════════════════════════════════════════════
  //  EXPONENTIAL EQUATION SOLVER  (same-base index law)
  //  e.g. a^x / a^4 = 1/a  →  x - 4 = -1  →  x = 3
  // ══════════════════════════════════════════════════════════
  function doSolveExponential(lhs, rhs, steps, solveFor) {
    // ── Strategy 1: compound-base  (expr)^x = (expr2)
    // If either side is entirely (something)^singleVar, expand both sides via index laws
    // and equate exponents of each variable to get x.
    function tryCompoundBase(lhs, rhs, solveFor) {
      const norm = s => normalise(s);

      // Detect the unknown exponent variable: look for a letter that appears as ^letter on either side
      // Pattern: something^letter — the letter is the unknown
      function findExpVar(expr) {
        const m = expr.match(/\)\^([a-zA-Z])$/) || expr.match(/\^([a-zA-Z])(?:[^a-zA-Z]|$)/);
        return m ? m[1] : null;
      }

      // Extract the base expression and exponent variable from an expression like:
      //   (inner)^x          → base=inner, expVar=x
      //   (num)/(den)^x      → base=(num)/(den), expVar=x  [^x on whole fraction]
      //   (num)^x/(den)^x    → same
      function extractCompound(expr) {
        const s = norm(expr);
        // Case 1: entire expr is (inner)^var
        const m1 = s.match(/^\((.+)\)\^([a-zA-Z])$/);
        if(m1) return {base:m1[1], expVar:m1[2]};

        // Case 2: fraction where ^var trails at end — (num)/(den)^var or (num)^var/(den)^var
        // Find the exponent variable from the end of the string
        const trailM = s.match(/\^([a-zA-Z])$/);
        if(!trailM) return null;
        const expVar = trailM[1];

        // Strip all occurrences of ^expVar from the expression to get the base fraction
        const baseExpr = s.replace(new RegExp("\\^"+expVar+"\\b","g"),"");
        // Verify the result looks like a valid fraction or monomial
        if(/[a-zA-Z]/.test(baseExpr)) return {base:baseExpr, expVar};
        return null;
      }

      const lhsC = extractCompound(lhs);
      const rhsC = extractCompound(rhs);

      let baseExpr, expVar, otherExpr;
      if(lhsC && (!solveFor || solveFor===lhsC.expVar)){
        expVar=lhsC.expVar; baseExpr=lhsC.base; otherExpr=rhs;
      } else if(rhsC && (!solveFor || solveFor===rhsC.expVar)){
        expVar=rhsC.expVar; baseExpr=rhsC.base; otherExpr=lhs;
      } else return null;

      // Expand baseExpr and otherExpr using doSimplify
      let baseSimp, otherSimp;
      try { baseSimp = doSimplify(normalise(baseExpr)); } catch(e){ return null; }
      try { otherSimp = doSimplify(normalise(otherExpr)); } catch(e){ return null; }

      steps.push({text:"Simplify base: ("+baseSimp.result+")^"+expVar+" = "+otherSimp.result, rule:"index law"});

      // Parse both as monomials
      let baseMon, otherMon;
      try { baseMon = parseMonomial(baseSimp.result); } catch(e){ return null; }
      try { otherMon = parseMonomial(otherSimp.result); } catch(e){ return null; }

      // (baseMon)^expVar = otherMon
      // For each variable v: baseMon.vars[v] * expVar = otherMon.vars[v]
      let xVal = null;
      const checks = [];
      for(const [v,e] of Object.entries(baseMon.vars)){
        const target = otherMon.vars[v]||0;
        if(e===0) continue;
        const candidate = target/e;
        checks.push({v, baseExp:e, targetExp:target, candidate});
        if(xVal===null) xVal=candidate;
        else if(Math.abs(xVal-candidate)>1e-9) return null; // inconsistent
      }
      for(const [v,e] of Object.entries(otherMon.vars)){
        if(!(v in baseMon.vars)&&e!==0) return null;
      }
      if(xVal===null) return null;

      const ex = checks[0];
      if(ex){
        steps.push({text:"Equate exponents of "+ex.v+": "+fmtNum(ex.baseExp)+"×"+expVar+" = "+fmtNum(ex.targetExp), rule:"index law"});
        steps.push({text:expVar+" = "+fmtNum(ex.targetExp)+" ÷ "+fmtNum(ex.baseExp)+" = "+fmtNum(xVal), rule:"solve"});
      }
      // Verify with another variable if available
      if(checks.length>1){
        const ex2=checks[1];
        steps.push({text:"Verify with "+ex2.v+": "+fmtNum(ex2.baseExp)+"×"+fmtNum(xVal)+" = "+fmtNum(ex2.targetExp)+" ✓", rule:"check"});
      }
      return {result: expVar+" = "+fmtNum(xVal), steps};
    }

    const compound = tryCompoundBase(lhs, rhs, solveFor);
    if(compound) return compound;

    // ── Strategy 2: same-base index law (original logic) ──
    // Collect all base^exp tokens from both sides
    // Returns null if it can't handle it
    function collectBaseExps(expr) {
      // Normalise and flatten: strip spaces, convert ÷ to /
      let s = normalise(expr);
      // Recursively strip outer parens from the whole expression
      while(s.startsWith("(")&&s.endsWith(")")){
        // Check if the outer parens actually wrap the whole thing
        let d=0,wraps=true;
        for(let i=0;i<s.length-1;i++){
          if(s[i]==="(")d++;else if(s[i]===")"){d--;if(d===0){wraps=false;break;}}
        }
        if(wraps)s=s.slice(1,-1);else break;
      }

      // Split into numerator and denominator groups at top-level /
      // Build a flat list of {base, exp, sign} where sign is +1 (num) or -1 (den)
      const pairs = [];

      function parseGroup(str, isDen) {
        // Strip outer parens
        let t = str;
        while(t.startsWith("(")&&t.endsWith(")")){
          let d=0,wraps=true;
          for(let i=0;i<t.length-1;i++){
            if(t[i]==="(")d++;else if(t[i]===")"){d--;if(d===0){wraps=false;break;}}
          }
          if(wraps)t=t.slice(1,-1);else break;
        }

        // Handle (inner_product)^exp — distribute exponent: (ab)^x → a^x * b^x
        // Match: starts with ( ... ) ^ exp where inner contains only variable letters/numbers
        const compoundM = t.match(/^\(([^()]+)\)\^(.+)$/);
        if(compoundM){
          const inner = compoundM[1];
          const outerExp = compoundM[2].replace(/^\(|\)$/g,"");
          // inner should be a product of simple vars like "ab", "a*b", "2ab" etc.
          // Strip leading coefficient
          const innerCoeffStrip = inner.match(/^-?\d*\.?\d*([a-zA-Z].*)$/) || [null, inner];
          const innerVarPart = innerCoeffStrip[1] || inner;
          // Extract each variable from inner (implicit exp 1 each)
          const varRe = /([a-zA-Z])(?:\^(-?\d+))?/g;
          let vm;
          while((vm=varRe.exec(innerVarPart))!==null){
            const v=vm[1], baseE=vm[2]!==undefined?parseInt(vm[2]):1;
            // Combined exponent: baseE * outerExp
            const combinedExp = baseE===1 ? outerExp : "("+baseE+"*("+outerExp+"))";
            pairs.push({base:v, exp: isDen?"(-("+combinedExp+"))":combinedExp});
          }
          return true;
        }

        // Strip optional leading numeric coefficient (e.g. "3a^4" → "a^4")
        const coeffStrip = t.match(/^-?\d*\.?\d*([a-zA-Z].*)$/);
        if(coeffStrip) t = coeffStrip[1];

        // Parse each base^exp pair by scanning left to right.
        // A letter starts a NEW BASE unless it is preceded by a digit AND is not itself
        // followed by ^ (meaning it's part of the preceding exponent, like the x in a^3x).
        let found = false;
        let i2 = 0;
        while(i2 < t.length){
          if(!/[a-zA-Z]/.test(t[i2])){i2++;continue;}
          const letter = t[i2];
          const afterLetter = t.slice(i2+1);

          if(afterLetter.startsWith("^")){
            // This letter has its own exponent — it's definitely a base.
            // Scan the exponent: grab chars until we hit a letter that ITSELF has a ^
            // (meaning that letter is a new base), or a letter not preceded by digit (new base).
            const expContent = afterLetter.slice(1); // after the ^
            let expEnd = 0;
            while(expEnd < expContent.length){
              const c = expContent[expEnd];
              if(/[a-zA-Z]/.test(c)){
                // Is this letter part of the exponent or a new base?
                // It's part of exponent if preceded by digit AND not followed by ^
                const prev = expEnd>0 ? expContent[expEnd-1] : "^";
                const nextC = expContent[expEnd+1];
                const prevIsDigit = /\d/.test(prev);
                const prevIsHat = prev === "^";
                const nextIsHat = nextC === "^";
                if((prevIsDigit || prevIsHat) && !nextIsHat){
                  expEnd++; // part of exponent (e.g. "x" alone, or "3x" where x follows 3)
                } else {
                  break; // new base starts here
                }
              } else {
                expEnd++;
              }
            }
            const expStr = expContent.slice(0, expEnd).replace(/^\(|\)$/g,"");
            pairs.push({base: letter, exp: isDen ? "(-("+expStr+"))" : expStr});
            found = true;
            i2 = i2 + 1 + 1 + expEnd; // letter + "^" + expContent consumed
          } else {
            // No ^ after this letter — bare variable, exponent = 1
            pairs.push({base: letter, exp: isDen ? "-1" : "1"});
            found = true;
            i2++;
          }
        }
        if(found) return true;

        // Pure number — skip
        if(/^-?\d+\.?\d*$/.test(t)||t==="1") return true;
        return false;
      }

      // Tokenise at top-level * and /
      let tokens=[], cur="", depth=0, curDen=false;
      const denFlags=[];
      for(let i=0;i<s.length;i++){
        const c=s[i];
        if(c==="(")depth++;
        else if(c===")")depth--;
        else if(c==="*"&&depth===0){tokens.push({t:cur,den:curDen});cur="";curDen=false;continue;}
        else if(c==="/"&&depth===0){tokens.push({t:cur,den:curDen});cur="";curDen=true;continue;}
        cur+=c;
      }
      if(cur)tokens.push({t:cur,den:curDen});

      for(const {t,den} of tokens){
        if(!t) continue;
        if(!parseGroup(t,den)) return null;
      }
      return pairs;
    }

    const lhsPairs = collectBaseExps(lhs);
    const rhsPairs = collectBaseExps(rhs);
    if(!lhsPairs||!rhsPairs) return null;

    // Group by base: net exponent (LHS positive, RHS negative)
    const baseMap = {};
    for(const {base,exp} of lhsPairs){
      if(!baseMap[base]) baseMap[base]={lhs:[],rhs:[]};
      baseMap[base].lhs.push(exp);
    }
    for(const {base,exp} of rhsPairs){
      if(!baseMap[base]) baseMap[base]={lhs:[],rhs:[]};
      baseMap[base].rhs.push(exp);
    }

    // For each base, we get: sum(lhsExps) = sum(rhsExps)
    // Expand and look for a linear equation in one unknown

    // Find which letter is the unknown (appears in an exponent as a variable, not as a base)
    const bases = new Set(Object.keys(baseMap));
    const allExpTokens = [...lhsPairs,...rhsPairs].map(p=>p.exp).join(" ");
    // The unknown is a single letter appearing in exponents that isn't a known base
    // Find letters in exponent strings
    const expLetters = new Set([...allExpTokens.matchAll(/([a-zA-Z])/g)].map(m=>m[1]));
    // Remove bases — the unknown is a letter that appears in the exponent strings but not only as a base
    // Actually we want letters that appear in exponent positions
    let unknowns = [...expLetters].filter(l=>!bases.has(l)||
      // also allow if a base letter also appears in exponents of other bases
      [...lhsPairs,...rhsPairs].some(p=>p.base!==l && p.exp.includes(l))
    );
    // More robust: find letters that appear inside exponent strings
    const exponentStringLetters = new Set([...allExpTokens.matchAll(/([a-zA-Z])/g)].map(m=>m[1]));
    // Filter to those that are actually the exponent variable (simple letter in exp string)
    // The unknown is the letter that shows up in exponents not as a whole numeric value
    // Let's just find letters in exponent values
    let unknown = solveFor || null;
    if(!unknown){
      for(const {base,exp} of [...lhsPairs,...rhsPairs]){
        const m = exp.match(/^-?([a-zA-Z])$/);
        if(m && m[1]!==base){ unknown=m[1]; break; }
        const cm = exp.match(/([a-zA-Z])/);
        if(cm && cm[1]!==base){ unknown=cm[1]; break; }
      }
    }
    if(!unknown) return null;

    steps.push({text:"Identify base(s): "+[...bases].join(", ")+";  unknown in exponent: "+unknown,rule:"exponential equation"});

    // For equations with a single base used throughout, equate the exponents
    // LHS net exponent = RHS net exponent for that base
    // Build a simple linear equation: sum LHS exps - sum RHS exps = 0

    // Try to parse each exponent as a linear expression in `unknown`
    // ax + b form
    function parseLinearExp(expStr, unknownVar) {
      let s = expStr.replace(/\s/g,"");
      // Handle negation wrapper from den: (-(inner)) — check BEFORE stripping parens
      const negM = s.match(/^\(-\((.+)\)\)$/) || s.match(/^-\((.+)\)$/);
      if(negM){
        const inner = parseLinearExp(negM[1], unknownVar);
        if(!inner) return null;
        return {a: -inner.a, b: -inner.b};
      }
      // Now strip outer parens
      s = s.replace(/^\(|\)$/g,"");
      // Handle plain negation of a simple value: -(4) already handled above, but "-4" etc
      // Simple cases: "x", "-x", "2x", "-2x", "3", "-3", "x+2", "x-2", "2x+3" etc
      const fullM = s.match(/^(-?\d*\.?\d*)([a-zA-Z])?([+-]\d+\.?\d*)?$/) ||
                    s.match(/^([+-]?\d*\.?\d*)([a-zA-Z])([+-]\d+\.?\d*)?$/);
      if(fullM){
        const cStr=fullM[1], vStr=fullM[2], numStr=fullM[3];
        const hasVar = vStr && vStr===unknownVar;
        const a = hasVar ? (cStr==="-"?-1:cStr===""||cStr==="+"?1:parseFloat(cStr)) : 0;
        const b = (numStr?parseFloat(numStr):0) + (hasVar?0:(cStr?parseFloat(cStr):0));
        return {a, b};
      }
      return null;
    }

    // Compute totalA just to check if unknown appears anywhere in exponents at all
    let totalA=0;
    for(const [base, {lhs:lhsExps, rhs:rhsExps}] of Object.entries(baseMap)){
      for(const exp of [...lhsExps,...rhsExps]){
        const parsed = parseLinearExp(exp, unknown);
        if(parsed) totalA+=Math.abs(parsed.a);
      }
    }

    if(totalA===0) return null; // unknown doesn't appear in any exponent

    // Clean up display of wrapped negations like (-(4)) → -4
    function cleanExpDisplay(e){return e.replace(/\(-\((.+?)\)\)/g,"(-$1)").replace(/^\((-?.+)\)$/,"$1");}

    // ── Per-base consistency check and solve ──
    // Rather than summing across all bases (which double-counts x),
    // solve from the first base that gives a linear equation, then verify all others match.
    const perBase = {};
    for(const [base, {lhs:lhsExps, rhs:rhsExps}] of Object.entries(baseMap)){
      let bA=0, bB=0;
      let ok=true;
      for(const exp of lhsExps){
        const p=parseLinearExp(exp,unknown);
        if(!p){ok=false;break;}
        bA+=p.a; bB+=p.b;
      }
      if(!ok) continue;
      for(const exp of rhsExps){
        const p=parseLinearExp(exp,unknown);
        if(!p){ok=false;break;}
        bA-=p.a; bB-=p.b;
      }
      if(!ok) continue;
      // bA*x + bB = 0 → x = -bB/bA  (if bA != 0)
      if(bA!==0) perBase[base]={a:bA, b:bB, sol:-bB/bA};
    }

    const solvedBases = Object.entries(perBase);
    if(solvedBases.length===0) return null;

    // Check consistency
    const firstSol = solvedBases[0][1].sol;
    for(const [base,{sol}] of solvedBases){
      if(Math.abs(sol-firstSol)>1e-9) return null; // inconsistent
    }

    // Build step display using the first solvable base
    const [exBase, exVals] = solvedBases[0];
    // Show exponent equation for that base
    const lhsExpParts = baseMap[exBase].lhs.map(e=>cleanExpDisplay(e)).join(" + ") || "0";
    const rhsExpParts = baseMap[exBase].rhs.map(e=>cleanExpDisplay(e)).join(" + ") || "0";
    steps.push({text:"Equate exponents of "+exBase+":  "+lhsExpParts+" = "+rhsExpParts, rule:"index law"});
    const lhsLinear = (exVals.a!==0?(Math.abs(exVals.a)===1?"":(Math.abs(exVals.a)))+unknown:"")+(exVals.b!==0?(exVals.b>0&&exVals.a!==0?"+":"")+fmtNum(exVals.b):"") || "0";
    const rhsLinear = fmtNum(exVals.a!==0 ? -exVals.b : 0);
    steps.push({text:"Solve: "+lhsLinear+" = "+rhsLinear+" → "+unknown+" = "+fmtNum(firstSol), rule:"linear"});

    // Show verification for other bases if any
    for(const [base,{sol}] of solvedBases.slice(1)){
      const lp = baseMap[base].lhs.map(e=>cleanExpDisplay(e)).join("+");
      const rp = baseMap[base].rhs.map(e=>cleanExpDisplay(e)).join("+");
      steps.push({text:"Verify with "+base+": "+lp+" = "+rp+" → "+unknown+" = "+fmtNum(sol)+" ✓", rule:"check"});
    }

    return {result: unknown+" = "+fmtNum(firstSol), steps};
  }

  function doSolve(raw, solveFor) {
    const s=normalise(raw);const steps=[];const ei=s.indexOf("=");
    if(ei===-1)throw new Error("No '=' found. Enter an equation like x^2 = 9.");
    let lhs=s.slice(0,ei),rhs=s.slice(ei+1);
    steps.push({text:"Equation: "+lhs+" = "+rhs});

    // Move everything to LHS: lhs - (rhs) = 0
    const rhsVal=tryParseNumber(rhs);
    const lhsMon=tryParseMonomial(lhs);

    // Check for exponential/index-law equation early (e.g. a^x / a^4 = 1/a)
    const looksExponential = /[a-zA-Z]\^[a-zA-Z(]/.test(lhs+rhs) || /\)\^[a-zA-Z]/.test(lhs+rhs);
    if(looksExponential){
      const expSteps=[{text:"Equation: "+lhs+" = "+rhs}];
      const expRes = doSolveExponential(lhs, rhs, expSteps, solveFor);
      if(expRes) return expRes;
    }

    if(lhsMon&&rhsVal!==null){
      const{coeff,varName,exp}=lhsMon;
      if(exp===1){
        const sol=rhsVal/coeff;
        steps.push({text:"Divide both sides by "+coeff,rule:"linear"});
        steps.push({text:varName+" = "+fmtNum(sol)});
        return{result:varName+" = "+fmtNum(sol),steps};
      }
      const r2=rhsVal/coeff;
      steps.push({text:"Divide both sides by "+coeff+": "+varName+"^"+exp+" = "+fmtNum(r2),rule:"power"});
      if(exp===2){
        if(r2<0){steps.push({text:"Negative under √ → no real solution"});return{result:"No real solution",steps};}
        const sr=Math.sqrt(r2);
        steps.push({text:"Square root both sides: "+varName+" = ±"+fmtNum(sr),rule:"square root"});
        return{result:varName+" = "+fmtNum(sr)+"  or  "+varName+" = "+fmtNum(-sr),steps};
      }
      const sol=Math.pow(r2,1/exp);
      steps.push({text:"Take "+exp+"th root: "+varName+" = "+fmtNum(sol),rule:"nth root"});
      return{result:varName+" = "+fmtNum(sol),steps};
    }

    // General polynomial approach: rearrange to LHS
    const combined=lhs+"-("+rhs+")";
    const poly=parsePolynomial(normalise(combined));
    let{a,b,c,varName}=poly;
    // If user specified a variable and it differs from auto-detected, try to honour it
    if(solveFor && solveFor!==varName && /^[a-zA-Z]$/.test(solveFor)) varName=solveFor;
    steps.push({text:"Rearranged: "+fmtPoly(a,b,c,varName)+" = 0",rule:"rearrange"});
    if(a===0){
      if(b===0){
        // Try exponential / index-law solver before giving up
        const expRes = doSolveExponential(lhs, rhs, steps, solveFor);
        if(expRes) return expRes;
        // Partial: if there are any variables at all, report what we have
        const anyVars=[...new Set([...s.matchAll(/[a-zA-Z]/g)].map(m=>m[0]))];
        const target = solveFor || (anyVars[0]||"?");
        steps.push({text:"Could not solve algebraically — try specifying 'Solve for: "+target+"' and ensure both sides use the same base"});
        return{result:"Could not solve for "+target,steps};
      }
      const sol=-c/b;
      steps.push({text:"Divide both sides by "+fmtNum(b)+": "+varName+" = "+fmtNum(sol),rule:"linear"});
      return{result:varName+" = "+fmtNum(sol),steps};
    }
    const disc=b*b-4*a*c;
    steps.push({text:"Discriminant = ("+fmtNum(b)+")² − 4("+fmtNum(a)+")("+fmtNum(c)+") = "+fmtNum(disc),rule:"discriminant"});
    if(disc<0)return{result:"No real solutions",steps};
    if(Math.abs(disc)<1e-9){
      const sol=-b/(2*a);
      steps.push({text:"Double root: "+varName+" = "+fmtNum(-b)+" ÷ "+fmtNum(2*a)+" = "+fmtNum(sol),rule:"quadratic formula"});
      return{result:varName+" = "+fmtNum(sol),steps};
    }
    const r1=(-b+Math.sqrt(disc))/(2*a),r2=(-b-Math.sqrt(disc))/(2*a);
    steps.push({text:varName+" = ("+fmtNum(-b)+" ± √"+fmtNum(disc)+") ÷ "+fmtNum(2*a),rule:"quadratic formula"});
    return{result:varName+" = "+fmtNum(r1)+"  or  "+varName+" = "+fmtNum(r2),steps};
  }

  // ══════════════════════════════════════════════════════════
  //  EXPAND (repeated multiplication)
  // ══════════════════════════════════════════════════════════
  const EXPAND_LIMIT=12;

  function expandToken(t,parts,steps) {
    const powMatch=t.match(/^\((.+)\)\^(-?\d+)$/);
    if(powMatch){
      const inner=powMatch[1],n=parseInt(powMatch[2]);
      if(n<0||n>EXPAND_LIMIT){
        parts.push("("+inner+")^"+n);
        steps.push({text:"("+inner+")^"+n+" kept as-is (large/negative exponent)"});
      } else {
        const innerParts=[];
        expandToken(inner,innerParts,steps);
        const group=innerParts.length>1?"("+innerParts.join(" × ")+")":innerParts[0];
        for(let i=0;i<n;i++)parts.push(group);
        steps.push({text:"("+inner+")^"+n+" → "+Array(n).fill(group).join(" × "),rule:"power of product"});
      }
      return;
    }
    const clean=t.replace(/^\(+|\)+$/g,"");
    let s2=clean,sign=1;
    if(s2.startsWith("-")){sign=-1;s2=s2.slice(1);}
    const nm=s2.match(/^(\d+\.?\d*)/);
    const coeff=nm?parseFloat(nm[1]):1;
    const rest=nm?s2.slice(nm[0].length):s2;
    const signedCoeff=sign*coeff;
    if(signedCoeff!==1||rest==="")parts.push(fmtNum(signedCoeff));
    const vr=/([a-zA-Z])(?:\^(-?\d+))?/g;
    let m;
    while((m=vr.exec(rest))!==null){
      const v=m[1],exp=m[2]!==undefined?parseInt(m[2]):1;
      if(exp===1){parts.push(v);}
      else if(exp<0||exp>EXPAND_LIMIT){parts.push(v+"^"+exp);steps.push({text:v+"^"+exp+" kept as-is"});}
      else{
        for(let i=0;i<exp;i++)parts.push(v);
        steps.push({text:v+"^"+exp+" → "+Array(exp).fill(v).join(" × "),rule:"expand power"});
      }
    }
  }

  function doExpand(raw) {
    const s=normalise(raw);const steps=[];
    steps.push({text:"Original: "+s.replace(/\*/g," × ").replace(/\//g," ÷ ")});
    const tokens=tokeniseTopLevel(s);
    const numParts=[],denParts=[];let curDen=false;
    for(const t of tokens){
      if(t==="*"){curDen=false;continue;}
      if(t==="/"){curDen=true;continue;}
      expandToken(t,curDen?denParts:numParts,steps);
    }
    if(numParts.length===0)numParts.push("1");
    let result=denParts.length===0?numParts.join(" × "):"("+numParts.join(" × ")+") ÷ ("+denParts.join(" × ")+")";
    steps.push({text:"Expanded: "+result});
    return{result,steps};
  }

  // ══════════════════════════════════════════════════════════
  //  INDEX FORM  (expand → collect)
  // ══════════════════════════════════════════════════════════
  function splitTopLevelMul(s) {
    const parts=[];let depth=0,cur="";
    for(let i=0;i<s.length;i++){
      const c=s[i];
      if(c==="("){depth++;cur+=c;}
      else if(c===")"){depth--;cur+=c;}
      else if(c==="*"&&depth===0){if(cur)parts.push(cur);cur="";}
      else cur+=c;
    }
    if(cur)parts.push(cur);return parts;
  }

  function doIndexForm(raw) {
    const steps=[];
    let s=raw.replace(/\s+/g,"").replace(/×/g,"*").replace(/÷/g,"/");
    const slashIdx=findTopLevelSlash(s);
    let numStr=s,denStr=null;
    if(slashIdx!==-1){numStr=s.slice(0,slashIdx);denStr=s.slice(slashIdx+1).replace(/^\(|\)$/g,"");}
    steps.push({text:"Original: "+raw.replace(/\s+/g," ").trim()});

    function processGroup(str,label){
      const parts=splitTopLevelMul(str.replace(/^\(|\)$/g,""));
      let coeff=1;const vars={};
      for(const p of parts){
        const clean=p.replace(/^\(|\)$/g,"");
        const asNum=parseFloat(clean);
        if(!isNaN(asNum)&&/^-?\d+\.?\d*$/.test(clean)){coeff*=asNum;}
        else{
          const m=clean.match(/^(-?\d*\.?\d*)([a-zA-Z])(?:\^(-?\d+))?$/);
          if(m){
            const c=m[1]?(m[1]==="-"?-1:parseFloat(m[1])):1;
            vars[m[2]]=(vars[m[2]]||0)+(m[3]?parseInt(m[3]):1);
            coeff*=c;
          } else {steps.push({text:"  Could not parse factor: "+clean});}
        }
      }
      steps.push({text:"  Count factors in "+label+": coeff="+fmtNum(coeff)+", vars="+JSON.stringify(vars),rule:"collect"});
      return{coeff,vars};
    }

    function toIndexStr(coeff,vars){
      const r=parseFloat(coeff.toFixed(9));let s="";
      const entries=Object.entries(vars).filter(([,e])=>e!==0).sort((a,b)=>a[0].localeCompare(b[0]));
      if(entries.length===0)return fmtNum(r);
      if(r===-1)s="-";else if(r!==1)s=fmtNum(r);
      for(const[v,e]of entries){s+=v;if(e!==1)s+="^"+e;}
      return s||"1";
    }

    const num=processGroup(numStr,"numerator");
    if(denStr){
      const den=processGroup(denStr,"denominator");
      const finalCoeff=num.coeff/den.coeff;
      const finalVars={...num.vars};
      for(const[v,e]of Object.entries(den.vars))finalVars[v]=(finalVars[v]||0)-e;
      const result=toIndexStr(finalCoeff,finalVars);
      steps.push({text:"Divide coefficients, subtract exponents",rule:"index law"});
      steps.push({text:"Result: "+result});
      return{result,steps};
    } else {
      const result=toIndexStr(num.coeff,num.vars);
      steps.push({text:"Result: "+result});
      return{result,steps};
    }
  }

  // ══════════════════════════════════════════════════════════
  //  FACTORISE
  //  Handles: HCF extraction, difference of squares,
  //           perfect squares, quadratics ax²+bx+c
  // ══════════════════════════════════════════════════════════
  function doFactorise(raw) {
    const s=normalise(raw);const steps=[];
    steps.push({text:"Expression: "+s});

    // Step 1: Extract HCF of all terms
    const terms=splitTopLevelAdd(s);
    const monomials=terms.map(t=>{try{return parseMonomial(t);}catch(e){return null;}});
    const allParsed=monomials.every(Boolean);

    // Numeric GCF of coefficients (always ≥ 1)
    let numGcf=1;
    if(allParsed&&monomials.length>=1){
      numGcf=monomials.reduce((g,m)=>gcd(g,Math.abs(Math.round(m.coeff))),Math.abs(Math.round(monomials[0].coeff)));
    }

    // Variable HCF: minimum exponent across all terms for each variable
    let varHcf={};
    if(allParsed&&monomials.length>1){
      const allVars=new Set(monomials.flatMap(m=>Object.keys(m.vars)));
      allVars.forEach(v=>{
        const minExp=Math.min(...monomials.map(m=>m.vars[v]||0));
        if(minExp>0)varHcf[v]=minExp;
      });
    }

    const hcfIsOne=(numGcf===1&&Object.keys(varHcf).length===0);
    let hcfStr=formatMonomial(numGcf,varHcf);
    let innerExpr=s;
    let hcfExtracted=false;

    if(!hcfIsOne&&allParsed){
      // Divide each term by the HCF
      const divided=terms.map(t=>{
        const m=parseMonomial(t);
        const newCoeff=m.coeff/numGcf;
        const newVars={...m.vars};
        Object.keys(varHcf).forEach(v=>{
          newVars[v]=(newVars[v]||0)-varHcf[v];
          if(newVars[v]===0)delete newVars[v];
        });
        return formatMonomial(newCoeff,newVars);
      });
      innerExpr=divided.join("+").replace(/\+-/g,"-");
      steps.push({text:"Extract HCF "+hcfStr+": "+hcfStr+"("+innerExpr+")",rule:"common factor"});
      hcfExtracted=true;
    }

    // Attempt to further factorise innerExpr as a polynomial
    const poly=parsePolynomial(innerExpr);
    const{a,b,c,varName}=poly;
    const prefix=hcfExtracted?hcfStr:"";

    // Linear — nothing more to do
    if(a===0){
      const result=hcfExtracted?hcfStr+"("+innerExpr+")":innerExpr;
      if(b!==0)steps.push({text:"Linear expression — no further factorisation"});
      return{result,steps};
    }

    // Difference of two squares: (√a·x)² − (√|c|)² = (√a·x+√|c|)(√a·x−√|c|)
    if(b===0&&c<0){
      const sqA=Math.sqrt(a),sqC=Math.sqrt(-c);
      if(Math.abs(sqA-Math.round(sqA))<1e-9&&Math.abs(sqC-Math.round(sqC))<1e-9){
        const sA=Math.round(sqA),sC=Math.round(sqC);
        const aCoeff=sA===1?"":String(sA);
        const f1="("+aCoeff+varName+"+"+sC+")";
        const f2="("+aCoeff+varName+"-"+sC+")";
        steps.push({text:"Difference of two squares: ("+aCoeff+varName+")² − "+sC+"²",rule:"DOTS"});
        steps.push({text:"= "+f1+f2});
        return{result:prefix+f1+f2,steps};
      }
    }

    // Perfect square trinomial: (√a·x ± √c)²
    if(c>0&&b!==0){
      const sqA=Math.sqrt(a),sqC=Math.sqrt(c);
      if(Math.abs(sqA-Math.round(sqA))<1e-9&&Math.abs(sqC-Math.round(sqC))<1e-9){
        const sA=Math.round(sqA),sC=Math.round(sqC);
        if(Math.abs(b)===2*sA*sC){
          const sign=b>0?"+":"-";
          const aCoeff=sA===1?"":String(sA);
          const factor="("+aCoeff+varName+sign+sC+")^2";
          steps.push({text:"Perfect square: ("+aCoeff+varName+")² "+(b>0?"+ ":"− ")+"2·"+sA+"·"+sC+" + "+sC+"²",rule:"perfect square"});
          steps.push({text:"= "+factor});
          return{result:prefix+factor,steps};
        }
      }
    }

    // AC method — find p,q integers such that p·q = a·c and p+q = b
    const ac=a*c;
    steps.push({text:"Find two numbers: product = ac = "+fmtNum(a)+"×"+fmtNum(c)+" = "+fmtNum(ac)+", sum = b = "+fmtNum(b),rule:"AC method"});
    let p=null,q=null;
    const limit=Math.abs(ac);
    outerLoop:for(let i=-limit;i<=limit;i++){
      if(i===0)continue;
      if(Number.isInteger(ac/i)){
        const j=ac/i;
        if(i+j===b){p=i;q=j;break outerLoop;}
      }
    }

    if(p===null){
      // Irrational roots — express as a(x−r1)(x−r2)
      const disc=b*b-4*a*c;
      if(disc<0){
        steps.push({text:"Discriminant < 0: does not factorise over the reals"});
        return{result:prefix+"("+innerExpr+")",steps};
      }
      const r1=(-b+Math.sqrt(disc))/(2*a),r2=(-b-Math.sqrt(disc))/(2*a);
      steps.push({text:"Roots: "+varName+" = "+fmtNum(r1)+" or "+varName+" = "+fmtNum(r2),rule:"quadratic formula"});
      const aStr=a!==1?fmtNum(a):"";
      const f1="("+varName+(r1<0?" + "+fmtNum(-r1):" − "+fmtNum(r1))+")";
      const f2="("+varName+(r2<0?" + "+fmtNum(-r2):" − "+fmtNum(r2))+")";
      const result=prefix+aStr+f1+f2;
      steps.push({text:"= "+result});
      return{result,steps};
    }

    // Integer factorisation found
    steps.push({text:"Split: "+fmtNum(p)+" and "+fmtNum(q)+" (product "+fmtNum(p*q)+" = ac, sum "+fmtNum(p+q)+" = b)",rule:"split"});

    if(a===1){
      // x² + (p+q)x + pq = (x+p)(x+q)
      const sign1=p>=0?"+":"";
      const sign2=q>=0?"+":"";
      const f1="("+varName+sign1+fmtNum(p)+")";
      const f2="("+varName+sign2+fmtNum(q)+")";
      steps.push({text:"("+varName+")("+varName+") gives ("+f1+")("+f2+")",rule:"factor pairs"});
      return{result:prefix+f1+f2,steps};
    }

    // General ax²+bx+c with integer factors using grouping
    // ax²+px+qx+c  →  group
    steps.push({text:fmtNum(a)+varName+"² + "+fmtNum(p)+varName+" + "+fmtNum(q)+varName+" + "+fmtNum(c),rule:"split middle"});
    // Group 1: ax²+px = x(ax+p), Group 2: qx+c
    // Common factor of group1: gcd(a,p)·x; common factor of group2: gcd(q,c)
    // Both groups should share a common linear bracket (ax+p) after factoring
    const g1=gcd(Math.abs(a),Math.abs(p));
    const g2=gcd(Math.abs(q),Math.abs(c));
    // The shared bracket
    const sharedA=a/g1,sharedB=p/g1;
    const sharedSign=sharedB>=0?"+":"";
    const shared="("+fmtNum(sharedA)+varName+sharedSign+fmtNum(sharedB)+")";
    const outerA=fmtNum(g1)+varName;
    const outerB=(q<0?"-":"")+fmtNum(Math.abs(q/sharedA));// q/sharedA = g2·(sign)
    const outerBStr=g2===1&&Math.abs(q/sharedA)===1?""+(q<0?"-":""):fmtNum(q/sharedA);
    // Direct root approach for general case
    const disc2=b*b-4*a*c;
    const r1=(-b+Math.sqrt(disc2))/(2*a),r2=(-b-Math.sqrt(disc2))/(2*a);
    const aStr=a!==1?fmtNum(a):"";
    // Express as a(x − r1)(x − r2) but rewrite using integer roots
    // Since we know integer p,q: roots are -p/a and -q (if a=leading)
    // Actually: roots of ax²+bx+c are r1,r2 found above
    // Build nice factor strings: a(x - r1)(x - r2)
    function niceRoot(r){
      const fr=fmtNum(r);
      // if r is a fraction like -2/3, build (3x+2)
      const fm=fr.match(/^(-?)(\d+)\/(\d+)$/);
      if(fm){
        const neg=fm[1]==="-";
        const num=parseInt(fm[2]),den=parseInt(fm[3]);
        // root = num/den (positive), so factor is (den·x − num) or (den·x + num)
        const dStr=den===1?"":String(den);
        const sign=neg?"+":"-";
        return"("+dStr+varName+sign+num+")";
      }
      const sign=r<0?" + ":" − ";
      return"("+varName+sign+fmtNum(Math.abs(r))+")";
    }
    const fac1=niceRoot(r1),fac2=niceRoot(r2);
    steps.push({text:"= "+aStr+fac1+fac2,rule:"factored"});
    return{result:prefix+aStr+fac1+fac2,steps};
  }

  // Split expression on top-level + and -
  function splitTopLevelAdd(s){
    const parts=[];let cur="",depth=0;
    for(let i=0;i<s.length;i++){
      const c=s[i];
      if(c==="(")depth++;
      else if(c===")")depth--;
      else if((c==="+"||c==="-")&&depth===0&&i>0){
        if(cur)parts.push(cur);cur=c;continue;
      }
      cur+=c;
    }
    if(cur)parts.push(cur);
    return parts;
  }

  // ══════════════════════════════════════════════════════════
  //  BINOMIAL EXPANSION  (a+b)^n via Pascal's triangle
  // ══════════════════════════════════════════════════════════
  function doBinomial(raw) {
    const s=normalise(raw);const steps=[];

    // Accept bare expressions like x+2 without outer parens for n=1
    let inner, n;
    const m=s.match(/^\((.+)\)\^(\d+)$/);
    if(!m)throw new Error("Enter in the form (a+b)^n, e.g. (x+2)^3");
    inner=m[1]; n=parseInt(m[2]);
    if(n>12)throw new Error("Exponent too large (max 12).");
    if(n===0)return{result:"1",steps:[{text:"Any non-zero expression to the power 0 = 1",rule:"zero power"}]};
    if(n===1)return{result:inner,steps:[{text:"Power 1: expression unchanged",rule:"identity"}]};

    // Find the top-level split point (the + or − separating A and B)
    let splitIdx=-1,splitSign="+",d=0;
    for(let i=0;i<inner.length;i++){
      if(inner[i]==="(")d++;
      else if(inner[i]===")")d--;
      else if((inner[i]==="+"||inner[i]==="-")&&d===0&&i>0){
        splitIdx=i;splitSign=inner[i];break;
      }
    }
    if(splitIdx===-1)throw new Error("No + or − found inside brackets. Enter (a+b)^n or (a-b)^n.");

    const Astr=inner.slice(0,splitIdx);
    const Bstr=inner.slice(splitIdx+1);
    // B sign baked into Bstr for computing numeric values; display uses splitSign

    steps.push({text:"("+Astr+(splitSign==="-"?" − ":" + ")+Bstr+")^"+n});

    // Pascal's row
    const C=[1];
    for(let i=1;i<=n;i++)C.push(C[i-1]*(n-i+1)/i);
    steps.push({text:"Pascal's coefficients (n="+n+"): "+C.join(", "),rule:"Pascal's triangle"});

    // Try to parse A and B as simple monomials: coefficient × variable^exp
    // e.g. A="2x" → {numCoeff:2, varPart:"x", varName:"x", varExp:1}
    // e.g. A="x"  → {numCoeff:1, varPart:"x", varName:"x", varExp:1}
    // e.g. A="3"  → {numCoeff:3, varPart:"",  varName:"",  varExp:0}
    function parseSide(str){
      str=str.replace(/^\(+|\)+$/g,"");
      const mm=str.match(/^(-?\d*\.?\d*)([a-zA-Z]?)(?:\^(-?\d+))?$/);
      if(!mm)return{numCoeff:1,varPart:str,varName:"",varExp:1,raw:str,isComplex:true};
      const nc=mm[1]?(mm[1]==="-"?-1:parseFloat(mm[1])):1;
      const vn=mm[2]||"";
      const ve=mm[3]?parseInt(mm[3]):vn?1:0;
      return{numCoeff:nc,varPart:vn,varName:vn,varExp:ve,isComplex:false};
    }

    const A=parseSide(Astr);
    // B: if splitSign is "-", the actual value is negative
    const Braw=parseSide(Bstr);
    const BnumCoeff=splitSign==="-"?-Braw.numCoeff:Braw.numCoeff;

    // Build each term
    const termStrings=[];
    for(let k=0;k<=n;k++){
      const binom=C[k];
      const aPow=n-k, bPow=k;

      // Numeric coefficient of this term
      let termCoeff=binom*Math.pow(A.numCoeff,aPow)*Math.pow(Math.abs(Braw.numCoeff),bPow);
      // Sign from B raised to bPow
      const bSignPow=splitSign==="-"?(bPow%2===0?1:-1):1;
      termCoeff*=bSignPow;

      // Variable parts
      let varStr="";
      if(!A.isComplex&&!Braw.isComplex){
        // Build clean variable string
        const aVarExp=aPow*A.varExp;
        const bVarExp=bPow*Braw.varExp;
        // A variable
        if(A.varName&&aVarExp>0){
          varStr+=A.varName;
          if(aVarExp>1)varStr+="^"+aVarExp;
        }
        // B variable (could be same or different)
        if(Braw.varName&&bVarExp>0){
          if(Braw.varName===A.varName){
            // Combine with A's variable
            const combined=aVarExp+bVarExp;
            varStr=A.varName+(combined>1?"^"+combined:"");
          } else {
            varStr+=Braw.varName;
            if(bVarExp>1)varStr+="^"+bVarExp;
          }
        }
      } else {
        // Complex expressions: use raw strings with ^n
        const aPart=aPow===0?"":aPow===1?"("+Astr+")":"("+Astr+")^"+aPow;
        const bPart=bPow===0?"":bPow===1?"("+Bstr+")":"("+Bstr+")^"+bPow;
        varStr=aPart+bPart;
      }

      // Format the term coefficient
      const absCoeff=Math.abs(termCoeff);
      const coeffStr=(absCoeff===1&&varStr)?"":(absCoeff===1&&!varStr?"1":fmtNum(absCoeff));
      const termStr=(termCoeff<0?"-":"")+(coeffStr+varStr||"0");

      // Step description
      steps.push({text:"k="+k+":  C("+n+","+k+")·("+Astr+")^"+(n-k)+"·("+Bstr+")^"+k+"  =  "+termStr.trim(),rule:"term "+(k+1)});
      termStrings.push({str:termStr.trim(),sign:termCoeff<0?-1:1});
    }

    // Join terms
    let result="";
    termStrings.forEach((t,i)=>{
      if(i===0){result+=t.str;}
      else if(t.sign<0){result+=" − "+t.str.replace(/^-/,"");}
      else{result+=" + "+t.str;}
    });

    steps.push({text:"Expanded: "+result});
    return{result,steps};
  }

  // ══════════════════════════════════════════════════════════
  //  HCF / LCM
  // ══════════════════════════════════════════════════════════
  function doHcfLcm(raw) {
    const s=normalise(raw);const steps=[];

    // Expect comma-separated expressions
    const parts=s.split(",").map(p=>p.trim()).filter(Boolean);
    if(parts.length<2)throw new Error("Enter two or more expressions separated by commas, e.g.  12x²y, 8xy³");

    steps.push({text:"Expressions: "+parts.join(" , ")});

    const parsed=parts.map(p=>{
      // Try to parse each as a monomial (possibly with a common factor prefix)
      try{return{raw:p,...parseMonomial(p)};}
      catch(e){throw new Error("Could not parse: "+p);}
    });

    // Numeric HCF and LCM
    const coeffs=parsed.map(p=>Math.abs(Math.round(p.coeff)));
    let numHcf=coeffs.reduce((a,b)=>gcd(a,b));
    let numLcm=coeffs.reduce((a,b)=>lcm(a,b));

    steps.push({text:"Coefficients: "+coeffs.join(", "),rule:"step 1"});
    steps.push({text:"Numeric HCF = "+numHcf+"  (largest number dividing all coefficients)",rule:"HCF"});
    steps.push({text:"Numeric LCM = "+numLcm+"  (smallest number divisible by all coefficients)",rule:"LCM"});

    // Variable HCF: minimum exponent of each variable across all terms
    // Variable LCM: maximum exponent
    const allVars=new Set(parsed.flatMap(p=>Object.keys(p.vars)));
    const varHcfMap={},varLcmMap={};
    allVars.forEach(v=>{
      const exps=parsed.map(p=>p.vars[v]||0);
      varHcfMap[v]=Math.min(...exps);
      varLcmMap[v]=Math.max(...exps);
    });

    // Show variable working
    allVars.forEach(v=>{
      const exps=parsed.map(p=>p.vars[v]||0);
      steps.push({text:v+": exponents ["+exps.join(", ")+"]  → HCF uses min="+varHcfMap[v]+", LCM uses max="+varLcmMap[v],rule:"variable"});
    });

    const hcfVars={};allVars.forEach(v=>{if(varHcfMap[v]>0)hcfVars[v]=varHcfMap[v];});
    const lcmVars={};allVars.forEach(v=>{if(varLcmMap[v]>0)lcmVars[v]=varLcmMap[v];});

    const hcfResult=formatMonomial(numHcf,hcfVars);
    const lcmResult=formatMonomial(numLcm,lcmVars);

    steps.push({text:"HCF = "+hcfResult,rule:"result"});
    steps.push({text:"LCM = "+lcmResult,rule:"result"});

    return{result:"HCF = "+hcfResult+"  |  LCM = "+lcmResult,steps};
  }

  // ══════════════════════════════════════════════════════════
  //  History store
  // ══════════════════════════════════════════════════════════
  const MAX_HISTORY=10;
