  function renderPanel(){
    var rows=[['Name',data.name],['Email',data.email],['Phone',data.phone],['DOB',data.dob],['Address',data.address],['Username',data.username],['Password',data.password]];
    panel.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;">'
      +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">Fake Data</span>'
      +'<div style="display:flex;gap:6px;">'
        +'<button id="__fd_gen__" style="background:#313244;color:#a6e3a1;border:none;border-radius:5px;padding:4px 8px;font-size:11px;cursor:pointer;">New</button>'
        +'<button id="__fd_fill__" style="background:#cba6f7;color:#1e1e2e;border:none;border-radius:5px;padding:4px 8px;font-size:11px;font-weight:600;cursor:pointer;">Fill form</button>'
        +'<button id="__fd_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0 2px;">x</button>'
