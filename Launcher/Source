function flatFilter(nodes,q){var r=[];for(var i=0;i<nodes.length;i++){var n=nodes[i];if(n.folder){var f=flatFilter(n.children||[],q);if(f.length||n.folder.toLowerCase().indexOf(q)>=0)r.push(Object.assign({},n,{children:f.length?f:n.children}));}else if(n.name.toLowerCase().indexOf(q)>=0||(n.desc&&n.desc.toLowerCase().indexOf(q)>=0))r.push(n);}return r;}
