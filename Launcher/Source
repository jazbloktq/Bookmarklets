        +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">LocalStorage <span style="color:#6c7086;font-weight:400;">('+data.length+' keys)</span></span>'
        +'<div style="display:flex;gap:6px;">'
          +'<button id="__ls_add__" style="background:#313244;color:#a6e3a1;border:none;border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">+ Add</button>'
          +'<button id="__ls_clr__" style="background:#313244;color:#f38ba8;border:none;border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">Clear all</button>'
          +'<button id="__ls_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0 2px;">×</button>'
