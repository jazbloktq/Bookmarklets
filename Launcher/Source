    var cookies=all.filter(function(c){return c.name.toLowerCase().includes(q)||c.value.toLowerCase().includes(q);});
    var rows=cookies.map(function(c,i){
      var shortVal=c.value.length>80?c.value.slice(0,80)+'…':c.value;
      return '<div style="padding:7px 10px;border-bottom:1px solid #313244;'+(i%2===0?'':'background:rgba(255,255,255,.02)')+'">'
