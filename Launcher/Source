    function doIt(){
      document.title=title;
      document.querySelectorAll("link[rel*='icon']").forEach(function(el){el.parentNode.removeChild(el);});
      var link=document.createElement('link');link.rel='shortcut icon';link.type='image/x-icon';link.href=iconUrl+'?cb='+Date.now();
      document.head.appendChild(link);
    }
    doIt();window.__tc_interval__=setInterval(doIt,1500);menu.remove();
  }
  cloaks.forEach(function(c){
    var btn=document.createElement('button');
    btn.style.cssText='display:flex;align-items:center;gap:8px;width:100%;padding:8px 12px;background:none;border:none;border-bottom:1px solid rgba(255,255,255,.07);color:rgba(255,255,255,.7);cursor:pointer;font-family:monospace;font-size:11px;text-align:left;';
    btn.onmouseover=function(){this.style.background='rgba(255,255,255,.06)';};btn.onmouseout=function(){this.style.background='none';};
    var img=document.createElement('img');img.src=c.icon;img.style.cssText='width:14px;height:14px;object-fit:contain;';
    var span=document.createElement('span');span.textContent=c.label;btn.appendChild(img);btn.appendChild(span);
    btn.addEventListener('click',function(){applyCloak(c.title,c.icon);});
    menu.appendChild(btn);
  });
  var sep=document.createElement('div');sep.style.cssText='padding:6px 12px 4px;font-size:10px;color:rgba(255,255,255,.3);letter-spacing:.06em;';sep.textContent='CUSTOM';menu.appendChild(sep);
  var customRow=document.createElement('div');customRow.style.cssText='padding:8px 12px;display:flex;flex-direction:column;gap:6px;border-top:1px solid rgba(255,255,255,.07);';
  var titleInp=document.createElement('input');titleInp.placeholder='Tab title...';
  titleInp.style.cssText='background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:#fff;font-size:11px;padding:4px 7px;outline:none;font-family:monospace;width:100%;box-sizing:border-box;';
  var fileRow=document.createElement('div');fileRow.style.cssText='display:flex;align-items:center;gap:6px;';
  var fileInp=document.createElement('input');fileInp.type='file';fileInp.accept='image/*';fileInp.style.cssText='display:none;';
  var fileLbl=document.createElement('button');fileLbl.textContent='Choose icon...';
  fileLbl.style.cssText='background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:10px;padding:4px 8px;cursor:pointer;font-family:monospace;flex:1;text-align:left;';
  var previewImg=document.createElement('img');previewImg.style.cssText='width:16px;height:16px;object-fit:contain;display:none;';
  var customIconUrl='';
  fileLbl.onclick=function(){fileInp.click();};
  fileInp.onchange=function(){
    var file=this.files[0];if(!file)return;
    var reader=new FileReader();
    reader.onload=function(e){
      customIconUrl=e.target.result;
      previewImg.src=customIconUrl;previewImg.style.display='block';
      fileLbl.textContent=file.name.slice(0,18)+(file.name.length>18?'...':'');
    };reader.readAsDataURL(file);
  };
  fileRow.appendChild(fileInp);fileRow.appendChild(fileLbl);fileRow.appendChild(previewImg);
  var applyBtn=document.createElement('button');applyBtn.textContent='Apply custom';
  applyBtn.style.cssText='background:#cba6f7;color:#1e1e2e;border:none;font-size:11px;padding:5px;cursor:pointer;font-family:monospace;font-weight:600;';
  applyBtn.onclick=function(){
    var t=titleInp.value.trim()||document.title;
    var icon=customIconUrl||'';
    if(!icon){alert('Please choose an icon image.');return;}
    applyCloak(t,icon);
  };
  customRow.appendChild(titleInp);customRow.appendChild(fileRow);customRow.appendChild(applyBtn);
  menu.appendChild(customRow);
  document.body.appendChild(menu);
})()`},
