      if(!confirm('Delete all accessible cookies for this domain?'))return;
      document.cookie.split(';').forEach(function(c){
        var name=c.split('=')[0].trim();
        ['','domain='+location.hostname,'domain=.'+location.hostname].forEach(function(d){document.cookie=name+'=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;'+d;});
      });render(q);
    };
    panel.querySelectorAll('[data-copy]').forEach(function(b){b.onclick=function(){navigator.clipboard.writeText(this.dataset.copy).catch(function(){});var t=b.textContent;b.textContent='✓';setTimeout(function(){b.textContent=t;},1200);};});
