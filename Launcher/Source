      {name:"To Markdown",type:"inline",src:`(function(){
  if(typeof TurndownService==='undefined'){
    var s=document.createElement('script');
    s.src='https://cdnjs.cloudflare.com/ajax/libs/turndown/7.1.2/turndown.min.js';
    s.onload=run;document.body.appendChild(s);
  } else {run();}
  function run(){
    var sel=window.getSelection();var h='';
    if(sel.rangeCount>0){var c=document.createElement('div');c.appendChild(sel.getRangeAt(0).cloneContents());h=c.innerHTML;}
    else{var art=document.querySelector('article');if(art){h=art.innerHTML;}else{alert('No selection found and no article element detected');return;}}
    if(!h){alert('No content found to convert');return;}
    var t=new TurndownService({headingStyle:'atx',codeBlockStyle:'fenced',emDelimiter:'*',strongDelimiter:'**'});
    var m=t.turndown(h);
    var id='__md__';var ex=document.getElementById(id);if(ex)ex.remove();
    var panel=document.createElement('div');panel.id=id;
    panel.style.cssText='position:fixed;top:20px;right:20px;width:420px;max-height:560px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden;';
    panel.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;flex-shrink:0;">'
      +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">To Markdown</span>'
      +'<div style="display:flex;gap:6px;">'
        +'<button id="__md_copy__" style="background:#313244;color:#a6e3a1;border:none;border-radius:5px;padding:4px 10px;font-size:11px;cursor:pointer;">Copy</button>'
        +'<button id="__md_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0 2px;">x</button>'
      +'</div>'
    +'</div>'
    +'<textarea id="__md_ta__" style="flex:1;min-height:200px;background:#181825;border:none;color:#cdd6f4;font-size:11px;font-family:monospace;padding:12px;resize:none;outline:none;overflow-y:auto;"></textarea>';
    document.body.appendChild(panel);
    var ta=document.getElementById('__md_ta__');ta.value=m;
    document.getElementById('__md_x__').onclick=function(){panel.remove();};
    document.getElementById('__md_copy__').onclick=function(){
