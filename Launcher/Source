  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;width:310px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:13px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 8px 32px rgba(0,0,0,.5);overflow:hidden;';
