      {name:"LocalStorage",type:"inline",src:`(function(){
  var id='__ls__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;width:400px;max-height:560px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden;';
  function getData(){var keys=Object.keys(localStorage).sort();return keys.map(function(k){return{key:k,val:localStorage.getItem(k)};});}
  function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
  function render(){
