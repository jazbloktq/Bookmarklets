      +'<div style="padding:6px 8px;border-bottom:1px solid #313244;background:#181825;flex-shrink:0;">'
        +'<input id="__ck_srch__" placeholder="Filter cookies…" value="'+escH(q)+'" style="width:100%;background:#313244;border:1px solid #45475a;border-radius:5px;color:#cdd6f4;font-size:11px;padding:4px 8px;outline:none;box-sizing:border-box;">'
