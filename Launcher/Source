    return{name:f+' '+l,email:f.toLowerCase()+'.'+l.toLowerCase()+rnd(1,99)+'@'+pick(doms),
      phone:'04'+rnd(10,99)+' '+rnd(100,999)+' '+rnd(100,999),
      dob:rnd(1,28)+'/'+rnd(1,12)+'/'+(new Date().getFullYear()-rnd(18,65)),
      address:rnd(1,200)+' '+pick(sts)+', '+pick(sbs)+' '+rnd(2000,6999),
      username:f.toLowerCase()+l.toLowerCase().slice(0,3)+rnd(10,99),
      password:'P@ss'+rnd(1000,9999)+'!'};
  }
  var data=gen();
  var panel=document.createElement('div');panel.id=id;
