        +'<input id="__ls_search__" placeholder="Filter keys…" style="width:100%;background:#313244;border:1px solid #45475a;border-radius:5px;color:#cdd6f4;font-size:11px;padding:5px 8px;outline:none;box-sizing:border-box;">'
      +'</div>';
    document.getElementById('__ls_x__').onclick=function(){panel.remove();};
    document.getElementById('__ls_clr__').onclick=function(){if(confirm('Clear ALL localStorage?')){localStorage.clear();render();}};
