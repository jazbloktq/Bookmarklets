      this.textContent='Copied!';var btn=this;setTimeout(function(){btn.textContent='Copy';},2000);
    };
  }
})()`},
      {name:"Auto Scroller",type:"inline",src:`(function(){
  var id='__as__';if(document.getElementById(id)){document.getElementById(id).remove();clearInterval(window.__as_iv__);return;}
  var speed=0,running=false;
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:#1e1e2e;border:1px solid #45475a;border-radius:30px;padding:8px 16px;display:flex;align-items:center;gap:10px;z-index:2147483647;box-shadow:0 4px 20px rgba(0,0,0,.5);font-family:system-ui,sans-serif;font-size:12px;color:#cdd6f4;user-select:none;white-space:nowrap;';
  function getCol(){return speed<0?'#93c5fd':speed>0?'#a6e3a1':'#6c7086';}
  function render(){
    panel.innerHTML='<span style="font-size:11px;color:#6c7086;">AUTO SCROLL</span>'
      +'<input id="__as_spd__" type="range" min="-10" max="10" step="0.5" value="'+speed+'" style="width:110px;accent-color:#cba6f7;">'
      +'<span id="__as_lbl__" style="color:'+getCol()+';font-size:11px;min-width:36px;text-align:center;">'+(speed===0?'STOP':(speed>0?'↓ '+Math.abs(speed):'↑ '+Math.abs(speed)))+'</span>'
      +'<button id="__as_tog__" style="background:'+(running?'#f38ba8':'#a6e3a1')+';color:#1e1e2e;border:none;border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;cursor:pointer;">'+(running?'Stop':'Start')+'</button>'
      +'<button id="__as_x__" style="background:none;border:none;color:#6c7086;font-size:16px;cursor:pointer;line-height:1;padding:0;">×</button>';
    document.getElementById('__as_spd__').oninput=function(){speed=parseFloat(this.value);document.getElementById('__as_lbl__').textContent=speed===0?'STOP':(speed>0?'↓ '+Math.abs(speed):'↑ '+Math.abs(speed));document.getElementById('__as_lbl__').style.color=getCol();};
    document.getElementById('__as_tog__').onclick=function(){running=!running;if(running){window.__as_iv__=setInterval(function(){window.scrollBy(0,speed);},16);}else{clearInterval(window.__as_iv__);}render();};
    document.getElementById('__as_x__').onclick=function(){clearInterval(window.__as_iv__);panel.remove();};
  }
  document.body.appendChild(panel);render();
})()`},
      {name:"Timestamp",type:"inline",src:`(function(){
