  panel.innerHTML=''
    +'<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;">'
      +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">Page Snapshot</span>'
      +'<button id="__ps_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0;">×</button>'
    +'</div>'
    +'<div style="padding:14px 12px;display:flex;flex-direction:column;gap:8px;">'
      +'<button id="__ps_live__" style="width:100%;background:#313244;color:#cdd6f4;border:1px solid #45475a;border-radius:7px;padding:10px 14px;font-size:12px;font-weight:600;cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;">'
        +'<span style="font-size:16px;">&#128196;</span><div><div>Current HTML</div><div style="font-size:10px;font-weight:400;color:#6c7086;margin-top:1px;">Saves the page exactly as it is right now</div></div>'
      +'</button>'
