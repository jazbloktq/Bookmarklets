      {name:"Speed Test",type:"inline",src:`(function(){
  var id='__st__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:300px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 16px 60px rgba(0,0,0,.7);overflow:hidden;';
  panel.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;">'
    +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">Speed Test</span>'
    +'<button id="__st_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0;">x</button>'
    +'</div>'
    +'<div style="padding:16px;">'
      +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">'
        +'<div style="background:#313244;border-radius:8px;padding:12px;text-align:center;">'
          +'<div id="__st_dl__" style="font-size:26px;font-weight:700;color:#a6e3a1;">--</div>'
          +'<div style="font-size:10px;color:#6c7086;margin-top:2px;">Mbps DOWN</div>'
        +'</div>'
        +'<div style="background:#313244;border-radius:8px;padding:12px;text-align:center;">'
          +'<div id="__st_ul__" style="font-size:26px;font-weight:700;color:#89b4fa;">--</div>'
          +'<div style="font-size:10px;color:#6c7086;margin-top:2px;">Mbps UP</div>'
        +'</div>'
      +'</div>'
      +'<div id="__st_status__" style="font-size:11px;color:#6c7086;text-align:center;margin-bottom:10px;">Press Start to begin</div>'
      +'<div style="background:#313244;border-radius:4px;height:4px;margin-bottom:14px;overflow:hidden;">'
        +'<div id="__st_bar__" style="height:100%;width:0%;background:#cba6f7;transition:width 0.3s;"></div>'
      +'</div>'
      +'<button id="__st_go__" style="width:100%;background:#cba6f7;color:#1e1e2e;border:none;border-radius:7px;padding:9px;font-size:12px;font-weight:600;cursor:pointer;">Start</button>'
    +'</div>';
  document.body.appendChild(panel);
  document.getElementById('__st_x__').onclick=function(){panel.remove();};
  document.getElementById('__st_go__').onclick=function(){runTest();};
  function setStatus(msg,pct){
    document.getElementById('__st_status__').textContent=msg;
    document.getElementById('__st_bar__').style.width=(pct||0)+'%';
  }
  function runTest(){
    var go=document.getElementById('__st_go__');
    go.disabled=true;go.style.opacity='0.5';
    document.getElementById('__st_dl__').textContent='--';
    document.getElementById('__st_ul__').textContent='--';
    setStatus('Testing download...',10);
    var dlUrl='https://speed.cloudflare.com/__down?bytes=10000000';
    var dlStart=Date.now();
    fetch(dlUrl+'&t='+Date.now(),{cache:'no-store'})
      .then(function(r){return r.blob();})
      .then(function(b){
        var secs=(Date.now()-dlStart)/1000;
        var mbps=((b.size*8)/(secs*1000000)).toFixed(2);
        document.getElementById('__st_dl__').textContent=mbps;
        setStatus('Testing upload...',55);
        var payload=new Blob([new Uint8Array(2000000)]);
        var ulStart=Date.now();
        fetch('https://speed.cloudflare.com/__up',{method:'POST',body:payload,cache:'no-store'})
          .then(function(){
            var usecs=(Date.now()-ulStart)/1000;
            var umbps=((payload.size*8)/(usecs*1000000)).toFixed(2);
            document.getElementById('__st_ul__').textContent=umbps;
            setStatus('Done',100);
            go.disabled=false;go.style.opacity='1';go.textContent='Test again';
          })
          .catch(function(){
            setStatus('Upload test failed (CORS)',80);
            go.disabled=false;go.style.opacity='1';go.textContent='Test again';
          });
      })
      .catch(function(){
        setStatus('Download test failed',0);
        go.disabled=false;go.style.opacity='1';
      });
  }
})()`},
      {name:"Citation Generator",type:"inline",src:`(function(){
  var id='__cit__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var fmt='APA';
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;width:380px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 8px 32px rgba(0,0,0,.5);overflow:hidden;';
  var currentUrl=location.href;
  function render(result){
    panel.innerHTML='<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;">'
      +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">Citation Generator</span>'
      +'<button id="__cit_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0;">x</button>'
      +'</div><div style="padding:12px;">'
      +'<div style="font-size:10px;color:#6c7086;margin-bottom:5px;letter-spacing:.06em;">FORMAT</div>'
      +'<div style="display:flex;gap:6px;margin-bottom:10px;">'
      +['APA','MLA','Chicago'].map(function(f){return'<button data-fmt="'+f+'" style="flex:1;background:'+(fmt===f?'#cba6f7':'#313244')+';color:'+(fmt===f?'#1e1e2e':'#cdd6f4')+';border:none;border-radius:5px;padding:5px;font-size:11px;font-weight:600;cursor:pointer;">'+f+'</button>';}).join('')
      +'</div>'
      +'<div style="font-size:10px;color:#6c7086;margin-bottom:5px;letter-spacing:.06em;">URL</div>'
      +'<div style="display:flex;gap:6px;margin-bottom:10px;">'
        +'<input id="__cit_url__" style="flex:1;background:#313244;border:1px solid #45475a;border-radius:5px;color:#cdd6f4;font-size:11px;padding:5px 8px;outline:none;">'
        +'<button id="__cit_go__" style="background:#cba6f7;color:#1e1e2e;border:none;border-radius:5px;padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer;">Cite</button>'
      +'</div>'
      +(result?'<div id="__cit_res__" style="background:#313244;border-radius:6px;padding:10px;font-size:11px;line-height:1.6;color:#cdd6f4;word-break:break-word;">'+result+'</div>'
        +'<button id="__cit_copy__" style="width:100%;margin-top:8px;background:#313244;color:#a6e3a1;border:none;border-radius:5px;padding:6px;font-size:11px;cursor:pointer;">Copy</button>':'')
      +'</div>';
    var urlInput=document.getElementById('__cit_url__');
    urlInput.value=currentUrl;
    document.getElementById('__cit_x__').onclick=function(){panel.remove();};
    panel.querySelectorAll('[data-fmt]').forEach(function(b){
      b.onclick=function(){
        currentUrl=document.getElementById('__cit_url__').value;
        fmt=this.dataset.fmt;
        render(null);
      };
    });
    document.getElementById('__cit_go__').onclick=function(){
      currentUrl=document.getElementById('__cit_url__').value;
      cite(currentUrl);
    };
    urlInput.addEventListener('keydown',function(e){if(e.key==='Enter'){currentUrl=urlInput.value;cite(currentUrl);}});
    var cp=document.getElementById('__cit_copy__');
    if(cp)cp.onclick=function(){navigator.clipboard.writeText(document.getElementById('__cit_res__').textContent).catch(function(){});this.textContent='Copied!';var s=this;setTimeout(function(){s.textContent='Copy';},1500);};
  }
  function cite(url){
    render('<span style="color:#6c7086;">Fetching...</span>');
    var siteName='';
    try{siteName=new URL(url).hostname.replace(/^www\./,'');}catch(e){siteName=url;}
    var year=new Date().getFullYear();
    var now=new Date();
    var months=['Jan.','Feb.','Mar.','Apr.','May','June','July','Aug.','Sept.','Oct.','Nov.','Dec.'];
    var accessedMLA=now.getDate()+' '+months[now.getMonth()]+' '+now.getFullYear();
    var urlNoProto=url.replace('https://','').replace('http://','');
    fetch('https://api.allorigins.win/get?url='+encodeURIComponent(url))
      .then(function(r){return r.json();})
      .then(function(d){
        var title=url;
        var author='';
        var m=d.contents&&new RegExp('<title[^>]*>([^<]+)<\\/title>','i').exec(d.contents);
        if(m)title=m[1].trim();
        var ref='';
        if(fmt==='APA'){
          ref=(author?author+'. ':'')+'('+year+'). '+title+'. '+siteName+'. '+url;
        } else if(fmt==='MLA'){
          ref=(author?author+'. ':'')+'"'+title+'." '+siteName+', '+year+', '+urlNoProto+'. Accessed '+accessedMLA+'.';
        } else {
          ref=(author?author+'. ':'')+'"'+title+'." '+siteName+'. '+year+'. '+url+'.';
        }
        render(ref);
      })
      .catch(function(){
        var ref='';
        var title=url;
        if(fmt==='APA'){ref='('+year+'). '+title+'. '+siteName+'. '+url;}
        else if(fmt==='MLA'){ref='"'+title+'." '+siteName+', '+year+', '+urlNoProto+'. Accessed '+accessedMLA+'.';}
        else{ref='"'+title+'." '+siteName+'. '+year+'. '+url+'.';}
        render(ref);
      });
  }
  document.body.appendChild(panel);render(null);
})()`},
      {name:"Wikipedia",type:"inline",src:`(function(){
  var id='__wiki__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:0;right:0;width:340px;height:100vh;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border-left:1px solid #45475a;z-index:2147483647;box-shadow:-4px 0 24px rgba(0,0,0,.4);display:flex;flex-direction:column;';
  panel.innerHTML='<div style="display:flex;align-items:center;gap:8px;padding:10px 12px;border-bottom:1px solid #313244;background:#181825;flex-shrink:0;">'
    +'<input id="__wiki_inp__" placeholder="Search Wikipedia..." style="flex:1;background:#313244;border:1px solid #45475a;border-radius:5px;color:#cdd6f4;font-size:12px;padding:6px 9px;outline:none;">'
    +'<button id="__wiki_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0;">x</button>'
    +'</div><div id="__wiki_body__" style="flex:1;overflow-y:auto;padding:12px;font-size:12px;line-height:1.6;color:#a6adc8;"></div>';
  document.body.appendChild(panel);
  var inp=document.getElementById('__wiki_inp__');
  document.getElementById('__wiki_x__').onclick=function(){panel.remove();};
  function search(q){
    if(!q)return;
    var body=document.getElementById('__wiki_body__');
    body.innerHTML='<span style="color:#6c7086;">Searching...</span>';
    fetch('https://en.wikipedia.org/api/rest_v1/page/summary/'+encodeURIComponent(q))
      .then(function(r){return r.json();})
      .then(function(d){
        if(!d.title||d.type==='https://mediawiki.org/wiki/HyperSwitch/errors/not_found'){body.innerHTML='<span style="color:#6c7086;">No article found.</span>';return;}
        var img=d.thumbnail?'<img src="'+d.thumbnail.source+'" style="width:100%;border-radius:6px;margin-bottom:10px;">':'';
        body.innerHTML=img+'<div style="font-size:15px;font-weight:600;color:#cdd6f4;margin-bottom:6px;">'+d.title+'</div>'
          +'<div style="font-size:11px;color:#a6adc8;line-height:1.7;">'+d.extract+'</div>'
          +'<a href="'+d.content_urls.desktop.page+'" target="_blank" style="display:inline-block;margin-top:10px;color:#89b4fa;font-size:11px;">Read full article</a>';
      }).catch(function(){body.innerHTML='<span style="color:#f38ba8;">Error.</span>';});
  }
