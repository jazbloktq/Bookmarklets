    }
    function scanDoc(doc){
      try{
        doc.querySelectorAll('img').forEach(function(el){addSrc(el.src||el.currentSrc);addSrc(el.getAttribute('data-src'));addSrc(el.getAttribute('data-lazy'));addSrc(el.getAttribute('data-original'));});
        doc.querySelectorAll('[style]').forEach(function(el){var m=el.style.backgroundImage.match(/url\(["']?([^"')]+)["']?\)/);if(m)addSrc(m[1]);});
        doc.querySelectorAll('source[srcset]').forEach(function(el){el.srcset.split(',').forEach(function(s){addSrc(s.trim().split(/\s+/)[0]);});});
        doc.querySelectorAll('a[href]').forEach(function(el){var h=el.getAttribute('href')||'';if(new RegExp('\\.(png|jpe?g|gif|webp|svg|bmp|ico)(\\?|$)','i').test(h))addSrc(el.href);});
        doc.querySelectorAll('iframe').forEach(function(fr){try{if(fr.contentDocument)scanDoc(fr.contentDocument);}catch(e){}});
      }catch(e){}
    }
    scanDoc(document);
