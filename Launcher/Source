    +'<input id="__dict_inp__" type="text" placeholder="Enter a word…" style="flex:1;background:#313244;border:1px solid #45475a;border-radius:6px;color:#cdd6f4;font-size:13px;padding:6px 10px;outline:none;font-family:system-ui,sans-serif;">'
    +'<button id="__dict_go__" style="background:#cba6f7;color:#1e1e2e;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;">Look up</button>'
    +'<button id="__dict_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0;">×</button>'
    +'</div>'
    +'<div id="__dict_body__" style="padding:12px 14px;max-height:360px;overflow-y:auto;color:#a6adc8;font-size:12px;">Type a word above and click Look up.</div>';
  document.body.appendChild(panel);
  var inp=document.getElementById('__dict_inp__');
  var sel=(window.getSelection()||'').toString().trim().split(/\s+/)[0];
  if(sel)inp.value=sel;
  document.getElementById('__dict_x__').onclick=function(){panel.remove();};
  function lookup(){
    var word=inp.value.trim();if(!word)return;
    document.getElementById('__dict_body__').textContent='Loading…';
    fetch('https://api.dictionaryapi.dev/api/v2/entries/en/'+encodeURIComponent(word))
      .then(function(r){return r.json();})
      .then(function(data){
        if(!data||!data[0]||data.title){document.getElementById('__dict_body__').textContent='No definition found for "'+word+'".';return;}
        var html='';var entry=data[0];
        if(entry.phonetic)html+='<div style="color:#89b4fa;margin-bottom:8px;">'+entry.phonetic+'</div>';
        (entry.meanings||[]).forEach(function(m){
          html+='<div style="margin-bottom:10px;"><span style="background:#313244;color:#a6e3a1;padding:2px 7px;border-radius:4px;font-size:10px;">'+m.partOfSpeech+'</span>';
          (m.definitions||[]).slice(0,3).forEach(function(d,i){
            html+='<div style="margin-top:5px;color:#cdd6f4;">'+(i+1)+'. '+d.definition+'</div>';
            if(d.example)html+='<div style="color:#6c7086;font-style:italic;margin-top:2px;">"'+d.example+'"</div>';
          });html+='</div>';
        });
        document.getElementById('__dict_body__').innerHTML=html;
      })
      .catch(function(){document.getElementById('__dict_body__').textContent='Error fetching definition.';});
  }
  document.getElementById('__dict_go__').onclick=lookup;
  inp.addEventListener('keydown',function(e){if(e.key==='Enter')lookup();});
  inp.focus();
})()`},
      {name:"Word Counter",type:"inline",src:`(function(){
  var id='__wc__';if(document.getElementById(id)){document.getElementById(id).remove();clearInterval(window.__wc_iv__);return;}
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:13px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;padding:16px 18px;box-shadow:0 8px 32px rgba(0,0,0,.5);min-width:220px;';
  panel.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">'
    +'<b id="__wc_ttl__" style="color:#cba6f7;font-size:13px;">Page Content</b>'
    +'<button id="__wc_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;">×</button>'
    +'</div>'
    +'<div id="__wc_sub__" style="font-size:10px;color:#6c7086;margin-bottom:12px;">No selection — full page</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">'
    +'<div style="background:#313244;border-radius:7px;padding:10px;text-align:center;"><div id="__wc_w__" style="font-size:22px;font-weight:700;color:#89b4fa;">0</div><div style="font-size:10px;color:#6c7086;margin-top:2px;">WORDS</div></div>'
    +'<div style="background:#313244;border-radius:7px;padding:10px;text-align:center;"><div id="__wc_c__" style="font-size:22px;font-weight:700;color:#a6e3a1;">0</div><div style="font-size:10px;color:#6c7086;margin-top:2px;">CHARS</div></div>'
    +'<div style="background:#313244;border-radius:7px;padding:10px;text-align:center;"><div id="__wc_ns__" style="font-size:22px;font-weight:700;color:#f38ba8;">0</div><div style="font-size:10px;color:#6c7086;margin-top:2px;">NO SPACES</div></div>'
    +'<div style="background:#313244;border-radius:7px;padding:10px;text-align:center;"><div id="__wc_s__" style="font-size:22px;font-weight:700;color:#fab387;">0</div><div style="font-size:10px;color:#6c7086;margin-top:2px;">SENTENCES</div></div>'
    +'</div>'
    +'<div id="__wc_rt__" style="margin-top:8px;font-size:10px;color:#6c7086;text-align:center;"></div>';
  document.body.appendChild(panel);
  var ttl=document.getElementById('__wc_ttl__');
  var sub=document.getElementById('__wc_sub__');
  var wEl=document.getElementById('__wc_w__');
  var cEl=document.getElementById('__wc_c__');
  var nsEl=document.getElementById('__wc_ns__');
  var sEl=document.getElementById('__wc_s__');
  var rtEl=document.getElementById('__wc_rt__');
  document.getElementById('__wc_x__').onclick=function(){clearInterval(window.__wc_iv__);panel.remove();};
  function update(){
    var sel=window.getSelection();
    var selText=sel&&sel.toString?sel.toString():'';
    var hasSel=selText.trim().length>0;
    var text=hasSel?selText.trim():(document.body.innerText||document.body.textContent||'').trim();
    var normalised=text.replace(/\s+/g,' ');
    var words=normalised.length>0?normalised.split(' ').filter(function(w){return w.length>0;}):[]; 
    var chars=text.length;
    var charsNoSpace=text.replace(/\s/g,'').length;
    var sentences=text.split(/[.!?]+/).filter(function(s){return s.trim().length>0;}).length;
    var readSecs=Math.round((words.length/238)*60);
    var readStr=readSecs<60?(readSecs+'s read'):(Math.ceil(readSecs/60)+' min read');
    ttl.textContent=hasSel?'Selection':'Page Content';
    sub.textContent=hasSel?'From highlighted text':'No selection — full page';
    wEl.textContent=words.length;cEl.textContent=chars;nsEl.textContent=charsNoSpace;sEl.textContent=sentences;rtEl.textContent='~'+readStr;
  }
  update();window.__wc_iv__=setInterval(update,67);
})()`},
      {name:"Highlighter",type:"inline",src:`(function(){
  var id='__hl__';
  if(document.getElementById(id)){document.getElementById(id).remove();document.removeEventListener('mouseup',window.__hl_up__);return;}
  var colours=['#fef08a','#86efac','#93c5fd','#f9a8d4','#fdba74'];
  var active=colours[0];var mode='highlight';
  var bar=document.createElement('div');bar.id=id;
  bar.style.cssText='position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:#1e1e2e;border:1px solid #45475a;border-radius:30px;padding:7px 14px;display:flex;align-items:center;gap:8px;z-index:2147483647;box-shadow:0 4px 20px rgba(0,0,0,.5);font-family:system-ui,sans-serif;font-size:12px;user-select:none;';
  function renderBar(){
    bar.innerHTML='';
    var lbl=document.createElement('span');lbl.textContent='Highlight:';lbl.style.cssText='color:#6c7086;font-size:11px;white-space:nowrap;';bar.appendChild(lbl);
    colours.forEach(function(c){
      var sw=document.createElement('button');
      sw.style.cssText='width:18px;height:18px;border-radius:50%;background:'+c+';border:2px solid '+(c===active&&mode==='highlight'?'#fff':'transparent')+';cursor:pointer;padding:0;flex-shrink:0;';
      sw.onclick=function(){active=c;mode='highlight';renderBar();};bar.appendChild(sw);
    });
    var sep=document.createElement('span');sep.style.cssText='width:1px;height:18px;background:#45475a;flex-shrink:0;';bar.appendChild(sep);
    var eraseBtn=document.createElement('button');eraseBtn.textContent='Eraser';
    eraseBtn.style.cssText='background:'+(mode==='erase'?'#f38ba8':'#313244')+';color:'+(mode==='erase'?'#1e1e2e':'#cdd6f4')+';border:none;border-radius:20px;padding:3px 10px;font-size:11px;cursor:pointer;';
    eraseBtn.onclick=function(){mode=mode==='erase'?'highlight':'erase';renderBar();};bar.appendChild(eraseBtn);
    var pauseBtn=document.createElement('button');pauseBtn.textContent=mode==='off'?'▶ Resume':'⏸ Pause';
    pauseBtn.style.cssText='background:#313244;color:#cdd6f4;border:none;border-radius:20px;padding:3px 10px;font-size:11px;cursor:pointer;';
    pauseBtn.onclick=function(){mode=mode==='off'?'highlight':'off';renderBar();};bar.appendChild(pauseBtn);
    var closeBtn=document.createElement('button');closeBtn.textContent='×';
    closeBtn.style.cssText='background:none;border:none;color:#6c7086;font-size:16px;cursor:pointer;padding:0;line-height:1;margin-left:2px;';
    closeBtn.onclick=function(){bar.remove();document.removeEventListener('mouseup',window.__hl_up__);};bar.appendChild(closeBtn);
  }
  renderBar();document.body.appendChild(bar);
  window.__hl_up__=function(e){
    if(bar.contains(e.target))return;if(mode==='off')return;
    var sel=window.getSelection();if(!sel||sel.isCollapsed||!sel.rangeCount)return;
    var range=sel.getRangeAt(0);
    if(mode==='erase'){
      var node=range.commonAncestorContainer;var mark=node.nodeType===3?node.parentElement:node;
      while(mark&&mark.tagName!=='MARK'&&mark!==document.body)mark=mark.parentElement;
      if(mark&&mark.tagName==='MARK'){var parent=mark.parentNode;while(mark.firstChild)parent.insertBefore(mark.firstChild,mark);parent.removeChild(mark);parent.normalize();}
      sel.removeAllRanges();return;
    }
    var mark2=document.createElement('mark');mark2.style.cssText='background:'+active+';color:inherit;border-radius:2px;';
    try{range.surroundContents(mark2);}catch(ex){var frag=range.extractContents();mark2.appendChild(frag);range.insertNode(mark2);}
    sel.removeAllRanges();
  };
  document.addEventListener('mouseup',window.__hl_up__);
})()`},
      {name:"Pomodoro Timer",type:"inline",src:`(function(){
  var id='__pom__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var WORK=25*60,BREAK=5*60;var timeLeft=WORK,isWork=true,running=false,iv=null;
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;border:1px solid #45475a;border-radius:12px;z-index:2147483647;padding:18px 22px;box-shadow:0 8px 32px rgba(0,0,0,.5);text-align:center;min-width:180px;user-select:none;';
  function fmt(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}
  function beep(){try{var a=new AudioContext();var o=a.createOscillator();var g=a.createGain();o.connect(g);g.connect(a.destination);o.frequency.value=880;g.gain.setValueAtTime(0.3,a.currentTime);g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+0.6);o.start();o.stop(a.currentTime+0.6);}catch(e){}}
  function render(){
    var col=isWork?'#f38ba8':'#a6e3a1';
    panel.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">'
      +'<span style="font-size:10px;letter-spacing:.1em;color:'+col+';">'+(isWork?'🍅 WORK':'☕ BREAK')+'</span>'
      +'<button id="__pom_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;">×</button>'
      +'</div>'
      +'<div style="font-size:44px;font-weight:700;letter-spacing:2px;color:'+col+';font-variant-numeric:tabular-nums;">'+fmt(timeLeft)+'</div>'
      +'<div style="margin:8px 0 14px;height:4px;background:#313244;border-radius:2px;"><div style="height:100%;width:'+(((isWork?WORK:BREAK)-timeLeft)/(isWork?WORK:BREAK)*100)+'%;background:'+col+';border-radius:2px;transition:width .5s;"></div></div>'
      +'<div style="display:flex;gap:8px;justify-content:center;">'
      +'<button id="__pom_tog__" style="background:'+col+';color:#1e1e2e;border:none;border-radius:7px;padding:7px 18px;font-size:12px;font-weight:600;cursor:pointer;">'+(running?'Pause':'Start')+'</button>'
      +'<button id="__pom_rst__" style="background:#313244;color:#cdd6f4;border:none;border-radius:7px;padding:7px 14px;font-size:12px;cursor:pointer;">Reset</button>'
      +'<button id="__pom_skip__" style="background:#313244;color:#cdd6f4;border:none;border-radius:7px;padding:7px 14px;font-size:12px;cursor:pointer;">Skip</button></div>';
    document.getElementById('__pom_x__').onclick=function(){clearInterval(iv);panel.remove();};
    document.getElementById('__pom_tog__').onclick=function(){
      running=!running;
      if(running){iv=setInterval(function(){timeLeft--;if(timeLeft<=0){clearInterval(iv);running=false;beep();isWork=!isWork;timeLeft=isWork?WORK:BREAK;}render();},1000);}else{clearInterval(iv);}render();};
    document.getElementById('__pom_rst__').onclick=function(){clearInterval(iv);running=false;timeLeft=isWork?WORK:BREAK;render();};
    document.getElementById('__pom_skip__').onclick=function(){clearInterval(iv);running=false;isWork=!isWork;timeLeft=isWork?WORK:BREAK;render();};
  }
  document.body.appendChild(panel);render();
})()`},
      {name:"Translate",type:"inline",src:`(function(){
