        +'<div style="display:flex;gap:6px;">'
          +'<button id="__ck_clr__" style="background:#313244;color:#f38ba8;border:none;border-radius:5px;padding:4px 8px;font-size:11px;cursor:pointer;">Clear all</button>'
          +'<button id="__ck_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0 2px;">×</button>'
