function bringRbToFront(){if(rb&&rb.parentNode)document.body.appendChild(rb);}

function runSandbox(idx){
  if(window.__SB_toggleToy){window.__SB_toggleToy(idx);return;}
  toast('Loading...');
  fetch(SB_SRC+'?cb='+Date.now()+Math.random(),{cache:'no-store'})
    .then(function(r){if(!r.ok)throw new Error(r.status);return r.text();})
    .then(function(code){(new Function(code))();window.__SB_toggleToy(idx);bringRbToFront();})
    .catch(function(e){alert('Sandbox failed: '+e);});
}

function runItem(item){
  if(item.type==='sandbox'){
    runSandbox(item.idx);
  } else if(item.type==='github'){
    var existing=document.querySelectorAll('['+GH_MARK+']');
    if(existing.length){existing.forEach(function(e){e.remove();});toast('Cleared: '+item.name);bringRbToFront();return;}
    var oc=document.createElement;
    document.createElement=function(){var el=oc.apply(this,arguments);try{el.setAttribute(GH_MARK,'1');}catch(e){}return el;};
    toast('Loading '+item.name+'...');
    fetch(item.src+'?cb='+Date.now()+Math.random(),{cache:'no-store'})
      .then(function(r){if(!r.ok)throw new Error(r.status);return r.text();})
      .then(function(code){(new Function(code))();document.createElement=oc;toast('Ran: '+item.name);bringRbToFront();})
      .catch(function(e){document.createElement=oc;alert(item.name+' failed: '+e);});
  } else if(item.type==='url'){
    window.open(item.src,'_blank');toast('Opened: '+item.name);
  } else if(item.type==='inline'){
    try{(new Function(item.src))();toast('Ran: '+item.name);bringRbToFront();}
    catch(e){alert(item.name+' failed: '+e);}
  }
}

