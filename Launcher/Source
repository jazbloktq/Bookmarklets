        +'<span style="font-size:16px;">&#128450;</span><div><div>Computed styles inlined</div><div style="font-size:10px;font-weight:400;color:#6c7086;margin-top:1px;">Attempts to inline computed CSS for offline viewing</div></div>'
      +'</button>'
    +'</div>'
