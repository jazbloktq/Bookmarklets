      +'</div>';
    }).join('');
    panel.innerHTML=''
      +'<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-bottom:1px solid #45475a;background:#181825;flex-shrink:0;">'
        +'<span style="color:#cba6f7;font-size:12px;font-weight:600;">Cookies <span style="color:#6c7086;font-weight:400;">('+cookies.length+' / '+all.length+')</span></span>'
        +'<div style="display:flex;gap:6px;">'
          +'<button id="__ck_clr__" style="background:#313244;color:#f38ba8;border:none;border-radius:5px;padding:4px 8px;font-size:11px;cursor:pointer;">Clear all</button>'
          +'<button id="__ck_x__" style="background:none;border:none;color:#6c7086;font-size:18px;cursor:pointer;line-height:1;padding:0 2px;">×</button>'
        +'</div>'
      +'</div>'
      +'<div style="padding:6px 8px;border-bottom:1px solid #313244;background:#181825;flex-shrink:0;">'
        +'<input id="__ck_srch__" placeholder="Filter cookies…" value="'+escH(q)+'" style="width:100%;background:#313244;border:1px solid #45475a;border-radius:5px;color:#cdd6f4;font-size:11px;padding:4px 8px;outline:none;box-sizing:border-box;">'
      +'</div>'
      +'<div style="overflow-y:auto;flex:1;">'+(cookies.length?rows:'<div style="padding:16px;color:#6c7086;text-align:center;font-size:11px;">'+(q?'No matches.':'No accessible cookies found.')+'</div>')+'</div>'
      +'<div style="padding:8px 10px;border-top:1px solid #313244;background:#181825;flex-shrink:0;font-size:10px;color:#6c7086;">HttpOnly cookies are not accessible via JS and will not appear here.</div>';
