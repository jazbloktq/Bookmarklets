      {name:"Cookies",type:"inline",src:`(function(){
  var id='__ck__';if(document.getElementById(id)){document.getElementById(id).remove();return;}
  var panel=document.createElement('div');panel.id=id;
  panel.style.cssText='position:fixed;top:20px;right:20px;width:440px;max-height:560px;background:#1e1e2e;color:#cdd6f4;font-family:system-ui,sans-serif;font-size:12px;border:1px solid #45475a;border-radius:10px;z-index:2147483647;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden;';
  function getCookies(){return document.cookie.split(';').map(function(c){var idx=c.indexOf('=');if(idx<0)return null;return{name:c.slice(0,idx).trim(),value:decodeURIComponent(c.slice(idx+1).trim())};}).filter(Boolean).sort(function(a,b){return a.name.localeCompare(b.name);});}
  function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
  function render(q){
