  function maxGuesses(){ return MAX_GUESSES[difficulty]; }

  // Score each letter: 2=correct position, 1=wrong position, 0=absent
  function scoreGuess(guess){
    const result=Array(5).fill(0);
    const ansArr=[...answer];
    const guessArr=[...guess];
    const used=Array(5).fill(false);
    // First pass: exact matches
    for(let i=0;i<5;i++){
      if(guessArr[i]===ansArr[i]){ result[i]=2; used[i]=true; }
    }
    // Second pass: wrong position
    for(let i=0;i<5;i++){
      if(result[i]===2) continue;
      for(let j=0;j<5;j++){
        if(!used[j]&&guessArr[i]===ansArr[j]){ result[i]=1; used[j]=true; break; }
      }
    }
    return result;
  }

  // Build keyboard letter status map
  function buildKeyMap(){
    const m={};
    for(const {word,score} of guesses){
      for(let i=0;i<5;i++){
        const ch=word[i];
        const s=score[i];
        if((m[ch]||0)<s) m[ch]=s;
      }
    }
    return m;
  }

  function submitGuess(){
    if(currentGuess.length<5){ flash('Not enough letters'); shakeRow=guesses.length; setTimeout(()=>shakeRow=-1,500); return; }
