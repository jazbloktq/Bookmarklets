// TOY 43 — GALAGA
// ════════════════════════════════════════════════════════════════════════════
function initGalaga(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF={
    enemySpeed:[0.4,0.7,1.1],
    diveBullets:[1,2,3],
    diveCooldown:[180,120,70],
    playerBulletCooldown:[18,22,28],
  };

  const ROWS=4, COLS=10;
  let player,bullets,enemyBullets,enemies,particles3;
  let score,lives,level,gameOver,wave,bonusStage;
  let diveCooldown,formTick,formDir;
  let keys2={};

  function init(){
    // MUST set W/H before spawnWave so enemy positions are calculated correctly
    W=c.width=body.clientWidth||400; H=c.height=body.clientHeight||300;
    score=0;lives=3;level=1;gameOver=false;bonusStage=false;
    player={x:W/2,y:H-50,w:28,h:20,fireCD:0,invincible:0};
    bullets=[];enemyBullets=[];particles3=[];
    diveCooldown=DIFF.diveCooldown[difficulty];
    formTick=0;formDir=1;
    spawnWave();
  }

  const ENEMY_TYPES=[
    {col:'#ff4444',pts:100,w:22,h:18,rows:[0]},   // boss bee
    {col:'#ff8844',pts:80, w:20,h:16,rows:[1]},   // butterfly
    {col:'#44aaff',pts:50, w:18,h:14,rows:[2,3]}, // bee
  ];

  function spawnWave(){
    enemies=[];
    const ew=W/(COLS+1), startY=60;
    for(let r=0;r<ROWS;r++){
      const type=r===0?0:r===1?1:2;
      const et=ENEMY_TYPES[type];
      for(let cc=0;cc<COLS;cc++){
        enemies.push({
          x:40+cc*ew, y:startY+r*36,
          baseX:40+cc*ew, baseY:startY+r*36,
          type, w:et.w, h:et.h,
          alive:true, diving:false,
          divePhase:0, diveX:0, diveY:0,
          diveVx:0, diveVy:0,
          escortOf:-1, pulse:0,
        });
      }
    }
    bonusStage=false;
  }

  function spawnBonusStage(){
    bonusStage=true; enemies=[];
    const ew=W/(20+1);
    for(let cc=0;cc<40;cc++){
      enemies.push({
        x:40+(cc%20)*ew, y:40+Math.floor(cc/20)*40,
        baseX:40+(cc%20)*ew, baseY:40+Math.floor(cc/20)*40,
        type:2,w:18,h:14,alive:true,diving:false,
        divePhase:0,diveX:0,diveY:0,diveVx:0,diveVy:0,pulse:0
      });
    }
  }

  function spawnParticle3(x,y,col,n){
    for(let i=0;i<n;i++){
      const a=Math.random()*Math.PI*2,spd=2+Math.random()*5;
      particles3.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,life:1,col,r:2+Math.random()*2});
    }
  }

  function drawShip(x,y,w,h,col,paper){
    // Simple fighter silhouette
    ctx.fillStyle=col;
    ctx.beginPath();
    ctx.moveTo(x,y-h/2);
    ctx.lineTo(x-w/2,y+h/2);
    ctx.lineTo(x-w*0.15,y+h*0.2);
    ctx.lineTo(x,y+h/2*0.3);
    ctx.lineTo(x+w*0.15,y+h*0.2);
    ctx.lineTo(x+w/2,y+h/2);
    ctx.closePath();ctx.fill();
    // cockpit
    ctx.fillStyle=paper?'rgba(255,255,255,0.5)':'rgba(180,220,255,0.6)';
    ctx.beginPath();ctx.ellipse(x,y-h*0.1,w*0.12,h*0.2,0,0,Math.PI*2);ctx.fill();
  }

  function drawEnemy(e,paper){
    const et=ENEMY_TYPES[e.type];
    const p=e.pulse;
    ctx.fillStyle=p>0.5?'#ffffff':et.col;
    if(!paper&&p>0.1){ctx.save();ctx.shadowColor=et.col;ctx.shadowBlur=10;}
    if(e.type===0){
      // boss — more detailed
      ctx.beginPath();
      ctx.moveTo(e.x,e.y-e.h/2);
      ctx.lineTo(e.x+e.w/2,e.y);
      ctx.lineTo(e.x+e.w*0.3,e.y+e.h/2);
      ctx.lineTo(e.x-e.w*0.3,e.y+e.h/2);
      ctx.lineTo(e.x-e.w/2,e.y);
      ctx.closePath();ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,100,0.6)';
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w*0.2,e.h*0.2,0,0,Math.PI*2);ctx.fill();
    } else if(e.type===1){
      // butterfly
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w/2,e.h/2,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.2)':et.col+'88';
      ctx.beginPath();ctx.ellipse(e.x-e.w*0.55,e.y,e.w*0.3,e.h*0.4,Math.PI*0.3,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(e.x+e.w*0.55,e.y,e.w*0.3,e.h*0.4,-Math.PI*0.3,0,Math.PI*2);ctx.fill();
    } else {
      // bee
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w*0.35,e.h/2,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
      ctx.beginPath();ctx.ellipse(e.x-e.w*0.4,e.y-e.h*0.1,e.w*0.25,e.h*0.3,-0.4,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(e.x+e.w*0.4,e.y-e.h*0.1,e.w*0.25,e.h*0.3,0.4,0,Math.PI*2);ctx.fill();
    }
    if(!paper&&p>0.1)ctx.restore();
    e.pulse=Math.max(0,p-0.08);
  }

  function step(){
    formTick++;
    // Formation oscillation
    const formOff=Math.sin(formTick*0.012*(1+level*0.1))*Math.min(60,W*0.12)*DIFF.enemySpeed[difficulty];

    // Enemy movement
    let anyAlive=false;
    for(const e of enemies){
      if(!e.alive) continue; anyAlive=true;
      if(!e.diving){
        e.x=e.baseX+formOff;
        e.y=e.baseY+Math.sin(formTick*0.018+e.baseX*0.05)*8;
      } else {
        // Dive arc
        e.divePhase+=0.04*(1+level*0.05);
        e.x+=e.diveVx; e.y+=e.diveVy;
        e.diveVy+=0.08; // gravity pull
        // Curve toward player
        const dx=player.x-e.x;
        e.diveVx+=dx*0.003;
        // clamp dive speed
        const spd=Math.hypot(e.diveVx,e.diveVy);
        const maxSpd=4+level*0.3;
        if(spd>maxSpd){e.diveVx=e.diveVx/spd*maxSpd;e.diveVy=e.diveVy/spd*maxSpd;}
        // Off screen — return to formation
        if(e.y>H+30){e.diving=false;e.x=e.baseX+formOff;e.y=e.baseY;}
      }
    }

    if(!anyAlive){
      level++;
      if(level%3===0) spawnBonusStage();
      else spawnWave();
      score+=bonusStage?2000:500;
      return;
    }

    // Trigger dives
    diveCooldown--;
    if(diveCooldown<=0){
      diveCooldown=DIFF.diveCooldown[difficulty];
      const free=enemies.filter(e=>e.alive&&!e.diving);
      const count=Math.min(DIFF.diveBullets[difficulty]+Math.floor(level/3),3);
      for(let i=0;i<count&&free.length;i++){
        const e=free.splice(Math.floor(Math.random()*free.length),1)[0];
        e.diving=true; e.diveVx=rndf(-2,2); e.diveVy=1+Math.random()*2;
        // Enemy fires when starting dive
        enemyBullets.push({x:e.x,y:e.y,vx:(player.x-e.x)*0.04,vy:4+Math.random()*2});
      }
    }

    // Player movement — arrow keys OR wasd
    const pspd=5;
    const goLeft  = keys2['ArrowLeft'] ||keys2['a']||keys2['A'];
    const goRight = keys2['ArrowRight']||keys2['d']||keys2['D'];
    const goUp    = keys2['ArrowUp']   ||keys2['w']||keys2['W'];
    const goDown  = keys2['ArrowDown'] ||keys2['s']||keys2['S'];
    if(goLeft)  player.x=Math.max(player.w/2,        player.x-pspd);
    if(goRight) player.x=Math.min(W-player.w/2,      player.x+pspd);
    if(goUp)    player.y=Math.max(H*0.35,             player.y-pspd);
    if(goDown)  player.y=Math.min(H-player.h/2-4,    player.y+pspd);
    if(player.fireCD>0) player.fireCD--;
    if(player.invincible>0) player.invincible--;

    // Auto-fire when space held
    if((keys2['Space']||keys2[' '])&&player.fireCD===0){
      bullets.push({x:player.x,y:player.y-player.h/2,vy:-11});
      player.fireCD=DIFF.playerBulletCooldown[difficulty];
    }

    // Move bullets
    for(const b of bullets) b.y+=b.vy;
    for(const b of enemyBullets){b.x+=b.vx;b.y+=b.vy;}

    // Bullet-enemy collisions
    for(const b of bullets){
      for(const e of enemies){
        if(!e.alive) continue;
        if(Math.abs(b.x-e.x)<e.w/2&&Math.abs(b.y-e.y)<e.h/2){
          e.alive=false; b.dead=true;
          score+=ENEMY_TYPES[e.type].pts*(bonusStage?2:1);
          spawnParticle3(e.x,e.y,ENEMY_TYPES[e.type].col,8);
        }
      }
    }
    bullets=bullets.filter(b=>!b.dead&&b.y>-20);
    enemyBullets=enemyBullets.filter(b=>b.y<H+10&&b.x>-10&&b.x<W+10);

    // Enemy bullet-player collisions
    if(player.invincible===0){
      for(const b of enemyBullets){
        if(Math.abs(b.x-player.x)<player.w/2&&Math.abs(b.y-player.y)<player.h/2){
          b.dead=true; lives--;
          spawnParticle3(player.x,player.y,'#44aaff',12);
          player.invincible=120;
          if(lives<=0){gameOver=true;}
        }
      }
      // Direct dive collision
      for(const e of enemies){
        if(!e.alive||!e.diving) continue;
        if(Math.abs(e.x-player.x)<(e.w+player.w)/2&&Math.abs(e.y-player.y)<(e.h+player.h)/2){
          e.alive=false; lives--;
          spawnParticle3(player.x,player.y,'#44aaff',12);
          player.invincible=120;
          if(lives<=0)gameOver=true;
        }
      }
    }
    enemyBullets=enemyBullets.filter(b=>!b.dead);

    // Particles
    for(const p of particles3){p.x+=p.vx;p.y+=p.vy;p.vy+=0.1;p.vx*=0.95;p.life-=0.04;}
    particles3=particles3.filter(p=>p.life>0);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    const newW=body.clientWidth||400, newH=body.clientHeight||300;
    if(newW!==W||newH!==H){
      W=c.width=newW; H=c.height=newH;
      if(enemies&&enemies.length>0&&enemies[0].baseX<2) spawnWave();
      if(player) player.y=H-50;
    }
    const paper=isPaper();
    if(!gameOver) step();

    ctx.fillStyle='#05030e'; ctx.fillRect(0,0,W,H);

    // Stars
    ctx.fillStyle='rgba(255,255,255,0.7)';
    for(let i=0;i<80;i++){
      const sx=((i*137)%W+W)%W, sy=((i*97)%Math.round(H*0.85)+Math.round(H*0.85))%Math.round(H*0.85);
      ctx.fillRect(sx,sy,i%5===0?2:1,i%5===0?2:1);
    }

    // Bonus stage banner
    if(bonusStage){
      ctx.fillStyle='rgba(255,220,50,0.15)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ffdd44'; ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center';ctx.fillText('★ BONUS STAGE — NO SHOOTING BACK ★',W/2,24);ctx.textAlign='left';
    }

    // Enemies
    for(const e of enemies) if(e.alive) drawEnemy(e,paper);

    // Bullets
    for(const b of bullets){
      if(!paper){ctx.save();ctx.shadowColor='#ffffaa';ctx.shadowBlur=8;}
      ctx.fillStyle=paper?'#886600':'#ffff88';
      ctx.fillRect(b.x-2,b.y-8,4,10);
      if(!paper)ctx.restore();
    }
    for(const b of enemyBullets){
      ctx.fillStyle=paper?'#cc2222':'#ff4444';
      ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);ctx.fill();
    }

    // Particles
    for(const p of particles3){
      ctx.globalAlpha=p.life; ctx.fillStyle=p.col;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r*p.life,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Player
    if(!gameOver){
      const alpha=player.invincible>0?(Math.sin(player.invincible*0.4)*0.5+0.5):1;
      ctx.globalAlpha=alpha;
      if(!paper){ctx.save();ctx.shadowColor='#44aaff';ctx.shadowBlur=10;}
      drawShip(player.x,player.y,player.w,player.h,paper?'#2244aa':'#44aaff',paper);
      if(!paper)ctx.restore();
      ctx.globalAlpha=1;
      // engine glow
      ctx.fillStyle=paper?'rgba(255,140,20,0.6)':'rgba(255,180,40,0.8)';
      ctx.beginPath();ctx.ellipse(player.x,player.y+player.h/2+4,4,6+Math.random()*4,0,0,Math.PI*2);ctx.fill();
    }

    // HUD
    ctx.fillStyle=paper?'rgba(255,255,255,0.7)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`; ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`score: ${score}`,8,6);
    ctx.textAlign='right';
    ctx.fillText(`${'♥ '.repeat(lives).trim()}  lv.${level}`,W-8,6);
    ctx.textAlign='left';

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.65)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle=paper?'#fff':'#ffdd44';
      ctx.font=`400 20px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-18);
      ctx.fillStyle=paper?'rgba(255,255,255,0.7)':'rgba(255,255,255,0.5)';
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillText(`score: ${score}  ·  click to retry`,W/2,H/2+14);
      ctx.textAlign='left';ctx.textBaseline='top';
    }
  }

  c.addEventListener('click',()=>{if(gameOver)init();});

  const onKey=e=>{
    keys2[e.key]=e.type==='keydown';
    // prevent page scroll for game keys
    if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Space',' ','w','a','s','d','W','A','S','D'].includes(e.key))
      e.preventDefault();
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});
  mkBtn('Restart',ctrl).addEventListener('click',init);

  const hint=mkInfo(ctrl);
  hint.textContent='WASD / arrows · Space to fire';

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 44 — MISSILE COMMAND
// ════════════════════════════════════════════════════════════════════════════
function initMissileCommand(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF={
    missileSpeed:[0.5,0.9,1.5],
    spawnRate:[0.008,0.016,0.028],
    interceptorAmmo:[12,10,8],
    interceptorSpeed:[6,5.5,5],
  };

  let cities,batteries,missiles,interceptors,explosions4;
  let score,wave,gameOver,ammo,tick5,waveDelay;

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    score=0;wave=1;gameOver=false;tick5=0;waveDelay=0;
    ammo=DIFF.interceptorAmmo[difficulty]*3;
    const groundY=H-28;

    // 6 cities spread across bottom
    cities=[];
    const cityPositions=[0.15,0.27,0.38,0.62,0.73,0.85];
    for(const xf of cityPositions) cities.push({x:W*xf,y:groundY,alive:true,destroyFlash:0});

    // 3 missile batteries
    batteries=[
      {x:W*0.1,y:groundY,ammo:DIFF.interceptorAmmo[difficulty],flash:0},
      {x:W*0.5,y:groundY,ammo:DIFF.interceptorAmmo[difficulty],flash:0},
      {x:W*0.9,y:groundY,ammo:DIFF.interceptorAmmo[difficulty],flash:0},
    ];

    missiles=[]; interceptors=[]; explosions4=[];
  }
  init();

  function spawnMissile(){
    const target=Math.random()<0.7
      ? cities.filter(c2=>c2.alive)[Math.floor(Math.random()*cities.filter(c2=>c2.alive).length)]
      : batteries[Math.floor(Math.random()*batteries.length)];
    if(!target) return;
    const sx=Math.random()*W, sy=0;
    const dist=Math.hypot(target.x-sx,target.y-sy)||1;
    const spd=DIFF.missileSpeed[difficulty]*(0.8+Math.random()*0.4)*(1+wave*0.08);
    missiles.push({
      x:sx,y:sy,vx:(target.x-sx)/dist*spd,vy:(target.y-sy)/dist*spd,
      tx:target.x,ty:target.y, trail:[], alive:true
    });
  }

  function fireInterceptor(tx,ty){
    // pick nearest battery with ammo
    let best=null,bestD=Infinity;
    for(const b of batteries){
      if(b.ammo<=0) continue;
      const d=Math.hypot(tx-b.x,ty-b.y);
      if(d<bestD){bestD=d;best=b;}
    }
    if(!best){return;}
    best.ammo--;best.flash=8;ammo--;
    const dist=Math.hypot(tx-best.x,ty-best.y)||1;
    const spd=DIFF.interceptorSpeed[difficulty];
    interceptors.push({x:best.x,y:best.y,vx:(tx-best.x)/dist*spd,vy:(ty-best.y)/dist*spd,tx,ty,trail:[]});
  }

  function addExplosion(x,y,r,col){
    explosions4.push({x,y,r,maxR:r,life:1,col,growing:true});
  }

  function step(){
    tick5++;
    // Spawn missiles
    if(Math.random()<DIFF.spawnRate[difficulty]*(1+wave*0.15)) spawnMissile();

    // Move missiles
    for(const m of missiles){
      if(!m.alive) continue;
      m.trail.push({x:m.x,y:m.y});
      if(m.trail.length>30) m.trail.shift();
      m.x+=m.vx; m.y+=m.vy;
      if(m.y>=m.ty-4){
        m.alive=false;
        addExplosion(m.tx,m.ty,38,'#ff6622');
        // damage city/battery at target
        for(const city of cities){
          if(city.alive&&Math.hypot(city.x-m.tx,city.y-m.ty)<40){city.alive=false;city.destroyFlash=30;}
        }
      }
    }
    missiles=missiles.filter(m=>m.alive&&m.y<H+20);

    // Move interceptors
    for(const iv of interceptors){
      iv.trail.push({x:iv.x,y:iv.y});
      if(iv.trail.length>20) iv.trail.shift();
      iv.x+=iv.vx; iv.y+=iv.vy;
      const dist=Math.hypot(iv.x-iv.tx,iv.y-iv.ty);
      if(dist<8){
        iv.dead=true;
        addExplosion(iv.tx,iv.ty,55,'#44aaff');
      }
    }
    interceptors=interceptors.filter(iv=>!iv.dead);

    // Explosion-missile collisions
    for(const exp of explosions4){
      if(exp.growing) exp.r=Math.min(exp.maxR,exp.r+2);
      else exp.r*=0.96;
      exp.life-=0.018;
      if(exp.r>=exp.maxR) exp.growing=false;
      for(const m of missiles){
        if(!m.alive) continue;
        if(Math.hypot(m.x-exp.x,m.y-exp.y)<exp.r){
          m.alive=false; score+=25*(wave);
          addExplosion(m.x,m.y,30,'#ffaa44');
        }
      }
    }
    explosions4=explosions4.filter(e=>e.life>0);

    // Check wave clear
    if(missiles.length===0&&interceptors.length===0&&tick5>120){
      const alive=cities.filter(c2=>c2.alive).length;
      if(alive>0){
        score+=alive*100+batteries.reduce((s,b)=>s+b.ammo,0)*10;
        wave++;
        // Restock ammo each wave
        for(const b of batteries) b.ammo=Math.min(DIFF.interceptorAmmo[difficulty]+wave,20);
        ammo=batteries.reduce((s,b)=>s+b.ammo,0);
        tick5=0;
      }
    }

    // Game over if all cities dead
    if(cities.every(c2=>!c2.alive)) gameOver=true;
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    if(!gameOver) step();

    // Sky gradient
    const sky=ctx.createLinearGradient(0,0,0,H);
    if(paper){sky.addColorStop(0,'#b0c8e8');sky.addColorStop(1,'#e0d0b0');}
    else{sky.addColorStop(0,'#000818');sky.addColorStop(1,'#0a1428');}
    ctx.fillStyle=sky; ctx.fillRect(0,0,W,H);

    // Stars (dark only)
    if(!paper){
      ctx.fillStyle='rgba(255,255,255,0.6)';
      for(let i=0;i<80;i++) ctx.fillRect((i*113)%W,(i*71)%H*0.7,1,1);
    }

    // Ground
    ctx.fillStyle=paper?'#7a6a40':'#1a3a1a';
    ctx.fillRect(0,H-28,W,28);
    ctx.fillStyle=paper?'#8a7a50':'#22441a';
    ctx.fillRect(0,H-28,W,4);

    // Missile trails
    for(const m of missiles){
      if(m.trail.length<2) continue;
      const [r2,g2,b2]=paper?[200,100,30]:[255,80,30];
      for(let i=1;i<m.trail.length;i++){
        const a=(i/m.trail.length)*0.5;
        ctx.strokeStyle=`rgba(${r2},${g2},${b2},${a})`;
        ctx.lineWidth=1.5;
        ctx.beginPath();ctx.moveTo(m.trail[i-1].x,m.trail[i-1].y);ctx.lineTo(m.trail[i].x,m.trail[i].y);ctx.stroke();
      }
    }
    // Missiles
    for(const m of missiles){
      ctx.fillStyle=paper?'#cc3322':'#ff4422';
      ctx.beginPath();ctx.arc(m.x,m.y,3,0,Math.PI*2);ctx.fill();
    }

    // Interceptor trails
    for(const iv of interceptors){
      if(iv.trail.length<2) continue;
      for(let i=1;i<iv.trail.length;i++){
        const a=(i/iv.trail.length)*0.7;
        ctx.strokeStyle=`rgba(100,200,255,${a})`;
        ctx.lineWidth=2;
        ctx.beginPath();ctx.moveTo(iv.trail[i-1].x,iv.trail[i-1].y);ctx.lineTo(iv.trail[i].x,iv.trail[i].y);ctx.stroke();
      }
    }
    // Target crosshairs
    for(const iv of interceptors){
      ctx.strokeStyle=paper?'rgba(0,100,200,0.4)':'rgba(100,200,255,0.3)';
      ctx.lineWidth=1; ctx.setLineDash([3,5]);
      ctx.beginPath();ctx.arc(iv.tx,iv.ty,12,0,Math.PI*2);ctx.stroke();
      ctx.setLineDash([]);
    }

    // Explosions
    for(const exp of explosions4){
      const [r2,g2,b2]=[parseInt(exp.col.slice(1,3),16),parseInt(exp.col.slice(3,5),16),parseInt(exp.col.slice(5,7),16)];
      const grd=ctx.createRadialGradient(exp.x,exp.y,0,exp.x,exp.y,exp.r);
      grd.addColorStop(0,`rgba(${r2},${g2},${b2},${exp.life*0.9})`);
      grd.addColorStop(0.4,`rgba(${r2},${g2},${b2},${exp.life*0.5})`);
      grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;
      ctx.beginPath();ctx.arc(exp.x,exp.y,exp.r,0,Math.PI*2);ctx.fill();
    }

    // Cities
    for(const city of cities){
      if(city.destroyFlash>0){city.destroyFlash--;continue;}
      if(!city.alive) continue;
      ctx.fillStyle=paper?'#44337a':'#8866ff';
      // Simple building silhouette
      const bx=city.x, by=city.y;
      ctx.fillRect(bx-14,by-20,8,20);
      ctx.fillRect(bx-4,by-28,12,28);
      ctx.fillRect(bx+10,by-16,8,16);
      ctx.fillStyle=paper?'rgba(255,220,100,0.5)':'rgba(255,220,100,0.4)';
      // windows
      for(let wy=by-24;wy<by;wy+=8)
        for(let wx=bx-2;wx<bx+10;wx+=5)
          if(Math.random()<0.7) ctx.fillRect(wx,wy,3,4);
    }

    // Batteries
    for(const bat of batteries){
      ctx.fillStyle=bat.ammo>0?(paper?'#334488':'#4466cc'):(paper?'#888':'#444');
      ctx.fillRect(bat.x-16,bat.y-14,32,14);
      if(bat.ammo>0){
        ctx.fillStyle=paper?'#5566aa':'#6688ff';
        ctx.fillRect(bat.x-4,bat.y-22,8,12);
      }
      // Ammo indicator dots
      for(let i=0;i<bat.ammo;i++){
        ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(100,180,255,0.7)';
        ctx.beginPath();ctx.arc(bat.x-10+i*4,bat.y-6,1.5,0,Math.PI*2);ctx.fill();
      }
    }

    // Cursor crosshair
    if(!gameOver){
      ctx.strokeStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
      ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(mouseX-14,mouseY);ctx.lineTo(mouseX+14,mouseY);ctx.stroke();
      ctx.beginPath();ctx.moveTo(mouseX,mouseY-14);ctx.lineTo(mouseX,mouseY+14);ctx.stroke();
      ctx.beginPath();ctx.arc(mouseX,mouseY,8,0,Math.PI*2);ctx.stroke();
    }

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.55)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`; ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`score: ${score}  wave: ${wave}  ammo: ${ammo}`,8,6);

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ff4422'; ctx.font=`400 20px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('THE CITIES HAVE FALLEN',W/2,H/2-20);
      ctx.fillStyle='rgba(255,255,255,0.6)'; ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillText(`final score: ${score}  ·  click to retry`,W/2,H/2+10);
      ctx.textAlign='left';ctx.textBaseline='top';
    }
  }

  let mouseX=W/2,mouseY=H/2;
  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouseX=e.clientX-r.left;mouseY=e.clientY-r.top;});
  c.addEventListener('click',e=>{
    if(gameOver){init();return;}
    const r=c.getBoundingClientRect();
    fireInterceptor(e.clientX-r.left,e.clientY-r.top);
  });

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});
  mkBtn('Restart',ctrl).addEventListener('click',init);
  mkInfo(ctrl).textContent='click to fire interceptors';

