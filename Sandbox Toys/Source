  mkBtn('Reset',ctrl).addEventListener('click',()=>{
    if(mode==='mandelbrot'){cxM=-0.5;cyM=0;zoomM=3.0;}else{cxJ=0;cyJ=0;zoomJ=3.5;}
    scheduleRender();
  });

  // Julia C tweaker — two small sliders for Re and Im of C
  const reLbl=document.createElement('span');reLbl.className='sb-info sb-speed-lbl';reLbl.style.marginLeft='4px';reLbl.textContent='c.re';ctrl.appendChild(reLbl);
  const resl=document.createElement('input');resl.type='range';resl.className='sb-slider';resl.min=-2;resl.max=2;resl.step=0.001;resl.value=juliaC.re;ctrl.appendChild(resl);styleSlider(resl);
  resl.addEventListener('input',()=>{juliaC.re=+resl.value;if(mode==='julia')scheduleRender();});
  const imLbl=document.createElement('span');imLbl.className='sb-info sb-speed-lbl';imLbl.style.marginLeft='4px';imLbl.textContent='c.im';ctrl.appendChild(imLbl);
  const imsl=document.createElement('input');imsl.type='range';imsl.className='sb-slider';imsl.min=-2;imsl.max=2;imsl.step=0.001;imsl.value=juliaC.im;ctrl.appendChild(imsl);styleSlider(imsl);
  imsl.addEventListener('input',()=>{juliaC.im=+imsl.value;if(mode==='julia')scheduleRender();});

  const iterLbl=document.createElement('span');iterLbl.className='sb-info sb-speed-lbl';iterLbl.style.marginLeft='4px';iterLbl.textContent='detail';ctrl.appendChild(iterLbl);
  const isl=document.createElement('input');isl.type='range';isl.className='sb-slider';isl.min=40;isl.max=600;isl.step=20;isl.value=maxIter;ctrl.appendChild(isl);styleSlider(isl);
  isl.addEventListener('input',()=>{maxIter=+isl.value;scheduleRender();});

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.style.marginLeft='4px';spdLbl.textContent='draw speed';ctrl.appendChild(spdLbl);
  const spsl=document.createElement('input');spsl.type='range';spsl.className='sb-slider';spsl.min=1;spsl.max=4;spsl.step=1;spsl.value=passesPerFrame;ctrl.appendChild(spsl);styleSlider(spsl);
  spsl.addEventListener('input',()=>{passesPerFrame=+spsl.value;});

  off.width=W;off.height=H;
  scheduleRender();
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 15 — RECURSIVE SUBDIVISION  (click to split, right-click to merge)
// ════════════════════════════════════════════════════════════════════════════
function initSubdivision(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let maxDepth=8,t=0;

  // Node: {x,y,w,h,depth,hue,children:[2]|[]}
  let root=null;

  function mkNode(x,y,w,h,depth,parentHue){
    // each child gets a hue stepped from parent so siblings differ
    const hue=(parentHue + 40 + Math.random()*60)%360;
    return {x,y,w,h,depth,hue,children:[]};
  }

  function buildRoot(){
    root=mkNode(0,0,W,H,0,Math.random()*360);
  }
  buildRoot();

  // Split a leaf into 2 children. Alternates H/V by depth parity.
  function splitNode(node){
    if(node.children.length||node.depth>=maxDepth)return false;
    const{x,y,w,h,depth,hue}=node;
    if(w>h){
      // vertical split
      const half=w/2;
      node.children=[
        mkNode(x,      y, half, h, depth+1, hue),
        mkNode(x+half, y, half, h, depth+1, hue),
      ];
    } else {
      // horizontal split
      const half=h/2;
      node.children=[
        mkNode(x, y,       w, half, depth+1, hue),
        mkNode(x, y+half,  w, half, depth+1, hue),
      ];
    }
    return true;
  }

  // Merge: remove children of a node, collapsing it back to a leaf
  function mergeNode(node){
    node.children=[];
  }

  // Find the deepest leaf containing (mx,my)
  function leafAt(node,mx,my){
    if(!node)return null;
    if(mx<node.x||mx>node.x+node.w||my<node.y||my>node.y+node.h)return null;
    for(const ch of node.children){
      const r=leafAt(ch,mx,my);
      if(r)return r;
    }
    return node; // this is the leaf
  }

  // Find the parent of a node that contains (mx,my) and has children
  // i.e. the split node we'd want to merge on right-click
  function splitParentAt(node,mx,my){
    if(!node)return null;
    if(mx<node.x||mx>node.x+node.w||my<node.y||my>node.y+node.h)return null;
    if(!node.children.length)return null;
    // try children first (deepest split wins)
    for(const ch of node.children){
      const r=splitParentAt(ch,mx,my);
      if(r)return r;
    }
    return node; // this node has children and contains point
  }

  function drawNode(node){
    if(node.children.length){
      for(const ch of node.children)drawNode(ch);
      return;
    }
    const paper=isPaper();
    const hue=(node.hue+t*6)%360;
    // colour brightness varies with depth so you can see the levels
    const depthFrac=node.depth/maxDepth;
    const sat=paper?(0.10+depthFrac*0.18):(0.40+depthFrac*0.30);
    const lig=paper?(0.88-depthFrac*0.22):(0.10+depthFrac*0.24);
    ctx.fillStyle=`hsl(${hue|0},${(sat*100)|0}%,${(lig*100)|0}%)`;
    ctx.fillRect(node.x,node.y,node.w,node.h);
    // border — thicker at shallower depths
    const bw=Math.max(0.5,2-node.depth*0.25);
    const ba=paper?(0.12+depthFrac*0.08):(0.10+depthFrac*0.08);
    ctx.strokeStyle=paper?`rgba(0,0,0,${ba})`:`rgba(255,255,255,${ba})`;
    ctx.lineWidth=bw;
    ctx.strokeRect(node.x+bw/2,node.y+bw/2,node.w-bw,node.h-bw);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    const nW=body.clientWidth,nH=body.clientHeight;
    if(nW!==W||nH!==H){W=c.width=nW;H=c.height=nH;buildRoot();}
    t+=0.016;
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    drawNode(root);
    // hint text if untouched
    if(!root.children.length){
      ctx.fillStyle=isPaper()?'rgba(0,0,0,0.2)':'rgba(255,255,255,0.18)';
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('click to split · right-click to merge',W/2,H/2);
    }
  }

  function getPos(e){const r=c.getBoundingClientRect();return[e.clientX-r.left,e.clientY-r.top];}

  c.addEventListener('click',e=>{
    const[mx,my]=getPos(e);
    const node=leafAt(root,mx,my);
    if(node)splitNode(node);
  });

  c.addEventListener('contextmenu',e=>{
    e.preventDefault();
    const[mx,my]=getPos(e);
    // merge the deepest split that contains this point
    const node=splitParentAt(root,mx,my);
    if(node)mergeNode(node);
  });

  mkBtn('Reset',ctrl).addEventListener('click',buildRoot);

  const depthLbl=document.createElement('span');
  depthLbl.className='sb-info sb-speed-lbl';depthLbl.style.marginLeft='4px';depthLbl.textContent='max splits';
  ctrl.appendChild(depthLbl);
  const dsl=document.createElement('input');dsl.type='range';dsl.className='sb-slider';
  dsl.min=1;dsl.max=30;dsl.step=1;dsl.value=maxDepth;ctrl.appendChild(dsl);styleSlider(dsl);
  dsl.addEventListener('input',()=>{maxDepth=+dsl.value;});

  draw();
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 16 — GRAVITY SANDBOX
// ════════════════════════════════════════════════════════════════════════════
function initGravity(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let bodies=[],trails=[],mode='planet',dragging=null,dragStart=null,mouse={x:0,y:0};
  let showTrails=true,paused=false;
  // camera
  let camX=0,camY=0,camZ=1; // camZ = zoom scale
  const G=120,MAX_TRAIL=180;

  // convert screen pos to world pos
  function toWorld(sx,sy){return{x:(sx-W/2)/camZ+camX, y:(sy-H/2)/camZ+camY};}
  // convert world pos to screen pos
  function toScreen(wx,wy){return{x:(wx-camX)*camZ+W/2, y:(wy-camY)*camZ+H/2};}

  function mkBody(x,y,mass,vx,vy){
    const r=Math.max(4,Math.pow(mass,0.38)*2.8);
    const hue=Math.random()*360;
    return{x,y,vx:vx||0,vy:vy||0,mass,r,hue,trail:[]};
  }
  function reset(){
    bodies=[];camX=0;camY=0;camZ=1;zoomSlider.value=1;styleSlider(zoomSlider);
    bodies.push(mkBody(0,0,800,0,0));bodies[0].hue=45;
    const orbits=[80,130,185,250];
    orbits.forEach((dist,i)=>{
      const angle=Math.random()*Math.PI*2;
      const spd=Math.sqrt(G*800/dist)*0.92;
      bodies.push(mkBody(Math.cos(angle)*dist,Math.sin(angle)*dist,3+i*2,-Math.sin(angle)*spd,Math.cos(angle)*spd));
      bodies[bodies.length-1].hue=60+i*70;
    });
  }

  function stepSim(){
    if(paused)return;
    const dt=0.016;
    for(let i=0;i<bodies.length;i++){
      let ax=0,ay=0;
      for(let j=0;j<bodies.length;j++){
        if(i===j)continue;
        const dx=bodies[j].x-bodies[i].x,dy=bodies[j].y-bodies[i].y;
        const d2=dx*dx+dy*dy,d=Math.sqrt(d2)+0.5;
        const f=G*bodies[j].mass/(d2+200);
        ax+=f*dx/d;ay+=f*dy/d;
      }
      bodies[i].vx+=ax*dt;bodies[i].vy+=ay*dt;
    }
    for(let i=0;i<bodies.length;i++){
      for(let j=i+1;j<bodies.length;j++){
        if(!bodies[i]||!bodies[j])continue;
        const dx=bodies[j].x-bodies[i].x,dy=bodies[j].y-bodies[i].y;
        const d=Math.sqrt(dx*dx+dy*dy);
        if(d<bodies[i].r+bodies[j].r-2){
          const[big,small]=bodies[i].mass>=bodies[j].mass?[i,j]:[j,i];
          const m=bodies[big].mass+bodies[small].mass;
          bodies[big].vx=(bodies[big].vx*bodies[big].mass+bodies[small].vx*bodies[small].mass)/m;
          bodies[big].vy=(bodies[big].vy*bodies[big].mass+bodies[small].vy*bodies[small].mass)/m;
          bodies[big].mass=m;bodies[big].r=Math.max(4,Math.pow(m,0.38)*2.8);
          bodies.splice(small,1);break;
        }
      }
    }
    for(const b of bodies){
      b.x+=b.vx*dt*60;b.y+=b.vy*dt*60;
      if(showTrails){b.trail.push({x:b.x,y:b.y});if(b.trail.length>MAX_TRAIL)b.trail.shift();}
      else b.trail=[];
    }
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    stepSim();
    ctx.fillStyle=bgFade(0.3);ctx.fillRect(0,0,W,H);
    const paper=isPaper();
    if(showTrails)for(const b of bodies){
      if(b.trail.length<2)continue;
      ctx.beginPath();
      const s0=toScreen(b.trail[0].x,b.trail[0].y);ctx.moveTo(s0.x,s0.y);
      for(let i=1;i<b.trail.length;i++){const s=toScreen(b.trail[i].x,b.trail[i].y);ctx.lineTo(s.x,s.y);}
      ctx.strokeStyle=paper?`hsla(${b.hue},20%,35%,0.25)`:`hsla(${b.hue},80%,65%,0.25)`;
      ctx.lineWidth=1;ctx.stroke();
    }
    for(const b of bodies){
      const{x:sx,y:sy}=toScreen(b.x,b.y);
      const sr=b.r*camZ;
      const grd=ctx.createRadialGradient(sx,sy,0,sx,sy,sr*2.2);
      if(paper){grd.addColorStop(0,`hsla(${b.hue},30%,45%,0.9)`);grd.addColorStop(1,`hsla(${b.hue},20%,65%,0)`);}
      else{grd.addColorStop(0,`hsla(${b.hue},90%,80%,1)`);grd.addColorStop(0.5,`hsla(${b.hue},80%,55%,0.6)`);grd.addColorStop(1,`hsla(${b.hue},70%,40%,0)`);}
      ctx.beginPath();ctx.arc(sx,sy,Math.max(1,sr*2.2),0,Math.PI*2);ctx.fillStyle=grd;ctx.fill();
      ctx.beginPath();ctx.arc(sx,sy,Math.max(1,sr),0,Math.PI*2);
      ctx.fillStyle=paper?`hsl(${b.hue},25%,40%)`:`hsl(${b.hue},85%,72%)`;ctx.fill();
    }
    if(dragging&&dragStart){
      ctx.strokeStyle=paper?'rgba(40,30,20,0.5)':'rgba(255,255,255,0.5)';ctx.lineWidth=1.5;ctx.setLineDash([4,4]);
      ctx.beginPath();ctx.moveTo(dragStart.sx,dragStart.sy);ctx.lineTo(mouse.x,mouse.y);ctx.stroke();ctx.setLineDash([]);
    }
  }

  function getPos(e){const r=c.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}
  function findBody(sx,sy){
    let best=Infinity,idx=-1;
    bodies.forEach((b,i)=>{
      const{x:bsx,y:bsy}=toScreen(b.x,b.y);
      const d=Math.hypot(bsx-sx,bsy-sy);
      if(d<b.r*camZ+10&&d<best){best=d;idx=i;}
    });
    return idx;
  }

  // scroll to zoom toward cursor
  c.addEventListener('wheel',e=>{
    e.preventDefault();
    const{x:sx,y:sy}=getPos(e);
    const wBefore=toWorld(sx,sy);
    camZ*=e.deltaY<0?1.15:0.87;
    camZ=Math.max(0.1,Math.min(10,camZ));
    const wAfter=toWorld(sx,sy);
    camX-=wAfter.x-wBefore.x;camY-=wAfter.y-wBefore.y;
    zoomSlider.value=camZ;styleSlider(zoomSlider);
  },{passive:false});

  let panDragging=false,panStart={x:0,y:0},panCam={x:0,y:0};
  c.addEventListener('mousedown',e=>{
    const{x,y}=getPos(e);
    if(e.button===1||e.altKey){panDragging=true;panStart={x,y};panCam={x:camX,y:camY};return;}
    dragStart={x,y,sx:x,sy:y,world:toWorld(x,y)};dragging=true;
  });
  c.addEventListener('mousemove',e=>{
    const{x,y}=getPos(e);mouse={x,y};
    if(panDragging){camX=panCam.x-(x-panStart.x)/camZ;camY=panCam.y-(y-panStart.y)/camZ;}
  });
  c.addEventListener('mouseup',e=>{
    if(panDragging){panDragging=false;return;}
    if(!dragging||!dragStart)return;dragging=false;
    const{x,y}=getPos(e);
    const dx=x-dragStart.x,dy=y-dragStart.y;
    const dist=Math.hypot(dx,dy);
    const wPos=toWorld(x,y);
    if(dist<5){
      if(mode==='planet'){bodies.push(mkBody(wPos.x,wPos.y,8+Math.random()*6));}
      else if(mode==='sun'){const b=mkBody(wPos.x,wPos.y,300,0,0);b.hue=45;bodies.push(b);}
      else if(mode==='remove'){const i=findBody(x,y);if(i>=0)bodies.splice(i,1);}
    } else {
      const wStart=dragStart.world;
      const mass=mode==='sun'?300:10;
      const b=mkBody(wStart.x,wStart.y,mass,dx*0.06/camZ,dy*0.06/camZ);
      if(mode==='sun')b.hue=45;
      bodies.push(b);
    }
    dragStart=null;
  });
  c.addEventListener('mouseleave',()=>{dragging=false;dragStart=null;panDragging=false;});

  const modeLabels=['Planet','Sun','Remove'];
  let modeIdx=0;
  const modeBtns=modeLabels.map((lbl,i)=>{
    const b=mkBtn(lbl,ctrl,i===0);
    b.addEventListener('click',()=>{modeIdx=i;mode=lbl.toLowerCase();modeBtns.forEach((bb,j)=>setLit(bb,j===i));});
    return b;
  });
  const trailBtn=mkBtn('Trails: On',ctrl,true);
  trailBtn.addEventListener('click',()=>{showTrails=!showTrails;trailBtn.textContent=`Trails: ${showTrails?'On':'Off'}`;setLit(trailBtn,showTrails);});
  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';setLit(pauseBtn,paused);});
  mkBtn('Reset',ctrl).addEventListener('click',reset);

  const zLbl=document.createElement('span');zLbl.className='sb-info sb-speed-lbl';zLbl.style.marginLeft='4px';zLbl.textContent='zoom';ctrl.appendChild(zLbl);
  const zoomSlider=document.createElement('input');zoomSlider.type='range';zoomSlider.className='sb-slider';zoomSlider.min=0.1;zoomSlider.max=10;zoomSlider.step=0.05;zoomSlider.value=1;ctrl.appendChild(zoomSlider);styleSlider(zoomSlider);
  zoomSlider.addEventListener('input',()=>{camZ=+zoomSlider.value;});

  reset();draw();
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 17 — STRING ART  (click to pluck strings that vibrate and decay)
// ════════════════════════════════════════════════════════════════════════════
function initStrings(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let strings=[],numStrings=12,orientation='h'; // h=horizontal, v=vertical, r=radial
  let orientIdx=0;
  const ORIENTS=['Horizontal','Vertical','Radial'];
  function mkString(i,total){
    const paper=isPaper();
    const hue=(i/total)*280+180;
    if(orientation==='h'){const y=H*(i+1)/(total+1);return{pts:Array.from({length:80},(_,j)=>({x:W*j/79,y,oy:y,vy:0})),hue,tension:0.28,damping:0.985};}
    if(orientation==='v'){const x=W*(i+1)/(total+1);return{pts:Array.from({length:80},(_,j)=>({x,ox:x,y:H*j/79,vy:0,vx:0})),hue,tension:0.28,damping:0.985,vert:true};}
    // radial
    const angle=(i/total)*Math.PI*2;const len=Math.min(W,H)*0.46;
    const cx2=W/2,cy2=H/2;
    return{pts:Array.from({length:60},(_,j)=>{const t2=j/59;const x=cx2+Math.cos(angle)*len*t2,y=cy2+Math.sin(angle)*len*t2;return{x,y,ox:x,oy:y,vx:0,vy:0};}),hue,tension:0.28,damping:0.988,radial:true};
  }
  function buildStrings(){strings=Array.from({length:numStrings},(_,i)=>mkString(i,numStrings));}
  buildStrings();
  function pluck(mx,my,force){
    for(const s of strings){
      for(const p of s.pts){
        const d=Math.hypot(p.x-mx,p.y-my);
        if(d<40){
          const amp=force*(1-d/40)*18;
          if(!s.vert&&!s.radial)p.vy+=amp;
          else if(s.vert)p.vx+=amp;
          else{p.vx+=amp*(p.x-mx)/(d||1);p.vy+=amp*(p.y-my)/(d||1);}
        }
      }
    }
  }
  function stepStrings(){
    for(const s of strings){
      const pts=s.pts,n=pts.length;
      for(let i=1;i<n-1;i++){
        if(!s.vert&&!s.radial){
          const acc=(pts[i-1].vy-2*pts[i].vy+pts[i+1].vy)*s.tension*22+(pts[i].oy-pts[i].y)*0.04;
          pts[i].vy+=acc*0.016;pts[i].vy*=s.damping;pts[i].y+=pts[i].vy;
        } else if(s.vert){
          const acc=(pts[i-1].vx-2*pts[i].vx+pts[i+1].vx)*s.tension*22+(pts[i].ox-pts[i].x)*0.04;
          pts[i].vx+=acc*0.016;pts[i].vx*=s.damping;pts[i].x+=pts[i].vx;
        } else {
          const nx=pts[i-1].x-2*pts[i].x+pts[i+1].x,ny=pts[i-1].y-2*pts[i].y+pts[i+1].y;
          pts[i].vx+=(nx*s.tension*22+(pts[i].ox-pts[i].x)*0.04)*0.016;
          pts[i].vy+=(ny*s.tension*22+(pts[i].oy-pts[i].y)*0.04)*0.016;
          pts[i].vx*=s.damping;pts[i].vy*=s.damping;
          pts[i].x+=pts[i].vx;pts[i].y+=pts[i].vy;
        }
      }
    }
  }
  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    stepStrings();
    ctx.fillStyle=bgFade(0.25);ctx.fillRect(0,0,W,H);
    const paper=isPaper();
    for(const s of strings){
      const amp=s.pts.reduce((m,p)=>Math.max(m,Math.abs(!s.vert&&!s.radial?p.y-p.oy:s.vert?p.x-p.ox:Math.hypot(p.x-p.ox,p.y-p.oy))),0);
      const glow=Math.min(1,amp/8);
      ctx.beginPath();ctx.moveTo(s.pts[0].x,s.pts[0].y);
      for(let i=1;i<s.pts.length;i++)ctx.lineTo(s.pts[i].x,s.pts[i].y);
      ctx.strokeStyle=paper?`hsla(${s.hue},${20+glow*35}%,${30+glow*15}%,${0.35+glow*0.55})`:`hsla(${s.hue},${60+glow*30}%,${50+glow*30}%,${0.4+glow*0.55})`;
      ctx.lineWidth=0.8+glow*1.8;ctx.stroke();
      if(!paper&&glow>0.15){ctx.strokeStyle=`hsla(${s.hue},90%,85%,${glow*0.3})`;ctx.lineWidth=3+glow*4;ctx.stroke();}
    }
  }
  let isDown=false,lastForce=0;
  c.addEventListener('mousedown',e=>{isDown=true;const r=c.getBoundingClientRect();pluck(e.clientX-r.left,e.clientY-r.top,1.2);});
  c.addEventListener('mousemove',e=>{if(!isDown)return;const r=c.getBoundingClientRect();pluck(e.clientX-r.left,e.clientY-r.top,0.25);});
  c.addEventListener('mouseup',()=>isDown=false);c.addEventListener('mouseleave',()=>isDown=false);
  const orientBtn=mkBtn(ORIENTS[orientIdx],ctrl);
  orientBtn.addEventListener('click',()=>{orientIdx=(orientIdx+1)%ORIENTS.length;orientation=ORIENTS[orientIdx].toLowerCase().charAt(0);orientBtn.textContent=ORIENTS[orientIdx];buildStrings();});
  mkBtn('Pluck All',ctrl).addEventListener('click',()=>{for(const s of strings)for(const p of s.pts)if(!s.vert&&!s.radial)p.vy+=rndf(-6,6);else if(s.vert)p.vx+=rndf(-6,6);else{p.vx+=rndf(-4,4);p.vy+=rndf(-4,4);}});
  mkBtn('Reset',ctrl).addEventListener('click',buildStrings);
  const cntLbl=document.createElement('span');cntLbl.className='sb-info sb-speed-lbl';cntLbl.style.marginLeft='4px';cntLbl.textContent='strings';ctrl.appendChild(cntLbl);
  const sl=document.createElement('input');sl.type='range';sl.className='sb-slider';sl.min=3;sl.max=30;sl.step=1;sl.value=numStrings;ctrl.appendChild(sl);styleSlider(sl);
  sl.addEventListener('input',()=>{numStrings=+sl.value;buildStrings();});
  draw();
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 18 — FLAPPY BIRD
// ════════════════════════════════════════════════════════════════════════════
function initFlappy(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let bird,pipes,score,gameOver,started,speed;
  const GAP=130,PW=52,GRAV=0.38,JUMP=-7.2;

  function init(){
    bird={x:W*0.22,y:H/2,vy:0,r:12};
    pipes=[];score=0;gameOver=false;started=false;speed=2.4;
    for(let i=0;i<3;i++) addPipe(W+i*(W/3));
  }
  function addPipe(x){
    const top=80+Math.random()*(H-GAP-160);
    pipes.push({x,top,scored:false});
  }
  function flap(){if(gameOver){init();return;}started=true;bird.vy=JUMP;}

  function step(){
    raf=requestAnimationFrame(step);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    if(started&&!gameOver){
      bird.vy+=GRAV;bird.y+=bird.vy;
      speed+=0.0006;
      for(const p of pipes){
        p.x-=speed;
        if(!p.scored&&p.x+PW<bird.x){p.scored=true;score++;scoreEl.textContent=`score ${score}`;}
      }
      if(pipes[0].x+PW<0){pipes.shift();addPipe(pipes[pipes.length-1].x+W/3);}
      // collision
      for(const p of pipes){
        const inX=bird.x+bird.r>p.x&&bird.x-bird.r<p.x+PW;
        if(inX&&(bird.y-bird.r<p.top||bird.y+bird.r>p.top+GAP))gameOver=true;
      }
      if(bird.y+bird.r>H||bird.y-bird.r<0)gameOver=true;
    }
    // draw bg
    ctx.fillStyle=paper?'#d4eaf7':'#0a1628';ctx.fillRect(0,0,W,H);
    // pipes
    for(const p of pipes){
      ctx.fillStyle=paper?'#5a8a3c':'#3a7a2c';
      ctx.fillRect(p.x,0,PW,p.top);
      ctx.fillRect(p.x,p.top+GAP,PW,H-p.top-GAP);
      // pipe caps
      ctx.fillStyle=paper?'#4a7a2c':'#2a6a1c';
      ctx.fillRect(p.x-4,p.top-14,PW+8,14);
      ctx.fillRect(p.x-4,p.top+GAP,PW+8,14);
    }
    // ground
    ctx.fillStyle=paper?'#c8a850':'#8a6830';
    ctx.fillRect(0,H-20,W,20);
    ctx.fillStyle=paper?'#a89040':'#6a5020';
    ctx.fillRect(0,H-24,W,6);
    // bird body
    const bx=bird.x,by=bird.y,br=bird.r;
    const tilt=Math.max(-0.4,Math.min(0.8,bird.vy*0.07));
    ctx.save();ctx.translate(bx,by);ctx.rotate(tilt);
    ctx.fillStyle=paper?'#e8c820':'#f0d020';
    ctx.beginPath();ctx.arc(0,0,br,0,Math.PI*2);ctx.fill();
    // wing
    ctx.fillStyle=paper?'#d0a010':'#e0b010';
    ctx.beginPath();ctx.ellipse(-3,4,br*0.7,br*0.45,0.3,0,Math.PI*2);ctx.fill();
    // eye
    ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(5,-3,4,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#222';ctx.beginPath();ctx.arc(6,-3,2,0,Math.PI*2);ctx.fill();
    // beak
    ctx.fillStyle='#e07010';ctx.beginPath();ctx.moveTo(br,0);ctx.lineTo(br+8,2);ctx.lineTo(br,-2);ctx.closePath();ctx.fill();
    ctx.restore();
    // HUD
    if(!started&&!gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
      ctx.font=`300 14px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('click or space to flap',W/2,H/2+50);
    }
    if(gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
      ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-18);
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;
      ctx.fillText(`score ${score} — click to restart`,W/2,H/2+14);
    }
  }
  const scoreEl=mkInfo(ctrl);
  c.addEventListener('click',flap);
  const onKey=e=>{if(e.code==='Space'){e.preventDefault();flap();}};
  document.addEventListener('keydown',onKey);
  init();requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}

