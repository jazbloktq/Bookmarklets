// ════════════════════════════════════════════════════════════════════════════
// TOY — BOUNCING DVD
// ════════════════════════════════════════════════════════════════════════════
function initBouncingDVD(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height, raf;

  const COLORS=['#ff3333','#ff9900','#ffff00','#33ff33','#3399ff','#cc33ff','#ff33cc','#00ffcc'];
  let colorIdx=0;
  let cornerHits=0;

  const logoW=120, logoH=60;
  let x=W/2-logoW/2, y=H/2-logoH/2;
  let vx=2.1, vy=1.7;
  let trail=[];
  const TRAIL_LEN=18;
  let showTrail=true;

  function drawLogo(lx,ly,col,alpha){
    ctx.save();
    ctx.globalAlpha=alpha||1;
    const r=6;
    roundRect(ctx,lx,ly,logoW,logoH,r);
    ctx.fillStyle='rgba(0,0,0,0.25)';
    ctx.fill();
    // DVD text
    ctx.fillStyle=col;
    ctx.font=`700 ${logoH*0.55}px 'IBM Plex Mono',monospace`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText('DVD',lx+logoW/2,ly+logoH*0.4);
    // underline bar
    ctx.fillStyle=col;
    ctx.fillRect(lx+logoW*0.12,ly+logoH*0.72,logoW*0.76,logoH*0.1);
    // Video text
    ctx.font=`300 ${logoH*0.22}px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=col;
    ctx.fillText('Video',lx+logoW/2,ly+logoH*0.86);
    ctx.restore();
  }

  function step(){
    raf=requestAnimationFrame(step);
    const nW=body.clientWidth||400, nH=body.clientHeight||300;
    if(nW!==W||nH!==H){W=c.width=nW;H=c.height=nH;}

    let hitCorner=false;
    let bounced=false;

    x+=vx; y+=vy;

    let hitX=false,hitY=false;
    if(x<=0){x=0;vx=Math.abs(vx);hitX=true;}
    if(x+logoW>=W){x=W-logoW;vx=-Math.abs(vx);hitX=true;}
    if(y<=0){y=0;vy=Math.abs(vy);hitY=true;}
    if(y+logoH>=H){y=H-logoH;vy=-Math.abs(vy);hitY=true;}

    if(hitX||hitY){
      bounced=true;
      colorIdx=(colorIdx+1)%COLORS.length;
      if(hitX&&hitY){cornerHits++;hitCorner=true;}
    }

    // Trail
    if(showTrail) trail.push({x,y,col:COLORS[colorIdx]});
    while(trail.length>TRAIL_LEN) trail.shift();

    // Draw
    ctx.fillStyle='#0a0a0a';
    ctx.fillRect(0,0,W,H);
    // scanlines for TV effect
    ctx.fillStyle='rgba(0,0,0,0.08)';
    for(let sy=0;sy<H;sy+=3){ctx.fillRect(0,sy,W,1);}

    // Trail
    if(showTrail){
      trail.forEach((t,i)=>{
        drawLogo(t.x,t.y,t.col,(i/trail.length)*0.25);
      });
    }

    // Corner flash
    if(hitCorner){
      ctx.fillStyle='rgba(255,255,255,0.15)';
      ctx.fillRect(0,0,W,H);
    }

    // Main logo
    drawLogo(x,y,COLORS[colorIdx],1);

    // Corner hit glow
    if(hitCorner){
      ctx.save();
      ctx.shadowColor=COLORS[colorIdx];
      ctx.shadowBlur=60;
      drawLogo(x,y,COLORS[colorIdx],1);
      ctx.restore();
    }

    // Corner counter
    ctx.fillStyle='rgba(255,255,255,0.2)';
    ctx.font=`300 10px 'IBM Plex Mono',monospace`;
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillText(`corner hits: ${cornerHits}`,8,8);
  }

  const trailBtn=mkBtn('Trail: On',ctrl,true);
  trailBtn.addEventListener('click',()=>{
    showTrail=!showTrail;
    if(!showTrail) trail=[];
    trailBtn.textContent=`Trail: ${showTrail?'On':'Off'}`;
    setLit(trailBtn,showTrail);
  });

  // Speed slider
  const speedLbl=document.createElement('span'); speedLbl.className='sb-info'; speedLbl.style.marginLeft='4px'; speedLbl.textContent='speed'; ctrl.appendChild(speedLbl);
  const speedSl=document.createElement('input'); speedSl.type='range'; speedSl.className='sb-slider'; speedSl.min=5; speedSl.max=60; speedSl.step=1; speedSl.value=21; ctrl.appendChild(speedSl); styleSlider(speedSl);
  speedSl.addEventListener('input',()=>{
    const spd=speedSl.value/10;
    const ang=Math.atan2(vy,vx);
    vx=Math.cos(ang)*spd; vy=Math.sin(ang)*spd;
  });

  mkBtn('Reset',ctrl).addEventListener('click',()=>{
    x=W/2-logoW/2; y=H/2-logoH/2; vx=2.1; vy=1.7;
    cornerHits=0; colorIdx=0; trail=[];
  });

  requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

