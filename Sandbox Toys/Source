  const cl = win.querySelector('.sb-win-close');
  if (cl) {
    cl.style.color = v.winClose; cl.style.borderLeft = `1px solid ${v.barBorder}`; cl.style.borderRadius = `0 ${radius} 0 0`;
    cl.onmouseenter = () => { cl.style.background=v.winCloseHovBg; cl.style.color=v.winCloseHov; };
