// TOY 11 — MINESWEEPER
// ════════════════════════════════════════════════════════════════════════════
function initMinesweeper(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height;
  let COLS=16,ROWS=16,MINES=40;
  let board,revealed,flagged,gameOver,won,firstClick,raf;
  let CW,CH,OX,OY;
  function recalc(){W=body.clientWidth;H=body.clientHeight;CW=Math.floor(Math.min((W-32)/COLS,(H-60)/ROWS));CH=CW;OX=Math.floor((W-CW*COLS)/2);OY=Math.floor((H-60-CH*ROWS)/2)+4;}
  recalc();
  function init(){
    board=Array.from({length:ROWS},()=>Array(COLS).fill(0));
    revealed=Array.from({length:ROWS},()=>Array(COLS).fill(false));
    flagged=Array.from({length:ROWS},()=>Array(COLS).fill(false));
    gameOver=false;won=false;firstClick=true;
  }
  function placeMines(sx,sy){
    let placed=0;
    while(placed<MINES){const r=Math.floor(Math.random()*ROWS),cc=Math.floor(Math.random()*COLS);if(board[r][cc]===-1||(Math.abs(r-sy)<=1&&Math.abs(cc-sx)<=1))continue;board[r][cc]=-1;placed++;}
    for(let r=0;r<ROWS;r++)for(let cc=0;cc<COLS;cc++){if(board[r][cc]===-1)continue;let n=0;for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){const nr=r+dr,nc=cc+dc;if(nr>=0&&nr<ROWS&&nc>=0&&nc<COLS&&board[nr][nc]===-1)n++;}board[r][cc]=n;}
  }
  function flood(r,cc){if(r<0||r>=ROWS||cc<0||cc>=COLS||revealed[r][cc]||flagged[r][cc])return;revealed[r][cc]=true;if(board[r][cc]===0)for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++)flood(r+dr,cc+dc);}
  function checkWin(){const unrevealed=revealed.flat().filter(v=>!v).length;if(unrevealed===MINES){won=true;gameOver=true;}}
  init();
  let raf2;
  function draw(){
    raf2=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;recalc();
    const paper=isPaper();
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    const numColors=paper?['','#2980b9','#27ae60','#c0392b','#8e44ad','#c0392b','#1abc9c','#2c3e50','#7f8c8d']:['','#74b9ff','#55efc4','#ff7675','#a29bfe','#fd79a8','#81ecec','#dfe6e9','#b2bec3'];
    for(let r=0;r<ROWS;r++)for(let cc=0;cc<COLS;cc++){
      const x=OX+cc*CW,y=OY+r*CH;
      if(revealed[r][cc]){
        ctx.fillStyle=paper?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.06)';ctx.fillRect(x,y,CW-1,CH-1);
        if(board[r][cc]===-1){ctx.fillStyle=paper?'#c0392b':'#ff6b6b';ctx.beginPath();ctx.arc(x+CW/2,y+CH/2,CW*0.3,0,Math.PI*2);ctx.fill();}
        else if(board[r][cc]>0){ctx.fillStyle=numColors[board[r][cc]];ctx.font=`400 ${Math.max(10,CW-6)}px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(board[r][cc],x+CW/2,y+CH/2);}
      } else {
        ctx.fillStyle=paper?'rgba(0,0,0,0.1)':'rgba(255,255,255,0.09)';ctx.fillRect(x,y,CW-1,CH-1);
        if(flagged[r][cc]){ctx.fillStyle=paper?'#e67e22':'#f39c12';ctx.font=`${Math.max(10,CW-6)}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('⚑',x+CW/2,y+CH/2);}
      }
    }
    const fg=paper?'rgba(30,20,10,0.6)':'rgba(255,255,255,0.45)';
    ctx.fillStyle=fg;ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='alphabetic';
    const flagCount=flagged.flat().filter(v=>v).length;
    ctx.fillText(`mines ${MINES-flagCount} remaining`,OX,OY+ROWS*CH+20);
    if(gameOver){ctx.fillStyle=paper?'rgba(30,20,10,0.88)':'rgba(255,255,255,0.88)';ctx.font=`400 18px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.fillText(won?'YOU WIN':'BOOM',W/2,H/2-10);ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText('click New to play again',W/2,H/2+14);}
  }
  const onClick=e=>{
    if(gameOver)return;
    const r2=c.getBoundingClientRect();
    const mx=e.clientX-r2.left,my=e.clientY-r2.top;
    const cc=Math.floor((mx-OX)/CW),r=Math.floor((my-OY)/CH);
    if(cc<0||cc>=COLS||r<0||r>=ROWS)return;
    if(e.button===2){e.preventDefault();if(!revealed[r][cc])flagged[r][cc]=!flagged[r][cc];return;}
    if(flagged[r][cc]||revealed[r][cc])return;
    if(firstClick){firstClick=false;placeMines(cc,r);}
    if(board[r][cc]===-1){revealed[r][cc]=true;gameOver=true;for(let rr=0;rr<ROWS;rr++)for(let c2=0;c2<COLS;c2++)if(board[rr][c2]===-1)revealed[rr][c2]=true;}
    else{flood(r,cc);checkWin();}
  };
  c.addEventListener('click',onClick);
  c.addEventListener('contextmenu',onClick);
  mkBtn('New',ctrl).addEventListener('click',init);
  const diffBtns={};
  [{k:'easy',label:'Easy',cols:9,rows:9,mines:10},{k:'med',label:'Medium',cols:16,rows:16,mines:40},{k:'hard',label:'Hard',cols:30,rows:16,mines:99}].forEach(d=>{
    const b=mkBtn(d.label,ctrl,d.k==='med');
    b.addEventListener('click',()=>{COLS=d.cols;ROWS=d.rows;MINES=d.mines;Object.values(diffBtns).forEach(b2=>setLit(b2,false));setLit(b,true);recalc();init();});
    diffBtns[d.k]=b;
  });
  draw();
  return ()=>{cancelAnimationFrame(raf2);ro.disconnect();c.removeEventListener('click',onClick);c.removeEventListener('contextmenu',onClick);};
}

