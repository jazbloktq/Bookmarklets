      const distMsg=lastScore>0?'  (+'+lastScore+'pts — close!)':'  (no points)';
      ctx.fillText(`✗  incorrect${distMsg}`,cx,statusY+10);
      ctx.fillStyle=paper?'#226622':'#44ff88';
      ctx.font=`400 ${Math.min(32,inputFontSize*0.75)}px 'IBM Plex Mono',monospace`;
      ctx.fillText(word.toUpperCase(),cx,statusY+34);
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
      ctx.fillText('press Enter/Space to skip',cx,statusY+58);
    } else {
      // typing state
      ctx.fillStyle=paper?'rgba(0,0,0,0.28)':'rgba(255,255,255,0.28)';
      ctx.fillText('type the word · Enter or Space to submit',cx,statusY+20);
    }

    // --- Wrong attempts this word ---
    if(wrongLetters.length>0){
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillStyle=paper?'rgba(150,30,20,0.7)':'rgba(255,100,80,0.7)';
      ctx.fillText(`attempts: ${wrongLetters.map(w2=>w2||'?').join('  ·  ')}`,cx,statusY+80);
    }

    // --- HUD ---
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
    ctx.fillText(`score: ${score}  streak: ${streak}`,8,6);

    // Live timer + word length display
    ctx.textAlign='right';
    if(gameState==='typing'){
      const elapsed=((Date.now()-wordStartTime)/1000).toFixed(1);
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
      ctx.fillText(`${elapsed}s  ·  ${word.length} letters`,W-8,6);
    } else {
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
      ctx.fillText(`${word.length} letters`,W-8,6);
    }
    ctx.textAlign='left';
  }

  const onKey=e=>{
    // Skip pause
    if(gameState==='correct'||gameState==='wrong'){
      if(e.key==='Enter'||e.key===' '){ e.preventDefault(); trySkipPause(); }
      return;
    }
    if(gameState!=='typing') return;

    if(e.key==='Enter'||e.key===' '){
      e.preventDefault();
      submit();
    } else if(e.key==='Backspace'){
      typed=typed.slice(0,-1);
    } else if(e.key.length===1&&/[a-zA-Z]/.test(e.key)){
      typed+=e.key.toLowerCase();
    }
  };
  document.addEventListener('keydown',onKey);

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];score=0;streak=0;newWord();});
  const nextBtn=mkBtn('Next',ctrl);
  nextBtn.addEventListener('click',()=>{
    if(gameState==='correct'||gameState==='wrong'){ trySkipPause(); }
    else { newWord(); }
  });
  mkInfo(ctrl).textContent='type & press Enter';

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}


// ════════════════════════════════════════════════════════════════════════════
// TOY 46 — LUNAR LANDER
// ════════════════════════════════════════════════════════════════════════════
function initLunarLander(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF={
    fuel:       [600, 400, 250],
    gravity:    [0.012, 0.018, 0.026],
    maxLandSpd: [2.2, 1.5, 1.0],
    maxLandTilt:[25,  18,  10 ],  // degrees
    thrustPow:  [0.032, 0.028, 0.024],
  };

  let lander, terrain, pads, particles4, stars4;
  let gameState; // 'playing' 'landed' 'crashed'
  let score, bestScore, keys3={};
  let explosionT=0;
  let camY=0; // vertical camera offset

  function genTerrain(){
    const pts=[];
    const segs=28;
    const segW=W/segs;
    // pick 1–2 flat landing pads
    pads=[];
    const padSegs=[Math.floor(segs*0.25), Math.floor(segs*0.72)];
    const padW=difficulty===0?4:difficulty===1?3:2;

    let y=H*0.55+rndf(-H*0.05,H*0.05);
    for(let i=0;i<=segs;i++){
      // check if this segment is a pad
      const isPad=padSegs.some(ps=>i>=ps&&i<ps+padW);
      const isPadStart=padSegs.some(ps=>i===ps);
      if(isPadStart){
        const padIdx=padSegs.indexOf(padSegs.find(ps=>i===ps));
        const flatY=H*0.58+rndf(-H*0.06,H*0.06);
        for(let j=0;j<padW;j++) pts.push({x:(i+j)*segW, y:flatY});
        const pts_=pts[pts.length-1];
        pads.push({x1:i*segW, x2:(i+padW)*segW, y:flatY,
          bonus: padIdx===0?2:1, // first pad worth 2x
          label: padIdx===0?'2×':'1×'});
        i+=padW-1; y=flatY;
        continue;
      }
      pts.push({x:i*segW, y});
      y+=rndf(-H*0.08, H*0.08);
      y=Math.max(H*0.35, Math.min(H*0.78, y));
    }
    return pts;
  }

  function init(){
    W=c.width=body.clientWidth||400; H=c.height=body.clientHeight||300;
    terrain=genTerrain();
    stars4=Array.from({length:80},()=>({x:Math.random()*W, y:Math.random()*H*0.8, r:Math.random()*1.2+0.3}));
    lander={
      x:W/2, y:H*0.1,
      vx:rndf(-0.6,0.6), vy:0.2,
      angle:0, // radians, 0=upright
      fuel:DIFF.fuel[difficulty],
      thrusting:false, rotL:false, rotR:false,
      w:18, h:22,
    };
    particles4=[]; gameState='playing'; camY=0; explosionT=0;
    if(!bestScore) bestScore=0;
  }
  init();

  function spawnThrust(x,y,angle){
    for(let i=0;i<3;i++){
      const spread=0.4;
      const a=angle+Math.PI+rndf(-spread,spread);
      const spd=rndf(1.5,3.5);
      particles4.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,
        life:1,col:`hsl(${30+rndf(-10,30)},100%,${55+rndf(0,30)}%)`});
    }
  }
  function spawnExplosion(x,y){
    for(let i=0;i<40;i++){
      const a=Math.random()*Math.PI*2, spd=rndf(1,8);
      particles4.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,
        life:1,col:`hsl(${rndf(0,50)},100%,${rndf(50,80)}%)`});
    }
  }

  function getTerrainY(px){
    for(let i=0;i<terrain.length-1;i++){
      const a=terrain[i],b=terrain[i+1];
      if(px>=a.x&&px<=b.x){
        const t=(px-a.x)/(b.x-a.x);
        return a.y+(b.y-a.y)*t;
      }
    }
    return H*0.8;
  }

  function step(){
    const g=DIFF.gravity[difficulty];
    const thrust=DIFF.thrustPow[difficulty];
    const L=lander;

    // Rotation
    const rotSpd=0.03;
    if(keys3['ArrowLeft']||keys3['a']||keys3['A'])  L.angle-=rotSpd;
    if(keys3['ArrowRight']||keys3['d']||keys3['D']) L.angle+=rotSpd;

    // Thrust
    L.thrusting=(keys3['ArrowUp']||keys3['w']||keys3['W']||keys3[' ']||keys3['Space'])&&L.fuel>0;
    if(L.thrusting){
      L.vx+=Math.sin(L.angle)*thrust;
      L.vy-=Math.cos(L.angle)*thrust;
      L.fuel=Math.max(0,L.fuel-1);
      // Exhaust from bottom of lander
      const ex=L.x+Math.sin(L.angle)*L.h*0.6;
      const ey=L.y-Math.cos(L.angle)*L.h*0.6;
      spawnThrust(ex,ey,L.angle);
    }

    // Gravity
    L.vy+=g;

    // Integrate
    L.x+=L.vx; L.y+=L.vy;

    // Wrap horizontal
    if(L.x<-20) L.x=W+20;
    if(L.x>W+20) L.x=-20;

    // Terrain collision — check corners + centre bottom
    const checkPts=[
      {x:L.x+Math.cos(L.angle)*L.w/2-Math.sin(L.angle)*L.h/2,
       y:L.y+Math.sin(L.angle)*L.w/2+Math.cos(L.angle)*L.h/2},
      {x:L.x-Math.cos(L.angle)*L.w/2-Math.sin(L.angle)*L.h/2,
       y:L.y-Math.sin(L.angle)*L.w/2+Math.cos(L.angle)*L.h/2},
      {x:L.x, y:L.y+L.h/2},
    ];

    for(const pt of checkPts){
      const ty=getTerrainY(pt.x);
      if(pt.y>=ty){
        // Check landing conditions
        const spd=Math.hypot(L.vx,L.vy);
        const tiltDeg=Math.abs(L.angle*(180/Math.PI))%360;
        const normalTilt=tiltDeg>180?360-tiltDeg:tiltDeg;
        const onPad=pads.some(p=>L.x>=p.x1&&L.x<=p.x2);
        const goodSpd=spd<DIFF.maxLandSpd[difficulty];
        const goodTilt=normalTilt<DIFF.maxLandTilt[difficulty];

        if(onPad&&goodSpd&&goodTilt){
          gameState='landed';
          const pad=pads.find(p=>L.x>=p.x1&&L.x<=p.x2);
          const fuelBonus=Math.floor(L.fuel*0.5);
          const spdBonus=Math.floor((DIFF.maxLandSpd[difficulty]-spd)*200);
          const pts=(1000+fuelBonus+spdBonus)*(pad?.bonus||1)*(difficulty+1);
          score=pts;
          if(pts>bestScore) bestScore=pts;
        } else {
          gameState='crashed';
          spawnExplosion(L.x,L.y);
          explosionT=0;
        }
        L.vy=0; L.vx=0; L.y=ty-L.h/2;
        return;
      }
    }

    // Particles
    for(const p of particles4){
      p.x+=p.vx; p.y+=p.vy; p.vy+=0.05; p.vx*=0.97; p.life-=0.04;
    }
    particles4=particles4.filter(p=>p.life>0);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    const newW=body.clientWidth||400, newH=body.clientHeight||300;
    if(newW!==W||newH!==H){ W=c.width=newW; H=c.height=newH; init(); return; }

    if(gameState==='playing') step();
    if(gameState==='crashed') explosionT+=0.04;

    const paper=isPaper();
    // Space background
    ctx.fillStyle=paper?'#1a1428':'#05030e';
    ctx.fillRect(0,0,W,H);

    // Stars
    ctx.fillStyle='rgba(255,255,255,0.7)';
    for(const s of stars4) ctx.fillRect(s.x,s.y,s.r,s.r);

    // Terrain
    ctx.beginPath();
    ctx.moveTo(0,H);
    for(const pt of terrain) ctx.lineTo(pt.x,pt.y);
    ctx.lineTo(W,H);
    ctx.closePath();
    ctx.fillStyle=paper?'#556644':'#334422';
    ctx.fill();
    ctx.strokeStyle=paper?'#889966':'#557733';
    ctx.lineWidth=1.5; ctx.stroke();

    // Landing pads
    for(const p of pads){
      ctx.strokeStyle='#44ffaa'; ctx.lineWidth=3;
      ctx.beginPath();ctx.moveTo(p.x1,p.y);ctx.lineTo(p.x2,p.y);ctx.stroke();
      // Pad lights
      for(let lx=p.x1;lx<=p.x2;lx+=(p.x2-p.x1)/4){
        ctx.fillStyle=`hsl(${Date.now()*0.05%360},100%,60%)`;
        ctx.beginPath();ctx.arc(lx,p.y,2.5,0,Math.PI*2);ctx.fill();
      }
      ctx.fillStyle='#44ffaa'; ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='bottom';
      ctx.fillText(p.label,(p.x1+p.x2)/2,p.y-6);
    }

    // Particles
    for(const p of particles4){
      ctx.globalAlpha=p.life; ctx.fillStyle=p.col;
      ctx.beginPath();ctx.arc(p.x,p.y,2*p.life,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Lander
    if(gameState!=='crashed'||(gameState==='crashed'&&explosionT<0.3)){
      const L=lander;
      ctx.save();
      ctx.translate(L.x,L.y); ctx.rotate(L.angle);
      // Body
      const lcol=gameState==='landed'?'#44ffaa':paper?'#aabbcc':'#88aacc';
      if(!paper){ctx.save();ctx.shadowColor=lcol;ctx.shadowBlur=8;}
      ctx.fillStyle=lcol;
      ctx.beginPath();
      ctx.moveTo(0,-L.h/2);
      ctx.lineTo(L.w/2,L.h/4);
      ctx.lineTo(L.w*0.3,L.h/2);
      ctx.lineTo(-L.w*0.3,L.h/2);
      ctx.lineTo(-L.w/2,L.h/4);
      ctx.closePath(); ctx.fill();
      if(!paper)ctx.restore();
      // Legs
      ctx.strokeStyle=paper?'#8899aa':'#667788'; ctx.lineWidth=1.5;
      ctx.beginPath();ctx.moveTo(L.w*0.3,L.h/2);ctx.lineTo(L.w*0.55,L.h/2+6);ctx.stroke();
      ctx.beginPath();ctx.moveTo(-L.w*0.3,L.h/2);ctx.lineTo(-L.w*0.55,L.h/2+6);ctx.stroke();
      // Thruster flame
      if(L.thrusting){
        ctx.fillStyle=`hsl(${30+rndf(0,30)},100%,60%)`;
        ctx.beginPath();
        ctx.moveTo(-5,L.h/2);
        ctx.lineTo(0,L.h/2+rndf(8,18));
        ctx.lineTo(5,L.h/2);
        ctx.closePath(); ctx.fill();
      }
      // Window
      ctx.fillStyle=paper?'rgba(180,220,255,0.6)':'rgba(100,200,255,0.5)';
      ctx.beginPath();ctx.arc(0,-L.h*0.1,4,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }

    // HUD
    const L=lander;
    const fuelPct=L.fuel/DIFF.fuel[difficulty];
    const spd=Math.hypot(L.vx,L.vy);
    const tiltDeg=Math.abs(L.angle*(180/Math.PI))%360;
    const dispTilt=tiltDeg>180?360-tiltDeg:tiltDeg;
    const spdOk=spd<DIFF.maxLandSpd[difficulty];
    const tiltOk=dispTilt<DIFF.maxLandTilt[difficulty];

    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.font=`300 10px 'IBM Plex Mono',monospace`;

    // Fuel bar
    ctx.fillStyle=paper?'rgba(255,255,255,0.15)':'rgba(255,255,255,0.1)';
    ctx.fillRect(8,8,80,8);
    ctx.fillStyle=fuelPct>0.3?'#44cc66':fuelPct>0.1?'#ffcc44':'#ff4444';
    ctx.fillRect(8,8,80*fuelPct,8);
    ctx.fillStyle=paper?'rgba(255,255,255,0.5)':'rgba(255,255,255,0.5)';
    ctx.fillText(`fuel`,8,20);

    // Speed & tilt readouts
    ctx.fillStyle=spdOk?(paper?'rgba(255,255,255,0.5)':'rgba(100,255,150,0.8)'):'#ff4444';
    ctx.fillText(`spd ${spd.toFixed(1)}`,8,32);
    ctx.fillStyle=tiltOk?(paper?'rgba(255,255,255,0.5)':'rgba(100,255,150,0.8)'):'#ff4444';
    ctx.fillText(`tilt ${dispTilt.toFixed(0)}°`,8,44);

    ctx.fillStyle=paper?'rgba(255,255,255,0.4)':'rgba(255,255,255,0.35)';
    ctx.fillText(`best: ${bestScore}`,8,56);

    ctx.textAlign='right';
    ctx.fillText(`W/↑ thrust  ·  A/D rotate`,W-8,8);

    // Game state overlay
    if(gameState==='landed'){
      ctx.fillStyle='rgba(0,0,0,0.55)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#44ffaa'; ctx.font=`400 18px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('LANDED!',W/2,H/2-22);
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillStyle='rgba(255,255,255,0.7)';
      ctx.fillText(`score: ${score}  ·  press R or click to retry`,W/2,H/2+8);
    } else if(gameState==='crashed'){
      ctx.fillStyle=`rgba(0,0,0,${Math.min(0.6,explosionT*0.8)})`;
      ctx.fillRect(0,0,W,H);
      if(explosionT>0.4){
        ctx.fillStyle='#ff4422'; ctx.font=`400 18px 'IBM Plex Mono',monospace`;
        ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText('CRASHED',W/2,H/2-22);
        ctx.font=`300 11px 'IBM Plex Mono',monospace`;
        ctx.fillStyle='rgba(255,255,255,0.6)';
        ctx.fillText(`press R or click to retry`,W/2,H/2+8);
      }
    }
    ctx.textAlign='left'; ctx.textBaseline='top';
  }

  const onKey=e=>{
    keys3[e.key]=e.type==='keydown';
    if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' ','Space'].includes(e.key)) e.preventDefault();
    if(e.type==='keydown'&&(e.key==='r'||e.key==='R')&&gameState!=='playing') init();
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);
  c.addEventListener('click',()=>{ if(gameState!=='playing') init(); });

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});
  mkBtn('Restart',ctrl).addEventListener('click',init);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

