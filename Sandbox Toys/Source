// TOY — TYPING SPEED TEST
// ════════════════════════════════════════════════════════════════════════════
function initTypingSpeed(body,ctrl){
  const {c,ctx,ro}=mkCanvas(body);
  let W=c.width,H=c.height,raf;

  const PASSAGES=[
    "the quick brown fox jumps over the lazy dog near the riverbank on a sunny afternoon",
    "practice makes perfect and every keystroke brings you closer to typing mastery",
    "the stars at night sparkle brightly above the quiet mountain village in winter",
    "a journey of a thousand miles begins with a single step taken in the right direction",
    "coding is the art of turning ideas into reality one character at a time",
    "the ocean waves crash gently against the shore while seagulls circle in the breeze",
    "music is a universal language that speaks to every heart across every culture",
    "science and curiosity together have unlocked the greatest mysteries of the universe",
    "the library was silent except for the soft rustle of pages turning in the lamplight",
    "hard work determination and a positive attitude are the keys to achieving great things",
    "the morning sun painted the sky in brilliant shades of orange pink and gold",
    "every great story begins with a single word written on a blank page with courage",
    "vegetables fruits and grains form the foundation of a healthy and balanced diet",
    "the ancient castle stood at the top of the hill overlooking the misty valley below",
    "technology changes fast but the fundamentals of clear thinking remain timeless",
  ];

  let passage,typed,started,finished,startTime,endTime,wpm,accuracy,mistakes;
  let cursorBlink=0;
  let difficulty=1;
  const DIFF_NAMES=['Easy','Normal','Hard'];
  // Easy = shorter passage, Normal = normal, Hard = no backspace allowed
  function pickPassage(){
    const pool=difficulty===0?PASSAGES.slice(0,5):difficulty===1?PASSAGES.slice(0,10):PASSAGES;
    return pool[Math.floor(Math.random()*pool.length)];
  }

  function newTest(){
    passage=pickPassage();
    typed=''; started=false; finished=false;
    startTime=0; endTime=0; wpm=0; accuracy=0; mistakes=0;
  }
  newTest();

  function calcStats(){
    const elapsed=(endTime-startTime)/1000/60; // minutes
    const wordCount=passage.split(' ').length;
    wpm=elapsed>0?Math.round(wordCount/elapsed):0;
    let correct=0;
    for(let i=0;i<typed.length;i++) if(typed[i]===passage[i]) correct++;
    accuracy=typed.length>0?Math.round((correct/typed.length)*100):100;
  }

  const onKey=e=>{
    if(finished) return;
    if(e.key==='Tab'){ e.preventDefault(); newTest(); return; }
    if(e.key.length===1&&!e.ctrlKey&&!e.metaKey){
      e.preventDefault();
      if(!started){ started=true; startTime=Date.now(); }
      if(typed.length<passage.length){
        if(typed[typed.length]!==e.key) mistakes++;
        typed+=e.key;
        if(typed.length===passage.length){
          finished=true; endTime=Date.now(); calcStats();
        }
      }
    } else if(e.key==='Backspace'){
      e.preventDefault();
      if(difficulty===2) return; // no backspace on hard
      if(typed.length>0) typed=typed.slice(0,-1);
    }
  };
  document.addEventListener('keydown',onKey);

  let lastTs=0;
  function draw(ts){
    raf=requestAnimationFrame(draw);
    const dt=Math.min(60,ts-lastTs); lastTs=ts;
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=paper?'#f5f1e8':'#0d1117'; ctx.fillRect(0,0,W,H);
    cursorBlink=(cursorBlink+dt/500)%1;

    const pad=20;
    const fontSize=Math.min(16, Math.max(11, W/38));
    ctx.font=`400 ${fontSize}px 'IBM Plex Mono',monospace`;
    const lineH=fontSize*1.65;
    const maxW=W-pad*2;

    // Word-wrap passage into lines
    const words=passage.split(' ');
    const lines=[];
    let cur='';
    for(const w of words){
      const test=cur+(cur?' ':'')+w;
      if(ctx.measureText(test).width>maxW&&cur){ lines.push(cur); cur=w; }
      else cur=test;
    }
    if(cur) lines.push(cur);

    const totalH=lines.length*lineH;
    const startY=(H-totalH)/2-20;

    // Status line
    ctx.textAlign='left'; ctx.textBaseline='top';
    if(!started){
      ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText('start typing to begin · Tab for new passage',pad,8);
    } else if(finished){
      ctx.fillStyle=paper?'#226622':'#44ee88';
      ctx.font=`700 13px 'IBM Plex Mono',monospace`;
      ctx.fillText(`${wpm} WPM  ·  ${accuracy}% accuracy  ·  ${mistakes} mistakes`,pad,8);
      ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
      ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.fillText('Tab or New Test for next',pad,24);
    } else {
      const elapsed=((Date.now()-startTime)/1000).toFixed(1);
      const liveWords=typed.trim().split(/\s+/).filter(Boolean).length;
      const liveWpm=elapsed>0?Math.round(liveWords/(elapsed/60)):0;
      ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(`${elapsed}s · ~${liveWpm} wpm · ${typed.length}/${passage.length}`,pad,8);
    }

    // Render passage character by character
    let charIdx=0;
    for(let li=0;li<lines.length;li++){
      const line=lines[li];
      let x=pad;
      const y=startY+li*lineH;
      for(let ci=0;ci<line.length;ci++){
        const ch=line[ci];
        let colour,bgColour=null;
        if(charIdx<typed.length){
          if(typed[charIdx]===ch){
            colour=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.4)'; // correct — dim
          } else {
            colour=paper?'#cc3333':'#ff5555'; // wrong
            bgColour=paper?'rgba(200,0,0,0.08)':'rgba(255,0,0,0.12)';
          }
        } else if(charIdx===typed.length){
          colour=paper?'#111':'#fff'; // current char
        } else {
          colour=paper?'rgba(0,0,0,0.28)':'rgba(255,255,255,0.28)'; // upcoming
        }
        ctx.font=`${charIdx<typed.length?'400':'400'} ${fontSize}px 'IBM Plex Mono',monospace`;
        const cw2=ctx.measureText(ch).width;
        if(bgColour){ ctx.fillStyle=bgColour; ctx.fillRect(x-1,y,cw2+2,lineH*0.9); }
        // Cursor
        if(charIdx===typed.length&&!finished){
          const curAlpha=0.5+0.5*Math.sin(cursorBlink*Math.PI*2);
          ctx.fillStyle=paper?`rgba(0,100,255,${curAlpha})`:`rgba(80,180,255,${curAlpha})`;
          ctx.fillRect(x,y+2,2,lineH*0.78);
        }
        ctx.fillStyle=colour;
        ctx.textBaseline='top';
        ctx.fillText(ch,x,y);
        x+=cw2;
        charIdx++;
      }
      // Space between words (if not last line)
      if(li<lines.length-1){
        if(charIdx===typed.length&&!finished){
          const curAlpha=0.5+0.5*Math.sin(cursorBlink*Math.PI*2);
          ctx.fillStyle=paper?`rgba(0,100,255,${curAlpha})`:`rgba(80,180,255,${curAlpha})`;
          ctx.fillRect(x,startY+li*lineH+2,2,lineH*0.78);
        }
        charIdx++; // space
      }
    }
    ctx.textAlign='left';
  }

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{
    difficulty=(difficulty+1)%3;
    diffBtn.textContent=DIFF_NAMES[difficulty];
    newTest(); diffBtn.blur();
  });
  mkBtn('New Test',ctrl).addEventListener('click',()=>{ newTest(); });
  mkInfo(ctrl).textContent='just start typing';

  requestAnimationFrame(draw);
  return()=>{ cancelAnimationFrame(raf); ro.disconnect(); document.removeEventListener('keydown',onKey); };
}



