  sl.style.background=`linear-gradient(to right, ${v.sliderThumb} 0%, ${v.sliderThumb} ${pct}%, ${v.sliderTrack} ${pct}%, ${v.sliderTrack} 100%)`;
  sl.style.accentColor=v.sliderThumb;
