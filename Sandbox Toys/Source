// TOY 42 — TIC-TAC-TOE
// ════════════════════════════════════════════════════════════════════════════
function initTicTacToe(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  // difficulty: 0=easy(random) 1=medium(minimax depth 3) 2=hard(perfect minimax)
  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF_DEPTH=[0,3,9];

  let board, turn, gameOver, winner, winLine, scores, thinking;
  let animT=0; // for win line animation

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    board=Array(9).fill(null); // null | 'X' | 'O'
    turn='X'; gameOver=false; winner=null; winLine=null; thinking=false; animT=0;
    if(!scores) scores={X:0,O:0,draws:0};
  }
  init();

  function checkWinner(b){
    const lines=[[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
    for(const [a,bk,ck] of lines){
      if(b[a]&&b[a]===b[bk]&&b[a]===b[ck]) return{winner:b[a],line:[a,bk,ck]};
    }
    if(b.every(c2=>c2)) return{winner:'draw',line:null};
    return null;
  }

  function minimax(b,depth,isMax,alpha,beta){
    const res=checkWinner(b);
    if(res){
      if(res.winner==='O') return 10-depth;
      if(res.winner==='X') return depth-10;
      return 0;
    }
    if(depth===0) return 0;
    if(isMax){
      let best=-Infinity;
      for(let i=0;i<9;i++){
        if(!b[i]){b[i]='O';best=Math.max(best,minimax(b,depth-1,false,alpha,beta));b[i]=null;alpha=Math.max(alpha,best);if(beta<=alpha)break;}
      }
      return best;
    } else {
      let best=Infinity;
      for(let i=0;i<9;i++){
        if(!b[i]){b[i]='X';best=Math.min(best,minimax(b,depth-1,true,alpha,beta));b[i]=null;beta=Math.min(beta,best);if(beta<=alpha)break;}
      }
      return best;
    }
  }

  function aiMove(){
    const depth=DIFF_DEPTH[difficulty];
    const empty=board.map((v,i)=>v?null:i).filter(i=>i!==null);
    if(!empty.length) return;
    if(difficulty===0){
      // random
      setTimeout(()=>{
        const i=empty[Math.floor(Math.random()*empty.length)];
        makeMove(i);
      },350);
    } else {
      setTimeout(()=>{
        let bestScore=-Infinity, bestMove=empty[0];
        for(const i of empty){
          board[i]='O';
          const s=minimax(board,depth,false,-Infinity,Infinity);
          board[i]=null;
          if(s>bestScore){bestScore=s;bestMove=i;}
        }
        makeMove(bestMove);
      },350);
    }
  }

  function makeMove(i){
    if(board[i]||gameOver) return;
    board[i]=turn;
    const res=checkWinner(board);
    if(res){
      gameOver=true; winner=res.winner; winLine=res.line;
      if(res.winner==='X') scores.X++;
      else if(res.winner==='O') scores.O++;
      else scores.draws++;
    } else {
      turn=turn==='X'?'O':'X';
      if(!twoPlayer && turn==='O'&&!gameOver){ thinking=true; aiMove(); }
    }
    thinking=false;
  }

  function cellRect(){
    const S=Math.min(W,H)*0.7;
    const ox=(W-S)/2, oy=(H-S)/2;
    return{S,ox,oy,cs:S/3};
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    if(gameOver&&winLine) animT=Math.min(1,animT+0.04);

    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
    const {S,ox,oy,cs}=cellRect();

    // Grid lines
    ctx.strokeStyle=paper?'rgba(0,0,0,0.2)':'rgba(255,255,255,0.18)';
    ctx.lineWidth=2; ctx.lineCap='round';
    for(let i=1;i<3;i++){
      ctx.beginPath();ctx.moveTo(ox+i*cs,oy);ctx.lineTo(ox+i*cs,oy+S);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ox,oy+i*cs);ctx.lineTo(ox+S,oy+i*cs);ctx.stroke();
    }

    // Cells
    for(let i=0;i<9;i++){
      const col=i%3, row=Math.floor(i/3);
      const cx2=ox+col*cs+cs/2, cy2=oy+row*cs+cs/2;
      const v=board[i];
      if(!v) continue;
      const isWin=winLine&&winLine.includes(i);
      if(v==='X'){
        ctx.strokeStyle=isWin?(paper?'#cc2222':'#ff4444'):(paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.55)');
        ctx.lineWidth=isWin?5:3; ctx.lineCap='round';
        const s=cs*0.3;
        if(!paper&&isWin){ctx.save();ctx.shadowColor='#ff4444';ctx.shadowBlur=12;}
        ctx.beginPath();ctx.moveTo(cx2-s,cy2-s);ctx.lineTo(cx2+s,cy2+s);ctx.stroke();
        ctx.beginPath();ctx.moveTo(cx2+s,cy2-s);ctx.lineTo(cx2-s,cy2+s);ctx.stroke();
        if(!paper&&isWin)ctx.restore();
      } else {
        ctx.strokeStyle=isWin?(paper?'#2244cc':'#4488ff'):(paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.55)');
        ctx.lineWidth=isWin?5:3;
        if(!paper&&isWin){ctx.save();ctx.shadowColor='#4488ff';ctx.shadowBlur=12;}
        ctx.beginPath();ctx.arc(cx2,cy2,cs*0.3,0,Math.PI*2);ctx.stroke();
        if(!paper&&isWin)ctx.restore();
      }
    }

    // Win line strike-through
    if(winLine&&winner!=='draw'&&animT>0){
      const [a,b2,c2]=winLine;
      const cols2=[a%3,b2%3,c2%3], rows2=[Math.floor(a/3),Math.floor(b2/3),Math.floor(c2/3)];
      const x1=ox+cols2[0]*cs+cs/2, y1=oy+rows2[0]*cs+cs/2;
      const x2=ox+cols2[2]*cs+cs/2, y2=oy+rows2[2]*cs+cs/2;
      ctx.strokeStyle=winner==='X'?(paper?'#cc2222':'#ff5555'):(paper?'#2244cc':'#5588ff');
      ctx.lineWidth=4; ctx.lineCap='round';
      if(!paper){ctx.save();ctx.shadowColor=winner==='X'?'#ff4444':'#4488ff';ctx.shadowBlur=10;}
      ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x1+(x2-x1)*animT,y1+(y2-y1)*animT);ctx.stroke();
      if(!paper)ctx.restore();
    }

    // Status
    ctx.textAlign='center'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.45)':'rgba(255,255,255,0.5)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;
    const statusY=oy+S+12;
    let status;
    if(gameOver) status=winner==='draw'?'Draw!':`${winner} wins!  ·  click to play again`;
    else if(twoPlayer) status=`Player ${turn==='X'?'1 (X)':'2 (O)'}'s turn`;
    else status=turn==='X'?'Your turn (X)':(thinking?'AI thinking…':'AI\'s turn (O)');
    ctx.fillText(status,W/2,statusY);

    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
    if(twoPlayer) ctx.fillText(`P1(X) ${scores.X}  ·  P2(O) ${scores.O}  ·  Draws ${scores.draws}`,W/2,statusY+20);
    else ctx.fillText(`You(X) ${scores.X}  ·  AI(O) ${scores.O}  ·  Draws ${scores.draws}`,W/2,statusY+20);

    ctx.textAlign='left';
  }

  c.addEventListener('click',e=>{
    if(gameOver){init();return;}
    if(!twoPlayer && (turn!=='X'||thinking)) return;
    const {ox,oy,cs}=cellRect();
    const r2=c.getBoundingClientRect();
    const mx=e.clientX-r2.left-ox, my=e.clientY-r2.top-oy;
    const col=Math.floor(mx/cs), row=Math.floor(my/cs);
    if(col<0||col>2||row<0||row>2) return;
    makeMove(row*3+col);
  });

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];scores={X:0,O:0,draws:0};init();});
  mkBtn('New Game',ctrl).addEventListener('click',()=>init());
  mkBtn('Reset Scores',ctrl).addEventListener('click',()=>{scores={X:0,O:0,draws:0};init();});

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 43 — GALAGA
// ════════════════════════════════════════════════════════════════════════════
function initGalaga(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF={
    enemySpeed:[0.4,0.7,1.1],
    diveBullets:[1,2,3],
    diveCooldown:[180,120,70],
    playerBulletCooldown:[18,22,28],
  };

  const ROWS=4, COLS=10;
  let player,bullets,enemyBullets,enemies,particles3;
  let score,lives,level,gameOver,wave,bonusStage;
  let diveCooldown,formTick,formDir;
  let keys2={};

  function init(){
    // MUST set W/H before spawnWave so enemy positions are calculated correctly
    W=c.width=body.clientWidth||400; H=c.height=body.clientHeight||300;
    score=0;lives=3;level=1;gameOver=false;bonusStage=false;
    player={x:W/2,y:H-50,w:28,h:20,fireCD:0,invincible:0};
    bullets=[];enemyBullets=[];particles3=[];
    diveCooldown=DIFF.diveCooldown[difficulty];
    formTick=0;formDir=1;
    spawnWave();
  }

  const ENEMY_TYPES=[
    {col:'#ff4444',pts:100,w:22,h:18,rows:[0]},   // boss bee
    {col:'#ff8844',pts:80, w:20,h:16,rows:[1]},   // butterfly
    {col:'#44aaff',pts:50, w:18,h:14,rows:[2,3]}, // bee
  ];

  function spawnWave(){
    enemies=[];
    const ew=W/(COLS+1), startY=60;
    for(let r=0;r<ROWS;r++){
      const type=r===0?0:r===1?1:2;
      const et=ENEMY_TYPES[type];
      for(let cc=0;cc<COLS;cc++){
        enemies.push({
          x:40+cc*ew, y:startY+r*36,
          baseX:40+cc*ew, baseY:startY+r*36,
          type, w:et.w, h:et.h,
          alive:true, diving:false,
          divePhase:0, diveX:0, diveY:0,
          diveVx:0, diveVy:0,
          escortOf:-1, pulse:0,
        });
      }
    }
    bonusStage=false;
  }

  function spawnBonusStage(){
    bonusStage=true; enemies=[];
    const ew=W/(20+1);
    for(let cc=0;cc<40;cc++){
      enemies.push({
        x:40+(cc%20)*ew, y:40+Math.floor(cc/20)*40,
        baseX:40+(cc%20)*ew, baseY:40+Math.floor(cc/20)*40,
        type:2,w:18,h:14,alive:true,diving:false,
        divePhase:0,diveX:0,diveY:0,diveVx:0,diveVy:0,pulse:0
      });
    }
  }

  function spawnParticle3(x,y,col,n){
    for(let i=0;i<n;i++){
      const a=Math.random()*Math.PI*2,spd=2+Math.random()*5;
      particles3.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,life:1,col,r:2+Math.random()*2});
    }
  }

  function drawShip(x,y,w,h,col,paper){
    // Simple fighter silhouette
    ctx.fillStyle=col;
    ctx.beginPath();
    ctx.moveTo(x,y-h/2);
    ctx.lineTo(x-w/2,y+h/2);
    ctx.lineTo(x-w*0.15,y+h*0.2);
    ctx.lineTo(x,y+h/2*0.3);
    ctx.lineTo(x+w*0.15,y+h*0.2);
    ctx.lineTo(x+w/2,y+h/2);
    ctx.closePath();ctx.fill();
    // cockpit
    ctx.fillStyle=paper?'rgba(255,255,255,0.5)':'rgba(180,220,255,0.6)';
    ctx.beginPath();ctx.ellipse(x,y-h*0.1,w*0.12,h*0.2,0,0,Math.PI*2);ctx.fill();
  }

  function drawEnemy(e,paper){
    const et=ENEMY_TYPES[e.type];
    const p=e.pulse;
    ctx.fillStyle=p>0.5?'#ffffff':et.col;
    if(!paper&&p>0.1){ctx.save();ctx.shadowColor=et.col;ctx.shadowBlur=10;}
    if(e.type===0){
      // boss — more detailed
      ctx.beginPath();
      ctx.moveTo(e.x,e.y-e.h/2);
      ctx.lineTo(e.x+e.w/2,e.y);
      ctx.lineTo(e.x+e.w*0.3,e.y+e.h/2);
      ctx.lineTo(e.x-e.w*0.3,e.y+e.h/2);
      ctx.lineTo(e.x-e.w/2,e.y);
      ctx.closePath();ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,100,0.6)';
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w*0.2,e.h*0.2,0,0,Math.PI*2);ctx.fill();
    } else if(e.type===1){
      // butterfly
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w/2,e.h/2,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.2)':et.col+'88';
      ctx.beginPath();ctx.ellipse(e.x-e.w*0.55,e.y,e.w*0.3,e.h*0.4,Math.PI*0.3,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(e.x+e.w*0.55,e.y,e.w*0.3,e.h*0.4,-Math.PI*0.3,0,Math.PI*2);ctx.fill();
    } else {
      // bee
      ctx.beginPath();ctx.ellipse(e.x,e.y,e.w*0.35,e.h/2,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
      ctx.beginPath();ctx.ellipse(e.x-e.w*0.4,e.y-e.h*0.1,e.w*0.25,e.h*0.3,-0.4,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.ellipse(e.x+e.w*0.4,e.y-e.h*0.1,e.w*0.25,e.h*0.3,0.4,0,Math.PI*2);ctx.fill();
    }
    if(!paper&&p>0.1)ctx.restore();
    e.pulse=Math.max(0,p-0.08);
  }

  function step(){
    formTick++;
    // Formation oscillation
    const formOff=Math.sin(formTick*0.012*(1+level*0.1))*Math.min(60,W*0.12)*DIFF.enemySpeed[difficulty];

    // Enemy movement
    let anyAlive=false;
    for(const e of enemies){
      if(!e.alive) continue; anyAlive=true;
      if(!e.diving){
        e.x=e.baseX+formOff;
        e.y=e.baseY+Math.sin(formTick*0.018+e.baseX*0.05)*8;
      } else {
        // Dive arc
        e.divePhase+=0.04*(1+level*0.05);
        e.x+=e.diveVx; e.y+=e.diveVy;
        e.diveVy+=0.08; // gravity pull
        // Curve toward player
        const dx=player.x-e.x;
        e.diveVx+=dx*0.003;
        // clamp dive speed
        const spd=Math.hypot(e.diveVx,e.diveVy);
        const maxSpd=4+level*0.3;
        if(spd>maxSpd){e.diveVx=e.diveVx/spd*maxSpd;e.diveVy=e.diveVy/spd*maxSpd;}
        // Off screen — return to formation
        if(e.y>H+30){e.diving=false;e.x=e.baseX+formOff;e.y=e.baseY;}
      }
    }

    if(!anyAlive){
      level++;
      if(level%3===0) spawnBonusStage();
      else spawnWave();
      score+=bonusStage?2000:500;
      return;
    }

    // Trigger dives
    diveCooldown--;
    if(diveCooldown<=0){
      diveCooldown=DIFF.diveCooldown[difficulty];
      const free=enemies.filter(e=>e.alive&&!e.diving);
      const count=Math.min(DIFF.diveBullets[difficulty]+Math.floor(level/3),3);
      for(let i=0;i<count&&free.length;i++){
        const e=free.splice(Math.floor(Math.random()*free.length),1)[0];
        e.diving=true; e.diveVx=rndf(-2,2); e.diveVy=1+Math.random()*2;
        // Enemy fires when starting dive
        enemyBullets.push({x:e.x,y:e.y,vx:(player.x-e.x)*0.04,vy:4+Math.random()*2});
      }
    }

    // Player movement — arrow keys OR wasd
    const pspd=5;
    const goLeft  = keys2['ArrowLeft'] ||keys2['a']||keys2['A'];
    const goRight = keys2['ArrowRight']||keys2['d']||keys2['D'];
    const goUp    = keys2['ArrowUp']   ||keys2['w']||keys2['W'];
    const goDown  = keys2['ArrowDown'] ||keys2['s']||keys2['S'];
    if(goLeft)  player.x=Math.max(player.w/2,        player.x-pspd);
    if(goRight) player.x=Math.min(W-player.w/2,      player.x+pspd);
    if(goUp)    player.y=Math.max(H*0.35,             player.y-pspd);
    if(goDown)  player.y=Math.min(H-player.h/2-4,    player.y+pspd);
    if(player.fireCD>0) player.fireCD--;
    if(player.invincible>0) player.invincible--;

    // Auto-fire when space held
    if((keys2['Space']||keys2[' '])&&player.fireCD===0){
      bullets.push({x:player.x,y:player.y-player.h/2,vy:-11});
      player.fireCD=DIFF.playerBulletCooldown[difficulty];
    }

    // Move bullets
    for(const b of bullets) b.y+=b.vy;
    for(const b of enemyBullets){b.x+=b.vx;b.y+=b.vy;}

    // Bullet-enemy collisions
    for(const b of bullets){
      for(const e of enemies){
        if(!e.alive) continue;
        if(Math.abs(b.x-e.x)<e.w/2&&Math.abs(b.y-e.y)<e.h/2){
          e.alive=false; b.dead=true;
          score+=ENEMY_TYPES[e.type].pts*(bonusStage?2:1);
          spawnParticle3(e.x,e.y,ENEMY_TYPES[e.type].col,8);
        }
      }
    }
    bullets=bullets.filter(b=>!b.dead&&b.y>-20);
    enemyBullets=enemyBullets.filter(b=>b.y<H+10&&b.x>-10&&b.x<W+10);

    // Enemy bullet-player collisions
    if(player.invincible===0){
      for(const b of enemyBullets){
        if(Math.abs(b.x-player.x)<player.w/2&&Math.abs(b.y-player.y)<player.h/2){
          b.dead=true; lives--;
          spawnParticle3(player.x,player.y,'#44aaff',12);
          player.invincible=120;
          if(lives<=0){gameOver=true;}
        }
      }
      // Direct dive collision
      for(const e of enemies){
        if(!e.alive||!e.diving) continue;
        if(Math.abs(e.x-player.x)<(e.w+player.w)/2&&Math.abs(e.y-player.y)<(e.h+player.h)/2){
          e.alive=false; lives--;
          spawnParticle3(player.x,player.y,'#44aaff',12);
          player.invincible=120;
          if(lives<=0)gameOver=true;
        }
      }
    }
    enemyBullets=enemyBullets.filter(b=>!b.dead);

    // Particles
    for(const p of particles3){p.x+=p.vx;p.y+=p.vy;p.vy+=0.1;p.vx*=0.95;p.life-=0.04;}
    particles3=particles3.filter(p=>p.life>0);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    const newW=body.clientWidth||400, newH=body.clientHeight||300;
    if(newW!==W||newH!==H){
      W=c.width=newW; H=c.height=newH;
      if(enemies&&enemies.length>0&&enemies[0].baseX<2) spawnWave();
      if(player) player.y=H-50;
    }
    const paper=isPaper();
    if(!gameOver) step();

    ctx.fillStyle='#05030e'; ctx.fillRect(0,0,W,H);

    // Stars
    ctx.fillStyle='rgba(255,255,255,0.7)';
    for(let i=0;i<80;i++){
      const sx=((i*137)%W+W)%W, sy=((i*97)%Math.round(H*0.85)+Math.round(H*0.85))%Math.round(H*0.85);
      ctx.fillRect(sx,sy,i%5===0?2:1,i%5===0?2:1);
    }

    // Bonus stage banner
    if(bonusStage){
      ctx.fillStyle='rgba(255,220,50,0.15)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ffdd44'; ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center';ctx.fillText('★ BONUS STAGE — NO SHOOTING BACK ★',W/2,24);ctx.textAlign='left';
    }

    // Enemies
    for(const e of enemies) if(e.alive) drawEnemy(e,paper);

    // Bullets
    for(const b of bullets){
      if(!paper){ctx.save();ctx.shadowColor='#ffffaa';ctx.shadowBlur=8;}
      ctx.fillStyle=paper?'#886600':'#ffff88';
      ctx.fillRect(b.x-2,b.y-8,4,10);
      if(!paper)ctx.restore();
    }
    for(const b of enemyBullets){
      ctx.fillStyle=paper?'#cc2222':'#ff4444';
      ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);ctx.fill();
    }

    // Particles
    for(const p of particles3){
      ctx.globalAlpha=p.life; ctx.fillStyle=p.col;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r*p.life,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Player
    if(!gameOver){
      const alpha=player.invincible>0?(Math.sin(player.invincible*0.4)*0.5+0.5):1;
      ctx.globalAlpha=alpha;
      if(!paper){ctx.save();ctx.shadowColor='#44aaff';ctx.shadowBlur=10;}
      drawShip(player.x,player.y,player.w,player.h,paper?'#2244aa':'#44aaff',paper);
      if(!paper)ctx.restore();
      ctx.globalAlpha=1;
      // engine glow
      ctx.fillStyle=paper?'rgba(255,140,20,0.6)':'rgba(255,180,40,0.8)';
      ctx.beginPath();ctx.ellipse(player.x,player.y+player.h/2+4,4,6+Math.random()*4,0,0,Math.PI*2);ctx.fill();
    }

    // HUD
    ctx.fillStyle=paper?'rgba(255,255,255,0.7)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`; ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`score: ${score}`,8,6);
    ctx.textAlign='right';
    ctx.fillText(`${'♥ '.repeat(lives).trim()}  lv.${level}`,W-8,6);
    ctx.textAlign='left';

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.65)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle=paper?'#fff':'#ffdd44';
      ctx.font=`400 20px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-18);
      ctx.fillStyle=paper?'rgba(255,255,255,0.7)':'rgba(255,255,255,0.5)';
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillText(`score: ${score}  ·  click to retry`,W/2,H/2+14);
      ctx.textAlign='left';ctx.textBaseline='top';
    }
  }

  c.addEventListener('click',()=>{if(gameOver)init();});

  const onKey=e=>{
    keys2[e.key]=e.type==='keydown';
    // prevent page scroll for game keys
    if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Space',' ','w','a','s','d','W','A','S','D'].includes(e.key))
      e.preventDefault();
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});
  mkBtn('Restart',ctrl).addEventListener('click',init);

  const hint=mkInfo(ctrl);
  hint.textContent='WASD / arrows · Space to fire';

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 44 — MISSILE COMMAND
// ════════════════════════════════════════════════════════════════════════════
function initMissileCommand(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF={
    missileSpeed:    [0.5, 0.9, 1.5],
    spawnRate:       [0.006,0.013,0.022],
    interceptorAmmo: [12,  10,   8],
    interceptorSpeed:[6,   5.5,  5],
  };

  // Wave type definitions — cycle as waves progress
  // 'normal'   : random trickle, business as usual
  // 'mirv'     : missiles split into 3 at mid-screen (wave 4+)
  // 'salvo'    : rapid sequential stream, wide spread, forces triage (wave 7+)
  // 'boss'     : single armoured missile, 3 hits, spawns 2 children on death (every 5th)
  function waveType(w){
    if(w%5===0) return 'boss';
    if(w>=7&&w%3===0) return 'salvo';
    if(w>=4&&w%2===0) return 'mirv';
    return 'normal';
  }

  let cities,batteries,missiles,interceptors,explosions4;
  let score,wave,gameOver,ammo,tick5;
  // Wave state machine
  let wavePhase;   // 'intro' | 'playing' | 'clear'
  let waveTimer;   // frames remaining in intro/clear pause
  let waveLabel;   // string shown during intro
  let salvoQueue;  // pending salvo missile specs [{delay,sx,tx,ty}]
  let bossAlive;   // true while boss wave boss is in play
  let waveHadMissiles; // true once first missile spawns this wave

  function groundY(){ return H-28; }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    score=0; wave=1; gameOver=false; tick5=0;
    ammo=DIFF.interceptorAmmo[difficulty]*3;

    cities=[];
    const cityPositions=[0.15,0.27,0.38,0.62,0.73,0.85];
    for(const xf of cityPositions)
      cities.push({x:W*xf, y:groundY(), alive:true, destroyFlash:0});

    batteries=[
      {x:W*0.1, y:groundY(), ammo:DIFF.interceptorAmmo[difficulty], flash:0},
      {x:W*0.5, y:groundY(), ammo:DIFF.interceptorAmmo[difficulty], flash:0},
      {x:W*0.9, y:groundY(), ammo:DIFF.interceptorAmmo[difficulty], flash:0},
    ];

    missiles=[]; interceptors=[]; explosions4=[];
    salvoQueue=[]; bossAlive=false;
    startWaveIntro();
  }

  // ── wave intro ──────────────────────────────────────────────────────────
  function startWaveIntro(){
    wavePhase='intro';
    waveTimer=90;
    tick5=0;
    waveHadMissiles=false;
    const t=waveType(wave);
    if(t==='boss')       waveLabel=`WAVE ${wave}  ★ BOSS INCOMING ★`;
    else if(t==='mirv')  waveLabel=`WAVE ${wave}  — MIRV ALERT`;
    else if(t==='salvo') waveLabel=`WAVE ${wave}  — SATURATION VOLLEY`;
    else                 waveLabel=`WAVE ${wave}`;

    // Pre-build salvo queue if needed
    salvoQueue=[];
    if(t==='salvo'){
      const count=6+wave;
      for(let i=0;i<count;i++){
        const aliveCities=cities.filter(c2=>c2.alive);
        const tgt=aliveCities.length
          ? aliveCities[Math.floor(Math.random()*aliveCities.length)]
          : batteries[Math.floor(Math.random()*batteries.length)];
        // Spread launch X across full width, stagger delay
        salvoQueue.push({delay:i*18, sx:Math.random()*W, tx:tgt.x, ty:tgt.y});
      }
    }
  }

  // ── wave clear ──────────────────────────────────────────────────────────
  function startWaveClear(){
    wavePhase='clear';
    waveTimer=100;
    const alive=cities.filter(c2=>c2.alive).length;
    score += alive*100 + batteries.reduce((s,b)=>s+b.ammo,0)*10;
    wave++;
    for(const b of batteries) b.ammo=Math.min(DIFF.interceptorAmmo[difficulty]+Math.floor(wave/2),20);
    ammo=batteries.reduce((s,b)=>s+b.ammo,0);
    bossAlive=false;
  }

  // ── missile factory ─────────────────────────────────────────────────────
  function makeMissile(sx,sy,tx,ty,opts={}){
    const spd=(opts.spd||DIFF.missileSpeed[difficulty])*(0.85+Math.random()*0.3)*(1+wave*0.07);
    const dist=Math.hypot(tx-sx,ty-sy)||1;
    const m=Object.assign({
      x:sx, y:sy,
      vx:(tx-sx)/dist*spd, vy:(ty-sy)/dist*spd,
      tx, ty, trail:[], alive:true,
      hp:1, isBoss:false, isMirv:false, mirvDone:false,
      col:'#ff4422', hitBy:new Set(),
    }, opts);
    if(!(m.hitBy instanceof Set)) m.hitBy=new Set();
    return m;
  }

  function spawnMissile(){
    const aliveCities=cities.filter(c2=>c2.alive);
    const pool=[...aliveCities,...batteries,...batteries]; // batteries weighted
    const tgt=pool[Math.floor(Math.random()*pool.length)];
    if(!tgt) return;
    const t=waveType(wave);
    const sx=Math.random()*W;
    if(t==='mirv'){
      // MIRV parent targets a mid-screen split point, NOT the ground.
      // It flies to that point then splits into 3 fast children targeting cities.
      const splitX=tgt.x+(Math.random()-0.5)*W*0.3; // slight horizontal drift
      const splitY=H*(0.35+Math.random()*0.15);      // upper-mid screen
      missiles.push(makeMissile(sx,0,splitX,splitY,{
        isMirv:true, col:'#ff8822',
        spd:DIFF.missileSpeed[difficulty]*0.55,
        hp:1,
      }));
    } else {
      missiles.push(makeMissile(sx,0,tgt.x,tgt.y));
    }
  }

  function spawnBoss(){
    // Boss enters from top-centre, arcs toward a random city
    bossAlive=true;
    const aliveCities=cities.filter(c2=>c2.alive);
    const tgt=aliveCities.length ? aliveCities[Math.floor(Math.random()*aliveCities.length)] : {x:W/2,y:groundY()};
    const sx=W*0.3+Math.random()*W*0.4;
    const spd=DIFF.missileSpeed[difficulty]*0.7*(1+wave*0.05);
    const dist=Math.hypot(tgt.x-sx,tgt.y)||1;
    missiles.push(makeMissile(sx,0,tgt.x,tgt.y,{
      spd, hp:3, isBoss:true,
      col:'#ff2200',
      w:10, // drawn bigger
    }));
  }

  function fireInterceptor(tx,ty){
    let best=null,bestD=Infinity;
    for(const b of batteries){
      if(b.ammo<=0) continue;
      const d=Math.hypot(tx-b.x,ty-b.y);
      if(d<bestD){bestD=d;best=b;}
    }
    if(!best) return;
    best.ammo--; best.flash=8; ammo--;
    const dist=Math.hypot(tx-best.x,ty-best.y)||1;
    const spd=DIFF.interceptorSpeed[difficulty];
    interceptors.push({x:best.x,y:best.y,vx:(tx-best.x)/dist*spd,vy:(ty-best.y)/dist*spd,tx,ty,trail:[]});
  }

  function addExplosion(x,y,r,col){
    explosions4.push({x,y,r,maxR:r,life:1,col,growing:true,id:Math.random()});
  }

  // ── step ────────────────────────────────────────────────────────────────
  function step(){
    // ── intro pause ──
    if(wavePhase==='intro'){
      waveTimer--;
      if(waveTimer<=0){
        wavePhase='playing';
        tick5=0; // start counting only once playing begins
        if(waveType(wave)==='boss') spawnBoss();
      }
      return;
    }

    // ── clear pause ──
    if(wavePhase==='clear'){
      waveTimer--;
      if(waveTimer<=0) startWaveIntro();
      return;
    }

    // ── playing ──
    tick5++;
    const t=waveType(wave);

    // Spawn logic per wave type
    if(t==='boss'){
      // Boss wave: only the boss missile; no extra spawns
    } else if(t==='salvo'){
      // Drain the salvo queue by delay countdown
      for(const s of salvoQueue) s.delay--;
      const ready=salvoQueue.filter(s=>s.delay<=0);
      salvoQueue=salvoQueue.filter(s=>s.delay>0);
      for(const s of ready){
        missiles.push(makeMissile(s.sx,0,s.tx,s.ty));
      }
    } else {
      // Normal / mirv: probabilistic spawn
      if(Math.random()<DIFF.spawnRate[difficulty]*(1+wave*0.12)) spawnMissile();
    }

    // Move missiles — use pendingMissiles so children aren't iterated mid-loop
    const pendingMissiles=[];
    for(const m of missiles){
      if(!m.alive) continue;
      m.trail.push({x:m.x,y:m.y});
      if(m.trail.length>35) m.trail.shift();
      m.x+=m.vx; m.y+=m.vy;

      // MIRV split — fires when missile reaches its split Y (same tolerance as target check)
      if(m.isMirv&&!m.mirvDone&&m.y>=m.ty-4){
        m.mirvDone=true; m.alive=false;
        // Create birth explosion with a known ID so children are immune to it
        const birthExpId=Math.random();
        explosions4.push({x:m.x,y:m.y,r:28,maxR:28,life:1,col:'#ff8822',id:birthExpId,growing:true});
        // Spawn 3 children targeting 3 different cities/batteries
        const alivePop=[...cities.filter(c2=>c2.alive),...batteries];
        const targets=[];
        const used=new Set();
        for(let ci2=0;ci2<3;ci2++){
          const pool2=alivePop.filter((_,i)=>!used.has(i));
          const pick=pool2.length ? pool2[Math.floor(Math.random()*pool2.length)] : alivePop[ci2%alivePop.length];
          targets.push(pick);
          const idx=alivePop.indexOf(pick); if(idx>=0) used.add(idx);
        }
        const childSpd=DIFF.missileSpeed[difficulty]*1.1*(1+wave*0.06);
        for(let ci2=0;ci2<targets.length;ci2++){
          const tgt=targets[ci2];
          const dist=Math.hypot(tgt.x-m.x,tgt.y-m.y)||1;
          const spreadX=(ci2-1)*20;
          pendingMissiles.push({
            x:m.x+spreadX, y:m.y,
            vx:(tgt.x-m.x)/dist*childSpd,
            vy:(tgt.y-m.y)/dist*childSpd,
            tx:tgt.x, ty:tgt.y,
            trail:[], alive:true,
            hp:1, isBoss:false, isMirv:false, mirvDone:true,
            col:'#ffcc44', isChild:true,
            hitBy:new Set([birthExpId]),
          });
        }
        continue;
      }

      // Reached target
      if(m.y>=m.ty-4){
        m.alive=false;
        const expR=m.isBoss?60:m.isChild?24:38;
        addExplosion(m.tx,m.ty,expR,'#ff6622');
        const blastR=m.isBoss?70:m.isChild?28:42;
        for(const city of cities){
          if(city.alive&&Math.hypot(city.x-m.tx,city.y-m.ty)<blastR){
            city.alive=false; city.destroyFlash=30;
          }
        }
        if(m.isBoss) bossAlive=false;
      }
    }
    missiles=missiles.filter(m=>m.alive&&m.y<H+20).concat(pendingMissiles);

    // Move interceptors
    for(const iv of interceptors){
      iv.trail.push({x:iv.x,y:iv.y});
      if(iv.trail.length>20) iv.trail.shift();
      iv.x+=iv.vx; iv.y+=iv.vy;
      if(Math.hypot(iv.x-iv.tx,iv.y-iv.ty)<8){
        iv.dead=true;
        addExplosion(iv.tx,iv.ty,55,'#44aaff');
      }
    }
    interceptors=interceptors.filter(iv=>!iv.dead);

    // Explosion-missile collisions
    const bossChildren=[];
    for(const exp of explosions4){
      if(exp.growing) exp.r=Math.min(exp.maxR,exp.r+2);
      else exp.r*=0.96;
      exp.life-=0.018;
      if(exp.r>=exp.maxR) exp.growing=false;
      for(const m of missiles){
        if(!m.alive) continue;
        if(m.hitBy.has(exp.id)) continue; // this explosion already hit this missile
        if(Math.hypot(m.x-exp.x,m.y-exp.y)<exp.r){
          m.hitBy.add(exp.id);
          m.hp--;
          if(m.hp<=0){
            m.alive=false;
            score+=m.isBoss?200*wave:25*wave;
            addExplosion(m.x,m.y,m.isBoss?50:30,'#ffaa44');
            // Boss spawns 3 fast children on death
            if(m.isBoss){
              bossAlive=false;
              const aliveCities=cities.filter(c2=>c2.alive);
              const bossDeathId=Math.random();
              explosions4.push({x:m.x,y:m.y,r:10,maxR:10,life:0.5,col:'#ff2200',id:bossDeathId,growing:false});
              for(let i=0;i<3;i++){
                const tgt=aliveCities.length
                  ? aliveCities[i % aliveCities.length]
                  : batteries[i % batteries.length];
                bossChildren.push(makeMissile(m.x,m.y,tgt.x,tgt.y,{
                  spd:DIFF.missileSpeed[difficulty]*1.5,
                  col:'#ff6600',
                  hitBy:new Set([bossDeathId]),
                }));
              }
            }
          } else {
            // Boss flashes when hit but survives
            m.col='#ffffff';
            setTimeout(()=>{if(m.alive)m.col='#ff2200';},80);
            addExplosion(m.x,m.y,20,'#ffcc44');
          }
        }
      }
    }
    missiles=missiles.concat(bossChildren);
    explosions4=explosions4.filter(e=>e.life>0);

    // Wave clear check
    // Only consider wave done once at least one missile has actually appeared
    if(missiles.length>0||interceptors.length>0) waveHadMissiles=true;
    const allGone=waveHadMissiles&&missiles.length===0&&interceptors.length===0&&salvoQueue.length===0&&tick5>60;
    if(allGone&&wavePhase==='playing'){
      if(cities.some(c2=>c2.alive)) startWaveClear();
    }

    // Game over
    if(cities.every(c2=>!c2.alive)) gameOver=true;
  }

  // ── draw ────────────────────────────────────────────────────────────────
  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    if(!gameOver) step();

    // Sky
    const sky=ctx.createLinearGradient(0,0,0,H);
    if(paper){sky.addColorStop(0,'#b0c8e8');sky.addColorStop(1,'#e0d0b0');}
    else{sky.addColorStop(0,'#000818');sky.addColorStop(1,'#0a1428');}
    ctx.fillStyle=sky; ctx.fillRect(0,0,W,H);

    if(!paper){
      ctx.fillStyle='rgba(255,255,255,0.6)';
      for(let i=0;i<80;i++) ctx.fillRect((i*113)%W,(i*71)%(H*0.7),1,1);
    }

    // Ground
    ctx.fillStyle=paper?'#7a6a40':'#1a3a1a'; ctx.fillRect(0,H-28,W,28);
    ctx.fillStyle=paper?'#8a7a50':'#22441a'; ctx.fillRect(0,H-28,W,4);

    // Missile trails
    for(const m of missiles){
      if(m.trail.length<2) continue;
      const isBoss=m.isBoss, isMirv=m.isMirv||m.col==='#ffaa22';
      const [r2,g2,b2]=paper?[200,100,30]:isBoss?[255,50,0]:isMirv?[255,160,30]:[255,80,30];
      for(let i=1;i<m.trail.length;i++){
        const a=(i/m.trail.length)*0.55;
        ctx.strokeStyle=`rgba(${r2},${g2},${b2},${a})`;
        ctx.lineWidth=isBoss?3:1.5;
        ctx.beginPath();ctx.moveTo(m.trail[i-1].x,m.trail[i-1].y);ctx.lineTo(m.trail[i].x,m.trail[i].y);ctx.stroke();
      }
    }
    // Missiles
    for(const m of missiles){
      ctx.fillStyle=m.col||(paper?'#cc3322':'#ff4422');
      const r=m.isBoss?7:m.isMirv&&!m.mirvDone?5:3;
      ctx.beginPath();ctx.arc(m.x,m.y,r,0,Math.PI*2);ctx.fill();
      // MIRV parent: pulsing outer ring + small label
      if(m.isMirv&&!m.mirvDone){
        const pulse=0.5+0.5*Math.sin(Date.now()*0.008);
        ctx.strokeStyle=`rgba(255,180,50,${0.4+0.4*pulse})`;
        ctx.lineWidth=1.5;
        ctx.beginPath();ctx.arc(m.x,m.y,9+pulse*3,0,Math.PI*2);ctx.stroke();
        ctx.fillStyle=paper?'rgba(0,0,0,0.7)':'rgba(255,200,80,0.85)';
        ctx.font=`300 7px 'IBM Plex Mono',monospace`;
        ctx.textAlign='center';ctx.textBaseline='bottom';
        ctx.fillText('MIRV',m.x,m.y-8);
        ctx.textAlign='left';ctx.textBaseline='top';
      }
      // Boss HP bar
      if(m.isBoss&&m.hp>0){
        ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(m.x-18,m.y-18,36,5);
        ctx.fillStyle='#ff4400';ctx.fillRect(m.x-18,m.y-18,36*(m.hp/3),5);
      }
    }

    // Interceptor trails + crosshairs
    for(const iv of interceptors){
      if(iv.trail.length<2) continue;
      for(let i=1;i<iv.trail.length;i++){
        const a=(i/iv.trail.length)*0.7;
        ctx.strokeStyle=`rgba(100,200,255,${a})`;
        ctx.lineWidth=2;
        ctx.beginPath();ctx.moveTo(iv.trail[i-1].x,iv.trail[i-1].y);ctx.lineTo(iv.trail[i].x,iv.trail[i].y);ctx.stroke();
      }
    }
    for(const iv of interceptors){
      ctx.strokeStyle=paper?'rgba(0,100,200,0.4)':'rgba(100,200,255,0.3)';
      ctx.lineWidth=1; ctx.setLineDash([3,5]);
      ctx.beginPath();ctx.arc(iv.tx,iv.ty,12,0,Math.PI*2);ctx.stroke();
      ctx.setLineDash([]);
    }

    // Explosions
    for(const exp of explosions4){
      const [r2,g2,b2]=[parseInt(exp.col.slice(1,3),16),parseInt(exp.col.slice(3,5),16),parseInt(exp.col.slice(5,7),16)];
      const grd=ctx.createRadialGradient(exp.x,exp.y,0,exp.x,exp.y,exp.r);
      grd.addColorStop(0,`rgba(${r2},${g2},${b2},${exp.life*0.9})`);
      grd.addColorStop(0.4,`rgba(${r2},${g2},${b2},${exp.life*0.5})`);
      grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;
      ctx.beginPath();ctx.arc(exp.x,exp.y,exp.r,0,Math.PI*2);ctx.fill();
    }

    // Cities
    for(const city of cities){
      if(city.destroyFlash>0){city.destroyFlash--;continue;}
      if(!city.alive) continue;
      ctx.fillStyle=paper?'#44337a':'#8866ff';
      const bx=city.x, by=city.y;
      ctx.fillRect(bx-14,by-20,8,20);
      ctx.fillRect(bx-4,by-28,12,28);
      ctx.fillRect(bx+10,by-16,8,16);
      ctx.fillStyle=paper?'rgba(255,220,100,0.5)':'rgba(255,220,100,0.4)';
      for(let wy=by-24;wy<by;wy+=8)
        for(let wx=bx-2;wx<bx+10;wx+=5)
          if(Math.random()<0.7) ctx.fillRect(wx,wy,3,4);
    }

    // Batteries
    for(const bat of batteries){
      ctx.fillStyle=bat.ammo>0?(paper?'#334488':'#4466cc'):(paper?'#888':'#444');
      ctx.fillRect(bat.x-16,bat.y-14,32,14);
      if(bat.ammo>0){
        ctx.fillStyle=paper?'#5566aa':'#6688ff';
        ctx.fillRect(bat.x-4,bat.y-22,8,12);
      }
      for(let i=0;i<Math.min(bat.ammo,20);i++){
        ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(100,180,255,0.7)';
        ctx.beginPath();ctx.arc(bat.x-10+i*4,bat.y-6,1.5,0,Math.PI*2);ctx.fill();
      }
    }

    // Cursor crosshair
    if(!gameOver&&wavePhase==='playing'){
      ctx.strokeStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
      ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(mouseX-14,mouseY);ctx.lineTo(mouseX+14,mouseY);ctx.stroke();
      ctx.beginPath();ctx.moveTo(mouseX,mouseY-14);ctx.lineTo(mouseX,mouseY+14);ctx.stroke();
      ctx.beginPath();ctx.arc(mouseX,mouseY,8,0,Math.PI*2);ctx.stroke();
    }

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.55)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`; ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`score: ${score}  wave: ${wave}  ammo: ${ammo}`,8,6);

    // Wave type label (small, top right)
    const t=waveType(wave);
    if(t!=='normal'&&wavePhase==='playing'){
      ctx.textAlign='right';
      ctx.fillStyle=t==='boss'?'#ff4422':t==='mirv'?'#ff8822':'#22aaff';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(t==='boss'?'★ BOSS':t==='mirv'?'⚠ MIRV':'⚡ SALVO',W-8,6);
      ctx.textAlign='left';
    }

    // Wave intro / clear overlay
    if(wavePhase==='intro'||wavePhase==='clear'){
      const alpha=wavePhase==='intro'
        ? Math.min(1,(90-waveTimer)/15)     // fade in
        : Math.min(1,waveTimer/15);          // fade out
      ctx.fillStyle=`rgba(0,0,0,${alpha*0.55})`;
      ctx.fillRect(0,0,W,H);
      ctx.globalAlpha=alpha;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      if(wavePhase==='intro'){
        const isBoss=waveType(wave)==='boss';
        ctx.fillStyle=isBoss?'#ff4422':'rgba(255,255,255,0.9)';
        ctx.font=`400 ${isBoss?22:18}px 'IBM Plex Mono',monospace`;
        ctx.fillText(waveLabel,W/2,H/2-10);
        if(isBoss){
          ctx.fillStyle='rgba(255,100,50,0.7)';
          ctx.font=`300 11px 'IBM Plex Mono',monospace`;
          ctx.fillText('armoured · 3 hits · spawns children',W/2,H/2+16);
        }
      } else {
        // Clear screen — show bonuses
        const alive=cities.filter(c2=>c2.alive).length;
        ctx.fillStyle='rgba(100,255,150,0.9)';
        ctx.font=`400 16px 'IBM Plex Mono',monospace`;
        ctx.fillText(`WAVE ${wave-1} CLEAR`,W/2,H/2-22);
        ctx.fillStyle='rgba(255,255,255,0.7)';
        ctx.font=`300 11px 'IBM Plex Mono',monospace`;
        ctx.fillText(`${alive} cities saved  +${alive*100}  ·  ammo bonus +${batteries.reduce((s,b)=>s+b.ammo,0)*10}`,W/2,H/2+4);
      }
      ctx.globalAlpha=1; ctx.textAlign='left'; ctx.textBaseline='top';
    }

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.75)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ff4422'; ctx.font=`400 20px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('THE CITIES HAVE FALLEN',W/2,H/2-20);
      ctx.fillStyle='rgba(255,255,255,0.6)'; ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillText(`final score: ${score}  ·  click to retry`,W/2,H/2+10);
      ctx.textAlign='left';ctx.textBaseline='top';
    }
  }

  let mouseX=W/2,mouseY=H/2;
  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouseX=e.clientX-r.left;mouseY=e.clientY-r.top;});
  c.addEventListener('click',e=>{
    if(gameOver){init();return;}
    if(wavePhase!=='playing') return;
    const r=c.getBoundingClientRect();
    fireInterceptor(e.clientX-r.left,e.clientY-r.top);
  });

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});
  mkBtn('Restart',ctrl).addEventListener('click',init);
  mkInfo(ctrl).textContent='click to fire interceptors';

  init();
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

