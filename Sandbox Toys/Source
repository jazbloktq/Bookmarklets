// TOY 22 — DOUBLE PENDULUM
// ════════════════════════════════════════════════════════════════════════════
function initPendulum(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let trailCanvas=document.createElement('canvas');
  let tctx=trailCanvas.getContext('2d');
  let showTrails=true,paused=false,trailFade=0.012;
  let numJoints=3; // number of segments in the chain
  let zoom=1.0;

  // N-joint pendulum chain using Verlet / Euler with N segments
  // Each segment: angle[i], velocity[i], length[i], mass[i]
  let angles=[],vels=[],lengths=[],masses=[],trail=[],trailCol='';

  function reset(){
    angles=[];vels=[];lengths=[];masses=[];trail=[];
    const L=Math.min(W||400,H||400)*(0.18/Math.sqrt(numJoints));
    for(let i=0;i<numJoints;i++){
      angles.push(Math.PI*0.5+0.01*(i+1));
      vels.push(0);
      lengths.push(L);
      masses.push(1);
    }
    const hue=200;
    trailCol=isPaper()?`hsla(${hue},50%,25%,0.7)`:`hsla(${hue},85%,65%,0.8)`;
    trailCanvas.width=W||400;trailCanvas.height=H||400;
    tctx.fillStyle=bgClr();tctx.fillRect(0,0,trailCanvas.width,trailCanvas.height);
  }
  reset();

  // Compute positions from pivot
  function getPositions(){
    const ox=W/2,oy=H*0.22;
    const pts=[{x:ox,y:oy}];
    for(let i=0;i<numJoints;i++){
      pts.push({x:pts[i].x+Math.sin(angles[i])*lengths[i]*zoom,
                y:pts[i].y+Math.cos(angles[i])*lengths[i]*zoom});
    }
    return pts;
  }

  // N-pendulum physics via Lagrangian (recursive approach, simplified as
  // iterative RK4 per segment treating prior as fixed — visually convincing)
  const G=9.81,DT=0.03;
  function stepChain(){
    // Use the standard 2-body formula iteratively applied per adjacent pair
    for(let iter=0;iter<4;iter++){
      for(let i=0;i<numJoints;i++){
        // effective pivot mass = sum of all masses below
        const mBelow=masses.slice(i).reduce((s,m)=>s+m,0);
        const mAbove=i>0?masses.slice(0,i).reduce((s,m)=>s+m,0):1e6;
        const l=lengths[i];
        // coupling with previous segment
        let acc=-G/l*Math.sin(angles[i]);
        if(i>0){
          const d=angles[i-1]-angles[i];
          acc+=vels[i-1]*vels[i-1]*lengths[i-1]/l*Math.sin(d)*mAbove/(mBelow+mAbove);
        }
        // coupling with next segment
        if(i<numJoints-1){
          const d=angles[i]-angles[i+1];
          acc-=vels[i+1]*vels[i+1]*lengths[i+1]/l*Math.sin(d)*masses[i+1]/(mBelow);
        }
        vels[i]+=acc*DT;
        vels[i]*=0.9998;
      }
      for(let i=0;i<numJoints;i++)angles[i]+=vels[i]*DT;
    }
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    if(trailCanvas.width!==W||trailCanvas.height!==H){
      trailCanvas.width=W;trailCanvas.height=H;
      tctx.fillStyle=bgClr();tctx.fillRect(0,0,W,H);
    }
    if(!paused){
      stepChain();
      const pts=getPositions();
      const tip=pts[pts.length-1];
      tctx.fillStyle=isPaper()?`rgba(245,241,232,${trailFade})`:`rgba(10,10,9,${trailFade})`;
      tctx.fillRect(0,0,W,H);
      if(showTrails&&trail.length>0){
        tctx.strokeStyle=trailCol;tctx.lineWidth=1.2;
        tctx.beginPath();tctx.moveTo(trail[trail.length-1][0],trail[trail.length-1][1]);
        tctx.lineTo(tip.x,tip.y);tctx.stroke();
      }
      trail.push([tip.x,tip.y]);if(trail.length>800)trail.shift();
    }
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    if(showTrails)ctx.drawImage(trailCanvas,0,0);
    const pts=getPositions();
    // rods
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.4)';ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++)ctx.lineTo(pts[i].x,pts[i].y);
    ctx.stroke();
    // joints/bobs
    for(let i=0;i<pts.length;i++){
      const r=i===0?5:(i===pts.length-1?10:7);
      const hue=i/numJoints*280+160;
      ctx.beginPath();ctx.arc(pts[i].x,pts[i].y,r,0,Math.PI*2);
      ctx.fillStyle=i===0?(isPaper()?'#555':'#888'):(isPaper()?`hsl(${hue},50%,30%)`:`hsl(${hue},85%,65%)`);
      ctx.fill();
    }
  }

  // Scroll to zoom
  c.addEventListener('wheel',e=>{
    e.preventDefault();
    zoom*=e.deltaY<0?1.12:0.89;
    zoom=Math.max(0.2,Math.min(5,zoom));
  },{passive:false});

  const trailBtn=mkBtn('Trails: On',ctrl,true);
  trailBtn.addEventListener('click',()=>{showTrails=!showTrails;trailBtn.textContent=`Trails: ${showTrails?'On':'Off'}`;setLit(trailBtn,showTrails);});
  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';setLit(pauseBtn,paused);});
  mkBtn('Reset',ctrl).addEventListener('click',reset);

  const pLbl=document.createElement('span');pLbl.className='sb-info sb-speed-lbl';pLbl.style.marginLeft='4px';pLbl.textContent='joints';ctrl.appendChild(pLbl);
  const psl=document.createElement('input');psl.type='range';psl.className='sb-slider';psl.min=1;psl.max=12;psl.step=1;psl.value=numJoints;ctrl.appendChild(psl);styleSlider(psl);
  psl.addEventListener('input',()=>{numJoints=+psl.value;reset();});

  const fadeLbl=document.createElement('span');fadeLbl.className='sb-info sb-speed-lbl';fadeLbl.style.marginLeft='4px';fadeLbl.textContent='fade';ctrl.appendChild(fadeLbl);
  const fsl=document.createElement('input');fsl.type='range';fsl.className='sb-slider';fsl.min=0.001;fsl.max=0.15;fsl.step=0.001;fsl.value=trailFade;ctrl.appendChild(fsl);styleSlider(fsl);
  fsl.addEventListener('input',()=>trailFade=+fsl.value);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 23 — SOFT BODY  (jelly blob you can poke)
// ════════════════════════════════════════════════════════════════════════════
function initSoftBody(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let blobs=[],mouse={x:-999,y:-999,down:false};

  function mkBlob(cx,cy,r,col){
    const N=20,pts=[];
    for(let i=0;i<N;i++){
      const a=i/N*Math.PI*2;
      pts.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,vx:0,vy:0,ox:cx+Math.cos(a)*r,oy:cy+Math.sin(a)*r});
    }
    return{pts,cx,cy,r,col,N};
  }
  function reset(){
    blobs=[
      mkBlob(W*0.38,H*0.5,Math.min(W,H)*0.18,isPaper()?'rgba(80,120,180,0.55)':'rgba(80,160,255,0.55)'),
      mkBlob(W*0.65,H*0.45,Math.min(W,H)*0.13,isPaper()?'rgba(160,80,80,0.55)':'rgba(255,100,100,0.55)'),
    ];
  }
  reset();

  const STIFF=0.08,DAMP=0.88,PRESSURE=0.9,GRAV=0.12;
  function stepBlob(b){
    const{pts,N}=b;
    // compute centroid
    let cx=0,cy=0;for(const p of pts){cx+=p.x;cy+=p.y;}cx/=N;cy/=N;
    b.cx=cx;b.cy=cy;
    // compute area (shoelace)
    let area=0;
    for(let i=0;i<N;i++){const j=(i+1)%N;area+=pts[i].x*pts[j].y-pts[j].x*pts[i].y;}
    area=Math.abs(area)/2;
    const targetArea=Math.PI*b.r*b.r;
    const pressureForce=(targetArea-area)/targetArea*PRESSURE;
    for(let i=0;i<N;i++){
      const p=pts[i];
      const prev=pts[(i-1+N)%N],next=pts[(i+1)%N];
      // spring to neighbours
      const fsx=(prev.x+next.x)/2-p.x,fsy=(prev.y+next.y)/2-p.y;
      // spring to rest position (relative to centroid)
      const restX=cx+(p.ox-b.cx)*1,restY=cy+(p.oy-b.cy)*1;
      // pressure (push outward from centroid)
      const nx=p.x-cx,ny=p.y-cy,nd=Math.sqrt(nx*nx+ny*ny)||1;
      p.vx+=(fsx*STIFF+(restX-p.x)*0.04+nx/nd*pressureForce*2)*1;
      p.vy+=(fsy*STIFF+(restY-p.y)*0.04+ny/nd*pressureForce*2+GRAV)*1;
      // mouse repulsion
      const mdx=p.x-mouse.x,mdy=p.y-mouse.y,md=Math.sqrt(mdx*mdx+mdy*mdy)||1;
      const mForce=mouse.down?60:30;
      if(md<60){p.vx+=mdx/md*(60-md)/60*mForce*0.04;p.vy+=mdy/md*(60-md)/60*mForce*0.04;}
      p.vx*=DAMP;p.vy*=DAMP;
      p.x+=p.vx;p.y+=p.vy;
      // floor/wall bounce
      if(p.y>H-4){p.y=H-4;p.vy*=-0.4;}
      if(p.x<4){p.x=4;p.vx*=-0.4;}if(p.x>W-4){p.x=W-4;p.vx*=-0.4;}
      if(p.y<4){p.y=4;p.vy*=-0.4;}
    }
  }

  function drawBlob(b){
    const{pts,col}=b;
    ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++)ctx.lineTo(pts[i].x,pts[i].y);
    ctx.closePath();
    ctx.fillStyle=col;ctx.fill();
    ctx.strokeStyle=col.replace(/[\d.]+\)$/,'0.8)');ctx.lineWidth=2;ctx.stroke();
    // sheen
    const grd=ctx.createRadialGradient(b.cx-b.r*0.3,b.cy-b.r*0.3,0,b.cx,b.cy,b.r*1.1);
    grd.addColorStop(0,'rgba(255,255,255,0.18)');grd.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle=grd;ctx.fill();
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    for(const b of blobs)stepBlob(b);
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    // floor line
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.06)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(0,H-4);ctx.lineTo(W,H-4);ctx.stroke();
    for(const b of blobs)drawBlob(b);
    // cursor indicator
    if(mouse.x>0){
      ctx.beginPath();ctx.arc(mouse.x,mouse.y,mouse.down?22:14,0,Math.PI*2);
      ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.15)';ctx.lineWidth=1;ctx.stroke();
    }
  }

  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
  c.addEventListener('mousedown',()=>mouse.down=true);
  c.addEventListener('mouseup',()=>mouse.down=false);
  c.addEventListener('mouseleave',()=>{mouse.x=-999;mouse.y=-999;mouse.down=false;});
  mkBtn('Reset',ctrl).addEventListener('click',reset);
  const cntLbl=document.createElement('span');cntLbl.className='sb-info sb-speed-lbl';cntLbl.style.marginLeft='4px';cntLbl.textContent='blobs';ctrl.appendChild(cntLbl);
  const bsl=document.createElement('input');bsl.type='range';bsl.className='sb-slider';bsl.min=1;bsl.max=6;bsl.step=1;bsl.value=blobs.length;ctrl.appendChild(bsl);styleSlider(bsl);
  bsl.addEventListener('input',()=>{
    const n=+bsl.value;
    while(blobs.length<n)blobs.push(mkBlob(rndf(W*0.2,W*0.8),rndf(H*0.2,H*0.7),Math.min(W,H)*(0.08+Math.random()*0.12),`hsla(${Math.random()*360},70%,${isPaper()?'45':'65'}%,0.55)`));
    while(blobs.length>n)blobs.pop();
  });
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

