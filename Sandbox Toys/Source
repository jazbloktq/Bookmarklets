// TOY 21 — 2048  (animated sliding tiles)
// ════════════════════════════════════════════════════════════════════════════
function init2048(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let grid,score,gameOver,won;
  let anims=[],animT=0,animating=false;
  const ANIM_DUR=0.12;
  const TILE_COLORS={
    0:'transparent',2:'#eee4da',4:'#ede0c8',8:'#f2b179',16:'#f59563',
    32:'#f67c5f',64:'#f65e3b',128:'#edcf72',256:'#edcc61',512:'#edc850',
    1024:'#edc53f',2048:'#edc22e',
  };
  function newGrid(){return Array.from({length:4},()=>[0,0,0,0]);}
  function addRandom(g){
    const empty=[];
    for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++)if(g[r][cc]===0)empty.push([r,cc]);
    if(!empty.length)return;
    const[r,cc]=empty[Math.floor(Math.random()*empty.length)];
    g[r][cc]=Math.random()<0.9?2:4;
  }
  function init(){grid=newGrid();score=0;gameOver=false;won=false;anims=[];animating=false;addRandom(grid);addRandom(grid);}
  init();
  function slideRowAnim(row,lineIdx,isRow){
    const moves=[];
    let r=[];
    for(let i=0;i<4;i++)if(row[i])r.push({v:row[i],orig:i});
    const result=[0,0,0,0];let dest=0;
    for(let i=0;i<r.length;i++){
      if(i+1<r.length&&r[i].v===r[i+1].v){
        const val=r[i].v*2;score+=val;result[dest]=val;
        moves.push({value:val,from:r[i].orig,to:dest,lineIdx,isRow,pop:true});
        moves.push({value:r[i].v,from:r[i+1].orig,to:dest,lineIdx,isRow,ghost:true});
        i++;dest++;
      } else {
        result[dest]=r[i].v;
        moves.push({value:r[i].v,from:r[i].orig,to:dest,lineIdx,isRow});
        dest++;
      }
    }
    return{result,moves};
  }
  function move(dir){
    if(animating||gameOver||won)return;
    const prev=grid.map(r=>r.slice());
    let g=grid.map(r=>r.slice());
    let allMoves=[];
    if(dir==='left'){
      for(let r=0;r<4;r++){const{result,moves}=slideRowAnim(g[r],r,true);g[r]=result;allMoves.push(...moves);}
    } else if(dir==='right'){
      for(let r=0;r<4;r++){
        const rev=[...g[r]].reverse();
        const{result,moves}=slideRowAnim(rev,r,true);
        g[r]=result.reverse();
        allMoves.push(...moves.map(m=>({...m,from:3-m.from,to:3-m.to})));
      }
    } else if(dir==='up'){
      for(let cc=0;cc<4;cc++){
        const col=g.map(r=>r[cc]);
        const{result,moves}=slideRowAnim(col,cc,false);
        result.forEach((v,r)=>g[r][cc]=v);
        allMoves.push(...moves);
      }
    } else if(dir==='down'){
      for(let cc=0;cc<4;cc++){
        const col=g.map(r=>r[cc]).reverse();
        const{result,moves}=slideRowAnim(col,cc,false);
        result.reverse().forEach((v,r)=>g[r][cc]=v);
        allMoves.push(...moves.map(m=>({...m,from:3-m.from,to:3-m.to})));
      }
    }
    if(JSON.stringify(g)===JSON.stringify(prev))return;
    grid=g;addRandom(grid);
    if(grid.flat().includes(2048))won=true;
    const hasMove=grid.flat().includes(0)||grid.some((r,ri)=>r.some((v,ci)=>(ci<3&&v===grid[ri][ci+1])||(ri<3&&v===grid[ri+1][ci])));
    if(!hasMove)gameOver=true;
    scoreEl.textContent='score '+score;
    anims=allMoves;animT=0;animating=true;
  }
  function drawTile(x,y,cell,v,scale){
    if(!v)return;
    const s=scale??1;
    const dx=x+cell/2*(1-s),dy=y+cell/2*(1-s),dw=cell*s,dh=cell*s;
    ctx.fillStyle=TILE_COLORS[v]||'#3d3a32';
    ctx.beginPath();ctx.roundRect?ctx.roundRect(dx,dy,dw,dh,6*s):ctx.rect(dx,dy,dw,dh);ctx.fill();
    const fs=(v<100?cell*0.42:v<1000?cell*0.34:cell*0.26)*s;
    ctx.fillStyle=v<=4?'#776e65':'#f9f6f2';
    ctx.font='700 '+fs+'px \'IBM Plex Mono\',monospace';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(v,x+cell/2,y+cell/2+2*s);
  }
  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const SZ=Math.min(W,H)-40,gap=SZ*0.03,cell=(SZ-gap*5)/4,cs=cell+gap;
    const ox=(W-SZ)/2,oy=(H-SZ)/2;
    ctx.fillStyle=isPaper()?'#f0e4d8':'#1a1610';ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#bbada0';ctx.beginPath();ctx.roundRect?ctx.roundRect(ox,oy,SZ,SZ,8):ctx.rect(ox,oy,SZ,SZ);ctx.fill();
    for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++){
      ctx.fillStyle=isPaper()?'rgba(180,160,140,0.35)':'rgba(0,0,0,0.25)';
      const x=ox+gap+cc*cs,y=oy+gap+r*cs;
      ctx.beginPath();ctx.roundRect?ctx.roundRect(x,y,cell,cell,4):ctx.rect(x,y,cell,cell);ctx.fill();
    }
    if(animating){
      animT+=0.016;
      const t=Math.min(1,animT/ANIM_DUR);
      const ease=t<0.5?2*t*t:1-Math.pow(-2*t+2,2)/2;
      for(const a of anims){
        if(a.ghost)continue;
        let fr,fc,tr2,tc2;
        if(a.isRow){fr=a.lineIdx;fc=a.from;tr2=a.lineIdx;tc2=a.to;}
        else{fr=a.from;fc=a.lineIdx;tr2=a.to;tc2=a.lineIdx;}
        const sx2=ox+gap+fc*cs,sy2=oy+gap+fr*cs;
        const ex=ox+gap+tc2*cs,ey=oy+gap+tr2*cs;
        const px=sx2+(ex-sx2)*ease,py=sy2+(ey-sy2)*ease;
        const scale=a.pop&&t>0.75?1+(t-0.75)*4*0.15*(1-(t-0.75)*4):1;
        drawTile(px,py,cell,a.value,Math.max(0.5,scale));
      }
      if(t>=1)animating=false;
    } else {
      for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++){
        const v=grid[r][cc];if(!v)continue;
        drawTile(ox+gap+cc*cs,oy+gap+r*cs,cell,v);
      }
    }
    if(gameOver||won){
      ctx.fillStyle='rgba(238,228,218,0.73)';ctx.fillRect(ox,oy,SZ,SZ);
      ctx.fillStyle=won?'#f9f6f2':'#776e65';
      ctx.font='700 '+(SZ*0.1)+'px \'IBM Plex Mono\',monospace';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(won?'You Win!':'Game Over',W/2,H/2-16);
      ctx.font='300 12px \'IBM Plex Mono\',monospace';ctx.fillStyle='#776e65';
      ctx.fillText('press R to restart',W/2,H/2+18);
    }
  }
  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',init);
  let tx=0,ty=0;
  c.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
  c.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;if(Math.abs(dx)>Math.abs(dy))move(dx>0?'right':'left');else move(dy>0?'down':'up');},{passive:true});
  const onKey=e=>{const m={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down'};if(m[e.key]){move(m[e.key]);e.preventDefault();}if(e.key==='r'||e.key==='R')init();};
  document.addEventListener('keydown',onKey);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}


// ════════════════════════════════════════════════════════════════════════════
// TOY 22 — DOUBLE PENDULUM
// ════════════════════════════════════════════════════════════════════════════
function initPendulum(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let trailCanvas=document.createElement('canvas');
  let tctx=trailCanvas.getContext('2d');
  let showTrails=true,paused=false,trailFade=0.012;
  let numJoints=3; // number of segments in the chain
  let zoom=1.0;

  // N-joint pendulum chain using Verlet / Euler with N segments
  // Each segment: angle[i], velocity[i], length[i], mass[i]
  let angles=[],vels=[],lengths=[],masses=[],trail=[],trailCol='';

  function reset(){
    angles=[];vels=[];lengths=[];masses=[];trail=[];
    const L=Math.min(W||400,H||400)*(0.18/Math.sqrt(numJoints));
    for(let i=0;i<numJoints;i++){
      angles.push(Math.PI*0.5+0.01*(i+1));
      vels.push(0);
      lengths.push(L);
      masses.push(1);
    }
    const hue=200;
    trailCol=isPaper()?`hsla(${hue},50%,25%,0.7)`:`hsla(${hue},85%,65%,0.8)`;
    trailCanvas.width=W||400;trailCanvas.height=H||400;
    tctx.fillStyle=bgClr();tctx.fillRect(0,0,trailCanvas.width,trailCanvas.height);
  }
  reset();

  // Compute positions from pivot
  function getPositions(){
    const ox=W/2,oy=H*0.22;
    const pts=[{x:ox,y:oy}];
    for(let i=0;i<numJoints;i++){
      pts.push({x:pts[i].x+Math.sin(angles[i])*lengths[i]*zoom,
                y:pts[i].y+Math.cos(angles[i])*lengths[i]*zoom});
    }
    return pts;
  }

  // N-pendulum physics via Lagrangian (recursive approach, simplified as
  // iterative RK4 per segment treating prior as fixed — visually convincing)
  const G=9.81,DT=0.03;
  function stepChain(){
    // Use the standard 2-body formula iteratively applied per adjacent pair
    for(let iter=0;iter<4;iter++){
      for(let i=0;i<numJoints;i++){
        // effective pivot mass = sum of all masses below
        const mBelow=masses.slice(i).reduce((s,m)=>s+m,0);
        const mAbove=i>0?masses.slice(0,i).reduce((s,m)=>s+m,0):1e6;
        const l=lengths[i];
        // coupling with previous segment
        let acc=-G/l*Math.sin(angles[i]);
        if(i>0){
          const d=angles[i-1]-angles[i];
          acc+=vels[i-1]*vels[i-1]*lengths[i-1]/l*Math.sin(d)*mAbove/(mBelow+mAbove);
        }
        // coupling with next segment
        if(i<numJoints-1){
          const d=angles[i]-angles[i+1];
          acc-=vels[i+1]*vels[i+1]*lengths[i+1]/l*Math.sin(d)*masses[i+1]/(mBelow);
        }
        vels[i]+=acc*DT;
        vels[i]*=0.9998;
      }
      for(let i=0;i<numJoints;i++)angles[i]+=vels[i]*DT;
    }
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    if(trailCanvas.width!==W||trailCanvas.height!==H){
      trailCanvas.width=W;trailCanvas.height=H;
      tctx.fillStyle=bgClr();tctx.fillRect(0,0,W,H);
    }
    if(!paused){
      stepChain();
      const pts=getPositions();
      const tip=pts[pts.length-1];
      tctx.fillStyle=isPaper()?`rgba(245,241,232,${trailFade})`:`rgba(10,10,9,${trailFade})`;
      tctx.fillRect(0,0,W,H);
      if(showTrails&&trail.length>0){
        tctx.strokeStyle=trailCol;tctx.lineWidth=1.2;
        tctx.beginPath();tctx.moveTo(trail[trail.length-1][0],trail[trail.length-1][1]);
        tctx.lineTo(tip.x,tip.y);tctx.stroke();
      }
      trail.push([tip.x,tip.y]);if(trail.length>800)trail.shift();
    }
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    if(showTrails)ctx.drawImage(trailCanvas,0,0);
    const pts=getPositions();
    // rods
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.4)';ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++)ctx.lineTo(pts[i].x,pts[i].y);
    ctx.stroke();
    // joints/bobs
    for(let i=0;i<pts.length;i++){
      const r=i===0?5:(i===pts.length-1?10:7);
      const hue=i/numJoints*280+160;
      ctx.beginPath();ctx.arc(pts[i].x,pts[i].y,r,0,Math.PI*2);
      ctx.fillStyle=i===0?(isPaper()?'#555':'#888'):(isPaper()?`hsl(${hue},50%,30%)`:`hsl(${hue},85%,65%)`);
      ctx.fill();
    }
  }

  // Scroll to zoom
  c.addEventListener('wheel',e=>{
    e.preventDefault();
    zoom*=e.deltaY<0?1.12:0.89;
    zoom=Math.max(0.2,Math.min(5,zoom));
  },{passive:false});

  const trailBtn=mkBtn('Trails: On',ctrl,true);
  trailBtn.addEventListener('click',()=>{showTrails=!showTrails;trailBtn.textContent=`Trails: ${showTrails?'On':'Off'}`;setLit(trailBtn,showTrails);});
  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';setLit(pauseBtn,paused);});
  mkBtn('Reset',ctrl).addEventListener('click',reset);

  const pLbl=document.createElement('span');pLbl.className='sb-info sb-speed-lbl';pLbl.style.marginLeft='4px';pLbl.textContent='joints';ctrl.appendChild(pLbl);
  const psl=document.createElement('input');psl.type='range';psl.className='sb-slider';psl.min=1;psl.max=12;psl.step=1;psl.value=numJoints;ctrl.appendChild(psl);styleSlider(psl);
  psl.addEventListener('input',()=>{numJoints=+psl.value;reset();});

  const fadeLbl=document.createElement('span');fadeLbl.className='sb-info sb-speed-lbl';fadeLbl.style.marginLeft='4px';fadeLbl.textContent='fade';ctrl.appendChild(fadeLbl);
  const fsl=document.createElement('input');fsl.type='range';fsl.className='sb-slider';fsl.min=0.001;fsl.max=0.15;fsl.step=0.001;fsl.value=trailFade;ctrl.appendChild(fsl);styleSlider(fsl);
  fsl.addEventListener('input',()=>trailFade=+fsl.value);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 23 — SOFT BODY  (jelly blob you can poke)
// ════════════════════════════════════════════════════════════════════════════
function initSoftBody(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let blobs=[],mouse={x:-999,y:-999,down:false};

  function mkBlob(cx,cy,r,col){
    const N=20,pts=[];
    for(let i=0;i<N;i++){
      const a=i/N*Math.PI*2;
      pts.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,vx:0,vy:0,ox:cx+Math.cos(a)*r,oy:cy+Math.sin(a)*r});
    }
    return{pts,cx,cy,r,col,N};
  }
  function reset(){
    blobs=[
      mkBlob(W*0.38,H*0.5,Math.min(W,H)*0.18,isPaper()?'rgba(80,120,180,0.55)':'rgba(80,160,255,0.55)'),
      mkBlob(W*0.65,H*0.45,Math.min(W,H)*0.13,isPaper()?'rgba(160,80,80,0.55)':'rgba(255,100,100,0.55)'),
    ];
  }
  reset();

  const STIFF=0.08,DAMP=0.88,PRESSURE=0.9,GRAV=0.12;
  function stepBlob(b){
    const{pts,N}=b;
    // compute centroid
    let cx=0,cy=0;for(const p of pts){cx+=p.x;cy+=p.y;}cx/=N;cy/=N;
    b.cx=cx;b.cy=cy;
    // compute area (shoelace)
    let area=0;
    for(let i=0;i<N;i++){const j=(i+1)%N;area+=pts[i].x*pts[j].y-pts[j].x*pts[i].y;}
    area=Math.abs(area)/2;
    const targetArea=Math.PI*b.r*b.r;
    const pressureForce=(targetArea-area)/targetArea*PRESSURE;
    for(let i=0;i<N;i++){
      const p=pts[i];
      const prev=pts[(i-1+N)%N],next=pts[(i+1)%N];
      // spring to neighbours
      const fsx=(prev.x+next.x)/2-p.x,fsy=(prev.y+next.y)/2-p.y;
      // spring to rest position (relative to centroid)
      const restX=cx+(p.ox-b.cx)*1,restY=cy+(p.oy-b.cy)*1;
      // pressure (push outward from centroid)
      const nx=p.x-cx,ny=p.y-cy,nd=Math.sqrt(nx*nx+ny*ny)||1;
      p.vx+=(fsx*STIFF+(restX-p.x)*0.04+nx/nd*pressureForce*2)*1;
      p.vy+=(fsy*STIFF+(restY-p.y)*0.04+ny/nd*pressureForce*2+GRAV)*1;
      // mouse repulsion
      const mdx=p.x-mouse.x,mdy=p.y-mouse.y,md=Math.sqrt(mdx*mdx+mdy*mdy)||1;
      const mForce=mouse.down?60:30;
      if(md<60){p.vx+=mdx/md*(60-md)/60*mForce*0.04;p.vy+=mdy/md*(60-md)/60*mForce*0.04;}
      p.vx*=DAMP;p.vy*=DAMP;
      p.x+=p.vx;p.y+=p.vy;
      // floor/wall bounce
      if(p.y>H-4){p.y=H-4;p.vy*=-0.4;}
      if(p.x<4){p.x=4;p.vx*=-0.4;}if(p.x>W-4){p.x=W-4;p.vx*=-0.4;}
      if(p.y<4){p.y=4;p.vy*=-0.4;}
    }
  }

  function drawBlob(b){
    const{pts,col}=b;
    ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++)ctx.lineTo(pts[i].x,pts[i].y);
    ctx.closePath();
    ctx.fillStyle=col;ctx.fill();
    ctx.strokeStyle=col.replace(/[\d.]+\)$/,'0.8)');ctx.lineWidth=2;ctx.stroke();
    // sheen
    const grd=ctx.createRadialGradient(b.cx-b.r*0.3,b.cy-b.r*0.3,0,b.cx,b.cy,b.r*1.1);
    grd.addColorStop(0,'rgba(255,255,255,0.18)');grd.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle=grd;ctx.fill();
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    for(const b of blobs)stepBlob(b);
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    // floor line
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.06)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(0,H-4);ctx.lineTo(W,H-4);ctx.stroke();
    for(const b of blobs)drawBlob(b);
    // cursor indicator
    if(mouse.x>0){
      ctx.beginPath();ctx.arc(mouse.x,mouse.y,mouse.down?22:14,0,Math.PI*2);
      ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.15)';ctx.lineWidth=1;ctx.stroke();
    }
  }

  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
  c.addEventListener('mousedown',()=>mouse.down=true);
  c.addEventListener('mouseup',()=>mouse.down=false);
  c.addEventListener('mouseleave',()=>{mouse.x=-999;mouse.y=-999;mouse.down=false;});
  mkBtn('Reset',ctrl).addEventListener('click',reset);
  const cntLbl=document.createElement('span');cntLbl.className='sb-info sb-speed-lbl';cntLbl.style.marginLeft='4px';cntLbl.textContent='blobs';ctrl.appendChild(cntLbl);
  const bsl=document.createElement('input');bsl.type='range';bsl.className='sb-slider';bsl.min=1;bsl.max=6;bsl.step=1;bsl.value=blobs.length;ctrl.appendChild(bsl);styleSlider(bsl);
  bsl.addEventListener('input',()=>{
    const n=+bsl.value;
    while(blobs.length<n)blobs.push(mkBlob(rndf(W*0.2,W*0.8),rndf(H*0.2,H*0.7),Math.min(W,H)*(0.08+Math.random()*0.12),`hsla(${Math.random()*360},70%,${isPaper()?'45':'65'}%,0.55)`));
    while(blobs.length>n)blobs.pop();
  });
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 24 — SPACE INVADERS
// ════════════════════════════════════════════════════════════════════════════
function initSpaceInvaders(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let player,invaders,bullets,bombs,barriers,score,lives,gameOver,started,wave,tick,invDir,invSpeed,dropFlag;

  const ROWS=4,COLS=10,INV_W=28,INV_H=20;

  function makeBarriers(){
    const bs=[];
    for(let i=0;i<4;i++){
      const bx=W*0.12+i*(W*0.76/3.5);
      const by=H-100;
      const blocks=[];
      for(let r=0;r<4;r++)for(let cc=0;cc<6;cc++){
        if((r===0&&(cc===0||cc===5))||(r===3&&(cc===2||cc===3)))continue;
        blocks.push({x:bx+cc*8,y:by+r*8,hp:3});
      }
      bs.push(blocks);
    }
    return bs;
  }

  function init(){
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    player={x:W/2,y:H-36,w:36,h:16,vx:0};
    invaders=[];
    const startX=W/2-COLS*INV_W*0.6;
    const startY=60;
    for(let r=0;r<ROWS;r++)for(let cc=0;cc<COLS;cc++){
      invaders.push({x:startX+cc*INV_W*1.2,y:startY+r*INV_H*1.5,r,cc,alive:true,frame:0});
    }
    bullets=[];bombs=[];score=0;lives=3;gameOver=false;started=false;wave=1;tick=0;
    invDir=1;invSpeed=1.2;dropFlag=false;
    barriers=makeBarriers();
  }
  init();

  function step(){
    tick++;
    if(!started||gameOver)return;
    // move player
    player.x=Math.max(player.w/2,Math.min(W-player.w/2,player.x+player.vx*3.5));
    // invader movement
    const alive=invaders.filter(i=>i.alive);
    if(!alive.length){wave++;invSpeed=Math.min(4,1.2+wave*0.4);init();started=true;return;}
    if(tick%2===0){
      let hitEdge=false;
      for(const inv of alive){
        inv.x+=invDir*invSpeed;
        if(inv.x<INV_W||inv.x>W-INV_W)hitEdge=true;
        if(tick%20===0)inv.frame^=1;
      }
      if(hitEdge){invDir*=-1;for(const inv of alive)inv.y+=14;}
    }
    // invader bombs
    if(tick%Math.max(20,60-wave*8)===0&&alive.length){
      const shooter=alive[Math.floor(Math.random()*alive.length)];
      bombs.push({x:shooter.x,y:shooter.y,vy:3+wave*0.5});
    }
    // move bullets
    for(const b of bullets)b.y-=10;
    for(const b of bombs)b.y+=b.vy;
    // bullet hits invader
    for(const b of bullets){
      for(const inv of invaders){
        if(!inv.alive)continue;
        if(Math.abs(b.x-inv.x)<INV_W*0.5&&Math.abs(b.y-inv.y)<INV_H*0.6){
          inv.alive=false;b.dead=true;score+=10*(ROWS-inv.r);
          scoreEl.textContent=`score ${score}`;
        }
      }
      // bullet hits barrier
      for(const bar of barriers)for(const bl of bar){
        if(bl.hp>0&&b.x>bl.x&&b.x<bl.x+8&&b.y>bl.y&&b.y<bl.y+8){b.dead=true;bl.hp--;}
      }
    }
    // bomb hits player
    for(const b of bombs){
      if(Math.abs(b.x-player.x)<player.w/2&&Math.abs(b.y-player.y)<player.h){
        b.dead=true;lives--;
        if(lives<=0)gameOver=true;
      }
      // bomb hits barrier
      for(const bar of barriers)for(const bl of bar){
        if(bl.hp>0&&b.x>bl.x&&b.x<bl.x+8&&b.y>bl.y&&b.y<bl.y+8){b.dead=true;bl.hp--;}
      }
    }
    // invader reaches player line
    for(const inv of invaders)if(inv.alive&&inv.y>H-60){gameOver=true;}
    // cleanup
    bullets=bullets.filter(b=>!b.dead&&b.y>0);
    bombs=bombs.filter(b=>!b.dead&&b.y<H);
  }

  function drawInv(inv){
    const paper=isPaper();
    const cols=['#ff4444','#ff8800','#ffcc00','#44ff88'];
    ctx.fillStyle=paper?`hsl(${inv.r*60},60%,35%)`:(cols[inv.r]||'#aaa');
    const x=inv.x,y=inv.y;
    // body
    ctx.fillRect(x-10,y-7,20,14);
    // legs
    if(inv.frame===0){ctx.fillRect(x-13,y+5,5,5);ctx.fillRect(x+8,y+5,5,5);}
    else{ctx.fillRect(x-11,y+7,5,5);ctx.fillRect(x+6,y+7,5,5);}
    // antennae
    ctx.fillRect(x-8,y-12,3,6);ctx.fillRect(x+5,y-12,3,6);
    // eyes
    ctx.fillStyle=paper?'#f0e8d0':'#000';
    ctx.fillRect(x-6,y-3,4,4);ctx.fillRect(x+2,y-3,4,4);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    step();
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=paper?'#e8f0f8':'#020810';ctx.fillRect(0,0,W,H);
    // stars
    if(!paper){ctx.fillStyle='rgba(255,255,255,0.5)';for(let i=0;i<40;i++){const sx=(i*73+tick*0.02)%W,sy=(i*41)%H;ctx.fillRect(sx,sy,1,1);}}

    // barriers
    for(const bar of barriers)for(const bl of bar){
      if(bl.hp<=0)continue;
      const a=[1,0.6,0.3][bl.hp-1]||0.2;
      ctx.fillStyle=paper?`rgba(40,120,40,${a})`:`rgba(80,220,80,${a})`;
      ctx.fillRect(bl.x,bl.y,7,7);
    }

    // invaders
    for(const inv of invaders){if(!inv.alive)continue;drawInv(inv);}

    // player ship
    ctx.fillStyle=paper?'#336699':'#44aaff';
    ctx.beginPath();ctx.moveTo(player.x,player.y-player.h);ctx.lineTo(player.x+player.w/2,player.y+2);ctx.lineTo(player.x-player.w/2,player.y+2);ctx.closePath();ctx.fill();
    // gun tip
    ctx.fillRect(player.x-2,player.y-player.h-6,4,8);

    // bullets
    ctx.fillStyle=paper?'#336699':'#88ddff';
    for(const b of bullets)ctx.fillRect(b.x-1.5,b.y-8,3,12);
    // bombs
    ctx.fillStyle=paper?'#cc4422':'#ff6633';
    for(const b of bombs){ctx.fillRect(b.x-2,b.y-6,4,10);}

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`lives: ${'♥ '.repeat(lives).trim()}  wave: ${wave}`,8,6);

    if(!started&&!gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.55)';
      ctx.font=`300 13px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('← → to move · space to shoot · click to start',W/2,H/2);
    }
    if(gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.65)':'rgba(0,0,0,0.65)';ctx.fillRect(0,H/2-36,W,72);
      ctx.fillStyle=paper?'#fff':'#fff';ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-12);
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillStyle='rgba(255,255,255,0.6)';
      ctx.fillText(`score ${score} — click to restart`,W/2,H/2+12);
    }
  }

  // controls
  const keys={};
  const onKey=e=>{
    if(e.type==='keydown'){
      keys[e.code]=true;
      if(e.code==='Space'){e.preventDefault();
        if(!started&&!gameOver)started=true;
        else if(gameOver)init();
        else if(bullets.length<4)bullets.push({x:player.x,y:player.y-player.h});
      }
      if(e.code==='ArrowLeft'||e.code==='KeyA')player.vx=-1;
      if(e.code==='ArrowRight'||e.code==='KeyD')player.vx=1;
    } else {
      delete keys[e.code];
      if((e.code==='ArrowLeft'||e.code==='KeyA')&&!keys['ArrowLeft']&&!keys['KeyA'])player.vx=0;
      if((e.code==='ArrowRight'||e.code==='KeyD')&&!keys['ArrowRight']&&!keys['KeyD'])player.vx=0;
    }
  };
  document.addEventListener('keydown',onKey);document.addEventListener('keyup',onKey);
  c.addEventListener('click',()=>{
    if(!started&&!gameOver){started=true;return;}
    if(gameOver){init();return;}
    if(bullets.length<4)bullets.push({x:player.x,y:player.y-player.h});
  });
  const scoreEl=mkInfo(ctrl);
  mkBtn('New Game',ctrl).addEventListener('click',()=>{init();started=true;});
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}


// TOY 27 — WHACK-A-MOLE
// ════════════════════════════════════════════════════════════════════════════
function initWhackMole(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let moles,score,misses,gameOver,timeLeft,tick,difficulty2;
  const GRID=3,MOLE_R=36,GAME_TIME=30;

  function holePos(i){
    const col=i%GRID,row=Math.floor(i/GRID);
    return{x:W*(0.18+col*0.32),y:H*(0.22+row*0.35)};
  }

  function init(){
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    moles=Array.from({length:9},(_,i)=>({...holePos(i),state:'down',t:0,dur:0,nextAt:rndf(500,2000)}));
    score=0;misses=0;gameOver=false;timeLeft=GAME_TIME;tick=0;difficulty2=1;
  }
  init();

  let lastTime=0;
  function step(ts){
    const dt=(ts-lastTime)/1000;lastTime=ts;
    if(gameOver)return;
    tick++;
    timeLeft-=dt;if(timeLeft<=0){timeLeft=0;gameOver=true;return;}
    const speed=1+score*0.01;
    for(const m of moles){
      m.t+=dt*1000;
      if(m.state==='down'&&m.t>m.nextAt){
        m.state='rising';m.t=0;m.dur=Math.max(400,1200-score*8)/speed;
      } else if(m.state==='rising'&&m.t>150){
        m.state='up';m.t=0;m.dur=Math.max(400,1000-score*10)/speed;
      } else if(m.state==='up'&&m.t>m.dur){
        m.state='falling';m.t=0;
      } else if(m.state==='falling'&&m.t>150){
        m.state='down';m.t=0;m.nextAt=rndf(200,1500)/speed;misses++;
      } else if(m.state==='whacked'&&m.t>350){
        m.state='falling';m.t=0;
      }
    }
  }

  function draw(ts){
    raf=requestAnimationFrame(draw);
    step(ts);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    // bg — grassy
    ctx.fillStyle=paper?'#c8e0a0':'#1a3a0a';ctx.fillRect(0,0,W,H);
    // dirt patches
    for(const m of moles){
      const grd=ctx.createRadialGradient(m.x,m.y+10,5,m.x,m.y+10,MOLE_R*1.3);
      grd.addColorStop(0,paper?'#8a6030':'#3a2010');grd.addColorStop(1,'transparent');
      ctx.beginPath();ctx.ellipse(m.x,m.y+14,MOLE_R*1.2,MOLE_R*0.6,0,0,Math.PI*2);ctx.fillStyle=grd;ctx.fill();
    }

    // holes + moles
    for(const m of moles){
      const y=m.y;
      // hole
      ctx.beginPath();ctx.ellipse(m.x,y+18,MOLE_R*0.88,MOLE_R*0.38,0,0,Math.PI*2);
      ctx.fillStyle=paper?'#4a2a08':'#1a0a00';ctx.fill();

      // mole offset by state
      let oy=MOLE_R*2;
      if(m.state==='rising')oy=MOLE_R*2*(1-m.t/150);
      else if(m.state==='up')oy=0;
      else if(m.state==='falling')oy=MOLE_R*2*(m.t/150);
      else if(m.state==='whacked'){oy=-MOLE_R*0.4*(1-m.t/350);ctx.save();ctx.translate(m.x,y-oy);ctx.rotate(rndf(-0.3,0.3));ctx.translate(-m.x,-(y-oy));}

      ctx.save();
      ctx.beginPath();ctx.ellipse(m.x,y+20,MOLE_R*1.1,MOLE_R*0.45,0,0,Math.PI*2);ctx.clip();
      // mole body
      const mx=m.x,my=y-oy;
      ctx.fillStyle=paper?'#7a4a18':'#5a3010';
      ctx.beginPath();ctx.ellipse(mx,my,MOLE_R*0.72,MOLE_R*0.9,0,0,Math.PI*2);ctx.fill();
      // face
      ctx.fillStyle=paper?'#c89060':'#aa7040';
      ctx.beginPath();ctx.ellipse(mx,my-4,MOLE_R*0.44,MOLE_R*0.5,0,0,Math.PI*2);ctx.fill();
      // eyes
      if(m.state==='whacked'){
        ctx.strokeStyle='#222';ctx.lineWidth=2;
        ctx.beginPath();ctx.moveTo(mx-9,my-14);ctx.lineTo(mx-5,my-10);ctx.moveTo(mx-5,my-14);ctx.lineTo(mx-9,my-10);ctx.stroke();
        ctx.beginPath();ctx.moveTo(mx+5,my-14);ctx.lineTo(mx+9,my-10);ctx.moveTo(mx+9,my-14);ctx.lineTo(mx+5,my-10);ctx.stroke();
      } else {
        ctx.fillStyle='#111';ctx.beginPath();ctx.arc(mx-7,my-12,3.5,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(mx+7,my-12,3.5,0,Math.PI*2);ctx.fill();
        ctx.fillStyle='rgba(255,255,255,0.6)';ctx.beginPath();ctx.arc(mx-6,my-13,1.5,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(mx+8,my-13,1.5,0,Math.PI*2);ctx.fill();
      }
      // nose
      ctx.fillStyle='#cc5577';ctx.beginPath();ctx.ellipse(mx,my-5,5,3.5,0,0,Math.PI*2);ctx.fill();
      ctx.restore();
      if(m.state==='whacked')ctx.restore();
      // score pop
      if(m.state==='whacked'&&m.t<200){
        ctx.fillStyle=paper?'#222':'#fff';ctx.font=`bold ${14}px 'IBM Plex Mono',monospace`;ctx.textAlign='center';
        ctx.fillText('+10',m.x,y-MOLE_R-m.t*0.1);
      }
    }

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.6)';
    ctx.font=`300 12px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='top';
    const barW=Math.max(0,W*0.6*(timeLeft/GAME_TIME));
    ctx.fillStyle=paper?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.1)';
    ctx.fillRect(W*0.2,6,W*0.6,8);
    ctx.fillStyle=timeLeft<8?(paper?'#aa3322':'#ff4433'):(paper?'#3a7a3a':'#44cc44');
    ctx.fillRect(W*0.2,6,barW,8);
    ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText(`score: ${score}  time: ${Math.ceil(timeLeft)}s`,W/2,18);

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.65)';ctx.fillRect(0,H/2-40,W,80);
      ctx.fillStyle='#fff';ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('TIME\'S UP!',W/2,H/2-14);
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;ctx.fillStyle='rgba(255,255,255,0.65)';
      ctx.fillText(`final score: ${score} — click to play again`,W/2,H/2+12);
    }
  }

  c.addEventListener('click',e=>{
    if(gameOver){init();return;}
    const rect=c.getBoundingClientRect();
    const mx=e.clientX-rect.left,my2=e.clientY-rect.top;
    for(const m of moles){
      if(m.state==='up'&&Math.hypot(mx-m.x,my2-m.y)<MOLE_R*1.1){
        m.state='whacked';m.t=0;score+=10;scoreEl.textContent=`score ${score}`;break;
      }
    }
  });
  const scoreEl=mkInfo(ctrl);
  mkBtn('New Game',ctrl).addEventListener('click',init);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

