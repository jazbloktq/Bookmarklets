// TOY 32 — ETCH-A-SKETCH
// ════════════════════════════════════════════════════════════════════════════
function initEtchSketch(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let posX=0.5, posY=0.5; // normalised 0-1
  let lines=[{pts:[[0.5,0.5]]}]; // array of polylines
  let curLine=lines[0];
  let keys={};
  let speed=0.003;
  let shaking=false, shakeT=0;
  let penColor='auto'; // 'auto' or fixed
  let hue=0;

  function getColor(){
    const paper=isPaper();
    if(paper) return `hsl(${hue},60%,28%)`;
    return `hsl(${hue},90%,65%)`;
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    posX=0.5; posY=0.5;
    lines=[{pts:[[0.5,0.5]],col:getColor()}];
    curLine=lines[0];
    shaking=false;shakeT=0;hue=0;
  }
  init();

  function shake(){
    shaking=true; shakeT=0;
    setTimeout(()=>{
      shaking=false;
      lines=[{pts:[[posX,posY]],col:getColor()}];
      curLine=lines[0];
    },600);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;

    const paper=isPaper();
    const MARGIN=24;

    // Body of etch-a-sketch
    ctx.fillStyle=paper?'#c8241a':'#b01a12';
    roundRect(ctx,0,0,W,H,paper?12:2);ctx.fill();

    // Screen
    const sx=MARGIN,sy=MARGIN+20,sw=W-MARGIN*2,sh=H-MARGIN*2-60;
    ctx.fillStyle=paper?'#d4c89a':'#1a1e14';
    ctx.beginPath();roundRect(ctx,sx,sy,sw,sh,4);ctx.fill();

    // Shake animation
    if(shaking){
      shakeT+=0.18;
      const amp=6*Math.max(0,1-shakeT/Math.PI);
      ctx.save();
      ctx.translate(Math.sin(shakeT*7)*amp, Math.cos(shakeT*5)*amp*0.5);
    }

    // Draw lines
    ctx.save();
    ctx.beginPath();roundRect(ctx,sx+2,sy+2,sw-4,sh-4,3);ctx.clip();
    for(const line of lines){
      if(line.pts.length<2)continue;
      ctx.strokeStyle=line.col||getColor();
      ctx.lineWidth=1.5;ctx.lineCap='round';ctx.lineJoin='round';
      ctx.beginPath();
      ctx.moveTo(sx+line.pts[0][0]*sw,sy+line.pts[0][1]*sh);
      for(let i=1;i<line.pts.length;i++)
        ctx.lineTo(sx+line.pts[i][0]*sw,sy+line.pts[i][1]*sh);
      ctx.stroke();
    }
    // cursor dot
    if(!shaking){
      ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.6)';
      ctx.beginPath();ctx.arc(sx+posX*sw,sy+posY*sh,2.5,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();

    if(shaking)ctx.restore();

    // Knob labels
    ctx.fillStyle=paper?'rgba(255,255,255,0.55)':'rgba(255,255,255,0.35)';
    ctx.font=`300 8px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
    const kbY=H-MARGIN*0.8;
    ctx.fillText('◁ ▷',MARGIN+18,kbY);
    ctx.fillText('△ ▽',W-MARGIN-18,kbY);

    // Draw knobs
    const kR=13;
    ctx.fillStyle=paper?'#e8dfc8':'#2a2e24';
    ctx.strokeStyle=paper?'rgba(0,0,0,0.25)':'rgba(255,255,255,0.18)';
    ctx.lineWidth=2;
    [MARGIN+18, W-MARGIN-18].forEach(kx=>{
      ctx.beginPath();ctx.arc(kx,kbY-1,kR,0,Math.PI*2);ctx.fill();ctx.stroke();
    });

    // Move cursor based on held keys
    if(!shaking){
      let moved=false;
      const step=speed*Math.min(W,H);
      if(keys['ArrowLeft']){posX=Math.max(0,posX-step/sw);moved=true;}
      if(keys['ArrowRight']){posX=Math.min(1,posX+step/sw);moved=true;}
      if(keys['ArrowUp']){posY=Math.max(0,posY-step/sh);moved=true;}
      if(keys['ArrowDown']){posY=Math.min(1,posY+step/sh);moved=true;}
      if(moved){
        hue=(hue+0.4)%360;
        // Only push if moved far enough to avoid duplicate pts
        const last=curLine.pts[curLine.pts.length-1];
        if(!last||Math.hypot(posX-last[0],posY-last[1])>0.001){
          curLine.pts.push([posX,posY]);
          curLine.col=getColor();
        }
      }
    }
  }

  const onKey=e=>{
    if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key)){
      e.preventDefault();
      keys[e.key]=e.type==='keydown';
    }
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.textContent='speed';ctrl.appendChild(spdLbl);
  const spdSl=document.createElement('input');spdSl.type='range';spdSl.className='sb-slider';spdSl.min=1;spdSl.max=10;spdSl.value=5;spdSl.step=1;ctrl.appendChild(spdSl);styleSlider(spdSl);
  spdSl.addEventListener('input',()=>speed=+spdSl.value*0.0006);

  mkBtn('🫨 Shake',ctrl).addEventListener('click',shake);
  mkBtn('Reset',ctrl).addEventListener('click',init);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

