    if(!valid.has(currentGuess.toLowerCase())&&!getWordList().includes(currentGuess.toLowerCase())){
      flash('Not a valid word'); shakeRow=guesses.length; setTimeout(()=>shakeRow=-1,500); return;
    }
    const score=scoreGuess(currentGuess);
    guesses.push({word:currentGuess,score});
    const isWin=score.every(s=>s===2);
    if(isWin){
      won=true; gameOver=true;
      flash('Brilliant! 🎉');
    } else if(guesses.length>=maxGuesses()){
      gameOver=true;
      flash(answer, 3500);
    }
    currentGuess='';
  }

