// TOY 12 — ASTEROIDS
// ════════════════════════════════════════════════════════════════════════════
function initAsteroids(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height;
  let ship,bullets,asteroids,score,lives,raf,gameOver,level,invincible,keys={};
  function mkShip(){return{x:W/2,y:H/2,vx:0,vy:0,angle:-Math.PI/2,thrust:false,dead:false};}
  function mkAsteroid(x,y,r){const angle=Math.random()*Math.PI*2,spd=rndf(0.6,1.8)*(1+level*0.12);return{x,y,vx:Math.cos(angle)*spd,vy:Math.sin(angle)*spd,r,angle:0,spin:rndf(-0.03,0.03),verts:Array.from({length:10},(_,i)=>{const a=i/10*Math.PI*2;return{x:Math.cos(a)*(r+rndf(-r*0.25,r*0.25)),y:Math.sin(a)*(r+rndf(-r*0.25,r*0.25))};})}}
  function spawnAsteroids(){
    asteroids=[];
    for(let i=0;i<4+level*1;i++){
      let x,y;do{x=Math.random()*W;y=Math.random()*H;}while(Math.abs(x-ship.x)<120&&Math.abs(y-ship.y)<120);
      asteroids.push(mkAsteroid(x,y,rndf(28,46)));
    }
  }
  function init(){ship=mkShip();bullets=[];score=0;lives=3;level=0;gameOver=false;invincible=0;spawnAsteroids();}
  init();
  let raf2;
  function step(ts){
    raf2=requestAnimationFrame(step);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    if(!gameOver){
      if(invincible>0)invincible--;
      if(keys['ArrowLeft']||keys['a'])ship.angle-=0.065;
      if(keys['ArrowRight']||keys['d'])ship.angle+=0.065;
      ship.thrust=keys['ArrowUp']||keys['w'];
      if(ship.thrust){ship.vx+=Math.cos(ship.angle)*0.18;ship.vy+=Math.sin(ship.angle)*0.18;}
      ship.vx*=0.98;ship.vy*=0.98;
      ship.x=(ship.x+ship.vx+W)%W;ship.y=(ship.y+ship.vy+H)%H;
      for(const b of bullets){b.x+=b.vx;b.y+=b.vy;b.life--;}
      bullets=bullets.filter(b=>b.life>0&&b.x>0&&b.x<W&&b.y>0&&b.y<H);
      for(const a of asteroids){a.x=(a.x+a.vx+W)%W;a.y=(a.y+a.vy+H)%H;a.angle+=a.spin;}
      // bullet-asteroid collision
      const nextAsteroids=[];
      for(const a of asteroids){
        let hit=false;
        bullets=bullets.filter(b=>{const dx=b.x-a.x,dy=b.y-a.y;if(Math.sqrt(dx*dx+dy*dy)<a.r){hit=true;return false;}return true;});
        if(hit){score+=a.r>30?20:a.r>16?50:100;if(a.r>16){for(let i=0;i<2;i++)nextAsteroids.push(mkAsteroid(a.x,a.y,a.r*0.5));}}
        else nextAsteroids.push(a);
      }
      asteroids=nextAsteroids;
      if(asteroids.length===0){level++;spawnAsteroids();}
      // ship-asteroid collision
      if(invincible===0){for(const a of asteroids){const dx=ship.x-a.x,dy=ship.y-a.y;if(Math.sqrt(dx*dx+dy*dy)<a.r+8){lives--;invincible=150;ship.vx=0;ship.vy=0;if(lives<=0){gameOver=true;}break;}}}
      scoreEl.textContent=`score ${score}  lives ${lives}`;
    }
    // draw asteroids
    const fg=fgClr();
    for(const a of asteroids){
      ctx.save();ctx.translate(a.x,a.y);ctx.rotate(a.angle);
      ctx.beginPath();ctx.moveTo(a.verts[0].x,a.verts[0].y);
      for(const v of a.verts)ctx.lineTo(v.x,v.y);ctx.closePath();
      ctx.strokeStyle=paper?'rgba(60,40,20,0.7)':'rgba(180,190,210,0.75)';ctx.lineWidth=1.5;ctx.stroke();
      ctx.restore();
    }
    // draw ship
    if(!gameOver&&!(invincible>0&&Math.floor(invincible/5)%2===0)){
      ctx.save();ctx.translate(ship.x,ship.y);ctx.rotate(ship.angle);
      ctx.beginPath();ctx.moveTo(16,0);ctx.lineTo(-10,9);ctx.lineTo(-6,0);ctx.lineTo(-10,-9);ctx.closePath();
      ctx.strokeStyle=paper?'rgba(40,30,15,0.9)':'rgba(220,230,255,0.9)';ctx.lineWidth=1.5;ctx.stroke();
      if(ship.thrust){ctx.beginPath();ctx.moveTo(-6,0);ctx.lineTo(-16,rndf(-4,4));ctx.strokeStyle=paper?'#c0392b':'#f39c12';ctx.lineWidth=2;ctx.stroke();}
      ctx.restore();
    }
    // draw bullets
    ctx.fillStyle=paper?'rgba(180,80,20,0.9)':'rgba(255,220,100,0.9)';
    for(const b of bullets){ctx.beginPath();ctx.arc(b.x,b.y,2.5,0,Math.PI*2);ctx.fill();}
    // hud
    const hfg=paper?'rgba(30,20,10,0.6)':'rgba(255,255,255,0.45)';
    ctx.fillStyle=hfg;ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`level ${level+1}`,12,12);
    if(gameOver){ctx.fillStyle=paper?'rgba(30,20,10,0.88)':'rgba(255,255,255,0.88)';ctx.font=`400 18px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('GAME OVER',W/2,H/2-14);ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText(`final score ${score}`,W/2,H/2+10);ctx.fillText('press R to restart',W/2,H/2+30);}
  }
  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',init);
  const onKey=e=>{
    keys[e.key]=e.type==='keydown';
    if(e.type==='keydown'){
      if((e.key==='r'||e.key==='R')&&gameOver)init();
      if(e.key===' '||e.key==='x'){
        if(!gameOver&&bullets.length<8){bullets.push({x:ship.x+Math.cos(ship.angle)*18,y:ship.y+Math.sin(ship.angle)*18,vx:Math.cos(ship.angle)*9+ship.vx,vy:Math.sin(ship.angle)*9+ship.vy,life:55});}
        e.preventDefault();
      }
      if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key))e.preventDefault();
    }
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);
  requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf2);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

