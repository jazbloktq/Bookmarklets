// TOY 31 — SPIROGRAPH
// ════════════════════════════════════════════════════════════════════════════
function initSpirograph(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  // Parameters
  let R=120;   // outer (fixed) circle radius
  let r=45;    // inner rolling circle radius
  let d=60;    // pen distance from centre of inner circle
  let speed=2; // degrees per frame
  let hue=0;
  let t=0;     // current angle
  let drawing=true;
  let paths=[]; // array of {pts, col} completed paths
  let curPts=[];
  let curCol='hsl(0,80%,60%)';
  let cycles=0;
  const MAX_CYCLES=8;
  let autoColor=true;

  function lcmVal(a,b){let x=a,y=b;while(y){let tmp=y;y=x%y;x=tmp;}return a*b/x;}
  function fullRevolutions(){
    // hypotrochoid repeats after lcm(R,r)/r full turns of the rolling circle
    const l=lcmVal(Math.round(R),Math.round(r));
    return l/Math.round(r);
  }

  function hypoPoint(theta){
    const rr=R-r;
    const x=(rr)*Math.cos(theta)+ d*Math.cos(rr/r*theta);
    const y=(rr)*Math.sin(theta)- d*Math.sin(rr/r*theta);
    return[x,y];
  }

  function startNewPath(){
    if(curPts.length>2) paths.push({pts:curPts,col:curCol});
    if(paths.length>20) paths.shift();
    curPts=[];t=0;cycles=0;
    hue=(hue+37)%360;
    curCol=`hsl(${hue},80%,${isPaper()?'38%':'62%'})`;
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    paths=[];curPts=[];t=0;cycles=0;hue=0;
    curCol='hsl(0,80%,62%)';
  }
  init();

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();

    ctx.fillStyle=bgFade(0.18);ctx.fillRect(0,0,W,H);

    const cx=W/2,cy=H/2;

    // Draw completed paths
    for(const path of paths){
      if(path.pts.length<2)continue;
      ctx.strokeStyle=path.col;ctx.lineWidth=1.2;ctx.globalAlpha=0.5;
      ctx.beginPath();
      ctx.moveTo(cx+path.pts[0][0],cy+path.pts[0][1]);
      for(let i=1;i<path.pts.length;i++)ctx.lineTo(cx+path.pts[i][0],cy+path.pts[i][1]);
      ctx.stroke();ctx.globalAlpha=1;
    }

    // Draw current path
    if(drawing&&curPts.length>1){
      ctx.strokeStyle=curCol;ctx.lineWidth=1.5;
      ctx.beginPath();
      ctx.moveTo(cx+curPts[0][0],cy+curPts[0][1]);
      for(let i=1;i<curPts.length;i++)ctx.lineTo(cx+curPts[i][0],cy+curPts[i][1]);
      ctx.stroke();
    }

    if(drawing){
      // Advance by speed degrees per frame
      for(let s=0;s<speed;s++){
        const rad=t*(Math.PI/180);
        const pt=hypoPoint(rad);
        curPts.push(pt);
        t+=1;
        // check if we've completed enough revolutions
        const revsDone=t/360;
        const needed=fullRevolutions();
        if(revsDone>=needed){
          startNewPath();
          break;
        }
      }
    }

    // Show the rolling gear machinery subtly
    if(!drawing||(t%360)<60){
      ctx.globalAlpha=0.1;
      ctx.strokeStyle=paper?'#000':'#fff';ctx.lineWidth=1;
      ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);ctx.stroke();
      const thetaRad=t*(Math.PI/180);
      const gx=cx+(R-r)*Math.cos(thetaRad);
      const gy=cy-(R-r)*Math.sin(thetaRad);
      ctx.beginPath();ctx.arc(gx,gy,r,0,Math.PI*2);ctx.stroke();
      // pen arm
      const[px,py]=hypoPoint(thetaRad);
      ctx.beginPath();ctx.moveTo(gx,gy);ctx.lineTo(cx+px,cy+py);ctx.stroke();
      ctx.globalAlpha=1;
    }

    // Labels
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.25)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`R=${Math.round(R)}  r=${Math.round(r)}  d=${Math.round(d)}`,8,6);
  }

  // ── controls ──
  function mkSlider(label, min2, max2, val, step2, onChange){
    const lbl=document.createElement('span');lbl.className='sb-info sb-speed-lbl';lbl.textContent=label;ctrl.appendChild(lbl);
    const sl=document.createElement('input');sl.type='range';sl.className='sb-slider';sl.min=min2;sl.max=max2;sl.value=val;sl.step=step2;ctrl.appendChild(sl);styleSlider(sl);
    sl.addEventListener('input',()=>{onChange(+sl.value);startNewPath();});
    return sl;
  }

  mkSlider('R',40,200,R,1,v=>R=v);
  mkSlider('r',5,Math.round(R)-1,r,1,v=>r=Math.min(v,R-1));
  mkSlider('d',5,200,d,1,v=>d=v);

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.textContent='speed';ctrl.appendChild(spdLbl);
  const spdSl=document.createElement('input');spdSl.type='range';spdSl.className='sb-slider';spdSl.min=1;spdSl.max=10;spdSl.value=speed;spdSl.step=1;ctrl.appendChild(spdSl);styleSlider(spdSl);
  spdSl.addEventListener('input',()=>speed=+spdSl.value);

  mkBtn('New',ctrl).addEventListener('click',startNewPath);
  mkBtn('Clear',ctrl).addEventListener('click',()=>{paths=[];curPts=[];t=0;cycles=0;});

  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{drawing=!drawing;pauseBtn.textContent=drawing?'Pause':'Resume';setLit(pauseBtn,!drawing);});

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

