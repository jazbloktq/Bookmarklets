// ── theme application ─────────────────────────────────────────────────────────
function applyTheme() {
  const v = tv();
  PANEL.style.cssText = `background:${v.panelBg};border-right:1px solid ${v.panelBorder};`;
  const head = document.getElementById('__SB_PANEL_HEAD__');
  head.style.borderBottom = `1px solid ${v.headBorder}`;
  document.getElementById('__SB_TITLE__').style.color = v.title;
  const colBtn = document.getElementById('__SB_COLLAPSE__');
  colBtn.style.color = v.collapse;
  colBtn.onmouseenter = () => colBtn.style.color = v.collapseHov;
  colBtn.onmouseleave = () => colBtn.style.color = v.collapse;
  LIST.querySelectorAll('.sb-item').forEach(item => refreshItem(item));
  LIST.querySelectorAll('.sb-divider').forEach(d => d.style.background = v.divider);
  TAB.style.cssText = `background:${v.tabBg};border:1px solid ${v.tabBorder};border-left:none;color:${v.tabText};`;
  TAB.onmouseenter = () => TAB.style.color = v.tabTextHov;
  TAB.onmouseleave = () => TAB.style.color = v.tabText;
  ROOT.querySelectorAll('.sb-win').forEach(w => styleWin(w));
  if (themeBtnEl) { themeBtnEl.textContent = v.themeBtnLabel; styleBtn(themeBtnEl); }
}

function refreshItem(item) {
  const v = tv();
  const isAct = item.classList.contains('active');
  const isWig = item.classList.contains('wiggle-active');
  item.style.background = isAct ? v.itemActBg : '';
  item.onmouseenter = () => { if (!isAct&&!isWig) item.style.background = v.itemHovBg; };
  item.onmouseleave = () => { item.style.background = isAct ? v.itemActBg : (isWig ? v.itemHovBg : ''); };
  const dot = item.querySelector('.sb-item-dot');
  if (dot) dot.style.background = isAct ? v.itemActDot : (isWig ? v.itemWigDot : v.itemDot);
  const nm = item.querySelector('.sb-item-name');
  if (nm) nm.style.color = (isAct||isWig) ? v.itemTextAct : v.itemText;
  const num = item.querySelector('.sb-item-num');
  if (num) num.style.color = v.itemNum;
}

function styleWin(win) {
  const v = tv();
  const radius = theme==='paper' ? '12px' : '2px';
  win.style.cssText = `left:${win.style.left};top:${win.style.top};width:${win.style.width};height:${win.style.height};background:${v.winBg};border:1px solid ${v.winBorder};box-shadow:${v.winShadow};display:flex;flex-direction:column;position:fixed;pointer-events:all;z-index:2147483644;min-width:320px;min-height:220px;border-radius:${radius};overflow:hidden;`;
