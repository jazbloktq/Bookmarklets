// TOY 24 — SPACE INVADERS
// ════════════════════════════════════════════════════════════════════════════
function initSpaceInvaders(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let player,invaders,bullets,bombs,barriers,score,lives,gameOver,started,wave,tick,invDir,invSpeed,dropFlag;

  const ROWS=4,COLS=10,INV_W=28,INV_H=20;

  function makeBarriers(){
    const bs=[];
    for(let i=0;i<4;i++){
      const bx=W*0.12+i*(W*0.76/3.5);
      const by=H-100;
      const blocks=[];
      for(let r=0;r<4;r++)for(let cc=0;cc<6;cc++){
        if((r===0&&(cc===0||cc===5))||(r===3&&(cc===2||cc===3)))continue;
        blocks.push({x:bx+cc*8,y:by+r*8,hp:3});
      }
      bs.push(blocks);
    }
    return bs;
  }

  function init(){
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    player={x:W/2,y:H-36,w:36,h:16,vx:0};
    invaders=[];
    const startX=W/2-COLS*INV_W*0.6;
    const startY=60;
    for(let r=0;r<ROWS;r++)for(let cc=0;cc<COLS;cc++){
      invaders.push({x:startX+cc*INV_W*1.2,y:startY+r*INV_H*1.5,r,cc,alive:true,frame:0});
    }
    bullets=[];bombs=[];score=0;lives=3;gameOver=false;started=false;wave=1;tick=0;
    invDir=1;invSpeed=1.2;dropFlag=false;
    barriers=makeBarriers();
  }
  init();

  function step(){
    tick++;
    if(!started||gameOver)return;
    // move player
    player.x=Math.max(player.w/2,Math.min(W-player.w/2,player.x+player.vx*3.5));
    // invader movement
    const alive=invaders.filter(i=>i.alive);
    if(!alive.length){wave++;invSpeed=Math.min(4,1.2+wave*0.4);init();started=true;return;}
    if(tick%2===0){
      let hitEdge=false;
      for(const inv of alive){
        inv.x+=invDir*invSpeed;
        if(inv.x<INV_W||inv.x>W-INV_W)hitEdge=true;
        if(tick%20===0)inv.frame^=1;
      }
      if(hitEdge){invDir*=-1;for(const inv of alive)inv.y+=14;}
    }
    // invader bombs
    if(tick%Math.max(20,60-wave*8)===0&&alive.length){
      const shooter=alive[Math.floor(Math.random()*alive.length)];
      bombs.push({x:shooter.x,y:shooter.y,vy:3+wave*0.5});
    }
    // move bullets
    for(const b of bullets)b.y-=10;
    for(const b of bombs)b.y+=b.vy;
    // bullet hits invader
    for(const b of bullets){
      for(const inv of invaders){
        if(!inv.alive)continue;
        if(Math.abs(b.x-inv.x)<INV_W*0.5&&Math.abs(b.y-inv.y)<INV_H*0.6){
          inv.alive=false;b.dead=true;score+=10*(ROWS-inv.r);
          scoreEl.textContent=`score ${score}`;
        }
      }
      // bullet hits barrier
      for(const bar of barriers)for(const bl of bar){
        if(bl.hp>0&&b.x>bl.x&&b.x<bl.x+8&&b.y>bl.y&&b.y<bl.y+8){b.dead=true;bl.hp--;}
      }
    }
    // bomb hits player
    for(const b of bombs){
      if(Math.abs(b.x-player.x)<player.w/2&&Math.abs(b.y-player.y)<player.h){
        b.dead=true;lives--;
        if(lives<=0)gameOver=true;
      }
      // bomb hits barrier
      for(const bar of barriers)for(const bl of bar){
        if(bl.hp>0&&b.x>bl.x&&b.x<bl.x+8&&b.y>bl.y&&b.y<bl.y+8){b.dead=true;bl.hp--;}
      }
    }
    // invader reaches player line
    for(const inv of invaders)if(inv.alive&&inv.y>H-60){gameOver=true;}
    // cleanup
    bullets=bullets.filter(b=>!b.dead&&b.y>0);
    bombs=bombs.filter(b=>!b.dead&&b.y<H);
  }

  function drawInv(inv){
    const paper=isPaper();
    const cols=['#ff4444','#ff8800','#ffcc00','#44ff88'];
    ctx.fillStyle=paper?`hsl(${inv.r*60},60%,35%)`:(cols[inv.r]||'#aaa');
    const x=inv.x,y=inv.y;
    // body
    ctx.fillRect(x-10,y-7,20,14);
    // legs
    if(inv.frame===0){ctx.fillRect(x-13,y+5,5,5);ctx.fillRect(x+8,y+5,5,5);}
    else{ctx.fillRect(x-11,y+7,5,5);ctx.fillRect(x+6,y+7,5,5);}
    // antennae
    ctx.fillRect(x-8,y-12,3,6);ctx.fillRect(x+5,y-12,3,6);
    // eyes
    ctx.fillStyle=paper?'#f0e8d0':'#000';
    ctx.fillRect(x-6,y-3,4,4);ctx.fillRect(x+2,y-3,4,4);
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    step();
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=paper?'#e8f0f8':'#020810';ctx.fillRect(0,0,W,H);
    // stars
    if(!paper){ctx.fillStyle='rgba(255,255,255,0.5)';for(let i=0;i<40;i++){const sx=(i*73+tick*0.02)%W,sy=(i*41)%H;ctx.fillRect(sx,sy,1,1);}}

    // barriers
    for(const bar of barriers)for(const bl of bar){
      if(bl.hp<=0)continue;
      const a=[1,0.6,0.3][bl.hp-1]||0.2;
      ctx.fillStyle=paper?`rgba(40,120,40,${a})`:`rgba(80,220,80,${a})`;
      ctx.fillRect(bl.x,bl.y,7,7);
    }

    // invaders
    for(const inv of invaders){if(!inv.alive)continue;drawInv(inv);}

    // player ship
    ctx.fillStyle=paper?'#336699':'#44aaff';
    ctx.beginPath();ctx.moveTo(player.x,player.y-player.h);ctx.lineTo(player.x+player.w/2,player.y+2);ctx.lineTo(player.x-player.w/2,player.y+2);ctx.closePath();ctx.fill();
    // gun tip
    ctx.fillRect(player.x-2,player.y-player.h-6,4,8);

    // bullets
    ctx.fillStyle=paper?'#336699':'#88ddff';
    for(const b of bullets)ctx.fillRect(b.x-1.5,b.y-8,3,12);
    // bombs
    ctx.fillStyle=paper?'#cc4422':'#ff6633';
    for(const b of bombs){ctx.fillRect(b.x-2,b.y-6,4,10);}

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`lives: ${'♥ '.repeat(lives).trim()}  wave: ${wave}`,8,6);

    if(!started&&!gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.55)';
      ctx.font=`300 13px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('← → to move · space to shoot · click to start',W/2,H/2);
    }
    if(gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.65)':'rgba(0,0,0,0.65)';ctx.fillRect(0,H/2-36,W,72);
      ctx.fillStyle=paper?'#fff':'#fff';ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-12);
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillStyle='rgba(255,255,255,0.6)';
      ctx.fillText(`score ${score} — click to restart`,W/2,H/2+12);
    }
  }

  // controls
  const keys={};
  const onKey=e=>{
    if(e.type==='keydown'){
      keys[e.code]=true;
      if(e.code==='Space'){e.preventDefault();
        if(!started&&!gameOver)started=true;
        else if(gameOver)init();
        else if(bullets.length<4)bullets.push({x:player.x,y:player.y-player.h});
      }
      if(e.code==='ArrowLeft'||e.code==='KeyA')player.vx=-1;
      if(e.code==='ArrowRight'||e.code==='KeyD')player.vx=1;
    } else {
      delete keys[e.code];
      if((e.code==='ArrowLeft'||e.code==='KeyA')&&!keys['ArrowLeft']&&!keys['KeyA'])player.vx=0;
      if((e.code==='ArrowRight'||e.code==='KeyD')&&!keys['ArrowRight']&&!keys['KeyD'])player.vx=0;
    }
  };
  document.addEventListener('keydown',onKey);document.addEventListener('keyup',onKey);
  c.addEventListener('click',()=>{
    if(!started&&!gameOver){started=true;return;}
    if(gameOver){init();return;}
    if(bullets.length<4)bullets.push({x:player.x,y:player.y-player.h});
  });
  const scoreEl=mkInfo(ctrl);
  mkBtn('New Game',ctrl).addEventListener('click',()=>{init();started=true;});
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}


// TOY 27 — WHACK-A-MOLE
// ════════════════════════════════════════════════════════════════════════════
function initWhackMole(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let moles,score,misses,gameOver,timeLeft,tick,difficulty2;
  const GRID=3,MOLE_R=36,GAME_TIME=30;

  function holePos(i){
    const col=i%GRID,row=Math.floor(i/GRID);
    return{x:W*(0.18+col*0.32),y:H*(0.22+row*0.35)};
  }

  function init(){
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    moles=Array.from({length:9},(_,i)=>({...holePos(i),state:'down',t:0,dur:0,nextAt:rndf(500,2000)}));
    score=0;misses=0;gameOver=false;timeLeft=GAME_TIME;tick=0;difficulty2=1;
  }
  init();

  let lastTime=0;
  function step(ts){
    const dt=(ts-lastTime)/1000;lastTime=ts;
    if(gameOver)return;
    tick++;
    timeLeft-=dt;if(timeLeft<=0){timeLeft=0;gameOver=true;return;}
    const speed=1+score*0.01;
    for(const m of moles){
      m.t+=dt*1000;
      if(m.state==='down'&&m.t>m.nextAt){
        m.state='rising';m.t=0;m.dur=Math.max(400,1200-score*8)/speed;
      } else if(m.state==='rising'&&m.t>150){
        m.state='up';m.t=0;m.dur=Math.max(400,1000-score*10)/speed;
      } else if(m.state==='up'&&m.t>m.dur){
        m.state='falling';m.t=0;
      } else if(m.state==='falling'&&m.t>150){
        m.state='down';m.t=0;m.nextAt=rndf(200,1500)/speed;misses++;
      } else if(m.state==='whacked'&&m.t>350){
        m.state='falling';m.t=0;
      }
    }
  }

  function draw(ts){
    raf=requestAnimationFrame(draw);
    step(ts);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    // bg — grassy
    ctx.fillStyle=paper?'#c8e0a0':'#1a3a0a';ctx.fillRect(0,0,W,H);
    // dirt patches
    for(const m of moles){
      const grd=ctx.createRadialGradient(m.x,m.y+10,5,m.x,m.y+10,MOLE_R*1.3);
      grd.addColorStop(0,paper?'#8a6030':'#3a2010');grd.addColorStop(1,'transparent');
      ctx.beginPath();ctx.ellipse(m.x,m.y+14,MOLE_R*1.2,MOLE_R*0.6,0,0,Math.PI*2);ctx.fillStyle=grd;ctx.fill();
    }

    // holes + moles
    for(const m of moles){
      const y=m.y;
      // hole
      ctx.beginPath();ctx.ellipse(m.x,y+18,MOLE_R*0.88,MOLE_R*0.38,0,0,Math.PI*2);
      ctx.fillStyle=paper?'#4a2a08':'#1a0a00';ctx.fill();

      // mole offset by state
      let oy=MOLE_R*2;
      if(m.state==='rising')oy=MOLE_R*2*(1-m.t/150);
      else if(m.state==='up')oy=0;
      else if(m.state==='falling')oy=MOLE_R*2*(m.t/150);
      else if(m.state==='whacked'){oy=-MOLE_R*0.4*(1-m.t/350);ctx.save();ctx.translate(m.x,y-oy);ctx.rotate(rndf(-0.3,0.3));ctx.translate(-m.x,-(y-oy));}

      ctx.save();
      ctx.beginPath();ctx.ellipse(m.x,y+20,MOLE_R*1.1,MOLE_R*0.45,0,0,Math.PI*2);ctx.clip();
      // mole body
      const mx=m.x,my=y-oy;
      ctx.fillStyle=paper?'#7a4a18':'#5a3010';
      ctx.beginPath();ctx.ellipse(mx,my,MOLE_R*0.72,MOLE_R*0.9,0,0,Math.PI*2);ctx.fill();
      // face
      ctx.fillStyle=paper?'#c89060':'#aa7040';
      ctx.beginPath();ctx.ellipse(mx,my-4,MOLE_R*0.44,MOLE_R*0.5,0,0,Math.PI*2);ctx.fill();
      // eyes
      if(m.state==='whacked'){
        ctx.strokeStyle='#222';ctx.lineWidth=2;
        ctx.beginPath();ctx.moveTo(mx-9,my-14);ctx.lineTo(mx-5,my-10);ctx.moveTo(mx-5,my-14);ctx.lineTo(mx-9,my-10);ctx.stroke();
        ctx.beginPath();ctx.moveTo(mx+5,my-14);ctx.lineTo(mx+9,my-10);ctx.moveTo(mx+9,my-14);ctx.lineTo(mx+5,my-10);ctx.stroke();
      } else {
        ctx.fillStyle='#111';ctx.beginPath();ctx.arc(mx-7,my-12,3.5,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(mx+7,my-12,3.5,0,Math.PI*2);ctx.fill();
        ctx.fillStyle='rgba(255,255,255,0.6)';ctx.beginPath();ctx.arc(mx-6,my-13,1.5,0,Math.PI*2);ctx.fill();
        ctx.beginPath();ctx.arc(mx+8,my-13,1.5,0,Math.PI*2);ctx.fill();
      }
      // nose
      ctx.fillStyle='#cc5577';ctx.beginPath();ctx.ellipse(mx,my-5,5,3.5,0,0,Math.PI*2);ctx.fill();
      ctx.restore();
      if(m.state==='whacked')ctx.restore();
      // score pop
      if(m.state==='whacked'&&m.t<200){
        ctx.fillStyle=paper?'#222':'#fff';ctx.font=`bold ${14}px 'IBM Plex Mono',monospace`;ctx.textAlign='center';
        ctx.fillText('+10',m.x,y-MOLE_R-m.t*0.1);
      }
    }

    // HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.6)';
    ctx.font=`300 12px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='top';
    const barW=Math.max(0,W*0.6*(timeLeft/GAME_TIME));
    ctx.fillStyle=paper?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.1)';
    ctx.fillRect(W*0.2,6,W*0.6,8);
    ctx.fillStyle=timeLeft<8?(paper?'#aa3322':'#ff4433'):(paper?'#3a7a3a':'#44cc44');
    ctx.fillRect(W*0.2,6,barW,8);
    ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText(`score: ${score}  time: ${Math.ceil(timeLeft)}s`,W/2,18);

    if(gameOver){
      ctx.fillStyle='rgba(0,0,0,0.65)';ctx.fillRect(0,H/2-40,W,80);
      ctx.fillStyle='#fff';ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('TIME\'S UP!',W/2,H/2-14);
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;ctx.fillStyle='rgba(255,255,255,0.65)';
      ctx.fillText(`final score: ${score} — click to play again`,W/2,H/2+12);
    }
  }

  c.addEventListener('click',e=>{
    if(gameOver){init();return;}
    const rect=c.getBoundingClientRect();
    const mx=e.clientX-rect.left,my2=e.clientY-rect.top;
    for(const m of moles){
      if(m.state==='up'&&Math.hypot(mx-m.x,my2-m.y)<MOLE_R*1.1){
        m.state='whacked';m.t=0;score+=10;scoreEl.textContent=`score ${score}`;break;
      }
    }
  });
  const scoreEl=mkInfo(ctrl);
  mkBtn('New Game',ctrl).addEventListener('click',init);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 28 — SUDOKU
// ════════════════════════════════════════════════════════════════════════════
function initSudoku(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let puzzle,solution,userGrid,selected2,errors,completed,notes;
  let difficulty3=1; // 0=easy,1=medium,2=hard

  function isValid(grid,r,col2,val,exclude=null){
    for(let i=0;i<9;i++){
      if(i!==col2&&grid[r][i]===val)return false;
      if(i!==r&&grid[i][col2]===val)return false;
    }
    const br=Math.floor(r/3)*3,bc=Math.floor(col2/3)*3;
    for(let dr=0;dr<3;dr++)for(let dc=0;dc<3;dc++){
      const nr=br+dr,nc=bc+dc;
      if((nr!==r||nc!==col2)&&grid[nr][nc]===val)return false;
    }
    return true;
  }

  function solve(grid){
    for(let r=0;r<9;r++)for(let c=0;c<9;c++){
      if(grid[r][c]===0){
        const nums=[1,2,3,4,5,6,7,8,9].sort(()=>Math.random()-0.5);
        for(const n of nums){
          if(isValid(grid,r,c,n)){
            grid[r][c]=n;if(solve(grid))return true;grid[r][c]=0;
          }
        }
        return false;
      }
    }
    return true;
  }

  function generate(){
    const g=Array.from({length:9},()=>Array(9).fill(0));
    solve(g);
    solution=g.map(r=>r.slice());
    const removes=[38,48,56][difficulty3];
    const cells=[];for(let r=0;r<9;r++)for(let c=0;c<9;c++)cells.push([r,c]);
    // shuffle
    for(let i=cells.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[cells[i],cells[j]]=[cells[j],cells[i]];}
    for(let i=0;i<removes;i++){const[r,c]=cells[i];g[r][c]=0;}
    puzzle=g.map(r=>r.slice());
    userGrid=g.map(r=>r.slice());
    notes=Array.from({length:9},()=>Array.from({length:9},()=>new Set()));
    selected2=null;errors=new Set();completed=false;
  }
  generate();

  function checkComplete(){
    for(let r=0;r<9;r++)for(let c=0;c<9;c++)if(userGrid[r][c]!==solution[r][c])return false;
    return true;
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    const SZ=Math.min(W,H)-24;const sq=SZ/9;const ox=(W-SZ)/2,oy=(H-SZ)/2;
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);

    // cells
    for(let r=0;r<9;r++)for(let c=0;c<9;c++){
      const x=ox+c*sq,y=oy+r*sq;
      const isGiven=puzzle[r][c]!==0;
      const isSel=selected2&&selected2[0]===r&&selected2[1]===c;
      const isSameNum=selected2&&userGrid[r][c]&&userGrid[r][c]===userGrid[selected2[0]][selected2[1]];
      const isRelated=selected2&&(r===selected2[0]||c===selected2[1]||(Math.floor(r/3)===Math.floor(selected2[0]/3)&&Math.floor(c/3)===Math.floor(selected2[1]/3)));
      const isErr=errors.has(`${r},${c}`);

      let bg=paper?'#faf6ee':'#1e1e2a';
      if(isRelated)bg=paper?'#ede8e0':'#252535';
      if(isSameNum)bg=paper?'#d8e8c8':'#1a3020';
      if(isSel)bg=paper?'#b8d4f0':'#152840';
      if(isErr)bg=paper?'#f8ddd8':'#2a1518';
      ctx.fillStyle=bg;ctx.fillRect(x,y,sq,sq);

      const val=userGrid[r][c];
      if(val){
        ctx.textAlign='center';ctx.textBaseline='middle';
        if(isGiven){
          ctx.font=`600 ${sq*0.54}px 'IBM Plex Mono',monospace`;
          ctx.fillStyle=paper?'#1a1208':'rgba(255,255,255,0.92)';
        } else {
          ctx.font=`300 ${sq*0.52}px 'IBM Plex Mono',monospace`;
          ctx.fillStyle=isErr?(paper?'#cc2222':'#ff5555'):(paper?'#2255aa':'#66aaff');
        }
        ctx.fillText(val,x+sq/2,y+sq/2+1);
      } else {
        // notes
        const ns=notes[r][c];
        if(ns.size>0){
          ctx.font=`300 ${sq*0.22}px 'IBM Plex Mono',monospace`;
          ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.3)';
          ctx.textAlign='center';ctx.textBaseline='middle';
          for(let n=1;n<=9;n++){
            if(ns.has(n)){
              const nc2=((n-1)%3),nr2=Math.floor((n-1)/3);
              ctx.fillText(n,x+sq*(0.2+nc2*0.3),y+sq*(0.2+nr2*0.3));
            }
          }
        }
      }
    }

    // grid lines
    for(let i=0;i<=9;i++){
      const thick=i%3===0;
      ctx.strokeStyle=paper?(thick?'rgba(0,0,0,0.5)':'rgba(0,0,0,0.15)'):(thick?'rgba(255,255,255,0.45)':'rgba(255,255,255,0.1)');
      ctx.lineWidth=thick?2:0.75;
      ctx.beginPath();ctx.moveTo(ox+i*sq,oy);ctx.lineTo(ox+i*sq,oy+SZ);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ox,oy+i*sq);ctx.lineTo(ox+SZ,oy+i*sq);ctx.stroke();
    }

    if(completed){
      ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(ox,oy+SZ/2-30,SZ,60);
      ctx.fillStyle='#aaff88';ctx.font=`400 20px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('✓ Solved!',ox+SZ/2,oy+SZ/2);
    }
  }

  c.addEventListener('click',e=>{
    if(completed)return;
    const SZ=Math.min(W,H)-24,sq=SZ/9,ox=(W-SZ)/2,oy=(H-SZ)/2;
    const rect=c.getBoundingClientRect();
    const mx=e.clientX-rect.left,my=e.clientY-rect.top;
    const r=Math.floor((my-oy)/sq),col2=Math.floor((mx-ox)/sq);
    if(r>=0&&r<9&&col2>=0&&col2<9)selected2=[r,col2];
  });

  const onKey=e=>{
    if(!selected2||completed)return;
    const[r,c]=selected2;
    // Digits: intercept in capture phase so toy-switcher never sees them
    if(/^[0-9]$/.test(e.key)){
      e.preventDefault();
      e.stopImmediatePropagation();
      if(puzzle[r][c]===0){
        const n=+e.key;
        if(n===0){userGrid[r][c]=0;errors.delete(`${r},${c}`);}
        else{
          userGrid[r][c]=n;errors.delete(`${r},${c}`);
          if(n!==solution[r][c])errors.add(`${r},${c}`);
          if(checkComplete())completed=true;
        }
      }
      return;
    }
    if(puzzle[r][c]===0&&(e.key==='Backspace'||e.key==='Delete')){userGrid[r][c]=0;errors.delete(`${r},${c}`);}
    if(e.key==='ArrowUp'&&r>0){e.preventDefault();selected2=[r-1,c];}
    if(e.key==='ArrowDown'&&r<8){e.preventDefault();selected2=[r+1,c];}
    if(e.key==='ArrowLeft'&&c>0){e.preventDefault();selected2=[r,c-1];}
    if(e.key==='ArrowRight'&&c<8){e.preventDefault();selected2=[r,c+1];}
  };
  document.addEventListener('keydown',onKey,true);

  const diffLabels2=['Easy','Medium','Hard'];
  const diffBtn2=mkBtn(diffLabels2[difficulty3],ctrl);
  diffBtn2.addEventListener('click',()=>{difficulty3=(difficulty3+1)%3;diffBtn2.textContent=diffLabels2[difficulty3];generate();});
  mkBtn('New Game',ctrl).addEventListener('click',generate);
  mkBtn('Reveal',ctrl).addEventListener('click',()=>{
    if(selected2){const[r,c]=selected2;if(puzzle[r][c]===0){userGrid[r][c]=solution[r][c];errors.delete(`${r},${c}`);if(checkComplete())completed=true;}}
  });
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey,true);};
}

