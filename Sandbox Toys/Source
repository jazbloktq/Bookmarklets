// TOY 12 — ASTEROIDS
// ════════════════════════════════════════════════════════════════════════════
function initAsteroids(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height;
  let ship,bullets,asteroids,score,lives,raf,gameOver,level,invincible,keys={};
  function mkShip(){return{x:W/2,y:H/2,vx:0,vy:0,angle:-Math.PI/2,thrust:false,dead:false};}
  function mkAsteroid(x,y,r){const angle=Math.random()*Math.PI*2,spd=rndf(0.6,1.8)*(1+level*0.12);return{x,y,vx:Math.cos(angle)*spd,vy:Math.sin(angle)*spd,r,angle:0,spin:rndf(-0.03,0.03),verts:Array.from({length:10},(_,i)=>{const a=i/10*Math.PI*2;return{x:Math.cos(a)*(r+rndf(-r*0.25,r*0.25)),y:Math.sin(a)*(r+rndf(-r*0.25,r*0.25))};})}}
  function spawnAsteroids(){
    asteroids=[];
    for(let i=0;i<4+level*1;i++){
      let x,y;do{x=Math.random()*W;y=Math.random()*H;}while(Math.abs(x-ship.x)<120&&Math.abs(y-ship.y)<120);
      asteroids.push(mkAsteroid(x,y,rndf(28,46)));
    }
  }
  function init(){ship=mkShip();bullets=[];score=0;lives=3;level=0;gameOver=false;invincible=0;spawnAsteroids();}
  init();
  let raf2;
  function step(ts){
    raf2=requestAnimationFrame(step);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    if(!gameOver){
      if(invincible>0)invincible--;
      if(keys['ArrowLeft']||keys['a'])ship.angle-=0.065;
      if(keys['ArrowRight']||keys['d'])ship.angle+=0.065;
      ship.thrust=keys['ArrowUp']||keys['w'];
      if(ship.thrust){ship.vx+=Math.cos(ship.angle)*0.18;ship.vy+=Math.sin(ship.angle)*0.18;}
      ship.vx*=0.98;ship.vy*=0.98;
      ship.x=(ship.x+ship.vx+W)%W;ship.y=(ship.y+ship.vy+H)%H;
      for(const b of bullets){b.x+=b.vx;b.y+=b.vy;b.life--;}
      bullets=bullets.filter(b=>b.life>0&&b.x>0&&b.x<W&&b.y>0&&b.y<H);
      for(const a of asteroids){a.x=(a.x+a.vx+W)%W;a.y=(a.y+a.vy+H)%H;a.angle+=a.spin;}
      // bullet-asteroid collision
      const nextAsteroids=[];
      for(const a of asteroids){
        let hit=false;
        bullets=bullets.filter(b=>{const dx=b.x-a.x,dy=b.y-a.y;if(Math.sqrt(dx*dx+dy*dy)<a.r){hit=true;return false;}return true;});
        if(hit){score+=a.r>30?20:a.r>16?50:100;if(a.r>16){for(let i=0;i<2;i++)nextAsteroids.push(mkAsteroid(a.x,a.y,a.r*0.5));}}
        else nextAsteroids.push(a);
      }
      asteroids=nextAsteroids;
      if(asteroids.length===0){level++;spawnAsteroids();}
      // ship-asteroid collision
      if(invincible===0){for(const a of asteroids){const dx=ship.x-a.x,dy=ship.y-a.y;if(Math.sqrt(dx*dx+dy*dy)<a.r+8){lives--;invincible=150;ship.vx=0;ship.vy=0;if(lives<=0){gameOver=true;}break;}}}
      scoreEl.textContent=`score ${score}  lives ${lives}`;
    }
    // draw asteroids
    const fg=fgClr();
    for(const a of asteroids){
      ctx.save();ctx.translate(a.x,a.y);ctx.rotate(a.angle);
      ctx.beginPath();ctx.moveTo(a.verts[0].x,a.verts[0].y);
      for(const v of a.verts)ctx.lineTo(v.x,v.y);ctx.closePath();
      ctx.strokeStyle=paper?'rgba(60,40,20,0.7)':'rgba(180,190,210,0.75)';ctx.lineWidth=1.5;ctx.stroke();
      ctx.restore();
    }
    // draw ship
    if(!gameOver&&!(invincible>0&&Math.floor(invincible/5)%2===0)){
      ctx.save();ctx.translate(ship.x,ship.y);ctx.rotate(ship.angle);
      ctx.beginPath();ctx.moveTo(16,0);ctx.lineTo(-10,9);ctx.lineTo(-6,0);ctx.lineTo(-10,-9);ctx.closePath();
      ctx.strokeStyle=paper?'rgba(40,30,15,0.9)':'rgba(220,230,255,0.9)';ctx.lineWidth=1.5;ctx.stroke();
      if(ship.thrust){ctx.beginPath();ctx.moveTo(-6,0);ctx.lineTo(-16,rndf(-4,4));ctx.strokeStyle=paper?'#c0392b':'#f39c12';ctx.lineWidth=2;ctx.stroke();}
      ctx.restore();
    }
    // draw bullets
    ctx.fillStyle=paper?'rgba(180,80,20,0.9)':'rgba(255,220,100,0.9)';
    for(const b of bullets){ctx.beginPath();ctx.arc(b.x,b.y,2.5,0,Math.PI*2);ctx.fill();}
    // hud
    const hfg=paper?'rgba(30,20,10,0.6)':'rgba(255,255,255,0.45)';
    ctx.fillStyle=hfg;ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`level ${level+1}`,12,12);
    if(gameOver){ctx.fillStyle=paper?'rgba(30,20,10,0.88)':'rgba(255,255,255,0.88)';ctx.font=`400 18px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('GAME OVER',W/2,H/2-14);ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText(`final score ${score}`,W/2,H/2+10);ctx.fillText('press R to restart',W/2,H/2+30);}
  }
  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',init);
  const onKey=e=>{
    keys[e.key]=e.type==='keydown';
    if(e.type==='keydown'){
      if((e.key==='r'||e.key==='R')&&gameOver)init();
      if(e.key===' '||e.key==='x'){
        if(!gameOver&&bullets.length<8){bullets.push({x:ship.x+Math.cos(ship.angle)*18,y:ship.y+Math.sin(ship.angle)*18,vx:Math.cos(ship.angle)*9+ship.vx,vy:Math.sin(ship.angle)*9+ship.vy,life:55});}
        e.preventDefault();
      }
      if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key))e.preventDefault();
    }
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);
  requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf2);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 12b — ASTEROIDS ROGUELITE  (asteroids + upgrades between waves)
// ════════════════════════════════════════════════════════════════════════════
function initAsteroidsRogue(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height;
  let ship,bullets,asteroids,particles,score,lives,raf2,level,invincible,keys={};
  let gameState; // 'playing' | 'upgrade' | 'dead'
  let upgrades, pendingUpgrades;

  // Upgrade definitions
  const UPGRADE_DEFS = [
    {id:'speed',    label:'Speed Boost',    desc:'Ship thrust & top speed +20%'},
    {id:'trishot',  label:'Triple Shot',    desc:'Fire 3 bullets in a spread'},
    {id:'shield',   label:'Extra Life',     desc:'Gain one extra life'},
    {id:'rapid',    label:'Rapid Fire',     desc:'Fire rate doubled, +4 bullet cap'},
    {id:'bomb',     label:'Shockwave',      desc:'Press B once every 2nd wave: destroys smalls, splits mediums, repels large rocks'},
    {id:'gravity',  label:'Gravity Well',   desc:'Bullets curve toward nearby rocks'},
    {id:'piercing', label:'Piercing Shot',  desc:'Bullets pass through asteroids'},
    {id:'giant',    label:'Giant Bullets',  desc:'Bullets 3× bigger, more range'},
  ];

  function mkShip(){return{x:W/2,y:H/2,vx:0,vy:0,angle:-Math.PI/2,thrust:false,dead:false};}
  function mkParticle(x,y,col){const a=Math.random()*Math.PI*2,spd=rndf(1,4);return{x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,r:rndf(1.5,3.5),life:1,col};}
  function mkAsteroid(x,y,r){
    const angle=Math.random()*Math.PI*2;
    const spd=rndf(0.5,1.6)*(1+level*0.1);
    return{x,y,vx:Math.cos(angle)*spd,vy:Math.sin(angle)*spd,r,angle:0,spin:rndf(-0.035,0.035),
      verts:Array.from({length:10},(_,i)=>{const a=i/10*Math.PI*2;return{x:Math.cos(a)*(r+rndf(-r*0.22,r*0.22)),y:Math.sin(a)*(r+rndf(-r*0.22,r*0.22))};})};
  }
  function spawnAsteroids(){
    asteroids=[];
    if(upgrades){
      if(upgrades.bombCooldown>0) upgrades.bombCooldown--;
      else upgrades.bombUsed=false; // ready again after cooldown waves
    }
    const count=3+level;
    for(let i=0;i<count;i++){
      let x,y;
      do{x=Math.random()*W;y=Math.random()*H;}while(Math.abs(x-ship.x)<130&&Math.abs(y-ship.y)<130);
      asteroids.push(mkAsteroid(x,y,rndf(28,46)));
    }
  }

  function pickUpgrades(){
    const pool=[...UPGRADE_DEFS];
    const result=[];
    while(result.length<3&&pool.length){
      const i=Math.floor(Math.random()*pool.length);
      result.push(pool.splice(i,1)[0]);
    }
    return result;
  }

  function applyUpgrade(id){
    upgrades[id]=(upgrades[id]||0)+1;
    gameState='playing';
    level++;
    spawnAsteroids();
  }

  function init(){
    ship=mkShip(); bullets=[]; asteroids=[]; particles=[];
    score=0; lives=3; level=0; invincible=0;
    upgrades={bombUsed:false,bombCooldown:0}; pendingUpgrades=[];
    gameState='playing';
    spawnAsteroids();
  }
  init();

  function fireBullet(){
    const cap=8+(upgrades.rapid||0)*4;
    if(bullets.length>=cap) return;
    const spd=9, sz=upgrades.giant?7:2.5;
    const pierce=!!(upgrades.piercing);
    const base={vx:Math.cos(ship.angle)*spd+ship.vx, vy:Math.sin(ship.angle)*spd+ship.vy, life:55+(upgrades.giant?20:0), r:sz, pierce};
    const bx=ship.x+Math.cos(ship.angle)*18, by=ship.y+Math.sin(ship.angle)*18;
    const shots=upgrades.trishot?[ship.angle-0.22,ship.angle,ship.angle+0.22]:[ship.angle];
    shots.forEach(a=>{
      bullets.push({x:bx,y:by,vx:Math.cos(a)*spd+ship.vx,vy:Math.sin(a)*spd+ship.vy,life:base.life,r:sz,pierce});
    });
  }

  function shockwave(){
    if(!(upgrades.bomb)) return;
    if(upgrades.bombUsed) return; // on cooldown
    upgrades.bombUsed=true;
    upgrades.bombCooldown=1; // skips 1 wave, usable every 2nd wave
    const paper=isPaper();
    const surviving=[];
    asteroids.forEach(a=>{
      if(a.r<=16){
        // small: destroy
        score+=100;
        for(let i=0;i<6;i++) particles.push(mkParticle(a.x,a.y,paper?'#c04010':'#ffaa22'));
      } else if(a.r<=30){
        // medium: split into two smalls, no score bonus
        for(let i=0;i<4;i++) particles.push(mkParticle(a.x,a.y,paper?'#c04010':'#ffaa22'));
        for(let i=0;i<2;i++) surviving.push(mkAsteroid(a.x,a.y,a.r*0.42));
      } else {
        // large: blast away from ship, survives
        const dx=a.x-ship.x, dy=a.y-ship.y;
        const dist=Math.sqrt(dx*dx+dy*dy)||1;
        a.vx=(dx/dist)*4; a.vy=(dy/dist)*4;
        surviving.push(a);
      }
    });
    asteroids=surviving;
  }

  function step(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    const spd=(1+(upgrades.speed||0)*0.2);

    if(invincible>0) invincible--;
    if(keys['ArrowLeft']||keys['a']) ship.angle-=0.065;
    if(keys['ArrowRight']||keys['d']) ship.angle+=0.065;
    ship.thrust=keys['ArrowUp']||keys['w'];
    if(ship.thrust){ship.vx+=Math.cos(ship.angle)*0.18*spd;ship.vy+=Math.sin(ship.angle)*0.18*spd;}
    const maxSpd=7*spd;
    const sv=Math.sqrt(ship.vx*ship.vx+ship.vy*ship.vy);
    if(sv>maxSpd){ship.vx=ship.vx/sv*maxSpd;ship.vy=ship.vy/sv*maxSpd;}
    ship.vx*=0.98; ship.vy*=0.98;
    ship.x=(ship.x+ship.vx+W)%W; ship.y=(ship.y+ship.vy+H)%H;

    // Bullets
    for(const b of bullets){
      if(upgrades.gravity){
        // Nudge toward nearest asteroid
        let nd=999,na=null;
        for(const a of asteroids){const dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d<nd){nd=d;na=a;}}
        if(na&&nd<180){const f=0.12/nd;b.vx+=( na.x-b.x)*f;b.vy+=(na.y-b.y)*f;}
      }
      b.x+=b.vx; b.y+=b.vy; b.life--;
    }
    bullets=bullets.filter(b=>b.life>0);

    for(const a of asteroids){a.x=(a.x+a.vx+W)%W;a.y=(a.y+a.vy+H)%H;a.angle+=a.spin;}

    // Bullet-asteroid collisions
    const nextAsteroids=[];
    for(const a of asteroids){
      let hit=false;
      bullets=bullets.filter(b=>{
        const dx=b.x-a.x,dy=b.y-a.y;
        if(Math.sqrt(dx*dx+dy*dy)<a.r+b.r){hit=true;return b.pierce;}
        return true;
      });
      if(hit){
        score+=a.r>30?20:a.r>16?50:100;
        const col=paper?'#c04010':'#ffaa22';
        for(let i=0;i<6;i++) particles.push(mkParticle(a.x,a.y,col));
        if(a.r>16){for(let i=0;i<2;i++) nextAsteroids.push(mkAsteroid(a.x,a.y,a.r*0.5));}
      } else nextAsteroids.push(a);
    }
    asteroids=nextAsteroids;

    // Particles
    particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.life-=0.035;p.vx*=0.95;p.vy*=0.95;});
    particles=particles.filter(p=>p.life>0);

    // Wave clear
    if(asteroids.length===0){
      pendingUpgrades=pickUpgrades();
      gameState='upgrade';
      return;
    }

    // Ship-asteroid collision
    if(invincible===0){
      for(const a of asteroids){
        const dx=ship.x-a.x,dy=ship.y-a.y;
        if(Math.sqrt(dx*dx+dy*dy)<a.r+8){
          lives--; invincible=150; ship.vx=0; ship.vy=0;
          if(lives<=0){gameState='dead';}
          break;
        }
      }
    }

    scoreEl.textContent=`score ${score}  lives ${lives}`;
  }

  function drawGame(){
    const paper=isPaper();
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);

    // Particles
    particles.forEach(p=>{
      ctx.globalAlpha=Math.max(0,p.life);
      ctx.fillStyle=p.col;
      ctx.beginPath(); ctx.arc(p.x,p.y,Math.max(0.5,p.r),0,Math.PI*2); ctx.fill();
    });
    ctx.globalAlpha=1;

    // Asteroids
    for(const a of asteroids){
      ctx.save(); ctx.translate(a.x,a.y); ctx.rotate(a.angle);
      ctx.beginPath(); ctx.moveTo(a.verts[0].x,a.verts[0].y);
      for(const v of a.verts) ctx.lineTo(v.x,v.y); ctx.closePath();
      ctx.strokeStyle=paper?'rgba(60,40,20,0.75)':'rgba(180,200,220,0.8)';
      ctx.lineWidth=1.5; ctx.stroke();
      ctx.restore();
    }

    // Ship
    if(!(invincible>0&&Math.floor(invincible/5)%2===0)){
      ctx.save(); ctx.translate(ship.x,ship.y); ctx.rotate(ship.angle);
      ctx.beginPath(); ctx.moveTo(16,0); ctx.lineTo(-10,9); ctx.lineTo(-6,0); ctx.lineTo(-10,-9); ctx.closePath();
      ctx.strokeStyle=paper?'rgba(40,30,15,0.9)':'rgba(220,235,255,0.9)'; ctx.lineWidth=1.5; ctx.stroke();
      if(ship.thrust){ctx.beginPath();ctx.moveTo(-6,0);ctx.lineTo(-16,rndf(-4,4));ctx.strokeStyle=paper?'#c0392b':'#f39c12';ctx.lineWidth=2;ctx.stroke();}
      ctx.restore();
    }

    // Bullets
    ctx.fillStyle=paper?'rgba(180,80,20,0.9)':'rgba(255,220,100,0.9)';
    for(const b of bullets){ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);ctx.fill();}

    // HUD
    const hfg=paper?'rgba(30,20,10,0.6)':'rgba(255,255,255,0.5)';
    ctx.fillStyle=hfg; ctx.font=`300 11px 'IBM Plex Mono',monospace`;
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillText(`wave ${level+1}`,12,12);

    // Upgrades HUD — top right
    const ulist=Object.entries(upgrades).filter(([,v])=>v>0).map(([id,v])=>{
      const def=UPGRADE_DEFS.find(d=>d.id===id);
      const coolTag=(id==='bomb'&&upgrades.bombUsed)?' [cd]':'';
      return `${def?def.label:id}${v>1?' ×'+v:''}${coolTag}`;
    });
    if(ulist.length){
      ctx.textAlign='right'; ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.fillStyle=paper?'rgba(30,20,10,0.45)':'rgba(255,255,255,0.35)';
      ulist.forEach((t,i)=>ctx.fillText(t,W-10,12+i*13));
    }

    if(gameState==='dead'){
      ctx.fillStyle=paper?'rgba(240,235,228,0.82)':'rgba(0,0,0,0.72)'; ctx.fillRect(0,0,W,H);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillStyle=paper?'rgba(30,20,10,0.9)':'rgba(255,255,255,0.9)';
      ctx.font=`400 20px 'IBM Plex Mono',monospace`;
      ctx.fillText('GAME OVER',W/2,H/2-20);
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;
      ctx.fillText(`wave ${level+1}  ·  score ${score}`,W/2,H/2+10);
      ctx.fillStyle=paper?'rgba(30,20,10,0.5)':'rgba(255,255,255,0.45)';
      ctx.fillText('press R or click New to restart',W/2,H/2+34);
    }
    ctx.textAlign='left';
  }

  function drawUpgrade(){
    const paper=isPaper();
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
    ctx.textAlign='center'; ctx.textBaseline='middle';

    const fg=paper?'rgba(20,14,8,0.9)':'rgba(255,255,255,0.9)';
    ctx.fillStyle=fg; ctx.font=`400 16px 'IBM Plex Mono',monospace`;
    ctx.fillText(`WAVE ${level+1} CLEAR  ·  score ${score}`,W/2,H*0.18);
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=paper?'rgba(20,14,8,0.5)':'rgba(255,255,255,0.45)';
    ctx.fillText('choose an upgrade',W/2,H*0.26);

    const boxW=Math.min(200,W*0.27), boxH=90, gap=18;
    const totalW=pendingUpgrades.length*(boxW+gap)-gap;
    const startX=(W-totalW)/2;
    const cy=H*0.5;

    pendingUpgrades.forEach((u,i)=>{
      const bx=startX+i*(boxW+gap), by=cy-boxH/2;
      ctx.fillStyle=paper?'rgba(0,0,0,0.07)':'rgba(255,255,255,0.07)';
      roundRect(ctx,bx,by,boxW,boxH,6); ctx.fill();
      ctx.strokeStyle=paper?'rgba(0,0,0,0.18)':'rgba(255,255,255,0.18)';
      ctx.lineWidth=1; roundRect(ctx,bx,by,boxW,boxH,6); ctx.stroke();

      ctx.fillStyle=fg; ctx.font=`400 11px 'IBM Plex Mono',monospace`;
      ctx.fillText(`[${i+1}]  ${u.label}`,bx+boxW/2,cy-18);
      ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.fillStyle=paper?'rgba(20,14,8,0.55)':'rgba(255,255,255,0.5)';
      // Wrap desc
      const words=u.desc.split(' '); let line='';
      let ty=cy+4;
      words.forEach(w=>{
        const test=line?line+' '+w:w;
        ctx.font=`300 9px 'IBM Plex Mono',monospace`;
        if(ctx.measureText(test).width>boxW-16&&line){ctx.fillText(line,bx+boxW/2,ty);ty+=13;line=w;}
        else line=test;
      });
      if(line) ctx.fillText(line,bx+boxW/2,ty);
    });
    ctx.textAlign='left';
  }

  function draw(){
    raf2=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    if(gameState==='upgrade') drawUpgrade();
    else { if(gameState==='playing') step(); drawGame(); }
  }

  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',()=>{init();});

  const onKey=e=>{
    keys[e.key]=e.type==='keydown';
    if(e.type!=='keydown') return;
    if((e.key==='r'||e.key==='R')&&gameState==='dead') init();
    if(e.key===' '||e.key==='x'){
      if(gameState==='playing') fireBullet();
      e.preventDefault();
    }
    if(e.key==='b'||e.key==='B') shockwave();
    if(gameState==='upgrade'&&['1','2','3'].includes(e.key)){
      const i=parseInt(e.key)-1;
      if(pendingUpgrades[i]) applyUpgrade(pendingUpgrades[i].id);
    }
    if(['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key)) e.preventDefault();
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);

  c.addEventListener('click',e=>{
    if(gameState==='dead'){init();return;}
    if(gameState==='upgrade'){
      const r2=c.getBoundingClientRect();
      const mx=e.clientX-r2.left, my=e.clientY-r2.top;
      const boxW=Math.min(200,W*0.27), boxH=90, gap=18;
      const totalW=pendingUpgrades.length*(boxW+gap)-gap;
      const startX=(W-totalW)/2, cy=H*0.5;
      pendingUpgrades.forEach((u,i)=>{
        const bx=startX+i*(boxW+gap), by=cy-boxH/2;
        if(mx>=bx&&mx<=bx+boxW&&my>=by&&my<=by+boxH) applyUpgrade(u.id);
      });
    }
  });

  requestAnimationFrame(draw);
  return ()=>{
    cancelAnimationFrame(raf2); ro.disconnect();
    document.removeEventListener('keydown',onKey);
    document.removeEventListener('keyup',onKey);
  };
}

