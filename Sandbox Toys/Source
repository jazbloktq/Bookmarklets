// TOY 38 — WAVE INTERFERENCE
// ════════════════════════════════════════════════════════════════════════════
function initWaveInterference(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let sources=[], tick3=0;
  let freq=0.04, amp=1, speed2=1, showPhase=false;
  let dragging2=null;
  const COLORS=['#ff4488','#44aaff','#44ffaa','#ffaa22','#cc44ff'];

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    sources=[
      {x:W*0.35,y:H*0.5,phase:0,col:COLORS[0]},
      {x:W*0.65,y:H*0.5,phase:0,col:COLORS[1]},
    ];
    tick3=0;
  }
  init();

  // Pre-allocate ImageData
  let imgData=null;

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    tick3+=speed2;

    const paper=isPaper();
    if(!imgData||imgData.width!==W||imgData.height!==H)
      imgData=ctx.createImageData(W,H);

    const data=imgData.data;
    // Subsample for perf: every 2 pixels
    const step=2;
    for(let y=0;y<H;y+=step){
      for(let x=0;x<W;x+=step){
        let sum=0;
        for(const s of sources){
          const d=Math.hypot(x-s.x,y-s.y);
          sum+=Math.sin(d*freq-tick3*0.08+s.phase)*amp;
        }
        const norm=(sum/sources.length+1)/2; // 0..1
        let r2,g2,b2;
        if(paper){
          const v=Math.floor(norm*220+20);
          r2=v; g2=Math.floor(v*0.85); b2=Math.floor(v*0.7);
        } else {
          if(norm<0.5){
            const t=norm*2;
            r2=Math.floor(t*50); g2=Math.floor(t*80); b2=Math.floor(150+t*80);
          } else {
            const t=(norm-0.5)*2;
            r2=Math.floor(50+t*200); g2=Math.floor(80+t*160); b2=Math.floor(230-t*180);
          }
        }
        for(let dy=0;dy<step&&y+dy<H;dy++){
          for(let dx=0;dx<step&&x+dx<W;dx++){
            const i=((y+dy)*W+(x+dx))*4;
            data[i]=r2; data[i+1]=g2; data[i+2]=b2; data[i+3]=255;
          }
        }
      }
    }
    ctx.putImageData(imgData,0,0);

    // Source markers
    for(let i=0;i<sources.length;i++){
      const s=sources[i];
      if(!paper){ctx.save();ctx.shadowColor=s.col;ctx.shadowBlur=12;}
      ctx.strokeStyle=s.col; ctx.lineWidth=2;
      const pulseR=((tick3*0.08*20/(Math.PI*2))%1)*30;
      ctx.globalAlpha=Math.max(0,1-pulseR/30);
      ctx.beginPath();ctx.arc(s.x,s.y,pulseR+4,0,Math.PI*2);ctx.stroke();
      ctx.globalAlpha=1;
      ctx.fillStyle=s.col;
      ctx.beginPath();ctx.arc(s.x,s.y,7,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=paper?'#000':'#fff';
      ctx.font=`700 9px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(i+1,s.x,s.y);
      if(!paper)ctx.restore();
    }

    ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.4)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`${sources.length} sources · drag to move · click empty to add`,8,6);
  }

  c.addEventListener('mousedown',e=>{
    const r=c.getBoundingClientRect();
    const mx=e.clientX-r.left,my=e.clientY-r.top;
    // drag existing?
    for(const s of sources){
      if(Math.hypot(mx-s.x,my-s.y)<16){dragging2=s;return;}
    }
    // add new
    if(sources.length<5){
      sources.push({x:mx,y:my,phase:0,col:COLORS[sources.length%COLORS.length]});
    }
  });
  c.addEventListener('mousemove',e=>{
    if(!dragging2) return;
    const r=c.getBoundingClientRect();
    dragging2.x=e.clientX-r.left; dragging2.y=e.clientY-r.top;
  });
  c.addEventListener('mouseup',()=>dragging2=null);
  c.addEventListener('contextmenu',e=>{
    e.preventDefault();
    const r=c.getBoundingClientRect();
    const mx=e.clientX-r.left,my=e.clientY-r.top;
    for(let i=sources.length-1;i>=0;i--){
      if(Math.hypot(mx-sources[i].x,my-sources[i].y)<16&&sources.length>1){sources.splice(i,1);break;}
    }
  });

  const freqLbl=document.createElement('span');freqLbl.className='sb-info sb-speed-lbl';freqLbl.textContent='freq';ctrl.appendChild(freqLbl);
  const freqSl=document.createElement('input');freqSl.type='range';freqSl.className='sb-slider';freqSl.min=0.01;freqSl.max=0.12;freqSl.step=0.005;freqSl.value=freq;ctrl.appendChild(freqSl);styleSlider(freqSl);
  freqSl.addEventListener('input',()=>freq=+freqSl.value);

  const spdLbl2=document.createElement('span');spdLbl2.className='sb-info sb-speed-lbl';spdLbl2.textContent='speed';ctrl.appendChild(spdLbl2);
  const spdSl2=document.createElement('input');spdSl2.type='range';spdSl2.className='sb-slider';spdSl2.min=0;spdSl2.max=4;spdSl2.step=0.1;spdSl2.value=speed2;ctrl.appendChild(spdSl2);styleSlider(spdSl2);
  spdSl2.addEventListener('input',()=>speed2=+spdSl2.value);

  mkBtn('Reset',ctrl).addEventListener('click',init);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

