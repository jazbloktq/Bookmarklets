// TOY 23 — SOFT BODY  (jelly blob you can poke)
// ════════════════════════════════════════════════════════════════════════════
function initSoftBody(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let blobs=[],mouse={x:-999,y:-999,down:false};

  function mkBlob(cx,cy,r,col){
    const N=20,pts=[];
    for(let i=0;i<N;i++){
      const a=i/N*Math.PI*2;
      pts.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,vx:0,vy:0,ox:cx+Math.cos(a)*r,oy:cy+Math.sin(a)*r});
    }
    return{pts,cx,cy,r,col,N};
  }
  function reset(){
    blobs=[
      mkBlob(W*0.38,H*0.5,Math.min(W,H)*0.18,isPaper()?'rgba(80,120,180,0.55)':'rgba(80,160,255,0.55)'),
      mkBlob(W*0.65,H*0.45,Math.min(W,H)*0.13,isPaper()?'rgba(160,80,80,0.55)':'rgba(255,100,100,0.55)'),
    ];
  }
  reset();

  const STIFF=0.08,DAMP=0.88,PRESSURE=0.9,GRAV=0.12;
  function stepBlob(b){
    const{pts,N}=b;
    // compute centroid
    let cx=0,cy=0;for(const p of pts){cx+=p.x;cy+=p.y;}cx/=N;cy/=N;
    b.cx=cx;b.cy=cy;
    // compute area (shoelace)
    let area=0;
    for(let i=0;i<N;i++){const j=(i+1)%N;area+=pts[i].x*pts[j].y-pts[j].x*pts[i].y;}
    area=Math.abs(area)/2;
    const targetArea=Math.PI*b.r*b.r;
    const pressureForce=(targetArea-area)/targetArea*PRESSURE;
    for(let i=0;i<N;i++){
      const p=pts[i];
      const prev=pts[(i-1+N)%N],next=pts[(i+1)%N];
      // spring to neighbours
      const fsx=(prev.x+next.x)/2-p.x,fsy=(prev.y+next.y)/2-p.y;
      // spring to rest position (relative to centroid)
      const restX=cx+(p.ox-b.cx)*1,restY=cy+(p.oy-b.cy)*1;
      // pressure (push outward from centroid)
      const nx=p.x-cx,ny=p.y-cy,nd=Math.sqrt(nx*nx+ny*ny)||1;
      p.vx+=(fsx*STIFF+(restX-p.x)*0.04+nx/nd*pressureForce*2)*1;
      p.vy+=(fsy*STIFF+(restY-p.y)*0.04+ny/nd*pressureForce*2+GRAV)*1;
      // mouse repulsion
      const mdx=p.x-mouse.x,mdy=p.y-mouse.y,md=Math.sqrt(mdx*mdx+mdy*mdy)||1;
      const mForce=mouse.down?60:30;
      if(md<60){p.vx+=mdx/md*(60-md)/60*mForce*0.04;p.vy+=mdy/md*(60-md)/60*mForce*0.04;}
      p.vx*=DAMP;p.vy*=DAMP;
      p.x+=p.vx;p.y+=p.vy;
      // floor/wall bounce
      if(p.y>H-4){p.y=H-4;p.vy*=-0.4;}
      if(p.x<4){p.x=4;p.vx*=-0.4;}if(p.x>W-4){p.x=W-4;p.vx*=-0.4;}
      if(p.y<4){p.y=4;p.vy*=-0.4;}
    }
  }

  function drawBlob(b){
    const{pts,col}=b;
    ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++)ctx.lineTo(pts[i].x,pts[i].y);
    ctx.closePath();
    ctx.fillStyle=col;ctx.fill();
    ctx.strokeStyle=col.replace(/[\d.]+\)$/,'0.8)');ctx.lineWidth=2;ctx.stroke();
    // sheen
    const grd=ctx.createRadialGradient(b.cx-b.r*0.3,b.cy-b.r*0.3,0,b.cx,b.cy,b.r*1.1);
    grd.addColorStop(0,'rgba(255,255,255,0.18)');grd.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle=grd;ctx.fill();
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    for(const b of blobs)stepBlob(b);
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    // floor line
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.06)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(0,H-4);ctx.lineTo(W,H-4);ctx.stroke();
    for(const b of blobs)drawBlob(b);
    // cursor indicator
    if(mouse.x>0){
      ctx.beginPath();ctx.arc(mouse.x,mouse.y,mouse.down?22:14,0,Math.PI*2);
      ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.15)';ctx.lineWidth=1;ctx.stroke();
    }
  }

  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
  c.addEventListener('mousedown',()=>mouse.down=true);
  c.addEventListener('mouseup',()=>mouse.down=false);
  c.addEventListener('mouseleave',()=>{mouse.x=-999;mouse.y=-999;mouse.down=false;});
  mkBtn('Reset',ctrl).addEventListener('click',reset);
  const cntLbl=document.createElement('span');cntLbl.className='sb-info sb-speed-lbl';cntLbl.style.marginLeft='4px';cntLbl.textContent='blobs';ctrl.appendChild(cntLbl);
  const bsl=document.createElement('input');bsl.type='range';bsl.className='sb-slider';bsl.min=1;bsl.max=6;bsl.step=1;bsl.value=blobs.length;ctrl.appendChild(bsl);styleSlider(bsl);
  bsl.addEventListener('input',()=>{
    const n=+bsl.value;
    while(blobs.length<n)blobs.push(mkBlob(rndf(W*0.2,W*0.8),rndf(H*0.2,H*0.7),Math.min(W,H)*(0.08+Math.random()*0.12),`hsla(${Math.random()*360},70%,${isPaper()?'45':'65'}%,0.55)`));
    while(blobs.length>n)blobs.pop();
  });
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

