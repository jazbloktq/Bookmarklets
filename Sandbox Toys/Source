  };

  let hintVisible=false;

  const MAX_WRONG=6;
  let word,guessed,wrong,gameState,score,streak;

  function pickWord(){
    const list=WORDS[difficulty];
    return list[Math.floor(Math.random()*list.length)];
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    word=pickWord(); guessed=new Set(); wrong=0; gameState='playing';
    hintVisible=false;
    if(!score){score=0;streak=0;}
  }
  init();

  function guess(letter){
    if(gameState!=='playing'||guessed.has(letter)) return;
    guessed.add(letter);
    if(word.includes(letter)){
      // check win
      if([...word].every(l=>guessed.has(l))){
        gameState='win'; score+=100*(difficulty+1)*(streak+1); streak++;
      }
    } else {
      wrong++;
      if(wrong>=MAX_WRONG){gameState='lose';streak=0;}
    }
  }

  function drawGallows(ox,oy,sz){
    const paper=isPaper();
    ctx.strokeStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.35)';
    ctx.lineWidth=3; ctx.lineCap='round';
    // Base
    ctx.beginPath();ctx.moveTo(ox,oy+sz);ctx.lineTo(ox+sz*0.7,oy+sz);ctx.stroke();
    // Pole
    ctx.beginPath();ctx.moveTo(ox+sz*0.2,oy+sz);ctx.lineTo(ox+sz*0.2,oy);ctx.stroke();
    // Arm
    ctx.beginPath();ctx.moveTo(ox+sz*0.2,oy);ctx.lineTo(ox+sz*0.6,oy);ctx.stroke();
    // Rope
    ctx.beginPath();ctx.moveTo(ox+sz*0.6,oy);ctx.lineTo(ox+sz*0.6,oy+sz*0.15);ctx.stroke();

    if(wrong===0) return;
    const hx=ox+sz*0.6, hy=oy+sz*0.18;
    const headR=sz*0.1;
    const col=gameState==='lose'?'#ff4444':'rgba(200,180,140,1)';
    ctx.strokeStyle=col; ctx.lineWidth=2.5;

    // Head
    ctx.beginPath();ctx.arc(hx,hy+headR,headR,0,Math.PI*2);ctx.stroke();
    if(wrong<2) return;
    // Body
    ctx.beginPath();ctx.moveTo(hx,hy+headR*2);ctx.lineTo(hx,hy+headR*2+sz*0.22);ctx.stroke();
    if(wrong<3) return;
    // Left arm
    ctx.beginPath();ctx.moveTo(hx,hy+headR*2+sz*0.06);ctx.lineTo(hx-sz*0.12,hy+headR*2+sz*0.16);ctx.stroke();
    if(wrong<4) return;
    // Right arm
    ctx.beginPath();ctx.moveTo(hx,hy+headR*2+sz*0.06);ctx.lineTo(hx+sz*0.12,hy+headR*2+sz*0.16);ctx.stroke();
    if(wrong<5) return;
    // Left leg
    ctx.beginPath();ctx.moveTo(hx,hy+headR*2+sz*0.22);ctx.lineTo(hx-sz*0.1,hy+headR*2+sz*0.36);ctx.stroke();
    if(wrong<6) return;
    // Right leg
    ctx.beginPath();ctx.moveTo(hx,hy+headR*2+sz*0.22);ctx.lineTo(hx+sz*0.1,hy+headR*2+sz*0.36);ctx.stroke();
    // X eyes if dead
    if(gameState==='lose'){
      ctx.lineWidth=1.5;
      const ex=hx,ey=hy+headR;
      ctx.beginPath();ctx.moveTo(ex-headR*0.4,ey-headR*0.25);ctx.lineTo(ex-headR*0.1,ey+headR*0.1);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ex-headR*0.4,ey+headR*0.1);ctx.lineTo(ex-headR*0.1,ey-headR*0.25);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ex+headR*0.1,ey-headR*0.25);ctx.lineTo(ex+headR*0.4,ey+headR*0.1);ctx.stroke();
      ctx.beginPath();ctx.moveTo(ex+headR*0.1,ey+headR*0.1);ctx.lineTo(ex+headR*0.4,ey-headR*0.25);ctx.stroke();
    }
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);

    // Layout: gallows left third, content right
    // Keyboard always anchored to BOTTOM of canvas with padding, scaled to fit
    const kbRows=['qwertyuiop','asdfghjkl','zxcvbnm'];
    const maxRowLen=10; // qwertyuiop
    const kbPad=10;
    const kbBottomPad=10;
    // Size keys so all 3 rows + gaps fit in bottom 28% of canvas, max 30px wide
    const kbTotalH=Math.min(H*0.28, 110);
    const kh=Math.floor((kbTotalH - kbPad*2) / 3) - 4;
    const kw=Math.min(kh*0.9, Math.floor((W - kbPad*2) / (maxRowLen + 0.5)));
    const kgap=Math.max(2, Math.floor(kw*0.1));
    const kbStartY=H - kbBottomPad - kbRows.length*(kh+kgap) + kgap;

    // Draw gallows in top-left quadrant
    const gallowsZone=Math.min(W*0.45, kbStartY*0.9);
    const sz=gallowsZone*0.85;
    const gallowsOx=W*0.04, gallowsOy=(kbStartY-sz)*0.3;
    drawGallows(gallowsOx,gallowsOy,sz);

    // Word blanks — centred horizontally, vertically between gallows and keyboard
    const letters=[...word];
    const wordZoneTop=gallowsOy+sz*0.5;
    const wordZoneBot=kbStartY-12;
    const wordCY=(wordZoneTop+wordZoneBot)/2;
    const maxLetterW=Math.min(32,(W*0.9)/letters.length);
    const totalWordW=letters.length*maxLetterW;
    const wordStartX=(W-totalWordW)/2;

    ctx.textAlign='center'; ctx.textBaseline='middle';
    for(let i=0;i<letters.length;i++){
      const lx=wordStartX+i*maxLetterW+maxLetterW/2;
      const revealed=guessed.has(letters[i]);
      ctx.strokeStyle=paper?'rgba(0,0,0,0.28)':'rgba(255,255,255,0.28)';
      ctx.lineWidth=1.5;
      ctx.beginPath();ctx.moveTo(lx-maxLetterW*0.38,wordCY+maxLetterW*0.52);ctx.lineTo(lx+maxLetterW*0.38,wordCY+maxLetterW*0.52);ctx.stroke();
      if(revealed||(gameState==='lose')){
        ctx.fillStyle=revealed?(paper?'#111':'#eee'):(paper?'#cc2222':'#ff4444');
        ctx.font=`500 ${Math.floor(maxLetterW*0.65)}px 'IBM Plex Mono',monospace`;
        ctx.fillText(letters[i].toUpperCase(),lx,wordCY);
      }
    }

    // Wrong guesses + hint — right side of gallows
    const infoX=gallowsOx+sz*0.75;
    const infoY=gallowsOy+sz*0.5;
    const wrongLetters=[...guessed].filter(l=>!word.includes(l));
    ctx.fillStyle=paper?'rgba(180,40,20,0.75)':'rgba(255,90,70,0.8)';
    ctx.font=`300 10px 'IBM Plex Mono',monospace`; ctx.textAlign='left'; ctx.textBaseline='top';
    if(wrongLetters.length) ctx.fillText(`wrong: ${wrongLetters.map(l=>l.toUpperCase()).join(' ')}`,infoX,infoY);
    const hint=(HINTS[difficulty]||{})[word];
    if(hint&&hintVisible){
      ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.28)';
      ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.fillText(`hint: ${hint}`,infoX,infoY+16);
    }
    ctx.fillStyle=paper?'rgba(0,0,0,0.32)':'rgba(255,255,255,0.32)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillText(`${MAX_WRONG-wrong} wrong guesses left`,infoX,infoY+30);

    // Keyboard — always fits, anchored to bottom
    for(let ri=0;ri<kbRows.length;ri++){
      const row=kbRows[ri];
      const rowTotalW=row.length*(kw+kgap)-kgap;
      const kbX=Math.floor((W-rowTotalW)/2);
      const ly=kbStartY+ri*(kh+kgap);
      for(let ci=0;ci<row.length;ci++){
        const letter=row[ci];
        const lx=kbX+ci*(kw+kgap);
        const isGuessed=guessed.has(letter);
        const isCorrect=isGuessed&&word.includes(letter);
        const isWrong=isGuessed&&!word.includes(letter);
        // Key bg
        ctx.fillStyle=isCorrect
          ?(paper?'#3a7a2a':'#33bb55')
          :isWrong
          ?(paper?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.06)')
          :(paper?'rgba(0,0,0,0.11)':'rgba(255,255,255,0.13)');
        roundRect(ctx,lx,ly,kw,kh,3); ctx.fill();
        // Key border
        ctx.strokeStyle=paper?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.1)';
        ctx.lineWidth=0.5; roundRect(ctx,lx,ly,kw,kh,3); ctx.stroke();
        // Letter
        ctx.fillStyle=isWrong
          ?(paper?'rgba(0,0,0,0.18)':'rgba(255,255,255,0.18)')
          :(paper?'rgba(0,0,0,0.8)':'rgba(255,255,255,0.85)');
        ctx.font=`400 ${Math.max(8,Math.floor(kw*0.52))}px 'IBM Plex Mono',monospace`;
        ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText(letter,lx+kw/2,ly+kh/2);
      }
    }

    // Status message
    ctx.textAlign='center'; ctx.textBaseline='middle';
    if(gameState==='win'){
      ctx.fillStyle=paper?'#226622':'#44ff88';
      ctx.font=`500 13px 'IBM Plex Mono',monospace`;
      ctx.fillText(`✓  "${word.toUpperCase()}"  ·  press Enter or click for next`,W/2,gallowsOy+sz*0.15);
    } else if(gameState==='lose'){
      ctx.fillStyle=paper?'#882222':'#ff4444';
      ctx.font=`500 13px 'IBM Plex Mono',monospace`;
      ctx.fillText(`"${word.toUpperCase()}"  ·  press Enter or click for next`,W/2,gallowsOy+sz*0.15);
    }

    // Top HUD
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`; ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillText(`score: ${score}  streak: ${streak}  ·  type or click letters`,8,6);
  }

  c.addEventListener('click',e=>{
    if(gameState!=='playing'){init();return;}
    const r2=c.getBoundingClientRect();
    const mx=e.clientX-r2.left, my=e.clientY-r2.top;
    const kbRows=['qwertyuiop','asdfghjkl','zxcvbnm'];
    const maxRowLen=10;
    const kbPad=10, kbBottomPad=10;
    const kbTotalH=Math.min(H*0.28,110);
    const kh=Math.floor((kbTotalH-kbPad*2)/3)-4;
    const kw=Math.min(kh*0.9,Math.floor((W-kbPad*2)/(maxRowLen+0.5)));
    const kgap=Math.max(2,Math.floor(kw*0.1));
    const kbStartY=H-kbBottomPad-kbRows.length*(kh+kgap)+kgap;
    for(let ri=0;ri<kbRows.length;ri++){
      const row=kbRows[ri];
      const rowTotalW=row.length*(kw+kgap)-kgap;
      const kbX=Math.floor((W-rowTotalW)/2);
      const ly=kbStartY+ri*(kh+kgap);
      for(let ci=0;ci<row.length;ci++){
        const lx=kbX+ci*(kw+kgap);
        if(mx>=lx&&mx<=lx+kw&&my>=ly&&my<=ly+kh){guess(row[ci]);return;}
      }
    }
  });

  const onKey=e=>{
    if(e.key.length===1&&/[a-z]/i.test(e.key)) guess(e.key.toLowerCase());
    if(e.key==='Enter'&&gameState!=='playing') init();
  };
  document.addEventListener('keydown',onKey);

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];score=0;streak=0;init();});
  mkBtn('New Word',ctrl).addEventListener('click',()=>{score=score;init();});
  const hintBtn=mkBtn('Hint',ctrl);
  hintBtn.addEventListener('click',()=>{hintVisible=!hintVisible;});

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}

