 #  #####  #
 ####   ####`,
    // 50
    `       ####
       #  ##
       #   ##
       # $$ ##
     ###$  $ ##
  ####    $   #
###  # #####  #
#    # #....$ #
# #   $ ....# #
#  $ # #.*..# #
###  #### ### #
  #### @$  ##$##
     ### $     #
       #  ##   #
       #########`,
    // 51
    `      ############
     ##..    #   #
    ##..* $    $ #
   ##..*.# # #$ ##
   #..*.# # # $  #
####...#  #    # #
#  ## #          #
# @$ $ ###  # # ##
# $   $   # #   #
###$$   # # # # #
  #   $   # # #####
  # $# #####      #
  #$   #   #   #  #
  #  ###   ##     #
  #  #      #    ##
  ####      ######`,
  ];

  // Parse a level string into a 2D grid and find player/boxes/goals
  function parseLevel(str) {
    const rows = str.split('\n');
    const grid = rows.map(r => r.split(''));
    let player = {x:0,y:0};
    const boxes = [], goals = [];
    for (let y=0; y<grid.length; y++) {
      for (let x=0; x<(grid[y]||[]).length; x++) {
        const ch = grid[y][x];
        if (ch==='@'||ch==='+') { player={x,y}; grid[y][x]=ch==='+'?'.':' '; }
        if (ch==='$'||ch==='*') { boxes.push({x,y}); grid[y][x]=ch==='*'?'.':' '; }
        if (ch==='.'||ch==='*'||ch==='+') goals.push({x,y});
      }
    }
    // Remove duplicate goals caused by player-on-goal / box-on-goal parsing
    const uniqueGoals = [];
    const seen = new Set();
    for (const g of goals) { const k=`${g.x},${g.y}`; if(!seen.has(k)){seen.add(k);uniqueGoals.push(g);} }
    return { grid, player, boxes, goals: uniqueGoals };
  }

  let currentLevel = 0;
  let state, history, moves, pushes;
  let completed = new Set(); // which levels have been beaten
  let showSelector = false;

  function loadLevel(idx) {
    currentLevel = idx;
    const parsed = parseLevel(LEVELS[idx]);
    state = parsed;
    history = [];
    moves = 0; pushes = 0;
    showSelector = false;
  }
  loadLevel(0);

  function cell(x, y) {
    const row = state.grid[y];
    return row ? (row[x] || ' ') : ' ';
  }
  function isWall(x, y) { return cell(x,y) === '#'; }
  function isGoal(x, y) { return cell(x,y) === '.'; }
  function boxAt(x, y) { return state.boxes.find(b=>b.x===x&&b.y===y); }
  function isSolved() { return state.boxes.every(b=>isGoal(b.x,b.y)); }

  function move(dx, dy) {
    if (isSolved()) return;
    const nx = state.player.x+dx, ny = state.player.y+dy;
    if (isWall(nx,ny)) return;
    const box = boxAt(nx,ny);
    if (box) {
      const bx=nx+dx, by=ny+dy;
      if (isWall(bx,by) || boxAt(bx,by)) return;
      // Save undo snapshot
      history.push({ player:{...state.player}, boxes: state.boxes.map(b=>({...b})) });
      box.x=bx; box.y=by;
      pushes++;
    } else {
      history.push({ player:{...state.player}, boxes: state.boxes.map(b=>({...b})) });
    }
    state.player.x=nx; state.player.y=ny;
    moves++;
    if (isSolved()) completed.add(currentLevel);
  }

  function undo() {
    if (!history.length) return;
    const snap = history.pop();
    state.player = snap.player;
    state.boxes = snap.boxes;
    moves = Math.max(0, moves-1);
  }

  // ── Input ─────────────────────────────────────────────────────────────────
  const KEY_MAP = { ArrowUp:[0,-1], ArrowDown:[0,1], ArrowLeft:[-1,0], ArrowRight:[1,0],
                    w:[0,-1], s:[0,1], a:[-1,0], d:[1,0] };
  function onKey(e) {
    if (showSelector) {
      if (e.key==='Escape') { showSelector=false; e.preventDefault(); }
      return;
    }
    const d = KEY_MAP[e.key];
    if (d) { e.preventDefault(); if (!isSolved()) move(d[0],d[1]); return; }
    if (e.key==='z'||e.key==='Z') { e.preventDefault(); undo(); }
    if (e.key==='r'||e.key==='R') { e.preventDefault(); loadLevel(currentLevel); }
  }
  document.addEventListener('keydown', onKey);

  // Touch/click drag for mobile
  let touchStart = null;
  c.addEventListener('touchstart', e=>{ touchStart={x:e.touches[0].clientX,y:e.touches[0].clientY}; e.preventDefault(); }, {passive:false});
  c.addEventListener('touchend', e=>{
    if (!touchStart) return;
    const dx=e.changedTouches[0].clientX-touchStart.x, dy=e.changedTouches[0].clientY-touchStart.y;
    if (Math.abs(dx)<10&&Math.abs(dy)<10) return;
    if (Math.abs(dx)>Math.abs(dy)) move(dx>0?1:-1,0); else move(0,dy>0?1:-1);
    touchStart=null; e.preventDefault();
  }, {passive:false});

  // ── Draw ─────────────────────────────────────────────────────────────────
  function draw() {
    raf = requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper = isPaper();

    ctx.fillStyle = bgClr(); ctx.fillRect(0,0,W,H);

    if (showSelector) { drawSelector(); return; }

    const rows = state.grid.length;
    const cols = Math.max(...state.grid.map(r=>r.length));
    const infoH = 48;
    const cs = Math.min(Math.floor((W-16)/cols), Math.floor((H-infoH-16)/rows));
    const ox = Math.round((W - cs*cols)/2);
    const oy = Math.round((H - infoH - cs*rows)/2);

    // Draw grid
    for (let y=0; y<rows; y++) {
      for (let x=0; x<cols; x++) {
        const ch = cell(x,y);
        const px=ox+x*cs, py=oy+y*cs;
        if (ch===' ') continue;

        if (ch==='#') {
          // Wall
          ctx.fillStyle = paper ? '#8a7a60' : '#3a3a5a';
          ctx.fillRect(px,py,cs,cs);
          ctx.fillStyle = paper ? '#a09070' : '#4a4a6a';
          ctx.fillRect(px,py,cs,cs-2);
          ctx.fillStyle = paper ? '#6a5a40' : '#2a2a4a';
          ctx.fillRect(px,py+cs-2,cs,2);
        } else {
          // Floor
          ctx.fillStyle = paper ? '#f0ece0' : '#1a1a2a';
          ctx.fillRect(px,py,cs,cs);
          if (ch==='.') {
            // Goal
            ctx.strokeStyle = paper ? '#c0392b' : '#ff6644';
            ctx.lineWidth = Math.max(1.5, cs*0.08);
            const m=cs*0.25;
            ctx.beginPath();
            ctx.moveTo(px+m,py+cs/2); ctx.lineTo(px+cs-m,py+cs/2);
            ctx.moveTo(px+cs/2,py+m); ctx.lineTo(px+cs/2,py+cs-m);
            ctx.stroke();
          }
        }
      }
    }

    // Draw boxes
    for (const b of state.boxes) {
      const px=ox+b.x*cs, py=oy+b.y*cs;
      const onGoal = isGoal(b.x,b.y);
      const pad = Math.max(2, cs*0.1);
      ctx.fillStyle = onGoal ? (paper?'#c0392b':'#ff6644') : (paper?'#8b6914':'#c49a14');
      ctx.fillRect(px+pad,py+pad,cs-pad*2,cs-pad*2);
      ctx.strokeStyle = onGoal ? (paper?'#8b2222':'#cc3322') : (paper?'#6b4a00':'#a07800');
      ctx.lineWidth=1.5;
      ctx.strokeRect(px+pad,py+pad,cs-pad*2,cs-pad*2);
      // Cross mark
      ctx.strokeStyle = onGoal ? (paper?'rgba(255,255,255,0.6)':'rgba(255,255,255,0.5)') : (paper?'rgba(255,255,255,0.4)':'rgba(0,0,0,0.3)');
      ctx.lineWidth=1;
      const m2=cs*0.28;
      ctx.beginPath();
      ctx.moveTo(px+cs/2-m2,py+cs/2-m2); ctx.lineTo(px+cs/2+m2,py+cs/2+m2);
      ctx.moveTo(px+cs/2+m2,py+cs/2-m2); ctx.lineTo(px+cs/2-m2,py+cs/2+m2);
      ctx.stroke();
    }

    // Draw player
    {
      const px=ox+state.player.x*cs, py=oy+state.player.y*cs;
      const cx2=px+cs/2, cy2=py+cs/2, r=cs*0.35;
      ctx.fillStyle = paper?'#2255bb':'#4488ff';
      ctx.beginPath(); ctx.arc(cx2,cy2,r,0,Math.PI*2); ctx.fill();
      // Face
      ctx.fillStyle = paper?'rgba(255,255,255,0.8)':'rgba(255,255,255,0.9)';
      ctx.beginPath(); ctx.arc(cx2-r*0.28,cy2-r*0.15,r*0.18,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(cx2+r*0.28,cy2-r*0.15,r*0.18,0,Math.PI*2); ctx.fill();
    }

    // Solved overlay
    if (isSolved()) {
      ctx.fillStyle = paper?'rgba(245,241,232,0.82)':'rgba(10,10,9,0.82)';
      ctx.fillRect(0,0,W,H);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillStyle = paper?'#2255bb':'#88aaff';
      ctx.font=`300 22px 'IBM Plex Mono',monospace`;
      ctx.fillText('Solved!', W/2, H/2-24);
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;
      ctx.fillStyle = paper?'rgba(0,0,0,0.45)':'rgba(255,255,255,0.5)';
      ctx.fillText(`${moves} moves · ${pushes} pushes`, W/2, H/2+6);
      ctx.fillText('→ or N for next level', W/2, H/2+26);
      ctx.textAlign='left';
    }

    // HUD
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.35)';
    const hy=oy+cs*rows+8;
    ctx.fillText(`Level ${currentLevel+1}/50  ·  moves ${moves}  ·  pushes ${pushes}`, ox, hy);
    ctx.textAlign='right';
    ctx.fillText(`${completed.size}/50 done`, W-ox, hy);
    ctx.textAlign='left';
  }

  function drawSelector() {
    const paper=isPaper();
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
    ctx.textAlign='center'; ctx.textBaseline='top';
    ctx.font=`300 11px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
    ctx.fillText('Select Level', W/2, 14);

    const cols=10, rows2=5;
    const bw=32,bh=28,gap=6;
    const gw=(bw+gap)*cols-gap, gh=(bh+gap)*rows2-gap;
    const ox2=(W-gw)/2, oy2=50;

    for (let i=0;i<50;i++) {
      const col=i%cols, row=Math.floor(i/cols);
      const bx=ox2+col*(bw+gap), by=oy2+row*(bh+gap);
      const done=completed.has(i), cur=i===currentLevel;
      ctx.fillStyle=cur?(paper?'#2255bb':'#4488ff'):done?(paper?'rgba(0,0,0,0.12)':'rgba(255,255,255,0.1)'):(paper?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.05)');
      ctx.fillRect(bx,by,bw,bh);
      ctx.strokeStyle=cur?(paper?'#2255bb':'#4488ff'):done?(paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.25)'):(paper?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.12)');
      ctx.lineWidth=1; ctx.strokeRect(bx,by,bw,bh);
      ctx.fillStyle=cur?'#fff':done?(paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)'):(paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.35)');
      ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(String(i+1).padStart(2,'0'), bx+bw/2, by+bh/2);
    }
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
    ctx.textAlign='center';
    ctx.fillText('click a level to play · Esc to close', W/2, oy2+rows2*(bh+gap)+8);
  }

  c.addEventListener('click', e => {
    if (showSelector) {
      const cols=10, bw=32,bh=28,gap=6;
      const gw=(bw+gap)*cols-gap;
      const ox2=(W-gw)/2, oy2=50;
      const mx=e.clientX-c.getBoundingClientRect().left;
      const my=e.clientY-c.getBoundingClientRect().top;
      for (let i=0;i<50;i++) {
        const col=i%cols, row=Math.floor(i/cols);
        const bx=ox2+col*(bw+gap), by=oy2+row*(bh+gap);
        if (mx>=bx&&mx<bx+bw&&my>=by&&my<by+bh) { loadLevel(i); return; }
      }
      showSelector=false; return;
    }
    if (isSolved()) { loadLevel(Math.min(49, currentLevel+1)); }
  });

  mkBtn('Restart',ctrl).addEventListener('click',()=>loadLevel(currentLevel));
  mkBtn('Undo',ctrl).addEventListener('click',()=>undo());
  mkBtn('Levels',ctrl).addEventListener('click',()=>{ showSelector=!showSelector; });
  mkBtn('Prev',ctrl).addEventListener('click',()=>loadLevel(Math.max(0,currentLevel-1)));
  mkBtn('Next',ctrl).addEventListener('click',()=>loadLevel(Math.min(49,currentLevel+1)));
  const infoEl=mkInfo(ctrl); infoEl.textContent='arrows · WASD · Z undo';

  requestAnimationFrame(draw);
  return ()=>{ cancelAnimationFrame(raf); ro.disconnect(); document.removeEventListener('keydown',onKey); };
}

// ════════════════════════════════════════════════════════════════════════════
// TOY — 8-BALL POOL
// ════════════════════════════════════════════════════════════════════════════
function init8Ball(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height, raf;

  // ── Constants ─────────────────────────────────────────────────────────────
  const BALL_R = 11;
  const FRICTION = 0.985;
  const MIN_SPD = 0.08;
  const POCKET_R = BALL_R * 1.82;
  const CUE_MAX_POWER = 18;

  // Ball colours: 0=cue(white), 1-7=solids, 8=eight, 9-15=stripes
  const BALL_COLORS = [
    '#f5f5f5',  // 0 cue
    '#f5c518',  // 1 yellow solid
    '#1a5fb4',  // 2 blue solid
    '#c01c28',  // 3 red solid
    '#613583',  // 4 purple solid
    '#c64600',  // 5 orange solid
    '#26a269',  // 6 green solid
    '#8b0000',  // 7 maroon solid
    '#1a1a1a',  // 8 eight ball
    '#f5c518',  // 9  yellow stripe
    '#1a5fb4',  // 10 blue stripe
    '#c01c28',  // 11 red stripe
    '#613583',  // 12 purple stripe
    '#c64600',  // 13 orange stripe
    '#26a269',  // 14 green stripe
    '#8b0000',  // 15 maroon stripe
  ];

  // ── Game state ────────────────────────────────────────────────────────────
  let balls, pockets, turn, groups, gameOver, winner, message;
  let shooting, aimStart, aimCurrent, dragging;
  let ballInHand, ballInHandPos;
  let breaking;
  let aiTimer;
  let difficulty=1; // 0=easy, 1=medium, 2=hard
  let aiThinking=false;
  let rotSensitivity=1.0; // multiplier for mouse rotation speed
  let keysHeld={}; // for W/S/arrow power control
  let keyPower=0;  // power set via keyboard (0 = use drag)

  function tableRect() {
    const pad=40, railW=18;
    const tw=W-pad*2, th=tw*0.5;
    const ox=(W-tw)/2, oy=(H-th)/2;
    return { ox:ox+railW, oy:oy+railW, tw:tw-railW*2, th:th-railW*2, rox:ox, roy:oy, rtw:tw, rth:th };
  }

  function initBalls() {
    const t=tableRect();
    const cx=t.ox+t.tw/2, cy=t.oy+t.th/2;
    const footX=t.ox+t.tw*0.75; // rack at 3/4

    // Rack triangle: 5 rows
    const order=[1,9,2,10,8,3,11,4,12,5,13,6,14,7,15]; // standard rack order
    const blist=[];
    let bi=0;
    const s=BALL_R*2.05;
    for (let row=0;row<5;row++) {
      for (let col=0;col<=row;col++) {
        const bx=footX+row*s*Math.cos(Math.PI/6);
        const by=cy+(col-(row/2))*s;
        blist.push({id:order[bi++],x:bx,y:by,vx:0,vy:0,pocketed:false,r:BALL_R});
      }
    }
    // Cue ball
    blist.unshift({id:0,x:t.ox+t.tw*0.25,y:cy,vx:0,vy:0,pocketed:false,r:BALL_R});

    // Pockets: 4 corners + 2 middle — placed at rail/felt junction
    const railW=18;
    pockets=[
      {x:t.ox-railW*0.3,        y:t.oy-railW*0.3},
      {x:t.ox+t.tw/2,           y:t.oy-railW*0.5},
      {x:t.ox+t.tw+railW*0.3,   y:t.oy-railW*0.3},
      {x:t.ox-railW*0.3,        y:t.oy+t.th+railW*0.3},
      {x:t.ox+t.tw/2,           y:t.oy+t.th+railW*0.5},
      {x:t.ox+t.tw+railW*0.3,   y:t.oy+t.th+railW*0.3},
    ];
    return blist;
  }

  function initGame() {
    balls=initBalls();
    turn=0; // 0=P1/human, 1=P2/AI
    groups=[null,null]; // null=unassigned, 'solids', 'stripes'
    gameOver=false; winner=-1; message=''; shooting=false; dragging=false;
    ballInHand=false; ballInHandPos=null; breaking=true; aiTimer=0;
  }
  initGame();

  function cueBall() { return balls.find(b=>b.id===0); }
  function eightBall() { return balls.find(b=>b.id===8); }
  function anyMoving() { return balls.some(b=>!b.pocketed&&(Math.abs(b.vx)>MIN_SPD||Math.abs(b.vy)>MIN_SPD)); }

  function applyShot(vx,vy) {
    const cb=cueBall(); if(!cb||cb.pocketed) return;
    cb.vx=vx; cb.vy=vy;
    shooting=false; dragging=false; breaking=false;
  }

  // ── Physics ───────────────────────────────────────────────────────────────
  function stepPhysics() {
    const t=tableRect();
    const pocketed_this_frame=[];

    for (const b of balls) {
      if (b.pocketed) continue;
      b.x+=b.vx; b.y+=b.vy;
      b.vx*=FRICTION; b.vy*=FRICTION;
      if (Math.abs(b.vx)<MIN_SPD) b.vx=0;
      if (Math.abs(b.vy)<MIN_SPD) b.vy=0;

      // Pocket check FIRST — before wall bounce
      let pocketed=false;
      for (const p of pockets) {
        const dx=b.x-p.x, dy=b.y-p.y;
        if (dx*dx+dy*dy<POCKET_R*POCKET_R) {
          b.pocketed=true; b.vx=0; b.vy=0;
          pocketed_this_frame.push(b); pocketed=true; break;
        }
      }
      if (pocketed) continue;

      // Wall bounces — but suppress near pocket openings so balls roll in
      const nearPocket=(wx,wy)=>pockets.some(p=>{
        const dx=wx-p.x, dy=wy-p.y;
        return dx*dx+dy*dy < (POCKET_R*2.2)**2;
      });

      if (b.x-b.r<t.ox     && !nearPocket(t.ox,     b.y)) { b.x=t.ox+b.r;     b.vx=Math.abs(b.vx)*0.75; }
      if (b.x+b.r>t.ox+t.tw && !nearPocket(t.ox+t.tw,b.y)) { b.x=t.ox+t.tw-b.r; b.vx=-Math.abs(b.vx)*0.75; }
      if (b.y-b.r<t.oy     && !nearPocket(b.x,     t.oy)) { b.y=t.oy+b.r;     b.vy=Math.abs(b.vy)*0.75; }
      if (b.y+b.r>t.oy+t.th && !nearPocket(b.x,t.oy+t.th)) { b.y=t.oy+t.th-b.r; b.vy=-Math.abs(b.vy)*0.75; }
    }

    // Ball-ball collisions
    for (let i=0;i<balls.length;i++) {
      for (let j=i+1;j<balls.length;j++) {
        const a=balls[i], b2=balls[j];
        if (a.pocketed||b2.pocketed) continue;
        const dx=b2.x-a.x, dy=b2.y-a.y;
        const dist=Math.sqrt(dx*dx+dy*dy);
        const minD=a.r+b2.r;
        if (dist<minD&&dist>0.01) {
          const nx=dx/dist, ny=dy/dist;
          const overlap=(minD-dist)/2;
          a.x-=nx*overlap; a.y-=ny*overlap;
          b2.x+=nx*overlap; b2.y+=ny*overlap;
          const dvx=a.vx-b2.vx, dvy=a.vy-b2.vy;
          const dot=dvx*nx+dvy*ny;
          if (dot>0) {
            const imp=dot*0.92;
            a.vx-=imp*nx; a.vy-=imp*ny;
            b2.vx+=imp*nx; b2.vy+=imp*ny;
          }
        }
      }
    }

    return pocketed_this_frame;
  }

  // ── Turn / rules logic ────────────────────────────────────────────────────
  let pendingPocketed=[];
  let shotInProgress=false;
  let foulThisShot=false;

  function onShotSettled() {
    shotInProgress=false;
    const cb=cueBall();
    const pocketed=pendingPocketed;
    pendingPocketed=[];
    const cuePocketed=pocketed.some(b=>b.id===0);
    const eightPocketed=pocketed.some(b=>b.id===8);
    const others=pocketed.filter(b=>b.id!==0&&b.id!==8);

    if (eightPocketed) {
      // Win if correct group cleared, foul otherwise
      const myGroup=groups[turn];
      const myBallsLeft=balls.filter(b=>!b.pocketed&&b.id!==0&&b.id!==8&&groupOf(b.id)===myGroup).length;
      if (myBallsLeft===0&&!cuePocketed&&!foulThisShot) {
        winner=turn; gameOver=true; message=twoPlayer?`Player ${turn+1} wins!`:(turn===0?'You win!':'AI wins!');
      } else {
        winner=1-turn; gameOver=true; message=twoPlayer?`Player ${turn+1} loses!`:(turn===0?'You lose!':'AI loses!');
      }
      foulThisShot=false; return;
    }

    // Assign groups on break if solids/stripes pocketed
    if (groups[turn]===null && others.length>0) {
      const hasS=others.some(b=>b.id<=7), hasT=others.some(b=>b.id>=9);
      if (hasS&&!hasT)       { groups[turn]='solids';  groups[1-turn]='stripes'; }
      else if (hasT&&!hasS)  { groups[turn]='stripes'; groups[1-turn]='solids';  }
    }

    let scoredOwn = others.length>0 && groups[turn]!==null && others.some(b=>groupOf(b.id)===groups[turn]);
    let fouled = cuePocketed || foulThisShot;
    foulThisShot=false;

    if (cuePocketed) { ballInHand=true; cb.pocketed=false; const t2=tableRect(); cb.x=t2.ox+t2.tw*0.25; cb.y=t2.oy+t2.th/2; cb.vx=0;cb.vy=0; }

    if (!fouled && scoredOwn) {
      // Same player goes again
      message='';
    } else {
      turn=1-turn;
      message=fouled?'Foul — ball in hand':'';
    }
  }

  function groupOf(id) { return id>=1&&id<=7?'solids':id>=9?'stripes':null; }

  // ── AI ────────────────────────────────────────────────────────────────────
  // Ghost-ball: angle to hit target ball into pocket
  function ghostBallAngle(cb, target, pocket) {
    // Direction from target to pocket
    const dx=pocket.x-target.x, dy=pocket.y-target.y;
    const dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<0.01) return null;
    const nx=dx/dist, ny=dy/dist;
    // Ghost ball position (cue ball should land here)
    const gx=target.x-nx*(BALL_R*2), gy=target.y-ny*(BALL_R*2);
    // Angle from cue ball to ghost ball
    return Math.atan2(gy-cb.y, gx-cb.x);
  }

  // Score a shot: higher = better
  function scoreShot(cb, target, pocket, angle) {
    const t=tableRect();
    // Check ghost ball is reachable (rough)
    const nx=Math.cos(angle), ny=Math.sin(angle);
    const gx=target.x-nx*(BALL_R*2)*0, gy=target.y-ny*(BALL_R*2)*0;
    // Prefer pocket shots over random hits
    const dpx=pocket.x-target.x, dpy=pocket.y-target.y;
    const pocketDist=Math.sqrt(dpx*dpx+dpy*dpy);
    const cbDist=Math.sqrt((target.x-cb.x)**2+(target.y-cb.y)**2);
    // Prefer closer balls and closer pockets
    return 1000 / (pocketDist*0.5 + cbDist*0.3 + 1);
  }

  function doAIShot() {
    if(aiThinking) return;
    const cb=cueBall(); if (!cb||cb.pocketed) return;
    aiThinking=true;

    // Thinking delay: easy=fast+random, medium=realistic, hard=deliberate
    const thinkMs = difficulty===0 ? 300+Math.random()*400
                  : difficulty===1 ? 700+Math.random()*600
                  :                  1200+Math.random()*800;

    setTimeout(()=>{
      if(gameOver){aiThinking=false;return;}
      const cb2=cueBall(); if(!cb2||cb2.pocketed){aiThinking=false;return;}

      const myGroup=groups[1]||'solids';
      const targets=balls.filter(b=>!b.pocketed&&b.id!==0&&(groups[1]===null||groupOf(b.id)===myGroup));

      let bestAngle=Math.random()*Math.PI*2, bestPower=8;
      let bestScore=-Infinity;

      if(targets.length>0) {
        for(const target of targets) {
          for(const pocket of pockets) {
            const angle=ghostBallAngle(cb2, target, pocket);
            if(angle===null) continue;
            const s=scoreShot(cb2, target, pocket, angle);
            if(s>bestScore){ bestScore=s; bestAngle=angle; }
          }
        }
        // Power based on distance
        const best=targets.reduce((a,b2)=>{ const da=(a.x-cb2.x)**2+(a.y-cb2.y)**2, db=(b2.x-cb2.x)**2+(b2.y-cb2.y)**2; return db<da?b2:a; });
        const d=Math.sqrt((best.x-cb2.x)**2+(best.y-cb2.y)**2);
        bestPower = Math.min(CUE_MAX_POWER, 7 + d*0.04);
      }

      // Add noise based on difficulty
      const noise = difficulty===0 ? (Math.random()-0.5)*0.55
                  : difficulty===1 ? (Math.random()-0.5)*0.18
                  :                  (Math.random()-0.5)*0.05;
      bestAngle += noise;

      // Power noise
      const powerNoise = difficulty===0 ? (Math.random()-0.5)*5
                       : difficulty===1 ? (Math.random()-0.5)*2
                       :                  (Math.random()-0.5)*0.8;
      bestPower = Math.max(4, Math.min(CUE_MAX_POWER, bestPower+powerNoise));

      aiThinking=false;
      if(!gameOver) { shotInProgress=true; applyShot(Math.cos(bestAngle)*bestPower, Math.sin(bestAngle)*bestPower); }
    }, thinkMs);
  }

  // ── Cue aim input ─────────────────────────────────────────────────────────
  let aimAngle=0, aimPower=0;
  let mousePos={x:0,y:0};

  c.addEventListener('mousemove', e=>{
    const r2=c.getBoundingClientRect();
    mousePos={x:e.clientX-r2.left, y:e.clientY-r2.top};
    if (dragging && aimStart) {
      const dx=mousePos.x-aimStart.x, dy=mousePos.y-aimStart.y;
      aimAngle=Math.atan2(dy,dx)+Math.PI; // shoot opposite direction of drag
      aimPower=Math.min(CUE_MAX_POWER, Math.sqrt(dx*dx+dy*dy)*0.18);
    }
  });

  c.addEventListener('mousedown', e=>{
    if (gameOver||anyMoving()) return;
    if (!twoPlayer && turn===1) return;
    if (ballInHand) return; // placement handled by click event
    const r2=c.getBoundingClientRect();
    const mx=e.clientX-r2.left, my=e.clientY-r2.top;

    const cb=cueBall(); if (!cb||cb.pocketed) return;
    const dx=mx-cb.x, dy=my-cb.y;
    if (dx*dx+dy*dy < (cb.r*3)**2) {
      dragging=true;
      aimStart={x:mx,y:my};
      aimAngle=Math.atan2(dy,dx)+Math.PI;
      aimPower=0;
    }
  });

  c.addEventListener('mouseup', e=>{
    if (!dragging) return;
    dragging=false;
    if (aimPower>0.5) {
      shotInProgress=true;
      applyShot(Math.cos(aimAngle)*aimPower, Math.sin(aimAngle)*aimPower);
    }
    aimPower=0;
  });

  // ── Draw ─────────────────────────────────────────────────────────────────
  function drawTable(t) {
    const paper=isPaper();

    // ── Outer shadow under the whole table
    ctx.shadowColor='rgba(0,0,0,0.55)'; ctx.shadowBlur=28; ctx.shadowOffsetY=6;
    ctx.fillStyle=paper?'#3a2008':'#0d1f0d';
    ctx.fillRect(t.rox-4,t.roy-4,t.rtw+8,t.rth+8);
    ctx.shadowColor='transparent'; ctx.shadowBlur=0; ctx.shadowOffsetY=0;

    // ── Rail (wood)
    const woodGrad=ctx.createLinearGradient(t.rox,t.roy,t.rox,t.roy+t.rth);
    if(paper){
      woodGrad.addColorStop(0,'#8b5a1a');
      woodGrad.addColorStop(0.35,'#c8801a');
      woodGrad.addColorStop(0.65,'#a06010');
      woodGrad.addColorStop(1,'#6a3808');
    } else {
      woodGrad.addColorStop(0,'#1c3a08');
      woodGrad.addColorStop(0.35,'#2a5810');
      woodGrad.addColorStop(0.65,'#1e4808');
      woodGrad.addColorStop(1,'#0e2204');
    }
    ctx.fillStyle=woodGrad;
    ctx.fillRect(t.rox,t.roy,t.rtw,t.rth);

    // Rail inner bevel highlight
    ctx.strokeStyle=paper?'rgba(255,220,120,0.25)':'rgba(100,200,80,0.18)';
    ctx.lineWidth=2;
    ctx.strokeRect(t.rox+1,t.roy+1,t.rtw-2,t.rth-2);
    ctx.strokeStyle=paper?'rgba(0,0,0,0.2)':'rgba(0,0,0,0.3)';
    ctx.lineWidth=2;
    ctx.strokeRect(t.rox+3,t.roy+3,t.rtw-6,t.rth-6);

    // ── Felt surface
    const feltGrad=ctx.createRadialGradient(t.ox+t.tw/2,t.oy+t.th/2,0,t.ox+t.tw/2,t.oy+t.th/2,Math.max(t.tw,t.th)*0.75);
    if(paper){
      feltGrad.addColorStop(0,'#2e7a40');
      feltGrad.addColorStop(0.6,'#286838');
      feltGrad.addColorStop(1,'#1f5028');
    } else {
      feltGrad.addColorStop(0,'#1a5228');
      feltGrad.addColorStop(0.6,'#154020');
      feltGrad.addColorStop(1,'#0e2e16');
    }
    ctx.fillStyle=feltGrad;
    ctx.fillRect(t.ox,t.oy,t.tw,t.th);

    // Felt subtle texture lines (nap direction)
    ctx.save();
    ctx.globalAlpha=0.04;
    ctx.strokeStyle=paper?'#fff':'#fff';
    ctx.lineWidth=1;
    for(let y=t.oy;y<t.oy+t.th;y+=6){
      ctx.beginPath(); ctx.moveTo(t.ox,y); ctx.lineTo(t.ox+t.tw,y); ctx.stroke();
    }
    ctx.restore();

    // ── Cushion inner shadow strip
    const cush=3;
    const cushCol=paper?'rgba(0,0,0,0.18)':'rgba(0,0,0,0.25)';
    ctx.fillStyle=cushCol;
    ctx.fillRect(t.ox,t.oy,t.tw,cush);
    ctx.fillRect(t.ox,t.oy+t.th-cush,t.tw,cush);
    ctx.fillRect(t.ox,t.oy,cush,t.th);
    ctx.fillRect(t.ox+t.tw-cush,t.oy,cush,t.th);

    // ── Diamond spots on rails
    const spotCol=paper?'rgba(255,210,100,0.55)':'rgba(180,255,160,0.35)';
    ctx.fillStyle=spotCol;
    const spotSize=3;
    // Top & bottom rail spots (quarters)
    const railH=t.rth - t.th; // rail thickness approx
    for(let i=1;i<4;i++){
      const sx=t.ox+t.tw*(i/4);
      // top rail
      ctx.beginPath(); ctx.arc(sx, t.roy+8, spotSize, 0, Math.PI*2); ctx.fill();
      // bottom rail
      ctx.beginPath(); ctx.arc(sx, t.roy+t.rth-8, spotSize, 0, Math.PI*2); ctx.fill();
    }
    for(let i=1;i<3;i++){
      const sy=t.oy+t.th*(i/3);
      // left rail
      ctx.beginPath(); ctx.arc(t.rox+8, sy, spotSize, 0, Math.PI*2); ctx.fill();
      // right rail
      ctx.beginPath(); ctx.arc(t.rox+t.rtw-8, sy, spotSize, 0, Math.PI*2); ctx.fill();
    }

    // ── Pocket holes with glow
    for (const p of pockets) {
      // Glow ring
      const glowR=ctx.createRadialGradient(p.x,p.y,POCKET_R*0.4,p.x,p.y,POCKET_R*1.6);
      glowR.addColorStop(0,'rgba(0,0,0,0.7)');
      glowR.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=glowR;
      ctx.beginPath(); ctx.arc(p.x,p.y,POCKET_R*1.6,0,Math.PI*2); ctx.fill();
      // Pocket hole
      ctx.fillStyle='#050505';
      ctx.beginPath(); ctx.arc(p.x,p.y,POCKET_R,0,Math.PI*2); ctx.fill();
      // Pocket rim highlight
      ctx.strokeStyle=paper?'rgba(180,120,40,0.6)':'rgba(60,140,60,0.5)';
      ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.arc(p.x,p.y,POCKET_R,0,Math.PI*2); ctx.stroke();
    }

    // ── Table markings
    // Center spot
    ctx.fillStyle=paper?'rgba(255,255,255,0.12)':'rgba(255,255,255,0.08)';
    ctx.beginPath(); ctx.arc(t.ox+t.tw/2, t.oy+t.th/2, 3, 0, Math.PI*2); ctx.fill();
    // Center line
    ctx.strokeStyle=paper?'rgba(255,255,255,0.08)':'rgba(255,255,255,0.06)'; ctx.lineWidth=1; ctx.setLineDash([4,6]);
    ctx.beginPath(); ctx.moveTo(t.ox+t.tw/2,t.oy); ctx.lineTo(t.ox+t.tw/2,t.oy+t.th); ctx.stroke();
    ctx.setLineDash([]);
    // Head string
    ctx.strokeStyle=paper?'rgba(255,255,255,0.07)':'rgba(255,255,255,0.05)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(t.ox+t.tw*0.25,t.oy); ctx.lineTo(t.ox+t.tw*0.25,t.oy+t.th); ctx.stroke();
    // Head spot
    ctx.fillStyle=paper?'rgba(255,255,255,0.1)':'rgba(255,255,255,0.06)';
    ctx.beginPath(); ctx.arc(t.ox+t.tw*0.25, t.oy+t.th/2, 3, 0, Math.PI*2); ctx.fill();
  }

  function drawBall(b) {
    if (b.pocketed) return;
    const col=BALL_COLORS[b.id];

    // Drop shadow
    ctx.fillStyle='rgba(0,0,0,0.3)';
    ctx.beginPath(); ctx.ellipse(b.x+3,b.y+4,b.r*0.9,b.r*0.45,0,0,Math.PI*2); ctx.fill();

    // Ball body with radial gradient for 3D look
    const bodyGrad=ctx.createRadialGradient(b.x-b.r*0.3,b.y-b.r*0.35,b.r*0.05,b.x,b.y,b.r);
    // Parse hex color to slightly lighter/darker
    bodyGrad.addColorStop(0, lightenColor(col,0.45));
    bodyGrad.addColorStop(0.5, col);
    bodyGrad.addColorStop(1, darkenColor(col,0.45));
    ctx.fillStyle=bodyGrad;
    ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fill();

    // Stripe overlay for balls 9-15
    if (b.id>=9) {
      ctx.save();
      ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.clip();
      ctx.fillStyle='#f0f0f0';
      ctx.fillRect(b.x-b.r,b.y-b.r*0.45,b.r*2,b.r*0.9);
      ctx.restore();
    }

    // Number circle
    if (b.id>0) {
      ctx.fillStyle='rgba(255,255,255,0.92)';
      ctx.beginPath(); ctx.arc(b.x,b.y,b.r*0.44,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='#111'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.font=`bold ${Math.max(6,b.r*0.56)}px 'IBM Plex Mono',monospace`;
      ctx.fillText(String(b.id),b.x,b.y+0.5);
    }

    // Specular highlight
    const shine=ctx.createRadialGradient(b.x-b.r*0.32,b.y-b.r*0.38,0,b.x-b.r*0.1,b.y-b.r*0.1,b.r*0.7);
    shine.addColorStop(0,'rgba(255,255,255,0.55)');
    shine.addColorStop(0.4,'rgba(255,255,255,0.1)');
    shine.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle=shine; ctx.beginPath(); ctx.arc(b.x,b.y,b.r,0,Math.PI*2); ctx.fill();
  }

  // Color helpers for ball gradient
  function lightenColor(hex,amt){
    let r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    r=Math.min(255,Math.round(r+(255-r)*amt));
    g=Math.min(255,Math.round(g+(255-g)*amt));
    b=Math.min(255,Math.round(b+(255-b)*amt));
    return `rgb(${r},${g},${b})`;
  }
  function darkenColor(hex,amt){
    let r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    r=Math.max(0,Math.round(r*(1-amt)));
    g=Math.max(0,Math.round(g*(1-amt)));
    b=Math.max(0,Math.round(b*(1-amt)));
    return `rgb(${r},${g},${b})`;
  }

  // ── Trajectory helpers ────────────────────────────────────────────────────
  // Cast a ray from (x,y) in direction (dx,dy), return first hit: {type:'wall'|'ball', x,y, ball?, nx,ny, angle}
  function castRay(x, y, dx, dy, skipBall, maxDist=2000) {
    const t=tableRect();
    let tMin=maxDist;
    let hit=null;

    // Wall intersections (treat table as a rectangle, ball has radius so walls are inset by BALL_R)
    const walls=[
      {a:t.ox+BALL_R,  b:null, axis:'x', side:'left'},
      {a:t.ox+t.tw-BALL_R, b:null, axis:'x', side:'right'},
      {a:t.oy+BALL_R,  b:null, axis:'y', side:'top'},
      {a:t.oy+t.th-BALL_R, b:null, axis:'y', side:'bottom'},
    ];
    for(const w of walls) {
      let tWall;
      if(w.axis==='x' && Math.abs(dx)>0.001) {
        tWall=(w.a-x)/dx;
        if(tWall>0.5 && tWall<tMin) {
          const hy=y+dy*tWall;
          if(hy>=t.oy&&hy<=t.oy+t.th){ tMin=tWall; hit={type:'wall',x:x+dx*tWall,y:hy,nx:(w.side==='left'?1:-1),ny:0}; }
        }
      } else if(w.axis==='y' && Math.abs(dy)>0.001) {
        tWall=(w.a-y)/dy;
        if(tWall>0.5 && tWall<tMin) {
          const hx=x+dx*tWall;
          if(hx>=t.ox&&hx<=t.ox+t.tw){ tMin=tWall; hit={type:'wall',x:hx,y:y+dy*tWall,nx:0,ny:(w.side==='top'?1:-1)}; }
        }
      }
    }

    // Ball intersections (ray-sphere)
    for(const b of balls) {
      if(b.pocketed||b===skipBall) continue;
      // Ray: P(t)=(x,y)+t*(dx,dy), sphere center (b.x,b.y), radius BALL_R*2
      const ex=x-b.x, ey=y-b.y;
      const a2=dx*dx+dy*dy;
      const b2=2*(ex*dx+ey*dy);
      const c2=ex*ex+ey*ey-(BALL_R*2)**2;
      const disc=b2*b2-4*a2*c2;
      if(disc<0) continue;
      const tBall=(-b2-Math.sqrt(disc))/(2*a2);
      if(tBall>1 && tBall<tMin) {
        tMin=tBall;
        const hx=x+dx*tBall, hy=y+dy*tBall;
        const nnx=(hx-b.x)/(BALL_R*2), nny=(hy-b.y)/(BALL_R*2);
        hit={type:'ball',x:hx,y:hy,ball:b,nx:nnx,ny:nny};
      }
    }
    return hit;
  }

  function drawTrajectory(cb) {
    if(!cb||cb.pocketed||ballInHand) return;
    const paper=isPaper();
    const lineCol='rgba(255,255,255,0.35)';
    const lineCol2='rgba(255,255,255,0.2)';
    const ballLineCol='rgba(255,255,180,0.45)';

    const dx=Math.cos(aimAngle), dy=Math.sin(aimAngle);

    // First segment: cue ball path
    const hit1=castRay(cb.x, cb.y, dx, dy, cb);

    if(!hit1) {
      // Just draw to edge
      ctx.strokeStyle=lineCol; ctx.lineWidth=1; ctx.setLineDash([5,5]);
      ctx.beginPath(); ctx.moveTo(cb.x+dx*cb.r,cb.y+dy*cb.r); ctx.lineTo(cb.x+dx*500,cb.y+dy*500);
      ctx.stroke(); ctx.setLineDash([]); return;
    }

    // Draw segment 1: cue ball -> hit point
    ctx.strokeStyle=lineCol; ctx.lineWidth=1; ctx.setLineDash([5,5]);
    ctx.beginPath();
    ctx.moveTo(cb.x+dx*cb.r, cb.y+dy*cb.r);
    ctx.lineTo(hit1.x, hit1.y);
    ctx.stroke(); ctx.setLineDash([]);

    // Draw ghost ball at hit point
    ctx.strokeStyle='rgba(255,255,255,0.25)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(hit1.x, hit1.y, BALL_R, 0, Math.PI*2); ctx.stroke();

    if(hit1.type==='wall') {
      // Reflect and draw second segment
      const dot=dx*hit1.nx+dy*hit1.ny;
      const rx=dx-2*dot*hit1.nx, ry=dy-2*dot*hit1.ny;
      const hit2=castRay(hit1.x+rx*1, hit1.y+ry*1, rx, ry, cb);
      ctx.strokeStyle=lineCol2; ctx.lineWidth=1; ctx.setLineDash([4,7]);
      ctx.beginPath(); ctx.moveTo(hit1.x, hit1.y);
      if(hit2) ctx.lineTo(hit2.x, hit2.y);
      else ctx.lineTo(hit1.x+rx*400, hit1.y+ry*400);
      ctx.stroke(); ctx.setLineDash([]);

    } else if(hit1.type==='ball') {
      // Deflect the hit ball: project incoming velocity onto normal
      const dot=dx*hit1.nx+dy*hit1.ny;
      // Hit ball goes in normal direction, cue deflects
      const tbx=hit1.nx*dot, tby=hit1.ny*dot; // target ball velocity direction
      const tbl=Math.sqrt(tbx*tbx+tby*tby);
      if(tbl>0.001) {
        const tnx=tbx/tbl, tny=tby/tbl;
        // Draw target ball trajectory
        const tbHit=castRay(hit1.ball.x, hit1.ball.y, tnx, tny, hit1.ball);
        ctx.strokeStyle=ballLineCol; ctx.lineWidth=1.5; ctx.setLineDash([5,5]);
        ctx.beginPath(); ctx.moveTo(hit1.ball.x, hit1.ball.y);
        if(tbHit) ctx.lineTo(tbHit.x, tbHit.y);
        else ctx.lineTo(hit1.ball.x+tnx*400, hit1.ball.y+tny*400);
        ctx.stroke(); ctx.setLineDash([]);
        // Small dot at target ball's predicted end
        if(tbHit) {
          ctx.strokeStyle='rgba(255,255,180,0.3)'; ctx.lineWidth=1;
          ctx.beginPath(); ctx.arc(tbHit.x, tbHit.y, BALL_R, 0, Math.PI*2); ctx.stroke();
        }
      }
    }
  }

  function drawCue(cb) {
    if (!cb||cb.pocketed||ballInHand) return;
    const paper=isPaper();

    // Draw trajectory first (behind cue stick)
    drawTrajectory(cb);

    // Cue stick
    const activePower = keyPower > 0 ? keyPower : aimPower;
    const pullback=activePower*3+12;
    const cx1=cb.x-Math.cos(aimAngle)*(cb.r+2);
    const cy1=cb.y-Math.sin(aimAngle)*(cb.r+2);
    const cxEnd=cx1+Math.cos(aimAngle+Math.PI)*(pullback+140);
    const cyEnd=cy1+Math.sin(aimAngle+Math.PI)*(pullback+140);
    const cxTip=cx1-Math.cos(aimAngle)*pullback;
    const cyTip=cy1-Math.sin(aimAngle)*pullback;

    const cueGrad=ctx.createLinearGradient(cxTip,cyTip,cxEnd,cyEnd);
    cueGrad.addColorStop(0,'#f0e0a0');
    cueGrad.addColorStop(0.15,'#c8a060');
    cueGrad.addColorStop(1,'#3a1a00');
    ctx.strokeStyle=cueGrad; ctx.lineWidth=6; ctx.lineCap='round';
    ctx.beginPath(); ctx.moveTo(cxTip,cyTip); ctx.lineTo(cxEnd,cyEnd); ctx.stroke();
    // Ferrule
    ctx.strokeStyle='#ccc'; ctx.lineWidth=7;
    ctx.beginPath(); ctx.moveTo(cxTip,cyTip); ctx.lineTo(cxTip+Math.cos(aimAngle+Math.PI)*8,cyTip+Math.sin(aimAngle+Math.PI)*8); ctx.stroke();

    // Power indicator — show for both drag and keyboard power
    const displayPower = keyPower > 0 ? keyPower : aimPower;
    if (displayPower > 0) {
      const pct=displayPower/CUE_MAX_POWER;
      const barW=110, barH=8, barX=10, barY=H-28;
      ctx.fillStyle=paper?'rgba(0,0,0,0.1)':'rgba(255,255,255,0.08)';
      ctx.fillRect(barX,barY,barW,barH);
      const barGrad=ctx.createLinearGradient(barX,0,barX+barW,0);
      barGrad.addColorStop(0,'#44cc44');
      barGrad.addColorStop(0.5,'#ddcc22');
      barGrad.addColorStop(1,'#ee3322');
      ctx.fillStyle=barGrad;
      ctx.fillRect(barX,barY,barW*pct,barH);
      ctx.strokeStyle=paper?'rgba(0,0,0,0.18)':'rgba(255,255,255,0.18)';
      ctx.lineWidth=1; ctx.strokeRect(barX,barY,barW,barH);
      ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.45)';
      ctx.font=`300 8px 'IBM Plex Mono',monospace`;
      ctx.textAlign='left'; ctx.textBaseline='top';
      ctx.fillText(keyPower>0?'power (W/S)':'power',barX,barY-10);
    }
  }

  function drawHUD() {
    const paper=isPaper();
    const t=tableRect();
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;

    // Group indicators
    const labels=['solids (1–7)','stripes (9–15)'];
    const names=twoPlayer?['P1','P2']:['You','AI'];
    for (let p=0;p<2;p++) {
      const g=groups[p];
      ctx.fillStyle=p===turn?(paper?'rgba(0,0,0,0.7)':'rgba(255,255,255,0.8)'):(paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)');
      const lbl=g?`${names[p]}: ${g}`:`${names[p]}: ?`;
      ctx.fillText(lbl, p===0?t.rox:t.rox+t.rtw-80, t.roy-14);
    }

    if (message) {
      ctx.textAlign='center';
      ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.65)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(message, W/2, t.oy+t.th+8);
    }

    if (ballInHand) {
      ctx.textAlign='center';
      ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.6)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText('Ball in hand — click to place cue ball', W/2, t.oy+t.th+8);
    }

    if (aiThinking && !gameOver) {
      ctx.textAlign='center';
      ctx.fillStyle=paper?'rgba(0,0,0,0.45)':'rgba(255,255,255,0.5)';
      ctx.font=`300 9px 'IBM Plex Mono',monospace`;
      const dots='.'.repeat(1+Math.floor(Date.now()/400)%3);
      ctx.fillText(`AI thinking${dots}`, W/2, t.roy-14);
    }

    if (gameOver) {
      ctx.fillStyle=paper?'rgba(245,241,232,0.88)':'rgba(10,10,9,0.88)';
      ctx.fillRect(0,0,W,H);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillStyle=paper?'#1a1510':'#fff';
      ctx.font=`300 24px 'IBM Plex Mono',monospace`;
      ctx.fillText(message, W/2, H/2-16);
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.4)';
      ctx.fillText('click New Game to play again', W/2, H/2+16);
    }
    ctx.textAlign='left'; ctx.textBaseline='top';
  }

  // ── Main loop ─────────────────────────────────────────────────────────────
  let wasMoving=false;
  function draw() {
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;

    const moved=anyMoving();
    if (moved) {
      const pocketed=stepPhysics();
      pendingPocketed.push(...pocketed);
    } else if (wasMoving && shotInProgress) {
      onShotSettled();
    }
    wasMoving=moved;

    // Update aim angle from mouse when idle
    if (!dragging && !moved && !gameOver && !ballInHand) {
      const cb=cueBall();
      if (cb&&!cb.pocketed) {
        const dx=mousePos.x-cb.x, dy=mousePos.y-cb.y;
        if (dx!==0||dy!==0) {
          const rawAngle=Math.atan2(dy,dx)+Math.PI;
          // Apply sensitivity: lerp toward raw angle, faster = higher sensitivity
          const delta=rawAngle-aimAngle;
          // Normalise delta to [-PI, PI]
          const dNorm=((delta+Math.PI*3)%(Math.PI*2))-Math.PI;
          aimAngle+=dNorm*Math.min(1, rotSensitivity*0.18);
        }
      }
    }

    // AI trigger
    if (!moved && !shotInProgress && !gameOver && !twoPlayer && turn===1 && !aiThinking) {
      if (ballInHand) {
        // AI places cue ball at a sensible spot (head string area, center Y)
        const t2=tableRect();
        const cb=cueBall();
        if(cb){ cb.x=t2.ox+t2.tw*0.25; cb.y=t2.oy+t2.th/2; ballInHand=false; }
      } else {
        doAIShot();
      }
    }

    // Draw
    ctx.fillStyle=isPaper()?'#e8dcc8':'#0a0a0a'; ctx.fillRect(0,0,W,H);
    const t=tableRect();
    drawTable(t);
    for (const b of balls) drawBall(b);

    // Cue stick only for human turn or 2P
    if (!anyMoving() && !gameOver && !ballInHand && (twoPlayer||turn===0)) {
      const cb=cueBall();
      if (cb&&!cb.pocketed) drawCue(cb);
    }

    if (ballInHand && !anyMoving()) {
      // Only move cue ball with mouse if it's the human's turn (or 2P)
      if (twoPlayer || turn===0) {
        const cb=cueBall();
        if (cb) { cb.x=mousePos.x; cb.y=mousePos.y; const t2=tableRect(); cb.x=Math.max(t2.ox+cb.r,Math.min(t2.ox+t2.tw-cb.r,cb.x)); cb.y=Math.max(t2.oy+cb.r,Math.min(t2.oy+t2.th-cb.r,cb.y)); }
      }
    }

    drawHUD();
    ctx.textAlign='left';
  }

  c.addEventListener('click', e => {
    if (gameOver) { initGame(); return; }
    // Place cue ball when human has ball-in-hand
    if (ballInHand && !anyMoving() && (twoPlayer || turn===0)) {
      const r2=c.getBoundingClientRect();
      const mx=e.clientX-r2.left, my=e.clientY-r2.top;
      const t2=tableRect();
      const cb=cueBall();
      if (cb) {
        cb.x=Math.max(t2.ox+cb.r, Math.min(t2.ox+t2.tw-cb.r, mx));
        cb.y=Math.max(t2.oy+cb.r, Math.min(t2.oy+t2.th-cb.r, my));
        ballInHand=false;
      }
    }
  });

  // ── Keyboard: W/S or Up/Down = power, fire on Space/Enter ─────────────────
  const poolKeyDown=e=>{
    // Only act when it's human's turn, idle, not ballInHand
    if(gameOver||anyMoving()||ballInHand) return;
    if(!twoPlayer && turn!==0) return;
    const k=e.key;
    if(k==='w'||k==='W'||k==='ArrowUp'){
      e.preventDefault();
      keyPower=Math.min(CUE_MAX_POWER, keyPower+CUE_MAX_POWER*0.07);
    } else if(k==='s'||k==='S'||k==='ArrowDown'){
      e.preventDefault();
      keyPower=Math.max(0, keyPower-CUE_MAX_POWER*0.07);
    } else if((k===' '||k==='Enter') && keyPower>0.5){
      e.preventDefault();
      shotInProgress=true;
      applyShot(Math.cos(aimAngle)*keyPower, Math.sin(aimAngle)*keyPower);
      keyPower=0;
    }
  };
  document.addEventListener('keydown', poolKeyDown);

  // ── Sensitivity slider ─────────────────────────────────────────────────────
  const POOL_DIFF_NAMES=['Easy','Medium','Hard'];
  const poolDiffBtn=mkBtn(POOL_DIFF_NAMES[difficulty],ctrl);
  poolDiffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;poolDiffBtn.textContent=POOL_DIFF_NAMES[difficulty];});

  // Sensitivity label + slider
  const sensLabel=document.createElement('span');
  sensLabel.className='sb-info';
  sensLabel.style.fontSize='8px';
  sensLabel.style.letterSpacing='.06em';
  sensLabel.textContent='rot sens';
  ctrl.appendChild(sensLabel);
  const sensSlider=document.createElement('input');
  sensSlider.type='range'; sensSlider.min='0.1'; sensSlider.max='3'; sensSlider.step='0.05';
  sensSlider.value=String(rotSensitivity);
  sensSlider.className='sb-slider';
  sensSlider.title='Rotation sensitivity';
  sensSlider.addEventListener('input',()=>{ rotSensitivity=parseFloat(sensSlider.value); });
  ctrl.appendChild(sensSlider);

  mkBtn('New Game',ctrl).addEventListener('click',()=>initGame());

  requestAnimationFrame(draw);
  return ()=>{ cancelAnimationFrame(raf); ro.disconnect(); document.removeEventListener('keydown',poolKeyDown); };
}
// TOY — JETPACK JOYRIDE
// ════════════════════════════════════════════════════════════════════════════
function initJetpack(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height, raf;

  const GRAVITY = 0.32;
  const THRUST  = 0.55;
  const PLAYER_X = 100;
  const FLOOR_TILES = 5;  // number of floor tile rows
  const CEIL_TILES  = 3;

  // Tile pixel size — computed per frame from H
  let TS = 20; // floor tile size
  let FLOOR_Y, CEIL_Y; // pixel positions

  let jetOn, vy, py;
  let dist, score, coinCount, hi;
  let obstacles, coins, particles, bgPipes, bgLights;
  let frame, scrollX, speed, state; // state: 'title'|'playing'|'dead'

  function init() {
    jetOn=false; vy=0;
    dist=0; score=0; coinCount=0;
    frame=0; scrollX=0; speed=4;
    obstacles=[]; coins=[]; particles=[];
    bgPipes=initBgPipes();
    bgLights=initBgLights();
    state='title';
    py=0; // set properly in draw once H is known
  }

  // ── Background ────────────────────────────────────────────────────────────
  function initBgPipes() {
    const pipes=[];
    for(let i=0;i<8;i++) pipes.push({x:i*180+200, variant:i%3});
    return pipes;
  }
  function initBgLights() {
    const lights=[];
    for(let i=0;i<12;i++) lights.push({x:i*120+60, y:0.15+Math.random()*0.6, r:2+Math.random()*4, phase:Math.random()*Math.PI*2});
    return lights;
  }

  // ── Spawn ─────────────────────────────────────────────────────────────────
  function spawnObstacle() {
    const playH = FLOOR_Y - CEIL_Y;
    const t = Math.random();
    if(t < 0.45) {
      // Zapper: two nodes connected by electric arc, player must go through gap
      const gapSize = playH * (0.28 + Math.random()*0.18);
      const gapTop  = CEIL_Y + Math.random()*(playH - gapSize);
      obstacles.push({type:'zapper', x:W+40, gapTop, gapBot:gapTop+gapSize, phase:0, w:14});
    } else if(t < 0.75) {
      // Missile: homes in, preceded by warning
      const ty = CEIL_Y + 30 + Math.random()*(FLOOR_Y-CEIL_Y-60);
      obstacles.push({type:'missile', x:W+200, y:ty, vy:0, warn:true, warnT:100, active:false, dead:false});
    } else {
      // Laser: horizontal beam, fires for a burst
      const ly = CEIL_Y + 30 + Math.random()*(FLOOR_Y - CEIL_Y - 60);
      obstacles.push({type:'laser', x:W+30, y:ly, warmup:80, on:0, maxOn:70, dead:false});
    }
  }

  function spawnCoinArc() {
    const playH = FLOOR_Y - CEIL_Y - 40;
    const baseY = CEIL_Y + 20 + Math.random()*playH;
    const arc   = Math.random()>0.5;
    const n     = 7+Math.floor(Math.random()*6);
    for(let i=0;i<n;i++) {
      const cx = W + 30 + i*30;
      const cy = arc ? baseY + Math.sin(i/n*Math.PI)*-60 : baseY;
      coins.push({x:cx, y:cy, hit:false});
    }
  }

  // ── Particles ─────────────────────────────────────────────────────────────
  function burst(x,y,col,n,spd,grav=0.08){
    for(let i=0;i<n;i++){
      const a=Math.random()*Math.PI*2, s=spd*(0.4+Math.random()*0.6);
      particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,g:grav,life:1,col,r:2+Math.random()*3});
    }
  }

  // ── Step ──────────────────────────────────────────────────────────────────
  function step() {
    frame++; dist++; score=dist+coinCount*50;
    speed = 4 + dist*0.0006;
    scrollX += speed;

    // Player physics — jetOn = minigun fires downward, recoil lifts player
    vy += jetOn ? -THRUST : GRAVITY;
    vy = Math.max(-10, Math.min(10, vy));
    py += vy;

    // Clamp to play area
    if(py >= FLOOR_Y - 32) { py=FLOOR_Y-32; vy=0; }
    if(py <= CEIL_Y)       { py=CEIL_Y;     vy=0; }

    // Minigun bullets firing downward
    if(jetOn && frame%2===0) {
      const spread = (Math.random()-0.5)*4;
      particles.push({
        x: PLAYER_X+11+spread, y: py+36,
        vx: spread*0.3, vy: 7+Math.random()*5,
        g: 0.15, life: 0.7, col: frame%4===0?'#ffffff':'#ffdd44', r: 2
      });
      if(frame%4===0) particles.push({x:PLAYER_X+11, y:py+38, vx:(Math.random()-0.5)*2, vy:2, g:0, life:0.2, col:'#ffffff', r:4});
    }

    // Spawn schedule
    if(dist>60) {
      if(frame%90===0) spawnObstacle();
      if(frame%60===0) spawnCoinArc();
    }

    const pr = {x:PLAYER_X+3, y:py+3, w:24, h:26};

    // Coins
    coins.forEach(cn=>{
      cn.x -= speed;
      if(!cn.hit) {
        const dx=cn.x-(PLAYER_X+24), dy=cn.y-(py+24);
        if(dx*dx+dy*dy < 28*28) { cn.hit=true; coinCount++; burst(cn.x,cn.y,'#ffe066',6,3,0.1); }
      }
    });
    coins = coins.filter(cn=>cn.x>-20);

    // Obstacles
    let died=false;
    obstacles.forEach(ob=>{
      if(ob.dead) return;
      ob.x -= speed;

      if(ob.type==='zapper') {
        ob.phase+=0.15;
        const topRect = {x:ob.x-ob.w/2, y:CEIL_Y,      w:ob.w, h:ob.gapTop-CEIL_Y};
        const botRect = {x:ob.x-ob.w/2, y:ob.gapBot,   w:ob.w, h:FLOOR_Y-ob.gapBot};
        if(overlap(pr,topRect)||overlap(pr,botRect)) died=true;
        if(ob.x < -30) ob.dead=true;
      }

      if(ob.type==='missile') {
        if(!ob.active) {
          ob.warnT--;
          if(ob.warnT<=0) ob.active=true;
        } else {
          ob.x -= 3.5; // extra speed on top of scroll
          const mr={x:ob.x-22,y:ob.y-9,w:44,h:18};
          if(overlap(pr,mr)) died=true;
          // Exhaust trail
          if(frame%2===0) particles.push({x:ob.x+24,y:ob.y+(Math.random()-0.5)*4,vx:speed*0.5+Math.random()*2,vy:(Math.random()-0.5)*1.5,g:0,life:0.5,col:frame%4===0?'#ffffff':'#ff8800',r:3+Math.random()*2});
        }
        if(ob.x<-80) ob.dead=true;
      }

      if(ob.type==='laser') {
        if(ob.warmup>0) { ob.warmup--; }
        else {
          ob.on++;
          if(ob.on>=ob.maxOn) { ob.dead=true; return; }
          // Full-width beam — player must dodge vertically
          const lr={x:0, y:ob.y-8, w:ob.x, h:16};
          if(overlap(pr,lr)) died=true;
        }
        if(ob.x<-20) ob.dead=true;
      }
    });
    obstacles = obstacles.filter(ob=>!ob.dead);

    if(died) {
      burst(PLAYER_X+24, py+24, '#ff4400', 16, 6);
      burst(PLAYER_X+24, py+24, '#ffcc00', 10, 4);
      state='dead';
    }

    // Particles
    particles.forEach(p=>{ p.x+=p.vx; p.y+=p.vy; p.vy+=p.g; p.life-=0.035; p.r*=0.97; });
    particles = particles.filter(p=>p.life>0&&p.y<H+20);
  }

  function overlap(a,b){ return a.x<b.x+b.w&&a.x+a.w>b.x&&a.y<b.y+b.h&&a.y+a.h>b.y; }

  // ── Draw ──────────────────────────────────────────────────────────────────
  function drawBg() {
    const paper=isPaper();
    // Lab gradient background
    const g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0, paper?'#b8c8d8':'#050510');
    g.addColorStop(1, paper?'#d0dce8':'#080820');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);

    // Scrolling background pipes
    bgPipes.forEach(p=>{
      const px=((p.x - scrollX*0.25)%W+W*2)%W;
      const variants=['#1a2a4a','#162238','#1e2e52'];
      const light=['#2244aa','#1a3888','#2a4acc'];
      const heights=[H*0.35, H*0.28, H*0.42];
      const h=heights[p.variant];
      ctx.fillStyle=paper?'rgba(150,170,190,0.3)':variants[p.variant];
      ctx.fillRect(px-10, H-FLOOR_Y-h+FLOOR_Y, 20, h);
      ctx.strokeStyle=paper?'rgba(100,130,170,0.4)':light[p.variant];
      ctx.lineWidth=1.5;
      ctx.strokeRect(px-10, H-FLOOR_Y-h+FLOOR_Y, 20, h);
      // Pipe top cap
      ctx.fillStyle=paper?'rgba(130,160,190,0.4)':light[p.variant];
      ctx.fillRect(px-14, FLOOR_Y-h-6, 28, 10);
    });

    // Scrolling lights on ceiling
    bgLights.forEach(l=>{
      const lx=((l.x - scrollX*0.5)%W+W*2)%W;
      const ly=CEIL_Y + l.y*(FLOOR_Y-CEIL_Y);
      const blink=Math.sin(frame*0.04+l.phase);
      if(blink>0) {
        ctx.globalAlpha=blink*0.4;
        ctx.fillStyle=paper?'#aaccff':'#4488ff';
        ctx.beginPath(); ctx.arc(lx,ly,l.r*2,0,Math.PI*2); ctx.fill();
        ctx.globalAlpha=blink*0.9;
        ctx.fillStyle=paper?'#ffffff':'#ccddff';
        ctx.beginPath(); ctx.arc(lx,ly,l.r*0.5,0,Math.PI*2); ctx.fill();
        ctx.globalAlpha=1;
      }
    });

    // Ceiling
    const ceilGrad=ctx.createLinearGradient(0,0,0,CEIL_Y);
    ceilGrad.addColorStop(0,paper?'#8090a8':'#111128');
    ceilGrad.addColorStop(1,paper?'#a0b0c0':'#1a1a3a');
    ctx.fillStyle=ceilGrad; ctx.fillRect(0,0,W,CEIL_Y);

    // Ceil tiles
    ctx.strokeStyle=paper?'rgba(0,0,0,0.12)':'rgba(60,80,160,0.35)';
    ctx.lineWidth=1;
    for(let x=-(scrollX%(TS*2));x<W;x+=TS*2){
      ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,CEIL_Y); ctx.stroke();
    }
    for(let y=0;y<CEIL_Y;y+=TS){
      ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke();
    }

    // Floor
    const floorGrad=ctx.createLinearGradient(0,FLOOR_Y,0,H);
    floorGrad.addColorStop(0,paper?'#8090a8':'#111128');
    floorGrad.addColorStop(1,paper?'#606878':'#080818');
    ctx.fillStyle=floorGrad; ctx.fillRect(0,FLOOR_Y,W,H-FLOOR_Y);

    // Floor tiles
    ctx.strokeStyle=paper?'rgba(0,0,0,0.12)':'rgba(60,80,160,0.35)';
    for(let x=-(scrollX%(TS*2));x<W;x+=TS*2){
      ctx.beginPath(); ctx.moveTo(x,FLOOR_Y); ctx.lineTo(x,H); ctx.stroke();
    }
    for(let y=FLOOR_Y;y<H;y+=TS){
      ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke();
    }

    // Floor/ceil edge lines
    ctx.strokeStyle=paper?'#607080':'#3355bb'; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(0,CEIL_Y); ctx.lineTo(W,CEIL_Y); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(0,FLOOR_Y); ctx.lineTo(W,FLOOR_Y); ctx.stroke();
  }

  function drawPlayer() {
    const px=PLAYER_X, paper=isPaper();

    // Minigun barrel pointing down (the jet)
    ctx.fillStyle=paper?'#222':'#111';
    ctx.fillRect(px+6, py+28, 14, 9);
    for(let i=0;i<3;i++){
      ctx.fillStyle='#000';
      ctx.beginPath(); ctx.arc(px+8+i*4, py+36, 1.5, 0, Math.PI*2); ctx.fill();
    }

    // Legs
    ctx.fillStyle=paper?'#223344':'#1a2a3a';
    ctx.fillRect(px+5,  py+22, 6, 7);
    ctx.fillRect(px+14, py+22, 6, 7);
    // Boots
    ctx.fillStyle=paper?'#334455':'#2a3a4a';
    ctx.fillRect(px+4,  py+27, 8, 4);
    ctx.fillRect(px+13, py+27, 8, 4);

    // Body
    ctx.fillStyle=paper?'#cc3311':'#dd2200';
    ctx.fillRect(px+4, py+10, 18, 14);
    ctx.fillStyle=paper?'#ff3300':'#ff4411';
    ctx.fillRect(px+6, py+12, 14, 2);

    // Jetpack backpack
    ctx.fillStyle=paper?'#445566':'#2a3a55';
    ctx.fillRect(px+20, py+7, 9, 16);
    ctx.fillStyle=paper?'#223':'#112';
    ctx.fillRect(px+21, py+21, 3, 4);
    ctx.fillRect(px+25, py+21, 3, 4);

    // Head
    ctx.fillStyle=paper?'#ffccaa':'#ffddbb';
    ctx.beginPath(); ctx.arc(px+11, py+7, 7, 0, Math.PI*2); ctx.fill();
    // Helmet top
    ctx.fillStyle=paper?'#334455':'#2a3a55';
    ctx.beginPath(); ctx.arc(px+11, py+7, 7, Math.PI, 0); ctx.fill();
    ctx.strokeStyle=paper?'#445566':'#3a4a66';
    ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.arc(px+11, py+7, 7, 0, Math.PI*2); ctx.stroke();
    // Visor
    ctx.fillStyle=paper?'rgba(60,160,220,0.8)':'rgba(80,200,255,0.8)';
    ctx.beginPath(); ctx.ellipse(px+12, py+8, 4, 3, 0.1, 0, Math.PI*2); ctx.fill();
  }

  function drawObstacles() {
    const paper=isPaper();
    obstacles.forEach(ob=>{
      if(ob.type==='zapper') {
        const glow=0.6+0.4*Math.sin(ob.phase);
        // Top rod
        const rodCol=paper?'#665500':'#443300';
        ctx.fillStyle=rodCol;
        ctx.fillRect(ob.x-5, CEIL_Y, 10, ob.gapTop-CEIL_Y);
        ctx.fillRect(ob.x-5, ob.gapBot, 10, FLOOR_Y-ob.gapBot);

        // Electric line along rod
        ctx.strokeStyle=paper?`rgba(255,200,0,${glow})`:`rgba(255,240,0,${glow})`;
        ctx.lineWidth=2+glow*2; ctx.lineCap='round';
        // Draw jagged electric line
        for(let seg=0;seg<2;seg++){
          const sy=seg===0?CEIL_Y:ob.gapBot, ey=seg===0?ob.gapTop:FLOOR_Y;
          ctx.beginPath(); ctx.moveTo(ob.x,sy);
          for(let y=sy+8;y<ey;y+=8) ctx.lineTo(ob.x+(Math.random()-0.5)*6, y);
          ctx.lineTo(ob.x,ey); ctx.stroke();
        }

        // End caps (glowing balls)
        const capCol=paper?`rgba(255,180,0,${glow})`:`rgba(255,255,0,${glow})`;
        ctx.fillStyle=capCol;
        ctx.beginPath(); ctx.arc(ob.x, ob.gapTop, 9, 0, Math.PI*2); ctx.fill();
        ctx.beginPath(); ctx.arc(ob.x, ob.gapBot, 9, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle='#fff';
        ctx.beginPath(); ctx.arc(ob.x, ob.gapTop, 4, 0, Math.PI*2); ctx.fill();
        ctx.beginPath(); ctx.arc(ob.x, ob.gapBot, 4, 0, Math.PI*2); ctx.fill();

        // Danger arc between caps (at low glow = zap!)
        if(glow>0.9) {
          ctx.strokeStyle=`rgba(255,255,255,${(glow-0.9)*10})`;
          ctx.lineWidth=1;
          ctx.beginPath(); ctx.moveTo(ob.x, ob.gapTop);
          for(let y=ob.gapTop;y<ob.gapBot;y+=5) ctx.lineTo(ob.x+(Math.random()-0.5)*12,y);
          ctx.lineTo(ob.x,ob.gapBot); ctx.stroke();
        }
      }

      if(ob.type==='missile') {
        if(!ob.active) {
          // Warning flash
          if(Math.floor(ob.warnT/8)%2===0) {
            ctx.fillStyle='#ff2200';
            ctx.font=`bold 13px monospace`;
            ctx.textAlign='right'; ctx.textBaseline='middle';
            ctx.fillText('⚠ MISSILE', W-8, ob.y);
          }
          return;
        }
        const ang=Math.atan2(ob.vy,-3.5);
        ctx.save();
        ctx.translate(ob.x, ob.y);
        ctx.rotate(ang);
        // Body
        ctx.fillStyle=paper?'#999':'#bbb';
        ctx.fillRect(-28,-8,50,16);
        // Nose cone
        ctx.fillStyle=paper?'#cc3300':'#ff4400';
        ctx.beginPath();
        ctx.moveTo(22,-8); ctx.lineTo(40,0); ctx.lineTo(22,8);
        ctx.closePath(); ctx.fill();
        // Fins
        ctx.fillStyle=paper?'#777':'#999';
        ctx.fillRect(-28,-14,14,6);
        ctx.fillRect(-28,8,14,6);
        // Window
        ctx.fillStyle=paper?'rgba(100,200,255,0.6)':'rgba(150,220,255,0.6)';
        ctx.beginPath(); ctx.ellipse(4,0,7,5,0,0,Math.PI*2); ctx.fill();
        ctx.restore();
      }

      if(ob.type==='laser') {
        if(ob.warmup>0) {
          // Warming up: pulsing emitter
          const pct=1-ob.warmup/80;
          const blink=Math.floor(ob.warmup/6)%2===0;
          ctx.fillStyle=blink?`rgba(255,100,0,${0.5+pct*0.5})`:'#441100';
          ctx.beginPath(); ctx.arc(ob.x, ob.y, 12, 0, Math.PI*2); ctx.fill();
          ctx.fillStyle='#ff6600';
          ctx.font=`bold 9px monospace`; ctx.textAlign='center'; ctx.textBaseline='middle';
          ctx.fillText('⚡', ob.x, ob.y);
          // Charge ring
          ctx.strokeStyle=`rgba(255,100,0,${pct})`;
          ctx.lineWidth=2;
          ctx.beginPath(); ctx.arc(ob.x, ob.y, 12+pct*8, 0, Math.PI*2); ctx.stroke();
        } else {
          // Firing: full beam from left wall to emitter
          const alpha=Math.min(1, ob.on/10);
          ctx.globalAlpha=alpha;
          // Glow
          ctx.strokeStyle=paper?'rgba(255,80,0,0.25)':'rgba(255,20,20,0.25)';
          ctx.lineWidth=22; ctx.lineCap='butt';
          ctx.beginPath(); ctx.moveTo(0,ob.y); ctx.lineTo(ob.x,ob.y); ctx.stroke();
          // Main beam
          ctx.strokeStyle=paper?'#ff5500':'#ff1100';
          ctx.lineWidth=5;
          ctx.beginPath(); ctx.moveTo(0,ob.y); ctx.lineTo(ob.x,ob.y); ctx.stroke();
          // Core
          ctx.strokeStyle='#ffffff'; ctx.lineWidth=1.5;
          ctx.beginPath(); ctx.moveTo(0,ob.y); ctx.lineTo(ob.x,ob.y); ctx.stroke();
          ctx.globalAlpha=1;
          // Emitter
          ctx.fillStyle='#ff3300';
          ctx.beginPath(); ctx.arc(ob.x,ob.y,12,0,Math.PI*2); ctx.fill();
          ctx.fillStyle='#ffffff';
          ctx.beginPath(); ctx.arc(ob.x,ob.y,5,0,Math.PI*2); ctx.fill();
        }
      }
    });
    ctx.textAlign='left';
  }

  function drawCoins() {
    const paper=isPaper();
    coins.forEach(cn=>{
      if(cn.hit) return;
      const spin=Math.abs(Math.cos(frame*0.08+cn.x*0.05));
      ctx.fillStyle=paper?'#cc9900':'#ffcc00';
      ctx.beginPath(); ctx.ellipse(cn.x, cn.y, 9*spin+0.5, 9, 0, 0, Math.PI*2); ctx.fill();
      ctx.strokeStyle=paper?'#ffdd44':'#ffffaa';
      ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.ellipse(cn.x, cn.y, 9*spin+0.5, 9, 0, 0, Math.PI*2); ctx.stroke();
      if(spin>0.3) {
        ctx.fillStyle=paper?'#ffee66':'#ffffcc';
        ctx.font=`bold 8px monospace`; ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText('$', cn.x, cn.y+1);
      }
    });
    ctx.textAlign='left';
  }

  function drawParticles() {
    particles.forEach(p=>{
      ctx.globalAlpha=Math.max(0,p.life);
      ctx.fillStyle=p.col;
      ctx.beginPath(); ctx.arc(p.x,p.y,Math.max(0.5,p.r),0,Math.PI*2); ctx.fill();
    });
    ctx.globalAlpha=1;
  }

  function drawHUD() {
    const paper=isPaper();
    // Top bar
    ctx.fillStyle=paper?'rgba(0,0,0,0.45)':'rgba(0,0,0,0.6)';
    ctx.fillRect(0, 0, W, CEIL_Y);

    ctx.fillStyle=paper?'#222':'#eee';
    ctx.font=`bold 12px 'IBM Plex Mono',monospace`;
    ctx.textAlign='left'; ctx.textBaseline='middle';
    ctx.fillText(`${Math.floor(dist)}m`, 10, CEIL_Y/2);

    ctx.fillStyle='#ffcc00';
    ctx.textAlign='center';
    ctx.fillText(`$ ${coinCount}`, W/2, CEIL_Y/2);

    ctx.fillStyle=paper?'#222':'#eee';
    ctx.textAlign='right';
    ctx.fillText(`${score}`, W-10, CEIL_Y/2);

    if(state==='title') {
      ctx.fillStyle='rgba(0,0,0,0.6)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ffff00';
      ctx.font=`bold ${Math.min(34,W*0.065)}px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('JETPACK JOYRIDE',W/2,H/2-40);
      ctx.fillStyle='rgba(255,255,255,0.85)';
      ctx.font=`300 13px 'IBM Plex Mono',monospace`;
      ctx.fillText('Hold SPACE / click / tap to fly',W/2,H/2);
      ctx.fillText('Dodge zappers · missiles · lasers',W/2,H/2+22);
      ctx.fillStyle='rgba(255,220,0,0.6)';
      ctx.fillText('collect $ coins for bonus score',W/2,H/2+44);
    }

    if(state==='dead') {
      ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#ff3300';
      ctx.font=`bold ${Math.min(36,W*0.07)}px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('MISSION FAILED',W/2,H/2-36);
      ctx.fillStyle='#ffcc00';
      ctx.font=`300 13px 'IBM Plex Mono',monospace`;
      ctx.fillText(`${Math.floor(dist)}m  ·  ${coinCount} coins  ·  score ${score}`,W/2,H/2);
      if(score>hi) hi=score;
      ctx.fillStyle='rgba(255,255,255,0.5)';
      ctx.fillText(`best: ${hi}`,W/2,H/2+22);
      ctx.fillStyle='rgba(255,255,255,0.7)';
      ctx.fillText('hold to restart',W/2,H/2+46);
    }
    ctx.textAlign='left';
  }

  function draw() {
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;

    // Compute layout from current size
    TS     = Math.max(16, Math.floor(H*0.04));
    CEIL_Y = TS * CEIL_TILES;
    FLOOR_Y= H - TS * FLOOR_TILES;

    // Init player Y on first frame
    if(py===0) py = CEIL_Y + (FLOOR_Y-CEIL_Y)*0.6;

    if(state==='playing') step();

    drawBg();
    drawCoins();
    drawObstacles();
    drawParticles();
    if(state!=='dead') drawPlayer();
    drawHUD();

    ctx.textAlign='left'; ctx.textBaseline='top';
  }

  // ── Input ──────────────────────────────────────────────────────────────────
  hi=0;
  function press(on) {
    if(state==='title') { if(on) { state='playing'; jetOn=true; } return; }
    if(state==='dead')  { if(on) { init(); py=0; state='playing'; jetOn=true; } return; }
    jetOn=on;
  }

  const onKey=e=>{
    const fly=e.key===' '||e.key==='ArrowUp'||e.key==='w'||e.key==='W';
    if(!fly) return;
    e.preventDefault();
    press(e.type==='keydown');
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);
  c.addEventListener('mousedown',()=>press(true));
  window.addEventListener('mouseup',()=>press(false));
  c.addEventListener('touchstart',e=>{e.preventDefault();press(true);},{passive:false});
  c.addEventListener('touchend',e=>{e.preventDefault();press(false);},{passive:false});

  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',()=>{init();py=0;});

  init();
  requestAnimationFrame(draw);
  return ()=>{
    cancelAnimationFrame(raf); ro.disconnect();
    document.removeEventListener('keydown',onKey);
    document.removeEventListener('keyup',onKey);
    window.removeEventListener('mouseup',()=>press(false));
  };
}


// ════════════════════════════════════════════════════════════════════════════
// TOY — MEMORY PATTERN
// ════════════════════════════════════════════════════════════════════════════
function initMemoryPattern(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height, raf;

  let difficulty=1; // 0=easy(3x3), 1=medium(5x5), 2=hard(7x7)
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const GRID_SIZE=[3,5,7];

  // Timing (ms) — hard mode uses tighter timings to keep it snappy on 9x9
  const TIMING=[
    {fadeIn:200, hold:500, fadeOut:220, gap:180, startDelay:700},  // easy
    {fadeIn:170, hold:420, fadeOut:180, gap:150, startDelay:600},  // medium
    {fadeIn:130, hold:340, fadeOut:150, gap:110, startDelay:500},  // hard
  ];
  function tm(){ return TIMING[difficulty]; }
  function stepDuration(){ const t=tm(); return t.fadeIn+t.hold+t.fadeOut+t.gap; }

  // per-cell animation state: {phase:'fadein'|'hold'|'fadeout', t:0..1}
  // litMap[idx] = 0..1 brightness (driven by animation below)
  let litMap={};       // idx -> 0..1 brightness right now
  let cellAnim={};     // idx -> {phase, elapsed, isPlayerFlash}

  // Game state
  let sequence, playerSeq, gamePhase, score, streak, level;
  let showIdx, showElapsed, waitingToStart;
  let resultMsg, resultTimer;
  let inputEnabled=false;
  let wrongIdx=-1;

  function cols(){ return GRID_SIZE[difficulty]; }

  function newGame(){
    sequence=[]; playerSeq=[];
    score=0; streak=0; level=1;
    litMap={}; cellAnim={};
    startRound();
  }

  function startRound(){
    const n=cols()*cols();
    const len=Math.max(2, level+1);
    sequence=[];
    let last=-1;
    for(let i=0;i<len;i++){
      let idx;
      do { idx=Math.floor(Math.random()*n); } while(idx===last&&n>1);
      sequence.push(idx); last=idx;
    }
    playerSeq=[];
    gamePhase='showing';
    showIdx=0;
    showElapsed=0;
    waitingToStart=true;
    inputEnabled=false;
    resultMsg=null;
    wrongIdx=-1;
    litMap={}; cellAnim={};
  }

  // Trigger a cell light-up animation
  function flashCell(idx, isPlayer){
    cellAnim[idx]={phase:'fadein', elapsed:0, isPlayer:!!isPlayer};
  }

  function step(dt){
    const t=tm();

    // Advance all cell animations
    for(const k in cellAnim){
      const a=cellAnim[k];
      a.elapsed+=dt;
      if(a.phase==='fadein'){
        litMap[k]=Math.min(1, a.elapsed/t.fadeIn);
        if(a.elapsed>=t.fadeIn){ a.phase='hold'; a.elapsed=0; }
      } else if(a.phase==='hold'){
        litMap[k]=1;
        if(a.elapsed>=t.hold){ a.phase='fadeout'; a.elapsed=0; }
      } else if(a.phase==='fadeout'){
        litMap[k]=Math.max(0, 1-a.elapsed/t.fadeOut);
        if(a.elapsed>=t.fadeOut){ litMap[k]=0; delete litMap[k]; delete cellAnim[k]; }
      }
    }

    if(gamePhase==='showing'){
      // Initial start delay before first cell
      if(waitingToStart){
        showElapsed+=dt;
        if(showElapsed>=t.startDelay){ waitingToStart=false; showElapsed=0; }
        return;
      }
      showElapsed+=dt;
      // Fire each cell at the right moment in the timeline
      const dur=stepDuration();
      const targetIdx=Math.floor(showElapsed/dur);
      if(targetIdx>showIdx-1 && showIdx<sequence.length){
        // Time to light up next cell
        flashCell(sequence[showIdx]);
        showIdx++;
      }
      // All cells triggered — wait for last animation to finish then go to input
      if(showIdx>=sequence.length){
        const lastFired=(showIdx-1)*dur;
        const animEnd=lastFired+t.fadeIn+t.hold+t.fadeOut;
        if(showElapsed>=animEnd+60){
          gamePhase='input';
          inputEnabled=true;
        }
      }
    }

    if(gamePhase==='result'){
      resultTimer-=dt;
      if(resultTimer<=0){
        litMap={}; cellAnim={};
        if(resultMsg==='correct'){ level++; startRound(); }
        else { newGame(); }
      }
    }
  }

  function handleCellClick(idx){
    if(!inputEnabled || gamePhase!=='input') return;
    flashCell(idx, true);
    playerSeq.push(idx);
    const pos=playerSeq.length-1;

    if(playerSeq[pos]!==sequence[pos]){
      inputEnabled=false;
      wrongIdx=idx;
      gamePhase='result';
      resultMsg='wrong';
      resultTimer=2000;
      streak=0;
    } else if(playerSeq.length===sequence.length){
      inputEnabled=false;
      score+=sequence.length*10*(difficulty+1);
      streak++;
      gamePhase='result';
      resultMsg='correct';
      resultTimer=1000;
    }
  }

  function cellRect(idx){
    const n=cols();
    const pad=18;
    const topPad=36;
    const avW=W-pad*2, avH=H-pad*2-topPad;
    const cellW=avW/n, cellH=avH/n;
    const size=Math.min(cellW,cellH);
    const gapFrac=n===3?0.10:n===6?0.08:0.06;
    const gap=size*gapFrac;
    const gridW=n*size, gridH=n*size;
    const ox=(W-gridW)/2, oy=topPad+(avH-gridH)/2;
    const row=Math.floor(idx/n), col=idx%n;
    return {
      x: ox+col*size+gap/2,
      y: oy+row*size+gap/2,
      w: size-gap,
      h: size-gap,
      r: (size-gap)*(n===3?0.16:n===6?0.12:0.09),
    };
  }

  function hitTest(mx,my){
    const total=cols()*cols();
    for(let i=0;i<total;i++){
      const r=cellRect(i);
      if(mx>=r.x&&mx<=r.x+r.w&&my>=r.y&&my<=r.y+r.h) return i;
    }
    return -1;
  }

  let lastTs=0;
  function draw(ts){
    raf=requestAnimationFrame(draw);
    const dt=Math.min(60, ts-lastTs||16); lastTs=ts;
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();

    step(dt);

    ctx.fillStyle=paper?'#f5f1e8':'#0d1117';
    ctx.fillRect(0,0,W,H);

    const n=cols(), total=n*n;

    for(let i=0;i<total;i++){
      const r=cellRect(i);
      const br=litMap[i]||0;
      const isWrong=(gamePhase==='result'&&resultMsg==='wrong'&&i===wrongIdx);
      const isCorrectFlash=(gamePhase==='result'&&resultMsg==='correct');

      // Base cell
      const baseDark=paper?'rgba(0,0,0,0.07)':'rgba(255,255,255,0.055)';
      ctx.fillStyle=baseDark;
      roundRect(ctx,r.x,r.y,r.w,r.h,r.r); ctx.fill();

      // Lit glow
      if(br>0&&!isWrong){
        // Outer colour fill
        const ease=br<0.5?2*br*br:1-Math.pow(-2*br+2,2)/2; // ease in-out
        ctx.fillStyle=paper?`rgba(60,140,255,${ease*0.88})`:`rgba(80,185,255,${ease*0.82})`;
        roundRect(ctx,r.x,r.y,r.w,r.h,r.r); ctx.fill();
        // Specular highlight at top
        const hlH=r.h*0.28;
        ctx.fillStyle=`rgba(255,255,255,${ease*0.38})`;
        roundRect(ctx,r.x+r.w*0.18,r.y+r.h*0.08,r.w*0.64,hlH,r.r*0.7); ctx.fill();
      }

      // Wrong cell — red flash
      if(isWrong){
        const pulse=0.7+0.3*Math.sin(Date.now()*0.012);
        ctx.fillStyle=`rgba(255,55,55,${pulse*0.9})`;
        roundRect(ctx,r.x,r.y,r.w,r.h,r.r); ctx.fill();
      }

      // Correct — green wash over whole grid
      if(isCorrectFlash){
        const fade=Math.max(0, resultTimer/1000);
        ctx.fillStyle=`rgba(60,210,110,${fade*0.45})`;
        roundRect(ctx,r.x,r.y,r.w,r.h,r.r); ctx.fill();
      }

      // Border
      ctx.strokeStyle=br>0
        ?(paper?'rgba(60,140,255,0.5)':'rgba(80,185,255,0.4)')
        :(paper?'rgba(0,0,0,0.10)':'rgba(255,255,255,0.07)');
      ctx.lineWidth=br>0?1.5:1;
      roundRect(ctx,r.x,r.y,r.w,r.h,r.r); ctx.stroke();
    }

    // ── HUD bar ──────────────────────────────────────────────────────────
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.28)':'rgba(255,255,255,0.28)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillText(`score: ${score}  streak: ${streak}  level: ${level}`,8,7);

    // Centre status
    ctx.textAlign='center'; ctx.textBaseline='top';
    const sy=8;
    if(gamePhase==='showing'){
      ctx.fillStyle=paper?'rgba(0,0,0,0.32)':'rgba(255,255,255,0.32)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      const prog=showIdx>0?` · ${showIdx}/${sequence.length}`:'';
      ctx.fillText(`watch the sequence${prog}`,W/2,sy);
    } else if(gamePhase==='input'){
      ctx.fillStyle=paper?'rgba(30,110,220,0.8)':'rgba(100,190,255,0.9)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(`your turn  ·  ${playerSeq.length} / ${sequence.length}`,W/2,sy);
    } else if(gamePhase==='result'){
      if(resultMsg==='correct'){
        ctx.fillStyle=paper?'#226622':'#44ee88';
        ctx.font=`400 10px 'IBM Plex Mono',monospace`;
        ctx.fillText(`✓  correct!  +${sequence.length*10*(difficulty+1)} pts`,W/2,sy);
      } else {
        ctx.fillStyle=paper?'#882222':'#ff6060';
        ctx.font=`400 10px 'IBM Plex Mono',monospace`;
        ctx.fillText(`✗  wrong — restarting…`,W/2,sy);
      }
    }
    ctx.textAlign='left';
  }

  const onClick=e=>{
    const r=c.getBoundingClientRect();
    handleCellClick(hitTest(e.clientX-r.left, e.clientY-r.top));
  };
  const onTouch=e=>{
    e.preventDefault();
    const r=c.getBoundingClientRect();
    const t=e.touches[0];
    handleCellClick(hitTest(t.clientX-r.left, t.clientY-r.top));
  };
  c.addEventListener('click',onClick);
  c.addEventListener('touchstart',onTouch,{passive:false});

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{
    difficulty=(difficulty+1)%3;
    diffBtn.textContent=DIFF_NAMES[difficulty];
    newGame();
  });
  mkBtn('New Game',ctrl).addEventListener('click',newGame);
  mkInfo(ctrl).textContent='repeat the sequence';

  newGame();
  requestAnimationFrame(draw);
  return ()=>{ cancelAnimationFrame(raf); ro.disconnect();
    c.removeEventListener('click',onClick);
    c.removeEventListener('touchstart',onTouch); };
}


// ════════════════════════════════════════════════════════════════════════════
// TOY — WORDLE
// ════════════════════════════════════════════════════════════════════════════
function initWordle(body, ctrl) {
  body.style.position='relative';
  body.style.overflow='hidden';

  let difficulty=1; // 0=easy(7 guesses), 1=normal(6), 2=hard(5)
  const DIFF_NAMES=['Easy','Normal','Hard'];
  const MAX_GUESSES=[7,6,5];

