// TOY 39 — POINTILLISM PAINTER
// ════════════════════════════════════════════════════════════════════════════
function initPointillism(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  let offscreen=null; // source image canvas
  let dots=[], dotTarget=4000, dotSize=4, phase2='draw'; // draw | upload
  let painting=false, brushCol='#ff4488', brushX=0, brushY=0;
  let drawCanvas=null, drawCtx=null;
  let mode='sketch'; // sketch | photo
  let spawnQueue=0, tick4=0;

  function mkDrawCanvas(){
    drawCanvas=document.createElement('canvas');
    drawCanvas.width=W; drawCanvas.height=H;
    drawCtx=drawCanvas.getContext('2d');
    drawCtx.fillStyle=isPaper()?'#f5f1e8':'#0a0a09';
    drawCtx.fillRect(0,0,W,H);
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    dots=[]; offscreen=null; spawnQueue=0; tick4=0;
    mkDrawCanvas();
  }
  init();

  function sampleColor(sx,sy){
    if(!offscreen) return brushCol;
    const ox=Math.round(sx/W*offscreen.width);
    const oy=Math.round(sy/H*offscreen.height);
    try{
      const d=offscreen.getContext('2d').getImageData(Math.max(0,Math.min(ox,offscreen.width-1)),Math.max(0,Math.min(oy,offscreen.height-1)),1,1).data;
      return `rgb(${d[0]},${d[1]},${d[2]})`;
    }catch(e){return brushCol;}
  }

  function spawnDot(sx,sy){
    const jx=sx+rndf(-dotSize*2,dotSize*2);
    const jy=sy+rndf(-dotSize*2,dotSize*2);
    if(jx<0||jy<0||jx>W||jy>H) return;
    const col=sampleColor(jx,jy);
    dots.push({x:jx,y:jy,r:dotSize*0.4+rndf(0,dotSize*0.8),col,alpha:0,targetAlpha:0.85+rndf(0,0.15),born:tick4});
  }

  function processImage(img){
    offscreen=document.createElement('canvas');
    offscreen.width=200; offscreen.height=Math.round(200*img.height/img.width);
    offscreen.getContext('2d').drawImage(img,0,0,offscreen.width,offscreen.height);
    dots=[];
    // scatter dots
    for(let i=0;i<dotTarget;i++){
      spawnDot(Math.random()*W,Math.random()*H);
    }
    dots.forEach(d=>{d.alpha=d.targetAlpha;});
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    tick4++;
    const paper=isPaper();

    // Spawn dots from sketch
    if(mode==='sketch'&&offscreen&&spawnQueue>0){
      const batch=Math.min(20,spawnQueue);
      for(let i=0;i<batch;i++){
        spawnDot(Math.random()*W,Math.random()*H);
      }
      spawnQueue-=batch;
    }

    ctx.fillStyle=paper?'#f8f4ea':'#0a0a09'; ctx.fillRect(0,0,W,H);

    // Animate dots appearing
    for(const d of dots){
      if(d.alpha<d.targetAlpha) d.alpha=Math.min(d.targetAlpha,d.alpha+0.04);
      ctx.globalAlpha=d.alpha;
      ctx.fillStyle=d.col;
      ctx.beginPath();ctx.arc(d.x,d.y,d.r,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Painting cursor
    if(painting&&mode==='sketch'){
      ctx.strokeStyle=brushCol;ctx.lineWidth=1.5;
      ctx.beginPath();ctx.arc(brushX,brushY,dotSize*3,0,Math.PI*2);ctx.stroke();
    }

    ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.3)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    if(mode==='sketch') ctx.fillText(`sketch mode · click-drag to paint · ${dots.length} dots`,8,6);
    else ctx.fillText(`photo mode · upload an image`,8,6);
  }

  // Sketch painting
  c.addEventListener('mousedown',e=>{
    if(mode!=='sketch') return;
    painting=true;
    const r=c.getBoundingClientRect();
    brushX=e.clientX-r.left; brushY=e.clientY-r.top;
    // paint on drawCanvas
    drawCtx.fillStyle=brushCol; drawCtx.beginPath();drawCtx.arc(brushX,brushY,12,0,Math.PI*2);drawCtx.fill();
    offscreen=drawCanvas;
    for(let i=0;i<8;i++) spawnDot(brushX+rndf(-20,20),brushY+rndf(-20,20));
  });
  c.addEventListener('mousemove',e=>{
    if(!painting||mode!=='sketch') return;
    const r=c.getBoundingClientRect();
    brushX=e.clientX-r.left; brushY=e.clientY-r.top;
    drawCtx.fillStyle=brushCol; drawCtx.beginPath();drawCtx.arc(brushX,brushY,12,0,Math.PI*2);drawCtx.fill();
    offscreen=drawCanvas;
    for(let i=0;i<4;i++) spawnDot(brushX+rndf(-20,20),brushY+rndf(-20,20));
  });
  c.addEventListener('mouseup',()=>painting=false);
  c.addEventListener('mouseleave',()=>painting=false);

  // Color picker from palette
  const PCOLS=['#ff4488','#ff8844','#ffcc44','#44ff88','#44aaff','#cc44ff','#ffffff','#000000'];
  const colBtns=PCOLS.map(col=>{
    const b=document.createElement('button');
    b.className='sb-btn'; b.style.cssText=`width:18px;height:18px;padding:0;background:${col};border:2px solid transparent;flex-shrink:0;`;
    b.title=col; ctrl.appendChild(b);
    b.addEventListener('click',()=>{
      brushCol=col;
      colBtns.forEach(bb=>bb.style.borderColor='transparent');
      b.style.borderColor='#fff';
    });
    return b;
  });
  colBtns[0].style.borderColor='#fff';

  const fileInput=document.createElement('input');
  fileInput.type='file'; fileInput.accept='image/*'; fileInput.style.display='none';
  body.appendChild(fileInput);
  fileInput.addEventListener('change',()=>{
    const file=fileInput.files[0]; if(!file) return;
    const img=new Image();
    img.onload=()=>{mode='photo';processImage(img);URL.revokeObjectURL(img.src);};
    img.src=URL.createObjectURL(file);
  });

  mkBtn('Upload Image',ctrl).addEventListener('click',()=>fileInput.click());
  mkBtn('Sketch Mode',ctrl).addEventListener('click',()=>{mode='sketch';offscreen=drawCanvas;});

  const szLbl=document.createElement('span');szLbl.className='sb-info sb-speed-lbl';szLbl.textContent='dot size';ctrl.appendChild(szLbl);
  const szSl=document.createElement('input');szSl.type='range';szSl.className='sb-slider';szSl.min=1;szSl.max=12;szSl.step=1;szSl.value=dotSize;ctrl.appendChild(szSl);styleSlider(szSl);
  szSl.addEventListener('input',()=>dotSize=+szSl.value);

  mkBtn('Clear',ctrl).addEventListener('click',()=>{
    dots=[];
    if(drawCtx){drawCtx.fillStyle=isPaper()?'#f5f1e8':'#0a0a09';drawCtx.fillRect(0,0,W,H);}
    offscreen=null;
  });

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

