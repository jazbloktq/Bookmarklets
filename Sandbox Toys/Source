// TOY 10 — TETRIS
// ════════════════════════════════════════════════════════════════════════════
function initTetris(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  const COLS=10, ROWS=20;
  let W=c.width, H=c.height;
  let CW,CH,OX,OY;
  function recalc(){W=body.clientWidth;H=body.clientHeight;CW=Math.floor(Math.min(W/COLS,(H-60)/ROWS));CH=CW;OX=Math.floor((W-CW*COLS)/2);OY=Math.floor((H-60-CH*ROWS)/2)+4;}
  recalc();
  const PIECES=[
    {shape:[[1,1,1,1]],color:'#00cfff'},
    {shape:[[1,0],[1,0],[1,1]],color:'#f5a623'},
    {shape:[[0,1],[0,1],[1,1]],color:'#4a90e2'},
    {shape:[[1,1],[1,1]],color:'#f8e71c'},
    {shape:[[0,1,1],[1,1,0]],color:'#7ed321'},
    {shape:[[1,1,1],[0,1,0]],color:'#9b59b6'},
    {shape:[[1,1,0],[0,1,1]],color:'#e74c3c'},
  ];
  const paperColors=['#8a7060','#7a6050','#6a5040','#b09080','#a08070','#907060','#c0a090'];
  let board,piece,px,py,score,lines,level,raf,speed,timer,gameOver,paused;
  function newBoard(){board=Array.from({length:ROWS},()=>Array(COLS).fill(0));}
  function randPiece(){const i=Math.floor(Math.random()*PIECES.length);return{...PIECES[i],colorIdx:i,shape:PIECES[i].shape.map(r=>[...r])};}
  function spawnPiece(){piece=randPiece();px=Math.floor((COLS-piece.shape[0].length)/2);py=0;if(!valid(piece.shape,px,py)){gameOver=true;}}
  function valid(shape,tx,ty){for(let r=0;r<shape.length;r++)for(let c2=0;c2<shape[r].length;c2++){if(!shape[r][c2])continue;const nx=tx+c2,ny=ty+r;if(nx<0||nx>=COLS||ny>=ROWS)return false;if(ny>=0&&board[ny][nx])return false;}return true;}
  function place(){for(let r=0;r<piece.shape.length;r++)for(let c2=0;c2<piece.shape[r].length;c2++){if(piece.shape[r][c2]&&py+r>=0)board[py+r][px+c2]=piece.colorIdx+1;}let cleared=0;for(let r=ROWS-1;r>=0;){if(board[r].every(v=>v)){board.splice(r,1);board.unshift(Array(COLS).fill(0));cleared++;}else r--;}if(cleared){lines+=cleared;score+=([0,100,300,500,800][cleared]||800)*(level+1);level=Math.floor(lines/10);speed=Math.max(80,500-level*40);}spawnPiece();}
  function rotate(shape){return shape[0].map((_,i)=>shape.map(r=>r[i]).reverse());}
  function init(){newBoard();score=0;lines=0;level=0;speed=500;timer=0;gameOver=false;paused=false;spawnPiece();}
  init();
  let lastT=0;
  function step(ts){
    raf=requestAnimationFrame(step);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;recalc();
    const dt=ts-lastT;lastT=ts;
    if(!paused&&!gameOver){timer+=dt;if(timer>=speed){timer=0;if(valid(piece.shape,px,py+1))py++;else place();}}
    const paper=isPaper();
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    // board bg
    ctx.fillStyle=paper?'rgba(0,0,0,0.04)':'rgba(255,255,255,0.03)';
    ctx.fillRect(OX,OY,CW*COLS,CH*ROWS);
    // board cells
    const clrs=paper?paperColors:PIECES.map(p=>p.color);
    for(let r=0;r<ROWS;r++)for(let cc=0;cc<COLS;cc++){if(board[r][cc]){ctx.fillStyle=clrs[board[r][cc]-1];ctx.fillRect(OX+cc*CW+1,OY+r*CH+1,CW-2,CH-2);}}
    // active piece
    if(!gameOver&&piece)for(let r=0;r<piece.shape.length;r++)for(let cc=0;cc<piece.shape[r].length;cc++){if(piece.shape[r][cc]){ctx.fillStyle=clrs[piece.colorIdx];ctx.fillRect(OX+(px+cc)*CW+1,OY+(py+r)*CH+1,CW-2,CH-2);}}
    // ghost
    let gy=py;while(valid(piece.shape,px,gy+1))gy++;
    if(gy!==py&&!gameOver)for(let r=0;r<piece.shape.length;r++)for(let cc=0;cc<piece.shape[r].length;cc++){if(piece.shape[r][cc]){ctx.fillStyle=paper?'rgba(0,0,0,0.12)':'rgba(255,255,255,0.12)';ctx.fillRect(OX+(px+cc)*CW+1,OY+(gy+r)*CH+1,CW-2,CH-2);}}
    // grid lines
    ctx.strokeStyle=paper?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.05)';ctx.lineWidth=0.5;
    for(let r=0;r<=ROWS;r++){ctx.beginPath();ctx.moveTo(OX,OY+r*CH);ctx.lineTo(OX+COLS*CW,OY+r*CH);ctx.stroke();}
    for(let cc=0;cc<=COLS;cc++){ctx.beginPath();ctx.moveTo(OX+cc*CW,OY);ctx.lineTo(OX+cc*CW,OY+ROWS*CH);ctx.stroke();}
    // score
    const fg=paper?'rgba(30,20,10,0.7)':'rgba(255,255,255,0.5)';
    ctx.fillStyle=fg;ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='left';
    ctx.fillText(`score ${score}  lines ${lines}  level ${level+1}`,OX,OY+ROWS*CH+20);
    if(gameOver){ctx.fillStyle=paper?'rgba(30,20,10,0.85)':'rgba(255,255,255,0.85)';ctx.font=`400 18px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.fillText('GAME OVER',W/2,H/2-10);ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.fillText('press R to restart',W/2,H/2+14);}
    if(paused&&!gameOver){ctx.fillStyle=paper?'rgba(30,20,10,0.85)':'rgba(255,255,255,0.85)';ctx.font=`300 13px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.fillText('PAUSED',W/2,H/2);}
    scoreEl.textContent=`score ${score}`;
  }
  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',init);
  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{if(gameOver)return;paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';});
  const onKey=e=>{
    if(gameOver){if(e.key==='r'||e.key==='R'){init();return;}}
    if(paused)return;
    if(e.key==='ArrowLeft'&&valid(piece.shape,px-1,py)){px--;e.preventDefault();}
    if(e.key==='ArrowRight'&&valid(piece.shape,px+1,py)){px++;e.preventDefault();}
    if(e.key==='ArrowDown'){if(valid(piece.shape,px,py+1))py++;e.preventDefault();}
    if(e.key==='ArrowUp'||e.key==='z'||e.key==='Z'){const r=rotate(piece.shape);if(valid(r,px,py))piece.shape=r;e.preventDefault();}
    if(e.key===' '){while(valid(piece.shape,px,py+1))py++;place();e.preventDefault();}
  };
  document.addEventListener('keydown',onKey);
  requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}

