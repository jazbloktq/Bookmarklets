// TOY 35 — RHYTHM TAP  (FNF-style, arrow keys)
// ════════════════════════════════════════════════════════════════════════════
function initRhythmTap(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  // Lane order: left, down, up, right — matching FNF layout
  // Keys map directly: ArrowLeft=lane0 ArrowDown=lane1 ArrowUp=lane2 ArrowRight=lane3
  // The ARROW SHAPES drawn: lane 0=←, 1=↓, 2=↑, 3=→
  // Notes fall FROM TOP TO BOTTOM. Receptor is at BOTTOM. Press when note reaches bottom.
  const LANES=4;
  const KEYS=['ArrowLeft','ArrowDown','ArrowUp','ArrowRight'];
  const COLS=['#ff44aa','#44ffaa','#44aaff','#ffaa44'];
  // Arrow directions for drawing: 0=left 1=down 2=up 3=right
  const DIRS=[0,1,2,3];
  const HIT_Y_FRAC=0.88;
  const NOTE_W=48, NOTE_H=48, LANE_GAP=64;
  const HIT_WINDOW_PX=38;
  const NOTE_SPEED_BASE=3.5;

  // Judgement popup
  let popups=[];

  let notes, score, combo, maxCombo, misses, tick2;
  let keysHeld={}, keyFlash={};
  let noteSpeed=NOTE_SPEED_BASE;
  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const DIFF_RATES=[0.010,0.020,0.034];

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    notes=[]; score=0; combo=0; maxCombo=0; misses=0; tick2=0;
    keysHeld={}; keyFlash={}; popups=[];
  }
  init();

  function spawnNote(){
    const lane=Math.floor(Math.random()*LANES);
    notes.push({lane, y:-NOTE_H, hit:false, miss:false, flash:0});
  }

  function laneX(lane){
    const totalW=LANES*NOTE_W+(LANES-1)*(LANE_GAP-NOTE_W);
    const startX=(W-totalW)/2+NOTE_W/2;
    return startX+lane*LANE_GAP;
  }

  // Draw a chunky arrow shape pointing in dir (0=left 1=down 2=up 3=right)
  function drawArrow(x,y,dir,col,alpha,sc){
    ctx.save();
    ctx.globalAlpha=Math.max(0,alpha);
    ctx.translate(x,y); ctx.scale(sc,sc);
    const s=NOTE_W*0.38; // half-size
    ctx.fillStyle=col;
    ctx.strokeStyle='rgba(255,255,255,0.55)'; ctx.lineWidth=2.5/sc;
    ctx.beginPath();
    if(dir===0){ // ← left arrow
      ctx.moveTo(s,s*0.45); ctx.lineTo(0,0); ctx.lineTo(s,-s*0.45);
      ctx.lineTo(s,-s*0.15); ctx.lineTo(s*1.6,-s*0.15);
      ctx.lineTo(s*1.6,s*0.15); ctx.lineTo(s,s*0.15);
    } else if(dir===1){ // ↓ down arrow
      ctx.moveTo(-s*0.45,-s); ctx.lineTo(0,0); ctx.lineTo(s*0.45,-s);
      ctx.lineTo(s*0.15,-s); ctx.lineTo(s*0.15,-s*1.6);
      ctx.lineTo(-s*0.15,-s*1.6); ctx.lineTo(-s*0.15,-s);
    } else if(dir===2){ // ↑ up arrow
      ctx.moveTo(-s*0.45,s); ctx.lineTo(0,0); ctx.lineTo(s*0.45,s);
      ctx.lineTo(s*0.15,s); ctx.lineTo(s*0.15,s*1.6);
      ctx.lineTo(-s*0.15,s*1.6); ctx.lineTo(-s*0.15,s);
    } else { // → right arrow
      ctx.moveTo(-s,s*0.45); ctx.lineTo(0,0); ctx.lineTo(-s,-s*0.45);
      ctx.lineTo(-s,-s*0.15); ctx.lineTo(-s*1.6,-s*0.15);
      ctx.lineTo(-s*1.6,s*0.15); ctx.lineTo(-s,s*0.15);
    }
    ctx.closePath();
    ctx.fill(); ctx.stroke();
    ctx.restore();
  }

  function addPopup(x,y,label,col){
    popups.push({x,y,label,col,life:1.0,vy:-1.8});
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    tick2++;

    if(Math.random()<DIFF_RATES[difficulty]) spawnNote();

    const hitY=H*HIT_Y_FRAC;

    // Advance notes downward
    for(const n of notes){
      if(!n.hit&&!n.miss) n.y+=noteSpeed;
      if(n.flash>0) n.flash-=0.07;
      if(!n.hit&&!n.miss&&n.y>hitY+HIT_WINDOW_PX+NOTE_H){
        n.miss=true; combo=0; misses++;
        addPopup(laneX(n.lane),hitY,'Miss','#ff4444');
      }
    }
    notes=notes.filter(n=>!(n.miss&&n.flash<=0)&&!(n.hit&&n.flash<=0)&&n.y<H+80);

    // Advance popups
    for(const p of popups){p.y+=p.vy;p.vy*=0.92;p.life-=0.035;}
    popups=popups.filter(p=>p.life>0);

    // BG
    ctx.fillStyle=paper?'#f0ece0':'#0a0810'; ctx.fillRect(0,0,W,H);

    // Lane stripes
    for(let l=0;l<LANES;l++){
      const lx=laneX(l);
      ctx.strokeStyle=paper?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.04)';
      ctx.lineWidth=NOTE_W+10;
      ctx.beginPath();ctx.moveTo(lx,0);ctx.lineTo(lx,H);ctx.stroke();
    }

    // Hit zone line
    ctx.strokeStyle=paper?'rgba(0,0,0,0.1)':'rgba(255,255,255,0.09)';
    ctx.lineWidth=1; ctx.setLineDash([5,7]);
    ctx.beginPath();ctx.moveTo(0,hitY);ctx.lineTo(W,hitY);ctx.stroke();
    ctx.setLineDash([]);

    // Receptor arrows at hit zone (static targets)
    for(let l=0;l<LANES;l++){
      const lx=laneX(l);
      const held=keysHeld[KEYS[l]];
      const alpha=held?0.95:0.22;
      const sc=held?1.18:1;
      if(!paper){ctx.save();ctx.shadowColor=COLS[l];ctx.shadowBlur=held?22:0;}
      drawArrow(lx,hitY,DIRS[l],COLS[l],alpha,sc);
      if(!paper)ctx.restore();
    }

    // Falling notes
    for(const n of notes){
      const lx=laneX(n.lane);
      const alpha=n.hit?n.flash:(n.miss?n.flash*0.4:1);
      const sc=n.hit?(1+n.flash*0.45):1;
      if(!paper){ctx.save();ctx.shadowColor=COLS[n.lane];ctx.shadowBlur=n.hit?22:7;}
      drawArrow(lx,n.y,DIRS[n.lane],COLS[n.lane],alpha,sc);
      if(!paper)ctx.restore();
    }

    // Combo glow
    if(combo>4){
      ctx.fillStyle=`rgba(255,220,50,${Math.min(0.18,combo*0.015)})`;
      ctx.fillRect(0,0,W,H);
    }

    // Popups
    for(const p of popups){
      ctx.save();
      ctx.globalAlpha=p.life;
      ctx.font=`600 16px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillStyle=p.col;
      // shadow for visibility
      ctx.shadowColor='rgba(0,0,0,0.7)'; ctx.shadowBlur=4;
      ctx.fillText(p.label,p.x,p.y);
      ctx.restore();
    }

    // Score HUD
    ctx.textAlign='center'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.55)':'rgba(255,255,255,0.6)';
    ctx.font=`400 22px 'IBM Plex Mono',monospace`;
    ctx.fillText(`${score}`,W/2,8);
    if(combo>1){
      ctx.fillStyle=paper?'#aa6600':'#ffcc44';
      ctx.font=`300 13px 'IBM Plex Mono',monospace`;
      ctx.fillText(`${combo}× combo`,W/2,36);
    }
    ctx.fillStyle=paper?'rgba(0,0,0,0.28)':'rgba(255,255,255,0.22)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillText(`best ${maxCombo}× · misses ${misses}`,W/2,H-18);
    ctx.textAlign='left';
    ctx.fillText('← ↓ ↑ → keys',8,6);
  }

  const onKey=e=>{
    if(e.type==='keydown') keysHeld[e.code]=true;
    if(e.type==='keyup')   keysHeld[e.code]=false;
    if(e.type!=='keydown') return;
    const li=KEYS.indexOf(e.code);
    if(li<0) return;
    e.preventDefault();
    const hitY=H*HIT_Y_FRAC;
    let best=null, bestDist=Infinity;
    for(const n of notes){
      if(n.lane!==li||n.hit||n.miss) continue;
      const dist=Math.abs(n.y-hitY);
      if(dist<HIT_WINDOW_PX*2&&dist<bestDist){ best=n; bestDist=dist; }
    }
    if(best){
      best.hit=true; best.flash=1;
      const lx=laneX(li);
      let label,pts,col;
      if(bestDist<HIT_WINDOW_PX*0.25){      label='Perfect!'; pts=500; col='#ffdd00';}
      else if(bestDist<HIT_WINDOW_PX*0.55){ label='Amazing';  pts=300; col='#44ffaa';}
      else if(bestDist<HIT_WINDOW_PX*0.85){ label='Good';     pts=150; col='#44aaff';}
      else{                                  label='OK';        pts=50;  col='#aaaaaa';}
      score+=pts*(1+Math.floor(combo/10));
      combo++; if(combo>maxCombo)maxCombo=combo;
      addPopup(lx,hitY-20,label,col);
    } else {
      combo=0;
      addPopup(laneX(li),hitY,'Miss','#ff4444');
    }
  };
  document.addEventListener('keydown',onKey);
  document.addEventListener('keyup',onKey);

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{difficulty=(difficulty+1)%3;diffBtn.textContent=DIFF_NAMES[difficulty];init();});

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.textContent='speed';ctrl.appendChild(spdLbl);
  const spdSl=document.createElement('input');spdSl.type='range';spdSl.className='sb-slider';spdSl.min=1;spdSl.max=8;spdSl.step=0.5;spdSl.value=noteSpeed;ctrl.appendChild(spdSl);styleSlider(spdSl);
  spdSl.addEventListener('input',()=>noteSpeed=+spdSl.value);

  mkBtn('Reset',ctrl).addEventListener('click',init);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);document.removeEventListener('keyup',onKey);};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 41 — FOURIER EPICYCLES
// ════════════════════════════════════════════════════════════════════════════
function initFourierEpicycles(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  const MODES=['draw','watch'];
  let mode='draw';
  let userPath=[];       // raw points drawn by user
  let fourierX=[];       // DFT coefficients (X component)
  let fourierY=[];       // DFT coefficients (Y component)
  let time=0;
  let tracePath=[];      // reconstructed path traced over time
  let numCircles=30;     // how many epicycles to show
  let speed=1;
  let drawing=false;
  let showCircles=true;
  let autoDemo=false;

  // --- DFT ---
  function dft(signal){
    const N=signal.length;
    const X=[];
    for(let k=0;k<N;k++){
      let re=0,im=0;
      for(let n=0;n<N;n++){
        const phi=(2*Math.PI*k*n)/N;
        re+=signal[n]*Math.cos(phi);
        im-=signal[n]*Math.sin(phi);
      }
      re/=N; im/=N;
      const amp=Math.hypot(re,im);
      const phase=Math.atan2(im,re);
      X.push({re,im,amp,phase,freq:k});
    }
    // sort by amplitude descending so biggest circles first
    X.sort((a,b)=>b.amp-a.amp);
    return X;
  }

  function computeFourier(){
    if(userPath.length<4) return;
    // Resample path to fixed N points
    const N=Math.min(256, userPath.length);
    const sampled=resample(userPath,N);
    // Centre
    const cx=sampled.reduce((s,p)=>s+p.x,0)/N;
    const cy=sampled.reduce((s,p)=>s+p.y,0)/N;
    const xs=sampled.map(p=>p.x-cx);
    const ys=sampled.map(p=>p.y-cy);
    fourierX=dft(xs);
    fourierY=dft(ys);
    time=0; tracePath=[];
    numCircles=Math.min(numCircles,N);
  }

  function resample(pts,N){
    // compute arc-length parameterised resample
    if(pts.length===0) return [];
    const totalLen=pts.reduce((s,p,i)=>i===0?0:s+Math.hypot(p.x-pts[i-1].x,p.y-pts[i-1].y),0);
    const step=totalLen/N;
    const out=[{x:pts[0].x,y:pts[0].y}];
    let acc=0, pi=0;
    for(let i=1;i<N;i++){
      const target=i*step;
      while(pi<pts.length-2&&acc+Math.hypot(pts[pi+1].x-pts[pi].x,pts[pi+1].y-pts[pi].y)<target){
        acc+=Math.hypot(pts[pi+1].x-pts[pi].x,pts[pi+1].y-pts[pi].y);
        pi++;
      }
      const seg=Math.hypot(pts[pi+1]?.x-pts[pi].x||0,pts[pi+1]?.y-pts[pi].y||0)||1;
      const t=Math.max(0,Math.min(1,(target-acc)/seg));
      const nx=pts[pi].x+(pts[pi+1]?.x-pts[pi].x||0)*t;
      const ny=pts[pi].y+(pts[pi+1]?.y-pts[pi].y||0)*t;
      out.push({x:nx,y:ny});
    }
    return out;
  }

  // Built-in demo shapes
  function demoHeart(){
    const pts=[];
    const N=200;
    for(let i=0;i<N;i++){
      const t=(i/N)*2*Math.PI;
      // Heart parametric
      const x=16*Math.pow(Math.sin(t),3);
      const y=-(13*Math.cos(t)-5*Math.cos(2*t)-2*Math.cos(3*t)-Math.cos(4*t));
      pts.push({x:W/2+x*Math.min(W,H)*0.025, y:H/2+y*Math.min(W,H)*0.025});
    }
    return pts;
  }

  function demoStar(){
    const pts=[];
    const N=200, spikes=5;
    for(let i=0;i<N;i++){
      const t=(i/N)*2*Math.PI*spikes;
      const r=Math.min(W,H)*0.28*(0.5+0.5*Math.abs(Math.sin(t/2)));
      const angle=(i/N)*2*Math.PI;
      pts.push({x:W/2+Math.cos(angle)*r, y:H/2+Math.sin(angle)*r});
    }
    return pts;
  }

  function demoCircle(){
    const pts=[];
    const N=200, R=Math.min(W,H)*0.3;
    for(let i=0;i<N;i++){
      const t=(i/N)*2*Math.PI;
      pts.push({x:W/2+Math.cos(t)*R, y:H/2+Math.sin(t)*R});
    }
    return pts;
  }

  function loadDemo(name){
    if(name==='heart') userPath=demoHeart();
    else if(name==='star') userPath=demoStar();
    else if(name==='circle') userPath=demoCircle();
    computeFourier(); mode='watch';
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    userPath=[]; fourierX=[]; fourierY=[]; tracePath=[]; time=0;
    mode='draw';
  }
  init();

  // Draw one set of epicycles (x-axis or y-axis decomposition)
  // Returns the tip position after all circles
  function drawEpicycles(startX,startY,rotation,fourier,n){
    let x=startX, y=startY;
    const paper=isPaper();
    for(let i=0;i<Math.min(n,fourier.length);i++){
      const f=fourier[i];
      const prevX=x, prevY=y;
      const angle=f.freq*time*2*Math.PI/fourier.length + f.phase + rotation;
      x+=f.amp*Math.cos(angle);
      y+=f.amp*Math.sin(angle);

      if(showCircles){
        // Circle outline
        ctx.strokeStyle=paper?`rgba(0,0,0,${0.06+0.04*(i===0?1:0)})`:`rgba(255,255,255,${0.06+0.04*(i===0?1:0)})`;
        ctx.lineWidth=0.7;
        ctx.beginPath();ctx.arc(prevX,prevY,f.amp,0,Math.PI*2);ctx.stroke();
        // Arm
        ctx.strokeStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.3)';
        ctx.lineWidth=1;
        ctx.beginPath();ctx.moveTo(prevX,prevY);ctx.lineTo(x,y);ctx.stroke();
      }
    }
    return {x,y};
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=bgFade(0.22); ctx.fillRect(0,0,W,H);

    if(mode==='draw'){
      // Show user stroke
      if(userPath.length>1){
        ctx.strokeStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
        ctx.lineWidth=2; ctx.lineCap='round'; ctx.lineJoin='round';
        ctx.beginPath();
        ctx.moveTo(userPath[0].x,userPath[0].y);
        for(let i=1;i<userPath.length;i++) ctx.lineTo(userPath[i].x,userPath[i].y);
        ctx.stroke(); ctx.lineCap='butt';
      }
      ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
      ctx.font=`300 11px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(userPath.length>10?'release to watch':'draw any shape with your mouse',W/2,H*0.1);
      return;
    }

    if(fourierX.length===0) return;

    // Advance time
    const N=fourierX.length;
    const dt=(2*Math.PI/N)*speed*0.5;
    time+=dt;
    if(time>2*Math.PI){ time-=2*Math.PI; tracePath=[]; }

    // Epicycles for X and Y separately, meeting in the middle
    const ex=W*0.5, ey=H*0.5;

    const tip=drawEpicycles(ex,ey,0,fourierX,numCircles);
    tracePath.push({x:tip.x,y:tip.y});

    // Draw trace
    if(tracePath.length>1){
      const paper2=isPaper();
      ctx.strokeStyle=paper2?'#cc3366':'#ff6699';
      ctx.lineWidth=1.8; ctx.lineCap='round'; ctx.lineJoin='round';
      if(!paper2){ctx.save();ctx.shadowColor='#ff44aa';ctx.shadowBlur=4;}
      ctx.beginPath();
      ctx.moveTo(tracePath[0].x,tracePath[0].y);
      for(let i=1;i<tracePath.length;i++) ctx.lineTo(tracePath[i].x,tracePath[i].y);
      ctx.stroke();
      if(!paper2)ctx.restore();
      ctx.lineCap='butt';
    }

    // Tip dot
    ctx.fillStyle=isPaper()?'#cc3366':'#ff44aa';
    ctx.beginPath();ctx.arc(tip.x,tip.y,4,0,Math.PI*2);ctx.fill();

    // Info
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.28)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`${Math.min(numCircles,N)} epicycles  ·  draw a new shape to replace`,8,6);
  }

  // Mouse drawing
  c.addEventListener('mousedown',e=>{
    const r=c.getBoundingClientRect();
    drawing=true; userPath=[{x:e.clientX-r.left,y:e.clientY-r.top}];
    mode='draw'; tracePath=[]; fourierX=[];
  });
  c.addEventListener('mousemove',e=>{
    if(!drawing) return;
    const r=c.getBoundingClientRect();
    userPath.push({x:e.clientX-r.left,y:e.clientY-r.top});
  });
  c.addEventListener('mouseup',()=>{
    drawing=false;
    if(userPath.length>8){ computeFourier(); mode='watch'; }
  });
  c.addEventListener('mouseleave',()=>{
    if(drawing&&userPath.length>8){ drawing=false; computeFourier(); mode='watch'; }
    drawing=false;
  });

  // Touch support
  c.addEventListener('touchstart',e=>{
    e.preventDefault();
    const r=c.getBoundingClientRect();
    drawing=true; userPath=[{x:e.touches[0].clientX-r.left,y:e.touches[0].clientY-r.top}];
    mode='draw'; tracePath=[]; fourierX=[];
  },{passive:false});
  c.addEventListener('touchmove',e=>{
    e.preventDefault();
    if(!drawing) return;
    const r=c.getBoundingClientRect();
    userPath.push({x:e.touches[0].clientX-r.left,y:e.touches[0].clientY-r.top});
  },{passive:false});
  c.addEventListener('touchend',()=>{
    drawing=false;
    if(userPath.length>8){ computeFourier(); mode='watch'; }
  });

  // Controls
  const circLbl=document.createElement('span');circLbl.className='sb-info sb-speed-lbl';circLbl.textContent='circles';ctrl.appendChild(circLbl);
  const circSl=document.createElement('input');circSl.type='range';circSl.className='sb-slider';circSl.min=1;circSl.max=128;circSl.step=1;circSl.value=numCircles;ctrl.appendChild(circSl);styleSlider(circSl);
  circSl.addEventListener('input',()=>{numCircles=+circSl.value;tracePath=[];time=0;});

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.textContent='speed';ctrl.appendChild(spdLbl);
  const spdSl=document.createElement('input');spdSl.type='range';spdSl.className='sb-slider';spdSl.min=0.1;spdSl.max=4;spdSl.step=0.1;spdSl.value=speed;ctrl.appendChild(spdSl);styleSlider(spdSl);
  spdSl.addEventListener('input',()=>{speed=+spdSl.value;tracePath=[];time=0;});

  const circBtn=mkBtn('Circles: on',ctrl);
  circBtn.addEventListener('click',()=>{showCircles=!showCircles;circBtn.textContent=`Circles: ${showCircles?'on':'off'}`;setLit(circBtn,!showCircles);});

  mkBtn('♡ Heart',ctrl).addEventListener('click',()=>loadDemo('heart'));
  mkBtn('★ Star',ctrl).addEventListener('click',()=>loadDemo('star'));
  mkBtn('○ Circle',ctrl).addEventListener('click',()=>loadDemo('circle'));
  mkBtn('Clear',ctrl).addEventListener('click',init);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}


// TOY 37 — PIXEL ART CANVAS
// ════════════════════════════════════════════════════════════════════════════
function initPixelArt(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;

  const GRID_SIZE=32;
  let pixelSize, offsetX, offsetY;
  let grid=new Array(GRID_SIZE*GRID_SIZE).fill('#ffffff00'); // RGBA strings
  let history=[], redoStack=[];
  let currentCol='#ff4444';
  let tool='draw'; // draw | fill | erase
  let mouseDown=false;
  let lastPainted=-1;

  const PALETTE=[
    '#000000','#ffffff','#ff4444','#ff8844','#ffcc44','#88ff44',
    '#44ffcc','#44aaff','#8844ff','#ff44cc','#886633','#aaaaaa',
    '#ff0000','#00cc00','#0000ff','#ffff00','#ff00ff','#00ffff',
    '#553311','#224422','#112244','#441122','#333333','#eeeeee',
  ];

  function calcLayout(){
    pixelSize=Math.floor(Math.min((W-110),(H-50))/GRID_SIZE);
    const gridW=pixelSize*GRID_SIZE, gridH=pixelSize*GRID_SIZE;
    offsetX=Math.floor((W-110-gridW)/2)+4;
    offsetY=Math.floor((H-gridH)/2);
  }

  function init(){
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    calcLayout();
    grid=new Array(GRID_SIZE*GRID_SIZE).fill('transparent');
    history=[]; redoStack=[];
  }
  init();

  function gridIdx(gx,gy){ return gy*GRID_SIZE+gx; }
  function screenToGrid(sx,sy){
    const gx=Math.floor((sx-offsetX)/pixelSize);
    const gy=Math.floor((sy-offsetY)/pixelSize);
    if(gx<0||gy<0||gx>=GRID_SIZE||gy>=GRID_SIZE) return null;
    return{gx,gy};
  }

  function saveHistory(){
    history.push([...grid]);
    if(history.length>50)history.shift();
    redoStack=[];
  }

  function floodFill(gx,gy,target,replacement){
    if(target===replacement) return;
    const stack=[[gx,gy]];
    while(stack.length){
      const [x,y]=stack.pop();
      if(x<0||y<0||x>=GRID_SIZE||y>=GRID_SIZE) continue;
      const i=gridIdx(x,y);
      if(grid[i]!==target) continue;
      grid[i]=replacement;
      stack.push([x+1,y],[x-1,y],[x,y+1],[x,y-1]);
    }
  }

  function paint(gx,gy){
    const i=gridIdx(gx,gy);
    if(tool==='erase'){ if(grid[i]!=='transparent'){grid[i]='transparent';} }
    else if(tool==='draw'){ if(grid[i]!==currentCol){grid[i]=currentCol;} }
    else if(tool==='fill'){
      saveHistory();
      floodFill(gx,gy,grid[i],tool==='erase'?'transparent':currentCol);
    }
  }

  function exportPng(){
    const ec=document.createElement('canvas');
    ec.width=ec.height=GRID_SIZE;
    const ectx=ec.getContext('2d');
    for(let gy=0;gy<GRID_SIZE;gy++)
      for(let gx=0;gx<GRID_SIZE;gx++){
        const col=grid[gridIdx(gx,gy)];
        if(col==='transparent') continue;
        ectx.fillStyle=col;
        ectx.fillRect(gx,gy,1,1);
      }
    const link=document.createElement('a');
    link.download='pixel-art.png';
    link.href=ec.toDataURL();
    link.click();
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    calcLayout();
    const paper=isPaper();
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);

    // Grid background (checkerboard for transparency)
    for(let gy=0;gy<GRID_SIZE;gy++){
      for(let gx=0;gx<GRID_SIZE;gx++){
        const px=offsetX+gx*pixelSize, py=offsetY+gy*pixelSize;
        const col=grid[gridIdx(gx,gy)];
        // checkerboard bg
        const light=(gx+gy)%2===0;
        ctx.fillStyle=paper?(light?'#ddd':'#ccc'):(light?'#222':'#1a1a1a');
        ctx.fillRect(px,py,pixelSize,pixelSize);
        if(col&&col!=='transparent'){
          ctx.fillStyle=col;
          ctx.fillRect(px,py,pixelSize,pixelSize);
        }
      }
    }

    // Grid lines
    if(pixelSize>=6){
      ctx.strokeStyle=paper?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.05)';
      ctx.lineWidth=0.5;
      for(let i=0;i<=GRID_SIZE;i++){
        ctx.beginPath();ctx.moveTo(offsetX+i*pixelSize,offsetY);ctx.lineTo(offsetX+i*pixelSize,offsetY+GRID_SIZE*pixelSize);ctx.stroke();
        ctx.beginPath();ctx.moveTo(offsetX,offsetY+i*pixelSize);ctx.lineTo(offsetX+GRID_SIZE*pixelSize,offsetY+i*pixelSize);ctx.stroke();
      }
    }

    // Grid border
    ctx.strokeStyle=paper?'rgba(0,0,0,0.25)':'rgba(255,255,255,0.2)';
    ctx.lineWidth=2;
    ctx.strokeRect(offsetX,offsetY,GRID_SIZE*pixelSize,GRID_SIZE*pixelSize);

    // Palette panel (right side)
    const palX=offsetX+GRID_SIZE*pixelSize+12;
    const swSize=16, swGap=2, palCols=4;
    ctx.fillStyle=paper?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.04)';
    roundRect(ctx,palX-4,offsetY,palCols*(swSize+swGap)+8,PALETTE.length/palCols*(swSize+swGap)+8,4);
    ctx.fill();
    PALETTE.forEach((col,i)=>{
      const px2=palX+(i%palCols)*(swSize+swGap);
      const py2=offsetY+4+Math.floor(i/palCols)*(swSize+swGap);
      ctx.fillStyle=col; ctx.fillRect(px2,py2,swSize,swSize);
      if(col===currentCol){
        ctx.strokeStyle='#fff'; ctx.lineWidth=2;
        ctx.strokeRect(px2-1,py2-1,swSize+2,swSize+2);
      }
    });

    // Tool label
    ctx.fillStyle=paper?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.35)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`; ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillText(`tool: ${tool}`,8,6);
  }

  c.addEventListener('mousedown',e=>{
    const r=c.getBoundingClientRect();
    const mx=e.clientX-r.left, my=e.clientY-r.top;
    // palette click
    const palX=offsetX+GRID_SIZE*pixelSize+12;
    const swSize=16,swGap=2,palCols=4;
    for(let i=0;i<PALETTE.length;i++){
      const px2=palX+(i%palCols)*(swSize+swGap);
      const py2=offsetY+4+Math.floor(i/palCols)*(swSize+swGap);
      if(mx>=px2&&mx<=px2+swSize&&my>=py2&&my<=py2+swSize){
        currentCol=PALETTE[i]; return;
      }
    }
    const g=screenToGrid(mx,my);
    if(!g) return;
    if(tool==='fill'){paint(g.gx,g.gy); return;}
    saveHistory(); mouseDown=true; paint(g.gx,g.gy); lastPainted=gridIdx(g.gx,g.gy);
  });
  c.addEventListener('mousemove',e=>{
    if(!mouseDown||tool==='fill') return;
    const r=c.getBoundingClientRect();
    const g=screenToGrid(e.clientX-r.left,e.clientY-r.top);
    if(!g) return;
    const i=gridIdx(g.gx,g.gy);
    if(i!==lastPainted){ paint(g.gx,g.gy); lastPainted=i; }
  });
  c.addEventListener('mouseup',()=>{ mouseDown=false; lastPainted=-1; });
  c.addEventListener('mouseleave',()=>{ mouseDown=false; });

  const toolBtn=mkBtn('Draw',ctrl);
  toolBtn.addEventListener('click',()=>{
    const t2=['draw','erase','fill'];
    tool=t2[(t2.indexOf(tool)+1)%3];
    toolBtn.textContent=tool[0].toUpperCase()+tool.slice(1);
  });
  mkBtn('Undo',ctrl).addEventListener('click',()=>{
    if(history.length){ redoStack.push([...grid]); grid=history.pop(); }
  });
  mkBtn('Redo',ctrl).addEventListener('click',()=>{
    if(redoStack.length){ history.push([...grid]); grid=redoStack.pop(); }
  });
  mkBtn('Clear',ctrl).addEventListener('click',()=>{saveHistory();grid=new Array(GRID_SIZE*GRID_SIZE).fill('transparent');});
  mkBtn('Export PNG',ctrl).addEventListener('click',exportPng);

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

