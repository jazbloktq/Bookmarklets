function mkCanvas(body) {
  const c = document.createElement('canvas'); body.appendChild(c);
  const sync = () => { c.width=body.clientWidth; c.height=body.clientHeight; };
  sync();
  const ro = new ResizeObserver(sync); ro.observe(body);
  return { c, ctx: c.getContext('2d'), sync, ro };
}
function rafLoop(fn) {
  let id, live=true;
  const tick=()=>{ if(!live)return; fn(); id=requestAnimationFrame(tick); };
  id=requestAnimationFrame(tick);
  return ()=>{ live=false; cancelAnimationFrame(id); };
}
function mkBtn(label, ctrl, lit) {
  const b=document.createElement('button'); b.className='sb-btn'+(lit?' lit':''); b.textContent=label; ctrl.appendChild(b); styleBtn(b); return b;
}
function mkInfo(ctrl) {
  const s=document.createElement('span'); s.className='sb-info'; s.style.color=tv().infoText; ctrl.appendChild(s); return s;
}
function rndf(a,b) { return Math.random()*(b-a)+a; }
function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath(); ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.arcTo(x+w,y,x+w,y+r,r);
  ctx.lineTo(x+w,y+h-r); ctx.arcTo(x+w,y+h,x+w-r,y+h,r); ctx.lineTo(x+r,y+h);
  ctx.arcTo(x,y+h,x,y+h-r,r); ctx.lineTo(x,y+r); ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
}

// ── drag / resize ─────────────────────────────────────────────────────────────
function makeDraggable(win, bar) {
  let ox,oy,on=false;
  bar.addEventListener('mousedown',e=>{ if(e.target===win.querySelector('.sb-win-close'))return; on=true; ox=e.clientX-win.offsetLeft; oy=e.clientY-win.offsetTop; e.preventDefault(); });
  const mv=e=>{ if(!on)return; win.style.left=Math.max(0,e.clientX-ox)+'px'; win.style.top=Math.max(0,e.clientY-oy)+'px'; };
  const up=()=>on=false;
  document.addEventListener('mousemove',mv); document.addEventListener('mouseup',up);
  return ()=>{ document.removeEventListener('mousemove',mv); document.removeEventListener('mouseup',up); };
}
function makeResizable(win, handle) {
  let sx,sy,sw,sh,on=false;
  handle.addEventListener('mousedown',e=>{ on=true; sx=e.clientX; sy=e.clientY; sw=win.offsetWidth; sh=win.offsetHeight; e.preventDefault(); e.stopPropagation(); });
  const mv=e=>{ if(!on)return; win.style.width=Math.max(320,sw+e.clientX-sx)+'px'; win.style.height=Math.max(220,sh+e.clientY-sy)+'px'; };
  const up=()=>on=false;
  document.addEventListener('mousemove',mv); document.addEventListener('mouseup',up);
}

// ── window manager ────────────────────────────────────────────────────────────
let activeWin = null;
function openWin(i, toy) {
  const W = Math.min(640, window.innerWidth-220);
  const H = Math.min(500, window.innerHeight-60);
  // always open centred in the space to the right of the panel
  const left = 216 + Math.round((window.innerWidth - 216 - W) / 2);
  const top  = Math.round((window.innerHeight - H) / 2);
  const win = document.createElement('div'); win.className='sb-win'; win._toyIdx=i;
  win.style.cssText = `left:${left}px;top:${top}px;width:${W}px;height:${H}px;`;
  const bar  = document.createElement('div'); bar.className='sb-win-bar';
  const nm   = document.createElement('span'); nm.className='sb-win-name'; nm.textContent=toy.name;
  const cl   = document.createElement('button'); cl.className='sb-win-close'; cl.textContent='—'; cl.title='Close';
  bar.appendChild(nm); bar.appendChild(cl);
  const body = document.createElement('div'); body.className='sb-win-body';
  const ctrl = document.createElement('div'); ctrl.className='sb-win-ctrl';
  const rz   = document.createElement('div'); rz.className='sb-win-resize';
  win.appendChild(bar); win.appendChild(body); win.appendChild(ctrl); win.appendChild(rz);
  ROOT.appendChild(win); styleWin(win);
  activeWin=win; items[i].classList.add('active'); refreshItem(items[i]);
  cl.addEventListener('click', ()=>closeWin(win));
  win._dc=makeDraggable(win,bar); makeResizable(win,rz);
  win._destroy=toy.init(body,ctrl);
}
function closeWin(win) {
  if(!win)return; win._destroy?.(); win._dc?.();
  items[win._toyIdx].classList.remove('active'); refreshItem(items[win._toyIdx]);
  win.remove(); if(activeWin===win)activeWin=null;
}
function toggleToy(i) {
  if(activeWin&&activeWin._toyIdx===i){ closeWin(activeWin); return; }
  if(activeWin) closeWin(activeWin);
  openWin(i, TOYS[i]);
}

// keyboard 1–8
document.addEventListener('keydown', e => {
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.isContentEditable)return;
  const n=parseInt(e.key); if(n>=1&&n<=8){ e.preventDefault(); toggleToy(n-1); }
});

// ── WIGGLE ────────────────────────────────────────────────────────────────────
// Only wiggles actual page content — skips html, body, and everything in #__SB_ROOT__
let wiggling=false, wigStyleEl=null;
function toggleWiggle(item) {
  if(wiggling) {
    wiggling=false; wigStyleEl?.remove(); wigStyleEl=null;
    document.querySelectorAll('[data-sb-wiggle]').forEach(el => {
      el.style.animation='';
      el.style.removeProperty('--sbwx'); el.style.removeProperty('--sbwy'); el.style.removeProperty('--sbwr');
      el.removeAttribute('data-sb-wiggle');
    });
    item.classList.remove('wiggle-active');
  } else {
    wiggling=true; item.classList.add('wiggle-active');
    wigStyleEl=document.createElement('style'); wigStyleEl.id='__SB_WIGGLE_STYLE__';
    wigStyleEl.textContent=`@keyframes __sbwgl__{0%,100%{transform:translate(0,0) rotate(0deg)}25%{transform:translate(var(--sbwx),var(--sbwy)) rotate(var(--sbwr))}75%{transform:translate(calc(-1*var(--sbwx)),var(--sbwy)) rotate(calc(-1*var(--sbwr)))}}`;
    document.head.appendChild(wigStyleEl);
    document.querySelectorAll('*').forEach(el => {
      // skip html & body (wiggling them shifts the whole viewport including the sidebar)
      if(el.tagName==='HTML' || el.tagName==='BODY') return;
      // skip ALL sandbox UI
      if(el===ROOT || el.closest('#__SB_ROOT__')) return;
      const amp=2+Math.random()*7, dur=(0.7+Math.random()*2.2).toFixed(2), delay=(-(Math.random()*parseFloat(dur))).toFixed(2);
      el.style.setProperty('--sbwx',`${((Math.random()-.5)*amp*2).toFixed(1)}px`);
      el.style.setProperty('--sbwy',`${((Math.random()-.5)*amp).toFixed(1)}px`);
      el.style.setProperty('--sbwr',`${((Math.random()-.5)*1.8).toFixed(2)}deg`);
      el.style.animation=`__sbwgl__ ${dur}s ${delay}s ease-in-out infinite`;
      el.setAttribute('data-sb-wiggle','1');
    });
  }
  refreshItem(item);
}

