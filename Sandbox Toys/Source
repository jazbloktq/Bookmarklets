// TOY 18 — FLAPPY BIRD
// ════════════════════════════════════════════════════════════════════════════
function initFlappy(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let bird,pipes,score,gameOver,started,speed;
  const GAP=130,PW=52,GRAV=0.38,JUMP=-7.2;

  function init(){
    bird={x:W*0.22,y:H/2,vy:0,r:12};
    pipes=[];score=0;gameOver=false;started=false;speed=2.4;
    for(let i=0;i<3;i++) addPipe(W+i*(W/3));
  }
  function addPipe(x){
    const top=80+Math.random()*(H-GAP-160);
    pipes.push({x,top,scored:false});
  }
  function flap(){if(gameOver){init();return;}started=true;bird.vy=JUMP;}

  function step(){
    raf=requestAnimationFrame(step);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const paper=isPaper();
    if(started&&!gameOver){
      bird.vy+=GRAV;bird.y+=bird.vy;
      speed+=0.0006;
      for(const p of pipes){
        p.x-=speed;
        if(!p.scored&&p.x+PW<bird.x){p.scored=true;score++;scoreEl.textContent=`score ${score}`;}
      }
      if(pipes[0].x+PW<0){pipes.shift();addPipe(pipes[pipes.length-1].x+W/3);}
      // collision
      for(const p of pipes){
        const inX=bird.x+bird.r>p.x&&bird.x-bird.r<p.x+PW;
        if(inX&&(bird.y-bird.r<p.top||bird.y+bird.r>p.top+GAP))gameOver=true;
      }
      if(bird.y+bird.r>H||bird.y-bird.r<0)gameOver=true;
    }
    // draw bg
    ctx.fillStyle=paper?'#d4eaf7':'#0a1628';ctx.fillRect(0,0,W,H);
    // pipes
    for(const p of pipes){
      ctx.fillStyle=paper?'#5a8a3c':'#3a7a2c';
      ctx.fillRect(p.x,0,PW,p.top);
      ctx.fillRect(p.x,p.top+GAP,PW,H-p.top-GAP);
      // pipe caps
      ctx.fillStyle=paper?'#4a7a2c':'#2a6a1c';
      ctx.fillRect(p.x-4,p.top-14,PW+8,14);
      ctx.fillRect(p.x-4,p.top+GAP,PW+8,14);
    }
    // ground
    ctx.fillStyle=paper?'#c8a850':'#8a6830';
    ctx.fillRect(0,H-20,W,20);
    ctx.fillStyle=paper?'#a89040':'#6a5020';
    ctx.fillRect(0,H-24,W,6);
    // bird body
    const bx=bird.x,by=bird.y,br=bird.r;
    const tilt=Math.max(-0.4,Math.min(0.8,bird.vy*0.07));
    ctx.save();ctx.translate(bx,by);ctx.rotate(tilt);
    ctx.fillStyle=paper?'#e8c820':'#f0d020';
    ctx.beginPath();ctx.arc(0,0,br,0,Math.PI*2);ctx.fill();
    // wing
    ctx.fillStyle=paper?'#d0a010':'#e0b010';
    ctx.beginPath();ctx.ellipse(-3,4,br*0.7,br*0.45,0.3,0,Math.PI*2);ctx.fill();
    // eye
    ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(5,-3,4,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#222';ctx.beginPath();ctx.arc(6,-3,2,0,Math.PI*2);ctx.fill();
    // beak
    ctx.fillStyle='#e07010';ctx.beginPath();ctx.moveTo(br,0);ctx.lineTo(br+8,2);ctx.lineTo(br,-2);ctx.closePath();ctx.fill();
    ctx.restore();
    // HUD
    if(!started&&!gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.5)';
      ctx.font=`300 14px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('click or space to flap',W/2,H/2+50);
    }
    if(gameOver){
      ctx.fillStyle=paper?'rgba(0,0,0,0.6)':'rgba(255,255,255,0.6)';
      ctx.font=`400 22px 'IBM Plex Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText('GAME OVER',W/2,H/2-18);
      ctx.font=`300 12px 'IBM Plex Mono',monospace`;
      ctx.fillText(`score ${score} — click to restart`,W/2,H/2+14);
    }
  }
  const scoreEl=mkInfo(ctrl);
  c.addEventListener('click',flap);
  const onKey=e=>{if(e.code==='Space'){e.preventDefault();flap();}};
  document.addEventListener('keydown',onKey);
  init();requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}

