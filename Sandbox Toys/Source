// TOY 21 — 2048  (animated sliding tiles)
// ════════════════════════════════════════════════════════════════════════════
function init2048(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let grid,score,gameOver,won;
  let anims=[],animT=0,animating=false;
  const ANIM_DUR=0.12;
  const TILE_COLORS={
    0:'transparent',2:'#eee4da',4:'#ede0c8',8:'#f2b179',16:'#f59563',
    32:'#f67c5f',64:'#f65e3b',128:'#edcf72',256:'#edcc61',512:'#edc850',
    1024:'#edc53f',2048:'#edc22e',
  };
  function newGrid(){return Array.from({length:4},()=>[0,0,0,0]);}
  function addRandom(g){
    const empty=[];
    for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++)if(g[r][cc]===0)empty.push([r,cc]);
    if(!empty.length)return;
    const[r,cc]=empty[Math.floor(Math.random()*empty.length)];
    g[r][cc]=Math.random()<0.9?2:4;
  }
  function init(){grid=newGrid();score=0;gameOver=false;won=false;anims=[];animating=false;addRandom(grid);addRandom(grid);}
  init();
  function slideRowAnim(row,lineIdx,isRow){
    const moves=[];
    let r=[];
    for(let i=0;i<4;i++)if(row[i])r.push({v:row[i],orig:i});
    const result=[0,0,0,0];let dest=0;
    for(let i=0;i<r.length;i++){
      if(i+1<r.length&&r[i].v===r[i+1].v){
        const val=r[i].v*2;score+=val;result[dest]=val;
        moves.push({value:val,from:r[i].orig,to:dest,lineIdx,isRow,pop:true});
        moves.push({value:r[i].v,from:r[i+1].orig,to:dest,lineIdx,isRow,ghost:true});
        i++;dest++;
      } else {
        result[dest]=r[i].v;
        moves.push({value:r[i].v,from:r[i].orig,to:dest,lineIdx,isRow});
        dest++;
      }
    }
    return{result,moves};
  }
  function move(dir){
    if(animating||gameOver||won)return;
    const prev=grid.map(r=>r.slice());
    let g=grid.map(r=>r.slice());
    let allMoves=[];
    if(dir==='left'){
      for(let r=0;r<4;r++){const{result,moves}=slideRowAnim(g[r],r,true);g[r]=result;allMoves.push(...moves);}
    } else if(dir==='right'){
      for(let r=0;r<4;r++){
        const rev=[...g[r]].reverse();
        const{result,moves}=slideRowAnim(rev,r,true);
        g[r]=result.reverse();
        allMoves.push(...moves.map(m=>({...m,from:3-m.from,to:3-m.to})));
      }
    } else if(dir==='up'){
      for(let cc=0;cc<4;cc++){
        const col=g.map(r=>r[cc]);
        const{result,moves}=slideRowAnim(col,cc,false);
        result.forEach((v,r)=>g[r][cc]=v);
        allMoves.push(...moves);
      }
    } else if(dir==='down'){
      for(let cc=0;cc<4;cc++){
        const col=g.map(r=>r[cc]).reverse();
        const{result,moves}=slideRowAnim(col,cc,false);
        result.reverse().forEach((v,r)=>g[r][cc]=v);
        allMoves.push(...moves.map(m=>({...m,from:3-m.from,to:3-m.to})));
      }
    }
    if(JSON.stringify(g)===JSON.stringify(prev))return;
    grid=g;addRandom(grid);
    if(grid.flat().includes(2048))won=true;
    const hasMove=grid.flat().includes(0)||grid.some((r,ri)=>r.some((v,ci)=>(ci<3&&v===grid[ri][ci+1])||(ri<3&&v===grid[ri+1][ci])));
    if(!hasMove)gameOver=true;
    scoreEl.textContent='score '+score;
    anims=allMoves;animT=0;animating=true;
  }
  function drawTile(x,y,cell,v,scale){
    if(!v)return;
    const s=scale??1;
    const dx=x+cell/2*(1-s),dy=y+cell/2*(1-s),dw=cell*s,dh=cell*s;
    ctx.fillStyle=TILE_COLORS[v]||'#3d3a32';
    ctx.beginPath();ctx.roundRect?ctx.roundRect(dx,dy,dw,dh,6*s):ctx.rect(dx,dy,dw,dh);ctx.fill();
    const fs=(v<100?cell*0.42:v<1000?cell*0.34:cell*0.26)*s;
    ctx.fillStyle=v<=4?'#776e65':'#f9f6f2';
    ctx.font='700 '+fs+'px \'IBM Plex Mono\',monospace';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(v,x+cell/2,y+cell/2+2*s);
  }
  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    const SZ=Math.min(W,H)-40,gap=SZ*0.03,cell=(SZ-gap*5)/4,cs=cell+gap;
    const ox=(W-SZ)/2,oy=(H-SZ)/2;
    ctx.fillStyle=isPaper()?'#f0e4d8':'#1a1610';ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#bbada0';ctx.beginPath();ctx.roundRect?ctx.roundRect(ox,oy,SZ,SZ,8):ctx.rect(ox,oy,SZ,SZ);ctx.fill();
    for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++){
      ctx.fillStyle=isPaper()?'rgba(180,160,140,0.35)':'rgba(0,0,0,0.25)';
      const x=ox+gap+cc*cs,y=oy+gap+r*cs;
      ctx.beginPath();ctx.roundRect?ctx.roundRect(x,y,cell,cell,4):ctx.rect(x,y,cell,cell);ctx.fill();
    }
    if(animating){
      animT+=0.016;
      const t=Math.min(1,animT/ANIM_DUR);
      const ease=t<0.5?2*t*t:1-Math.pow(-2*t+2,2)/2;
      for(const a of anims){
        if(a.ghost)continue;
        let fr,fc,tr2,tc2;
        if(a.isRow){fr=a.lineIdx;fc=a.from;tr2=a.lineIdx;tc2=a.to;}
        else{fr=a.from;fc=a.lineIdx;tr2=a.to;tc2=a.lineIdx;}
        const sx2=ox+gap+fc*cs,sy2=oy+gap+fr*cs;
        const ex=ox+gap+tc2*cs,ey=oy+gap+tr2*cs;
        const px=sx2+(ex-sx2)*ease,py=sy2+(ey-sy2)*ease;
        const scale=a.pop&&t>0.75?1+(t-0.75)*4*0.15*(1-(t-0.75)*4):1;
        drawTile(px,py,cell,a.value,Math.max(0.5,scale));
      }
      if(t>=1)animating=false;
    } else {
      for(let r=0;r<4;r++)for(let cc=0;cc<4;cc++){
        const v=grid[r][cc];if(!v)continue;
        drawTile(ox+gap+cc*cs,oy+gap+r*cs,cell,v);
      }
    }
    if(gameOver||won){
      ctx.fillStyle='rgba(238,228,218,0.73)';ctx.fillRect(ox,oy,SZ,SZ);
      ctx.fillStyle=won?'#f9f6f2':'#776e65';
      ctx.font='700 '+(SZ*0.1)+'px \'IBM Plex Mono\',monospace';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(won?'You Win!':'Game Over',W/2,H/2-16);
      ctx.font='300 12px \'IBM Plex Mono\',monospace';ctx.fillStyle='#776e65';
      ctx.fillText('press R to restart',W/2,H/2+18);
    }
  }
  const scoreEl=mkInfo(ctrl);
  mkBtn('New',ctrl).addEventListener('click',init);
  let tx=0,ty=0;
  c.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
  c.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;if(Math.abs(dx)>Math.abs(dy))move(dx>0?'right':'left');else move(dy>0?'down':'up');},{passive:true});
  const onKey=e=>{const m={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down'};if(m[e.key]){move(m[e.key]);e.preventDefault();}if(e.key==='r'||e.key==='R')init();};
  document.addEventListener('keydown',onKey);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();document.removeEventListener('keydown',onKey);};
}


// ════════════════════════════════════════════════════════════════════════════
// TOY 22 — DOUBLE PENDULUM
// ════════════════════════════════════════════════════════════════════════════
function initPendulum(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let pendulums=[];
  let trailCanvas=document.createElement('canvas');
  let tctx=trailCanvas.getContext('2d');
  let showTrails=true,paused=false,trailFade=0.012;

  function mkPendulumN(i,total){
    const hue=i/total*320;
    const paper=isPaper();
    const col=paper?`hsla(${hue},50%,25%,0.8)`:`hsla(${hue},90%,70%,0.85)`;
    return{a1:Math.PI/2+0.01+i*0.008,a2:Math.PI/2+i*0.005,v1:0,v2:0,l1:0,l2:0,m1:1,m2:1,col,trail:[]};
  }
  let numPendulums=2;
  function reset(){
    pendulums=Array.from({length:numPendulums},(_,i)=>mkPendulumN(i,numPendulums));
    trailCanvas.width=W||400;trailCanvas.height=H||400;
    tctx.fillStyle=bgClr();tctx.fillRect(0,0,trailCanvas.width,trailCanvas.height);
  }
  reset();

  const G=9.81,DT=0.04;
  function stepPendulum(p){
    const{a1,a2,v1,v2,m1,m2}=p;
    const l1=p.l1,l2=p.l2;
    const d=a1-a2,sd=Math.sin(d),cd=Math.cos(d);
    const denom1=(m1+m2)*l1-m2*l1*cd*cd;
    const denom2=(l2/l1)*denom1;
    const aa1=((m2*G*Math.sin(a2)*cd-m2*sd*(l2*v2*v2+l1*v1*v1*cd)-((m1+m2)*G*Math.sin(a1)))/denom1);
    const aa2=(((m1+m2)*(l1*v1*v1*sd-G*Math.sin(a2)+G*Math.sin(a1)*cd)+m2*l2*v2*v2*sd*cd)/denom2);
    p.v1+=aa1*DT;p.v2+=aa2*DT;
    p.a1+=p.v1*DT;p.a2+=p.v2*DT;
    p.v1*=0.9995;p.v2*=0.9995;
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    if(trailCanvas.width!==W||trailCanvas.height!==H){trailCanvas.width=W;trailCanvas.height=H;tctx.fillStyle=bgClr();tctx.fillRect(0,0,W,H);}
    const L=Math.min(W,H)*0.22;
    for(const p of pendulums){p.l1=L;p.l2=L;}
    const ox=W/2,oy=H*0.28;
    if(!paused){
      for(let i=0;i<3;i++)for(const p of pendulums)stepPendulum(p);
      // fade trails
      tctx.fillStyle=isPaper()?`rgba(245,241,232,${trailFade})`:`rgba(10,10,9,${trailFade})`;
      tctx.fillRect(0,0,W,H);
      // draw new trail points
      for(const p of pendulums){
        const x1=ox+Math.sin(p.a1)*p.l1;const y1=oy+Math.cos(p.a1)*p.l1;
        const x2=x1+Math.sin(p.a2)*p.l2;const y2=y1+Math.cos(p.a2)*p.l2;
        if(showTrails){tctx.strokeStyle=p.col;tctx.lineWidth=1.5;tctx.beginPath();if(p.trail.length>0){tctx.moveTo(p.trail[p.trail.length-1][0],p.trail[p.trail.length-1][1]);}tctx.lineTo(x2,y2);tctx.stroke();}
        p.trail.push([x2,y2]);if(p.trail.length>600)p.trail.shift();
      }
    }
    ctx.fillStyle=bgClr();ctx.fillRect(0,0,W,H);
    if(showTrails)ctx.drawImage(trailCanvas,0,0);
    // draw rods and bobs
    for(const p of pendulums){
      const x1=ox+Math.sin(p.a1)*p.l1,y1=oy+Math.cos(p.a1)*p.l1;
      const x2=x1+Math.sin(p.a2)*p.l2,y2=y1+Math.cos(p.a2)*p.l2;
      ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';ctx.lineWidth=1.5;
      ctx.beginPath();ctx.moveTo(ox,oy);ctx.lineTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
      [ox,x1,x2].forEach((x,i)=>{
        const y=[oy,y1,y2][i];const r=[4,10,8][i];
        ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);
        ctx.fillStyle=i===0?(isPaper()?'#555':'#888'):p.col.replace(/[\d.]+\)$/,'1)');ctx.fill();
      });
    }
    // pivot
    ctx.beginPath();ctx.arc(ox,oy,4,0,Math.PI*2);ctx.fillStyle=isPaper()?'#333':'#aaa';ctx.fill();
  }

  const trailBtn=mkBtn('Trails: On',ctrl,true);
  trailBtn.addEventListener('click',()=>{showTrails=!showTrails;trailBtn.textContent=`Trails: ${showTrails?'On':'Off'}`;setLit(trailBtn,showTrails);});
  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';setLit(pauseBtn,paused);});
  mkBtn('Reset',ctrl).addEventListener('click',reset);

  const pLbl=document.createElement('span');pLbl.className='sb-info sb-speed-lbl';pLbl.style.marginLeft='4px';pLbl.textContent='count';ctrl.appendChild(pLbl);
  const psl=document.createElement('input');psl.type='range';psl.className='sb-slider';psl.min=1;psl.max=20;psl.step=1;psl.value=numPendulums;ctrl.appendChild(psl);styleSlider(psl);
  psl.addEventListener('input',()=>{numPendulums=+psl.value;reset();});

  const fadeLbl=document.createElement('span');fadeLbl.className='sb-info sb-speed-lbl';fadeLbl.style.marginLeft='4px';fadeLbl.textContent='fade';ctrl.appendChild(fadeLbl);
  const fsl=document.createElement('input');fsl.type='range';fsl.className='sb-slider';fsl.min=0.001;fsl.max=0.15;fsl.step=0.001;fsl.value=trailFade;ctrl.appendChild(fsl);styleSlider(fsl);
  fsl.addEventListener('input',()=>trailFade=+fsl.value);
  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

