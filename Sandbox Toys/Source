// TOY — MAHJONG SOLITAIRE
// ════════════════════════════════════════════════════════════════════════════
function initMahjong(body,ctrl){
  // Create canvas manually — sized every frame so it always matches the body
  const c=document.createElement('canvas');
  c.style.cssText='position:absolute;inset:0;display:block;';
  body.appendChild(c);
  const ctx=c.getContext('2d');
  let raf;

  // ── Tile types ────────────────────────────────────────────────────────────
  // 34 base types × 4 copies = 136 + 8 bonus = 144 tiles / 72 pairs
  const TYPES=[
    {k:0, label:'1',short:'B',col:'#1a9944'},{k:1, label:'2',short:'B',col:'#1a9944'},
    {k:2, label:'3',short:'B',col:'#1a9944'},{k:3, label:'4',short:'B',col:'#1a9944'},
    {k:4, label:'5',short:'B',col:'#1a9944'},{k:5, label:'6',short:'B',col:'#1a9944'},
    {k:6, label:'7',short:'B',col:'#1a9944'},{k:7, label:'8',short:'B',col:'#1a9944'},
    {k:8, label:'9',short:'B',col:'#1a9944'},
    {k:9, label:'1',short:'C',col:'#bb3311'},{k:10,label:'2',short:'C',col:'#bb3311'},
    {k:11,label:'3',short:'C',col:'#bb3311'},{k:12,label:'4',short:'C',col:'#bb3311'},
    {k:13,label:'5',short:'C',col:'#bb3311'},{k:14,label:'6',short:'C',col:'#bb3311'},
    {k:15,label:'7',short:'C',col:'#bb3311'},{k:16,label:'8',short:'C',col:'#bb3311'},
    {k:17,label:'9',short:'C',col:'#bb3311'},
    {k:18,label:'1',short:'O',col:'#1155bb'},{k:19,label:'2',short:'O',col:'#1155bb'},
    {k:20,label:'3',short:'O',col:'#1155bb'},{k:21,label:'4',short:'O',col:'#1155bb'},
    {k:22,label:'5',short:'O',col:'#1155bb'},{k:23,label:'6',short:'O',col:'#1155bb'},
    {k:24,label:'7',short:'O',col:'#1155bb'},{k:25,label:'8',short:'O',col:'#1155bb'},
    {k:26,label:'9',short:'O',col:'#1155bb'},
    {k:27,label:'E', short:'W',col:'#776600'},{k:28,label:'S',short:'W',col:'#776600'},
    {k:29,label:'W', short:'W',col:'#776600'},{k:30,label:'N',short:'W',col:'#776600'},
    {k:31,label:'中',short:'D',col:'#773388'},{k:32,label:'發',short:'D',col:'#773388'},
    {k:33,label:'白',short:'D',col:'#773388'},
  ]; // 34 types, k = pair group (0-33)
  // Each type gets 4 tiles = 2 pairs. Pair id = k*2 or k*2+1
  // Build the full 144-spec list
  const SPECS=[];
  TYPES.forEach(t=>{
    SPECS.push({...t,pair:t.k*2});   SPECS.push({...t,pair:t.k*2});
    SPECS.push({...t,pair:t.k*2+1}); SPECS.push({...t,pair:t.k*2+1});
  }); // 136
  SPECS.push({label:'🌸',short:'F',col:'#bb4466',pair:200},{label:'🌸',short:'F',col:'#bb4466',pair:200});
  SPECS.push({label:'🌸',short:'F',col:'#bb4466',pair:201},{label:'🌸',short:'F',col:'#bb4466',pair:201});
  SPECS.push({label:'🍂',short:'S',col:'#bb6622',pair:202},{label:'🍂',short:'S',col:'#bb6622',pair:202});
  SPECS.push({label:'🍂',short:'S',col:'#bb6622',pair:203},{label:'🍂',short:'S',col:'#bb6622',pair:203});
  // 136 + 8 = 144 ✓

  // ── Layout: 144 positions ─────────────────────────────────────────────────
  const POS=[];
  for(let r=0;r<4;r++) for(let col=0;col<14;col++) POS.push({z:0,r,c:col});
  POS.push({z:0,r:1,c:-1},{z:0,r:2,c:-1},{z:0,r:1,c:14},{z:0,r:2,c:14}); // wings
  for(let col=1;col<13;col++) POS.push({z:0,r:4,c:col});                   // row4
  for(let r=1;r<4;r++) for(let col=1;col<13;col++) POS.push({z:1,r,c:col}); // L1
  for(let r=1;r<3;r++) for(let col=2;col<11;col++) POS.push({z:2,r,c:col}); // L2
  for(let r=1;r<3;r++) for(let col=5;col<9;col++)  POS.push({z:3,r,c:col}); // L3
  for(let r=1;r<3;r++) for(let col=6;col<8;col++)  POS.push({z:4,r,c:col}); // L4
  POS.push({z:5,r:1,c:6});                                                   // L5
  for(let col=1;col<6;col++) POS.push({z:0,r:5,c:col});                      // extra row
  // Total = 72+4+12+36+18+8+4+1+5 = 144 ✓... wait 72+4+12=88? No:
  // 4*14=56 + 4wings + 12row4 = 72, then +36+18+8+4+1+5 = 144 ✓

  // ── Game state ────────────────────────────────────────────────────────────
  let tiles=[], sel=null, score=0, moves=0;

  function shuffle(a){for(let i=a.length-1;i>0;i--){const j=0|Math.random()*(i+1);[a[i],a[j]]=[a[j],a[i]];}}

  function free(t,arr){
    if(t.gone) return false;
    if(arr.some(u=>!u.gone&&u.id!==t.id&&u.z===t.z+1&&Math.abs(u.r-t.r)<=1&&Math.abs(u.c-t.c)<=1)) return false;
    const bL=arr.some(u=>!u.gone&&u.id!==t.id&&u.z===t.z&&u.c===t.c-1&&Math.abs(u.r-t.r)<=1);
    const bR=arr.some(u=>!u.gone&&u.id!==t.id&&u.z===t.z&&u.c===t.c+1&&Math.abs(u.r-t.r)<=1);
    return !bL||!bR;
  }

  function newGame(){
    // Build solvable board: reverse-simulate, repeatedly pick 2 free slots and assign matching pairs
    let built=null;
    while(!built){
      const slots=POS.map((p,i)=>({...p,id:i,gone:false,pair:-1,label:'',short:'?',col:'#888'}));
      const specs=[...SPECS]; shuffle(specs);
      let ok=true;
      for(let step=0;step<72;step++){
        const freeSlots=slots.filter(s=>!s.gone&&free(s,slots));
        if(freeSlots.length<2){ok=false;break;}
        shuffle(freeSlots);
        const a=freeSlots[0],b=freeSlots[1],sp=specs[step];
        a.pair=sp.pair; a.label=sp.label; a.short=sp.short; a.col=sp.col;
        b.pair=sp.pair; b.label=sp.label; b.short=sp.short; b.col=sp.col;
        a.gone=true; b.gone=true;
      }
      if(ok) built=slots;
    }
    tiles=built.map(s=>({...s,gone:false}));
    sel=null; score=0; moves=0;
  }

  function hasPair(){
    const f=tiles.filter(t=>!t.gone&&free(t,tiles));
    for(let i=0;i<f.length;i++) for(let j=i+1;j<f.length;j++) if(f[i].pair===f[j].pair) return true;
    return false;
  }

  function layout(W,H){
    // returns {tw,th,gx,gy} — tile size and grid origin
    const cols=16, rows=7; // grid spans c:-1..14 = 16, r:0..5 = 6, +1 buffer
    const tw=Math.min((W-16)/cols,(H-28)/rows);
    const th=tw*1.42;
    const gx=(W-tw*cols)/2+tw; // +tw offsets col -1 into view
    const gy=(H-th*rows)/2+16;
    return{tw,th,gx,gy};
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    // Always size canvas to body — works whether attached or detached
    const W=body.offsetWidth, H=body.offsetHeight;
    if(W<1||H<1) return;
    c.width=W; c.height=H;

    const paper=isPaper();
    ctx.fillStyle=paper?'#e8e0d0':'#0d1117';
    ctx.fillRect(0,0,W,H);

    if(!tiles.length) return;

    const {tw,th,gx,gy}=layout(W,H);
    const sorted=[...tiles].sort((a,b)=>a.z-b.z||a.r-b.r||a.c-b.c);

    for(const t of sorted){
      if(t.gone) continue;
      const isF=free(t,tiles);
      const isSel=sel&&sel.id===t.id;
      const x=gx+t.c*tw+t.z*3;
      const y=gy+t.r*th-t.z*4;
      const w=tw-2, h=th-2;

      // shadow
      ctx.fillStyle='rgba(0,0,0,0.2)';
      ctx.beginPath(); ctx.roundRect(x+3,y+3,w,h,3); ctx.fill();
      // body
      ctx.fillStyle=isSel?'#ffe84d':isF?(paper?'#faf6ee':'#252d3a'):(paper?'#c8c0b0':'#161b22');
      ctx.beginPath(); ctx.roundRect(x,y,w,h,3); ctx.fill();
      // colour band
      ctx.fillStyle=isF?t.col:(paper?'#bbb':'#333');
      ctx.beginPath(); ctx.roundRect(x+1,y+1,w-2,h*0.27,2); ctx.fill();
      // border
      ctx.strokeStyle=isSel?'#cc9900':isF?(paper?'rgba(0,0,0,0.25)':'rgba(255,255,255,0.15)'):'rgba(128,128,128,0.12)';
      ctx.lineWidth=isSel?2:1;
      ctx.beginPath(); ctx.roundRect(x,y,w,h,3); ctx.stroke();
      // label
      const lsz=Math.max(6,tw*0.36|0);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.font=`700 ${lsz}px 'IBM Plex Mono',monospace`;
      ctx.fillStyle=isSel?'#222':isF?(paper?'#111':'#eee'):'#666';
      ctx.fillText(t.label,x+w/2,y+h*0.67);
      // suit tag
      ctx.font=`500 ${Math.max(5,tw*0.21|0)}px 'IBM Plex Mono',monospace`;
      ctx.fillStyle='rgba(255,255,255,0.85)';
      ctx.fillText(t.short,x+w/2,y+h*0.15);
    }

    // HUD
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;
    ctx.fillText(`tiles: ${tiles.filter(t=>!t.gone).length}/144  score: ${score}  pairs: ${moves}`,6,4);

    const allGone=tiles.every(t=>t.gone);
    const noMoves=!allGone&&!hasPair();
    if(allGone||noMoves){
      ctx.fillStyle=paper?'rgba(245,241,232,0.93)':'rgba(13,17,23,0.93)';
      ctx.fillRect(0,0,W,H);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      if(allGone){
        ctx.fillStyle=paper?'#226622':'#44ee88';
        ctx.font=`700 20px 'IBM Plex Mono',monospace`;
        ctx.fillText('Board cleared! 🎉',W/2,H/2-14);
      } else {
        ctx.fillStyle=paper?'#882222':'#ff5555';
        ctx.font=`700 18px 'IBM Plex Mono',monospace`;
        ctx.fillText('No more moves',W/2,H/2-14);
      }
      ctx.fillStyle=paper?'#555':'rgba(255,255,255,0.5)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(`score: ${score}  ·  ${moves} pairs  ·  click New Game`,W/2,H/2+12);
    }
    ctx.textAlign='left';
  }

  c.addEventListener('click',e=>{
    const W=c.width, H=c.height;
    const rect=c.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(W/rect.width);
    const my=(e.clientY-rect.top)*(H/rect.height);
    const {tw,th,gx,gy}=layout(W,H);
    let hit=null;
    for(const t of tiles){
      if(t.gone||!free(t,tiles)) continue;
      const x=gx+t.c*tw+t.z*3, y=gy+t.r*th-t.z*4;
      if(mx>=x&&mx<=x+tw-2&&my>=y&&my<=y+th-2)
        if(!hit||t.z>hit.z) hit=t;
    }
    if(!hit) return;
    if(sel){
      if(sel.id===hit.id){sel=null;return;}
      if(sel.pair===hit.pair){
        sel.gone=true; hit.gone=true;
        score+=10*(sel.z+hit.z+2); moves++; sel=null;
      } else { sel=hit; }
    } else { sel=hit; }
  });

  mkBtn('New Game',ctrl).addEventListener('click',()=>newGame());
  mkInfo(ctrl).textContent='match free pairs · clear all 144';

  newGame();
  requestAnimationFrame(draw);
  return ()=>{ cancelAnimationFrame(raf); };
}

