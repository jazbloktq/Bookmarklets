// TOY 6 — ELEMENT SANDBOX
// ════════════════════════════════════════════════════════════════════════════
function initElementSandbox(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height;
  const SCALE=3;
  let COLS=Math.floor(W/SCALE), ROWS=Math.floor(H/SCALE);

  // Elements: 0=empty,1=sand,2=water,3=stone,4=fire,5=ice,6=lava,7=steam,8=smoke
  const EMPTY=0,SAND=1,WATER=2,STONE=3,FIRE=4,ICE=5,LAVA=6,STEAM=7,SMOKE=8;
  const ELEMENTS=[
    {name:'Sand',  v:SAND},  {name:'Water', v:WATER}, {name:'Stone',v:STONE},
    {name:'Fire',  v:FIRE},  {name:'Ice',   v:ICE},   {name:'Lava', v:LAVA},
    {name:'Erase', v:EMPTY},
  ];

  // colours: base [r,g,b] with optional variation
  const COLS_MAP={
    [EMPTY]:[0,0,0,0],
    [SAND]: [194,174,134], [WATER]:[60,140,220], [STONE]:[120,115,110],
    [FIRE]: [255,80,20],   [ICE]:  [180,230,255],[LAVA]: [220,60,10],
    [STEAM]:[180,190,210], [SMOKE]:[90,85,80],
  };

  let grid=new Uint8Array(COLS*ROWS);
  // temperature grid for fire/lava propagation (0-255)
  let heat=new Uint8Array(COLS*ROWS);
  let raf, pouring=false, mouseGX=0, mouseGY=0, material=SAND;

  const idx=(x,y)=>y*COLS+x;
  const inBounds=(x,y)=>x>=0&&x<COLS&&y>=0&&y<ROWS;
  const get=(x,y)=>inBounds(x,y)?grid[idx(x,y)]:STONE;
  const set=(x,y,v)=>{if(inBounds(x,y)){grid[idx(x,y)]=v;}};
  const getH=(x,y)=>inBounds(x,y)?heat[idx(x,y)]:0;
  const setH=(x,y,v)=>{if(inBounds(x,y))heat[idx(x,y)]=Math.max(0,Math.min(255,v));};

  function step(){
    const dir=Math.random()<0.5?1:-1;
    // process bottom-up for falling, top-down pass for steam/fire
    for(let y=ROWS-1;y>=0;y--){
      for(let xi=0;xi<COLS;xi++){
        const x=dir>0?xi:COLS-1-xi;
        const v=get(x,y);
        if(v===EMPTY)continue;

        if(v===SAND){
          if(get(x,y+1)===EMPTY){set(x,y,EMPTY);set(x,y+1,SAND);}
          else if(get(x,y+1)===WATER){set(x,y,WATER);set(x,y+1,SAND);}// sink through water
          else if(get(x+dir,y+1)===EMPTY){set(x,y,EMPTY);set(x+dir,y+1,SAND);}
          else if(get(x-dir,y+1)===EMPTY){set(x,y,EMPTY);set(x-dir,y+1,SAND);}
          // fire turns sand to... nothing (just burns away, rarely)
          if(getH(x,y)>180&&Math.random()<0.01){set(x,y,EMPTY);setH(x,y,0);}
        }
        else if(v===WATER){
          // water + fire = steam (check first, skip movement if converting)
          if(getH(x,y)>120){set(x,y,STEAM);setH(x,y,40);continue;}
          // water + lava = stone
          if(get(x,y-1)===LAVA||get(x+1,y)===LAVA||get(x-1,y)===LAVA){set(x,y,STONE);continue;}
          // water freezes near ice
          if((get(x,y-1)===ICE||get(x+1,y)===ICE||get(x-1,y)===ICE)&&Math.random()<0.08){set(x,y,ICE);continue;}
          // water flows: treat STEAM as empty (flows through rising steam)
          const canFlow=t=>t===EMPTY||t===STEAM;
          if(canFlow(get(x,y+1))){set(x,y,EMPTY);set(x,y+1,WATER);}
          else if(canFlow(get(x+dir,y))){set(x,y,EMPTY);set(x+dir,y,WATER);}
          else if(canFlow(get(x-dir,y))){set(x,y,EMPTY);set(x-dir,y,WATER);}
        }
        else if(v===FIRE){
          // fire rises
          if(get(x,y-1)===EMPTY&&Math.random()<0.6){set(x,y,EMPTY);set(x,y-1,FIRE);setH(x,y-1,220);}
          else if(get(x+dir,y-1)===EMPTY&&Math.random()<0.4){set(x,y,EMPTY);set(x+dir,y-1,FIRE);setH(x+dir,y-1,200);}
          // fire spreads heat
          setH(x,y,230);
          setH(x,y-1,Math.max(getH(x,y-1),200));
          setH(x+1,y,Math.max(getH(x+1,y),160));
          setH(x-1,y,Math.max(getH(x-1,y),160));
          // fire produces smoke
          if(get(x,y-1)===EMPTY&&Math.random()<0.15){set(x,y-1,SMOKE);}
          // fire dies out
          if(Math.random()<0.03){set(x,y,EMPTY);setH(x,y,0);}
          // fire melts ice
          if(get(x,y+1)===ICE||get(x+1,y)===ICE||get(x-1,y)===ICE){
            const tx=x+(Math.random()<0.5?1:-1),ty=y+(Math.random()<0.5?1:0);
            if(get(tx,ty)===ICE){set(tx,ty,WATER);}
          }
          // fire ignites lava drips on sand/stone
          if(get(x,y+1)===STONE&&Math.random()<0.001){set(x,y+1,LAVA);}
        }
        else if(v===ICE){
          // ice melts if surrounded by heat
          if(getH(x,y)>100&&Math.random()<0.04){set(x,y,WATER);setH(x,y,0);}
        }
        else if(v===LAVA){
          if(get(x,y+1)===EMPTY){set(x,y,EMPTY);set(x,y+1,LAVA);}
          else if(get(x+dir,y+1)===EMPTY){set(x,y,EMPTY);set(x+dir,y+1,LAVA);}
          else if(get(x-dir,y+1)===EMPTY){set(x,y,EMPTY);set(x-dir,y+1,LAVA);}
          else if(get(x+dir,y)===EMPTY){set(x,y,EMPTY);set(x+dir,y,LAVA);}
          else if(get(x-dir,y)===EMPTY){set(x,y,EMPTY);set(x-dir,y,LAVA);}
          // lava spawns fire above
          if(get(x,y-1)===EMPTY&&Math.random()<0.12){set(x,y-1,FIRE);setH(x,y-1,230);}
          setH(x,y,240);setH(x,y-1,Math.max(getH(x,y-1),200));
          // lava cools to stone over time
          if(Math.random()<0.002){set(x,y,STONE);}
          // lava + water = stone
          if(get(x,y+1)===WATER||get(x+1,y)===WATER||get(x-1,y)===WATER){set(x,y,STONE);}
        }
        else if(v===STEAM){
          // steam rises fast
          if(get(x,y-1)===EMPTY){set(x,y,EMPTY);set(x,y-1,STEAM);}
          else if(get(x+dir,y-1)===EMPTY){set(x,y,EMPTY);set(x+dir,y-1,STEAM);}
          else if(get(x+dir,y)===EMPTY){set(x,y,EMPTY);set(x+dir,y,STEAM);}
          else if(get(x-dir,y)===EMPTY){set(x,y,EMPTY);set(x-dir,y,STEAM);}
          // steam condenses
          if(Math.random()<0.004){set(x,y,WATER);}
          // steam dissipates
          if(Math.random()<0.006){set(x,y,EMPTY);}
        }
        else if(v===SMOKE){
          if(get(x,y-1)===EMPTY&&Math.random()<0.5){set(x,y,EMPTY);set(x,y-1,SMOKE);}
          else if(get(x+dir,y-1)===EMPTY&&Math.random()<0.3){set(x,y,EMPTY);set(x+dir,y-1,SMOKE);}
          else if(get(x+dir,y)===EMPTY&&Math.random()<0.2){set(x,y,EMPTY);set(x+dir,y,SMOKE);}
          if(Math.random()<0.008){set(x,y,EMPTY);}
        }
        // heat diffusion and decay
        if(heat[idx(x,y)]>0){
          heat[idx(x,y)]=Math.max(0,heat[idx(x,y)]-2);
          if(inBounds(x,y-1))heat[idx(x,y-1)]=Math.max(heat[idx(x,y-1)],Math.floor(heat[idx(x,y)]*0.7));
        }
      }
    }

    if(pouring){
      const r2=material===STONE?3:2;
      for(let i=-r2;i<=r2;i++) for(let j=-r2;j<=r2;j++)
        if(Math.random()<0.55&&i*i+j*j<=r2*r2) set(mouseGX+i,mouseGY+j,material);
    }

    // render
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    COLS=Math.floor(W/SCALE); ROWS=Math.floor(H/SCALE);
    const imageData=ctx.createImageData(W,H);
    const d=imageData.data;
    const paper=isPaper();
    const [br,bg,bb]=paper?[245,241,232]:[10,10,9];
    for(let y=0;y<ROWS;y++) for(let x=0;x<COLS;x++){
      const v=get(x,y);
      let r=br,g=bg,b=bb;
      if(v!==EMPTY){
        const base=COLS_MAP[v];
        // add slight noise for texture
        const noise=(Math.random()-0.5)*12;
        if(v===FIRE){
          // fire flickers: orange→yellow→white
          const flicker=Math.random();
          r=Math.min(255,220+flicker*35);g=Math.min(255,30+flicker*130);b=Math.min(255,flicker*40);
        } else if(v===LAVA){
          const flicker=Math.random();
          r=Math.min(255,200+flicker*55);g=Math.max(0,20+flicker*80);b=0;
        } else if(v===STEAM||v===SMOKE){
          const a=v===STEAM?0.45:0.6;
          r=Math.round(br*(1-a)+base[0]*a+noise);
          g=Math.round(bg*(1-a)+base[1]*a+noise);
          b=Math.round(bb*(1-a)+base[2]*a+noise);
        } else {
          r=Math.max(0,Math.min(255,base[0]+noise));
          g=Math.max(0,Math.min(255,base[1]+noise));
          b=Math.max(0,Math.min(255,base[2]+noise));
          if(paper&&v===WATER){r=120;g=160;b=200;}
          if(paper&&v===ICE){r=200;g=225;b=245;}
        }
      }
      for(let py=0;py<SCALE;py++) for(let px=0;px<SCALE;px++){
        const i=((y*SCALE+py)*W+(x*SCALE+px))*4;
        d[i]=r;d[i+1]=g;d[i+2]=b;d[i+3]=255;
      }
    }
    ctx.putImageData(imageData,0,0);
    raf=requestAnimationFrame(step);
  }

  const toGrid=e=>{const r=c.getBoundingClientRect();return{x:Math.floor((e.clientX-r.left)/SCALE),y:Math.floor((e.clientY-r.top)/SCALE)};};
  const onDown=e=>{pouring=true;const g=toGrid(e);mouseGX=g.x;mouseGY=g.y;};
  const onMove=e=>{if(!pouring)return;const g=toGrid(e);mouseGX=g.x;mouseGY=g.y;};
  const onUp=()=>pouring=false;
  c.addEventListener('mousedown',onDown);c.addEventListener('mousemove',onMove);
  c.addEventListener('mouseleave',onUp);window.addEventListener('mouseup',onUp);

  // element buttons
  const btns={};
  ELEMENTS.forEach(({name,v})=>{
    const b=mkBtn(name,ctrl,v===material);
    b.addEventListener('click',()=>{
      material=v;
      Object.entries(btns).forEach(([,bb])=>setLit(bb,false));
      setLit(b,true);
    });
    btns[v]=b;
  });
  mkBtn('Clear',ctrl).addEventListener('click',()=>{grid=new Uint8Array(COLS*ROWS);heat=new Uint8Array(COLS*ROWS);});
  requestAnimationFrame(step);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();window.removeEventListener('mouseup',onUp);};
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 7 — PONG  (logic verbatim from reference + difficulty)
// ════════════════════════════════════════════════════════════════════════════
function initPong(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height;
  const PW=10, PH=60, BR=6, RR=4;
  // difficulty: cpu lerp speed, initial ball speed
  const DIFFS = {
    easy:   {cpu:0.04, spd:3.0},
    medium: {cpu:0.07, spd:4.0},
    hard:   {cpu:0.13, spd:5.5},
  };
  let diff='medium';
  let p1,p2,ball,score1,score2,raf,mouseY;

  function init() {
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const spd=DIFFS[diff].spd;
    p1={x:14,y:H/2-PH/2}; p2={x:W-14-PW,y:H/2-PH/2};
    ball={x:W/2,y:H/2, vx:spd*(Math.random()<0.5?1:-1), vy:rndf(-2,2)};
    score1=0; score2=0; mouseY=H/2;
    scoreEl.textContent='0 — 0';
  }
  function step() {
    raf=requestAnimationFrame(step);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const cpu=DIFFS[diff].cpu;
    // player
    p1.y+=(mouseY-PH/2-p1.y)*0.15;
    p1.y=Math.max(0,Math.min(H-PH,p1.y));
    // cpu
    p2.y+=(ball.y-PH/2-p2.y)*cpu;
    p2.y=Math.max(0,Math.min(H-PH,p2.y));
    // ball
    ball.x+=ball.vx; ball.y+=ball.vy;
    if(ball.y-BR<0){ball.y=BR;ball.vy=Math.abs(ball.vy);}
    if(ball.y+BR>H){ball.y=H-BR;ball.vy=-Math.abs(ball.vy);}
    // paddle collisions — matching reference exactly
    if(ball.x-BR<p1.x+PW&&ball.y>p1.y&&ball.y<p1.y+PH&&ball.vx<0){
      ball.vx=Math.abs(ball.vx)*1.05;
      ball.vy+=((ball.y-(p1.y+PH/2))/(PH/2))*2;
      ball.x=p1.x+PW+BR;
    }
    if(ball.x+BR>p2.x&&ball.y>p2.y&&ball.y<p2.y+PH&&ball.vx>0){
      ball.vx=-Math.abs(ball.vx)*1.05;
      ball.vy+=((ball.y-(p2.y+PH/2))/(PH/2))*2;
      ball.x=p2.x-BR;
    }
    // scoring
    const spd=DIFFS[diff].spd;
    if(ball.x<0){score2++;ball={x:W/2,y:H/2,vx:-spd,vy:rndf(-2,2)};scoreEl.textContent=score1+' — '+score2;}
    if(ball.x>W){score1++;ball={x:W/2,y:H/2,vx: spd,vy:rndf(-2,2)};scoreEl.textContent=score1+' — '+score2;}
    // draw
    ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
    ctx.strokeStyle=isPaper()?'rgba(0,0,0,0.07)':'rgba(255,255,255,0.07)';
    ctx.lineWidth=1; ctx.setLineDash([4,6]);
    ctx.beginPath(); ctx.moveTo(W/2,0); ctx.lineTo(W/2,H); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle=fgClr();
    [[p1.x,p1.y],[p2.x,p2.y]].forEach(([x,y])=>{ roundRect(ctx,x,y,PW,PH,RR); ctx.fill(); });
    ctx.beginPath(); ctx.arc(ball.x,ball.y,BR,0,Math.PI*2); ctx.fill();
  }
  const scoreEl=mkInfo(ctrl);
  const onMove = e => { const r=c.getBoundingClientRect(); mouseY=e.clientY-r.top; };
  c.addEventListener('mousemove',onMove);
  // difficulty buttons
  const diffBtns={};
  ['easy','medium','hard'].forEach(k=>{
    const b=mkBtn(k,ctrl,k===diff);
    b.addEventListener('click',()=>{
      diff=k;
      Object.entries(diffBtns).forEach(([dk,db])=>{ db.classList.toggle('lit',dk===k); styleBtn(db); });
      init();
    });
    diffBtns[k]=b;
  });
  mkBtn('New',ctrl).addEventListener('click',init);
  init(); requestAnimationFrame(step);
  return ()=>{ cancelAnimationFrame(raf); ro.disconnect(); c.removeEventListener('mousemove',onMove); };
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 8 — FLOW FIELD  (logic verbatim from reference + palette/paper mode)
// ════════════════════════════════════════════════════════════════════════════
function initFlow(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height;
  const RES=20;
  let COLS=Math.ceil(W/RES)+1, ROWS=Math.ceil(H/RES)+1;
  let NUM=200;
  let field=[], pts=[], raf, seed=Math.random()*1000, palIdx=0;
  const PALS=[
    t=>`hsla(${200+t*80},70%,65%,0.55)`,
    t=>`hsla(${20+t*50},80%,62%,0.55)`,
    t=>`hsla(${100+t*60},60%,58%,0.55)`,
    t=>`hsla(${280+t*80},65%,68%,0.55)`,
  ];

  function noise(x,y,z) {
    const X=Math.floor(x),Y=Math.floor(y),u=x-X,v=y-Y;
    const a=Math.sin(X*127.1+Y*311.7+z*74.3)*43758.5453;
    const b=Math.sin((X+1)*127.1+Y*311.7+z*74.3)*43758.5453;
    const cc=Math.sin(X*127.1+(Y+1)*311.7+z*74.3)*43758.5453;
    const d=Math.sin((X+1)*127.1+(Y+1)*311.7+z*74.3)*43758.5453;
    const lerp=(a,b,t)=>a+(b-a)*(t*t*(3-2*t));
    return lerp(lerp(a-Math.floor(a),b-Math.floor(b),u),lerp(cc-Math.floor(cc),d-Math.floor(d),u),v);
  }
  function buildField() {
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    COLS=Math.ceil(W/RES)+1; ROWS=Math.ceil(H/RES)+1;
    field=[];
    for(let y=0;y<ROWS;y++) for(let x=0;x<COLS;x++) {
      const angle=noise(x*0.15,y*0.15,seed)*Math.PI*4;
      field.push({ax:Math.cos(angle)*0.4, ay:Math.sin(angle)*0.4});
    }
  }
  function reset() {
    pts=Array.from({length:NUM},()=>({
      x:rndf(0,W), y:rndf(0,H), vx:0, vy:0,
      life:rndf(0.4,1), decay:rndf(0.003,0.008),
      size:rndf(0.8,2), opacity:rndf(0.2,0.5)
    }));
  }
  // step() replaced by step2() below
  const palNames=['Cyan','Ember','Forest','Violet'];
  const palBtn=mkBtn(`Palette: ${palNames[palIdx]}`,ctrl);
  palBtn.style.display=isPaper()?'none':'';
  palBtn.addEventListener('click',()=>{ palIdx=(palIdx+1)%PALS.length; palBtn.textContent=`Palette: ${palNames[palIdx]}`; });
  mkBtn('Regenerate',ctrl).addEventListener('click',()=>{ seed=Math.random()*1000; buildField(); ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H); });
  mkBtn('Clear trails',ctrl).addEventListener('click',()=>{ ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H); });

  // density label + slider
  const densLbl = document.createElement('span'); densLbl.className='sb-info sb-speed-lbl'; densLbl.style.marginLeft='4px'; densLbl.textContent='density'; ctrl.appendChild(densLbl);
  const densSlider = document.createElement('input'); densSlider.type='range'; densSlider.className='sb-slider'; densSlider.min=20; densSlider.max=800; densSlider.step=10; densSlider.value=NUM; ctrl.appendChild(densSlider); styleSlider(densSlider);
  densSlider.addEventListener('input',()=>{ NUM=+densSlider.value; reset(); });
  let _lastTheme=theme;
  // override step to also sync palette button visibility
  function step2(){
    if(theme!==_lastTheme){ _lastTheme=theme; palBtn.style.display=isPaper()?'none':''; }
    raf=requestAnimationFrame(step2);
    const paper=isPaper();
    ctx.fillStyle=paper?bgFade(0.08):'rgba(10,10,9,0.08)';
    ctx.fillRect(0,0,W,H);
    for(const p of pts) {
      const gx=Math.floor(p.x/RES), gy=Math.floor(p.y/RES);
      const fi=gy*COLS+gx;
      if(fi>=0&&fi<field.length){ p.vx+=field[fi].ax; p.vy+=field[fi].ay; }
      p.vx*=0.95; p.vy*=0.95;
      p.x+=p.vx; p.y+=p.vy;
      p.life-=p.decay;
      if(p.life<=0||p.x<0||p.x>W||p.y<0||p.y>H){
        p.x=rndf(0,W); p.y=rndf(0,H); p.vx=0; p.vy=0; p.life=rndf(0.4,1);
      }
      ctx.globalAlpha=p.life*p.opacity;
      ctx.fillStyle=paper?fgClr():PALS[palIdx](p.life);
      ctx.beginPath(); ctx.arc(p.x,p.y,p.size,0,Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha=1;
  }
  ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
  buildField(); reset(); step2();
  return ()=>{ cancelAnimationFrame(raf); ro.disconnect(); };
}

// ════════════════════════════════════════════════════════════════════════════
// TOY 9 — BOIDS  (Reynolds flocking + cursor attraction)
// ════════════════════════════════════════════════════════════════════════════
function initBoids(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width, H=c.height;
  let NUM=120, mouse={x:W/2,y:H/2,inside:false}, attract=true;
  const boids=[];
  function mkBoid(){
    const angle=Math.random()*Math.PI*2;
    return {x:rndf(0,W),y:rndf(0,H),vx:Math.cos(angle)*2,vy:Math.sin(angle)*2};
  }
  function reset(){ boids.length=0; for(let i=0;i<NUM;i++) boids.push(mkBoid()); }
  reset();
  const PERCEPTION=80, MAX_SPD=3.2, MIN_SPD=1.2;
  const WEIGHTS={sep:1.6,ali:1.0,coh:0.9,cur:0.55};
  let raf;
  function step(){
    raf=requestAnimationFrame(step);
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    ctx.fillStyle=bgFade(0.18); ctx.fillRect(0,0,W,H);
    const paper=isPaper();
    for(const b of boids){
      let sx=0,sy=0,ax=0,ay=0,cx=0,cy=0,n=0;
      for(const o of boids){
        if(o===b)continue;
        const dx=o.x-b.x,dy=o.y-b.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<PERCEPTION){
          if(d<28){sx-=dx/(d||1);sy-=dy/(d||1);}
          ax+=o.vx;ay+=o.vy;cx+=o.x;cy+=o.y;n++;
        }
      }
      let fx=sx*WEIGHTS.sep, fy=sy*WEIGHTS.sep;
      if(n){fx+=ax/n*WEIGHTS.ali+(cx/n-b.x)*0.005*WEIGHTS.coh*80;fy+=ay/n*WEIGHTS.ali+(cy/n-b.y)*0.005*WEIGHTS.coh*80;}
      if(mouse.inside&&attract){const dx=mouse.x-b.x,dy=mouse.y-b.y,d=Math.sqrt(dx*dx+dy*dy)||1;fx+=(dx/d)*WEIGHTS.cur*MAX_SPD;fy+=(dy/d)*WEIGHTS.cur*MAX_SPD;}
      b.vx+=fx*0.04; b.vy+=fy*0.04;
      const spd=Math.sqrt(b.vx*b.vx+b.vy*b.vy)||1;
      const clamped=Math.min(MAX_SPD,Math.max(MIN_SPD,spd));
      b.vx=b.vx/spd*clamped; b.vy=b.vy/spd*clamped;
      b.x=(b.x+b.vx+W)%W; b.y=(b.y+b.vy+H)%H;
      // draw arrowhead
      const angle=Math.atan2(b.vy,b.vx);
      const sz=5;
      ctx.save(); ctx.translate(b.x,b.y); ctx.rotate(angle);
      ctx.beginPath(); ctx.moveTo(sz*2,0); ctx.lineTo(-sz,sz); ctx.lineTo(-sz,-sz); ctx.closePath();
      ctx.fillStyle=paper?`rgba(26,21,16,0.7)`:`rgba(200,220,255,0.75)`;
      ctx.fill(); ctx.restore();
    }
    ctx.globalAlpha=1;
  }
  c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;mouse.inside=true;});
  c.addEventListener('mouseleave',()=>mouse.inside=false);
  ctx.fillStyle=bgClr(); ctx.fillRect(0,0,W,H);
  const attractBtn=mkBtn('Attract: On',ctrl,true);
  attractBtn.addEventListener('click',()=>{attract=!attract;attractBtn.textContent=`Attract: ${attract?'On':'Off'}`;setLit(attractBtn,attract);});
  const densLbl=document.createElement('span');densLbl.className='sb-info sb-speed-lbl';densLbl.style.marginLeft='4px';densLbl.textContent='flock size';ctrl.appendChild(densLbl);
  const sl=document.createElement('input');sl.type='range';sl.className='sb-slider';sl.min=20;sl.max=300;sl.step=10;sl.value=NUM;ctrl.appendChild(sl);styleSlider(sl);
  sl.addEventListener('input',()=>{NUM=+sl.value;reset();});
  step();
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

