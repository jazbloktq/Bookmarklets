  // Compute keyboard geometry (call each frame so it stays responsive)
  function kbGeom(W,H,rows){
    // keyboard takes up fixed height at bottom
    const KB_H=Math.min(H*0.30, 130);
    const KEY_GAP=4;
    const ROW_GAP=5;
    const kh=(KB_H - ROW_GAP*2) / 3;           // height of each key row
    // Width: fit 10 keys across with gaps, with a small side margin
    const margin=8;
    const kw=Math.floor((W - margin*2 - KEY_GAP*9) / 10);
    return {KB_H, KEY_GAP, ROW_GAP, kh, kw, margin};
  }

  function tileSize(W,H,rows,KB_H){
    const gridMarginTop=10;
    const gridMarginBot=12;
    const availH=H - KB_H - gridMarginTop - gridMarginBot;
    const availW=W - 20;
    const byH=(availH - TILE_GAP*(rows-1)) / rows;
    const byW=(availW - TILE_GAP*(COLS-1)) / COLS;
    return Math.max(24, Math.min(54, byH, byW));
  }

