// TOY — LIGHTS OUT
// ════════════════════════════════════════════════════════════════════════════
function initLightsOut(body,ctrl){
  const {c,ctx,ro}=mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let difficulty=1;
  const DIFF_NAMES=['Easy','Medium','Hard'];
  const GRID_SIZES=[3,5,7];

  let grid,moves,best,solved,solvedFlash;

  function gs(){ return GRID_SIZES[difficulty]; }

  function newGame(){
    const n=gs();
    grid=Array.from({length:n},()=>Array(n).fill(false));
    moves=0; solved=false; solvedFlash=0;
    // Generate solvable puzzle: start solved, apply random toggles
    const toggles=difficulty===0?5:difficulty===1?12:20;
    for(let t=0;t<toggles;t++){
      const r=Math.floor(Math.random()*n);
      const c2=Math.floor(Math.random()*n);
      toggle(r,c2,true);
    }
    // If already solved (unlikely but possible), try again
    if(isSolved()) newGame();
  }

  function toggle(r,c2,silent){
    const n=gs();
    grid[r][c2]=!grid[r][c2];
    if(r>0) grid[r-1][c2]=!grid[r-1][c2];
    if(r<n-1) grid[r+1][c2]=!grid[r+1][c2];
    if(c2>0) grid[r][c2-1]=!grid[r][c2-1];
    if(c2<n-1) grid[r][c2+1]=!grid[r][c2+1];
    if(!silent){ moves++; }
  }

  function isSolved(){ return grid.every(row=>row.every(v=>!v)); }

  function cellAt(mx,my){
    const n=gs();
    const pad=20;
    const sz=Math.min((W-pad*2)/n,(H-pad*2-40)/n);
    const gx=(W-sz*n)/2,gy=(H-sz*n)/2+10;
    const col2=Math.floor((mx-gx)/sz);
    const row=Math.floor((my-gy)/sz);
    if(row<0||row>=n||col2<0||col2>=n) return null;
    return [row,col2];
  }

  let lastTs=0;
  function draw(ts){
    raf=requestAnimationFrame(draw);
    const dt=Math.min(60,ts-lastTs); lastTs=ts;
    W=c.width=body.clientWidth; H=c.height=body.clientHeight;
    const paper=isPaper();
    ctx.fillStyle=paper?'#f5f1e8':'#0d1117'; ctx.fillRect(0,0,W,H);

    if(solved) solvedFlash=Math.min(1,solvedFlash+dt/300);

    const n=gs();
    const pad=20;
    const sz=Math.min((W-pad*2)/n,(H-pad*2-40)/n);
    const gx=(W-sz*n)/2,gy=(H-sz*n)/2+10;
    const gap=sz*0.08;

    for(let r=0;r<n;r++){
      for(let c2=0;c2<n;c2++){
        const x=gx+c2*sz+gap/2,y=gy+r*sz+gap/2;
        const w2=sz-gap,h2=sz-gap;
        const lit=grid[r][c2];

        if(lit){
          // Lit cell — glowing yellow
          ctx.fillStyle=paper?'#f0c040':'#ffe060';
          roundRect(ctx,x,y,w2,h2,w2*0.15); ctx.fill();
          // Inner glow highlight
          ctx.fillStyle='rgba(255,255,220,0.5)';
          roundRect(ctx,x+w2*0.15,y+h2*0.08,w2*0.7,h2*0.32,w2*0.08); ctx.fill();
          // Outer glow
          ctx.shadowColor='rgba(255,220,0,0.6)';
          ctx.shadowBlur=sz*0.3;
          ctx.fillStyle='rgba(255,200,0,0.0)';
          roundRect(ctx,x,y,w2,h2,w2*0.15); ctx.fill();
          ctx.shadowBlur=0;
        } else {
          ctx.fillStyle=paper?'rgba(0,0,0,0.12)':'rgba(255,255,255,0.06)';
          roundRect(ctx,x,y,w2,h2,w2*0.15); ctx.fill();
        }
        ctx.strokeStyle=paper?'rgba(0,0,0,0.15)':'rgba(255,255,255,0.08)';
        ctx.lineWidth=1;
        roundRect(ctx,x,y,w2,h2,w2*0.15); ctx.stroke();
      }
    }

    // HUD
    ctx.textAlign='left'; ctx.textBaseline='top';
    ctx.fillStyle=paper?'rgba(0,0,0,0.35)':'rgba(255,255,255,0.35)';
    ctx.font=`300 10px 'IBM Plex Mono',monospace`;
    ctx.fillText(`moves: ${moves}`,8,6);

    if(solved){
      ctx.fillStyle=paper?`rgba(245,241,232,${solvedFlash*0.9})`:`rgba(13,17,23,${solvedFlash*0.9})`;
      ctx.fillRect(0,0,W,H);
      ctx.fillStyle=paper?'#226622':'#ffe060';
      ctx.font=`700 22px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('Lights Out! 🌑',W/2,H/2-14);
      ctx.fillStyle=paper?'#444':'rgba(255,255,255,0.55)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText(`solved in ${moves} moves`,W/2,H/2+12);
    }
    ctx.textAlign='left';
  }

  c.addEventListener('click',e=>{
    if(solved) return;
    const r2=c.getBoundingClientRect();
    const cell=cellAt(e.clientX-r2.left,e.clientY-r2.top);
    if(!cell) return;
    toggle(cell[0],cell[1]);
    if(isSolved()){ solved=true; }
  });
  c.addEventListener('touchstart',e=>{ e.preventDefault(); const r2=c.getBoundingClientRect(),t=e.touches[0]; const cell=cellAt(t.clientX-r2.left,t.clientY-r2.top); if(cell&&!solved){ toggle(cell[0],cell[1]); if(isSolved()) solved=true; } },{passive:false});

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{ difficulty=(difficulty+1)%3; diffBtn.textContent=DIFF_NAMES[difficulty]; newGame(); diffBtn.blur(); });
  mkBtn('New Game',ctrl).addEventListener('click',()=>{ newGame(); });
  mkInfo(ctrl).textContent='turn all lights off';

  newGame(); requestAnimationFrame(draw);
  return()=>{ cancelAnimationFrame(raf); ro.disconnect(); };
}


