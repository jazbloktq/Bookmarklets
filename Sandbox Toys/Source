      for(let col=0;col<COLS;col++){
        const gx=rowX+col*(ts2+TILE_GAP);
        let letter='', score=-1;
        if(row<guesses.length){ letter=guesses[row].word[col]; score=guesses[row].score[col]; }
        else if(isActive&&col<currentGuess.length){ letter=currentGuess[col]; }

        let bg;
        if(score===2) bg=clr('correct');
        else if(score===1) bg=clr('present');
        else if(score===0) bg=clr('absent');
        else bg=clr('empty');

        const border=(isActive&&col===currentGuess.length)?clr('activeBorder'):clr('border');

        ctx.fillStyle=bg;
        roundRect(ctx,gx,gy,ts2,ts2,4); ctx.fill();
        ctx.strokeStyle=border; ctx.lineWidth=(isActive&&col<currentGuess.length)?2:1;
        roundRect(ctx,gx,gy,ts2,ts2,4); ctx.stroke();

        if(letter){
          ctx.fillStyle=score>=0?clr('tileText'):clr('text');
          ctx.font=`700 ${Math.floor(ts2*0.50)}px 'IBM Plex Mono',monospace`;
          ctx.textAlign='center'; ctx.textBaseline='middle';
          ctx.fillText(letter,gx+ts2/2,gy+ts2/2);
        }
      }
    }

    // ── Keyboard ──────────────────────────────────────────────────────────
    // Row 0: QWERTYUIOP (10 keys)
    // Row 1: ASDFGHJKL  (9 keys, centred)
    // Row 2: ENTER + ZXCVBNM + ⌫
    for(let ri=0;ri<KB_ROWS.length;ri++){
      const row=KB_ROWS[ri];
      const ky=kbTop + ri*(kh+ROW_GAP);

      if(ri<2){
        // Simple letter rows
        const rowW=row.length*kw+(row.length-1)*KEY_GAP;
        const kx=(W-rowW)/2;
        for(let ci=0;ci<row.length;ci++){
          const ch=row[ci];
          const st=keyMap[ch]||0;
          let kbg=st===2?clr('correct'):st===1?clr('present'):st===0?clr('absent'):clr('keyBg');
          ctx.fillStyle=kbg;
          roundRect(ctx,kx+ci*(kw+KEY_GAP),ky,kw,kh,4); ctx.fill();
          ctx.fillStyle=st>0?clr('tileText'):clr('keyText');
          ctx.font=`500 ${Math.max(9,Math.floor(kw*0.40))}px 'IBM Plex Mono',monospace`;
          ctx.textAlign='center'; ctx.textBaseline='middle';
          ctx.fillText(ch,kx+ci*(kw+KEY_GAP)+kw/2,ky+kh/2);
        }
      } else {
        // Bottom row: [ENTER] [Z X C V B N M] [⌫]
        // ENTER and ⌫ are 1.5× key width
        const enterW=Math.floor(kw*1.5);
        const bsW=Math.floor(kw*1.5);
        const nLetters=row.length; // 7
        const rowW=enterW+KEY_GAP + nLetters*kw+(nLetters-1)*KEY_GAP + KEY_GAP+bsW;
        const kx=(W-rowW)/2;

        // ENTER
        ctx.fillStyle=clr('keyBg');
        roundRect(ctx,kx,ky,enterW,kh,4); ctx.fill();
        ctx.fillStyle=clr('keyText');
        ctx.font=`500 ${Math.max(7,Math.floor(kw*0.30))}px 'IBM Plex Mono',monospace`;
        ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText('ENTER',kx+enterW/2,ky+kh/2);

        // Letter keys
        let lx=kx+enterW+KEY_GAP;
        for(let ci=0;ci<nLetters;ci++){
          const ch=row[ci];
          const st=keyMap[ch]||0;
          let kbg=st===2?clr('correct'):st===1?clr('present'):st===0?clr('absent'):clr('keyBg');
          ctx.fillStyle=kbg;
          roundRect(ctx,lx+ci*(kw+KEY_GAP),ky,kw,kh,4); ctx.fill();
          ctx.fillStyle=st>0?clr('tileText'):clr('keyText');
          ctx.font=`500 ${Math.max(9,Math.floor(kw*0.40))}px 'IBM Plex Mono',monospace`;
          ctx.textAlign='center'; ctx.textBaseline='middle';
          ctx.fillText(ch,lx+ci*(kw+KEY_GAP)+kw/2,ky+kh/2);
        }

        // ⌫
        const bsX=lx+nLetters*(kw+KEY_GAP);
        ctx.fillStyle=clr('keyBg');
        roundRect(ctx,bsX,ky,bsW,kh,4); ctx.fill();
        ctx.fillStyle=clr('keyText');
        ctx.font=`500 ${Math.max(11,Math.floor(kh*0.45))}px 'IBM Plex Mono',monospace`;
        ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText('⌫',bsX+bsW/2,ky+kh/2);
      }
    }
    ctx.textAlign='left';

    // ── Toast (inside the grid area, not above it) ─────────────────────────
    if(messageTimer>0&&message){
      const alpha=Math.min(1,messageTimer/250);
      ctx.globalAlpha=alpha;
      const mw=Math.min(W-32,260);
      const mh=34;
      const mx=(W-mw)/2;
      const my=gridY+gridH/2-mh/2; // vertically centred over grid
      ctx.fillStyle=clr('msgBg');
      roundRect(ctx,mx,my,mw,mh,8); ctx.fill();
      ctx.fillStyle=clr('msgText');
      ctx.font=`500 12px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(message,W/2,my+mh/2);
      ctx.globalAlpha=1;
      ctx.textAlign='left';
    }

    // ── Game over overlay ─────────────────────────────────────────────────
    if(gameOver&&messageTimer<=0){
      ctx.fillStyle=paper?'rgba(245,241,232,0.88)':'rgba(13,17,23,0.88)';
      ctx.fillRect(0,0,W,availForGrid); // only cover grid area, not keyboard
      ctx.fillStyle=won?(paper?'#226622':'#44ee88'):(paper?'#882222':'#ff5555');
      ctx.font=`700 22px 'IBM Plex Mono',monospace`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(won?'Solved! 🎉':answer,W/2,availForGrid/2-16);
      ctx.fillStyle=paper?'#444':'rgba(255,255,255,0.55)';
      ctx.font=`300 10px 'IBM Plex Mono',monospace`;
      ctx.fillText('Enter or tap New Word',W/2,availForGrid/2+14);
      ctx.textAlign='left';
    }
  }

  // ── Input ─────────────────────────────────────────────────────────────────
  const onKey=e=>{
    if(e.key==='Enter'||e.key==='Backspace') e.preventDefault();
    if(e.key==='Enter'){
      if(gameOver){ newGame(); return; }
      submitGuess(); return;
    }
    if(gameOver) return;
    if(e.key==='Backspace'){ currentGuess=currentGuess.slice(0,-1); }
    else if(e.key.length===1&&/[a-zA-Z]/.test(e.key)&&currentGuess.length<5){
      currentGuess+=e.key.toUpperCase();
    }
  };
  document.addEventListener('keydown',onKey);

  // Click on canvas keyboard
  c.addEventListener('click',e=>{
    const W2=c.clientWidth, H2=c.clientHeight;
    const r=c.getBoundingClientRect();
    const mx=e.clientX-r.left, my2=e.clientY-r.top;
    const rows=maxGuesses();
    const geo=kbGeom(W2,H2,rows);
    const {KB_H,KEY_GAP,ROW_GAP,kh,kw}=geo;
    const kbTop=H2-KB_H;

    // Check if click is in game-over overlay area
    if(gameOver&&my2<kbTop){ newGame(); return; }
    if(gameOver) return;

    for(let ri=0;ri<KB_ROWS.length;ri++){
      const row=KB_ROWS[ri];
      const ky=kbTop+ri*(kh+ROW_GAP);
      if(my2<ky||my2>ky+kh) continue;

      if(ri<2){
        const rowW=row.length*kw+(row.length-1)*KEY_GAP;
        const kx=(W2-rowW)/2;
        for(let ci=0;ci<row.length;ci++){
          const tx=kx+ci*(kw+KEY_GAP);
          if(mx>=tx&&mx<=tx+kw){ if(currentGuess.length<5) currentGuess+=row[ci]; return; }
        }
      } else {
        const enterW=Math.floor(kw*1.5);
        const bsW=Math.floor(kw*1.5);
        const nLetters=row.length;
        const rowW=enterW+KEY_GAP+nLetters*kw+(nLetters-1)*KEY_GAP+KEY_GAP+bsW;
        const kx=(W2-rowW)/2;
        if(mx>=kx&&mx<=kx+enterW){ submitGuess(); return; }
        let lx=kx+enterW+KEY_GAP;
        for(let ci=0;ci<nLetters;ci++){
          const tx=lx+ci*(kw+KEY_GAP);
          if(mx>=tx&&mx<=tx+kw){ if(currentGuess.length<5) currentGuess+=row[ci]; return; }
        }
        const bsX=lx+nLetters*(kw+KEY_GAP);
        if(mx>=bsX&&mx<=bsX+bsW){ currentGuess=currentGuess.slice(0,-1); return; }
      }
    }
  });

  const diffBtn=mkBtn(DIFF_NAMES[difficulty],ctrl);
  diffBtn.addEventListener('click',()=>{
    difficulty=(difficulty+1)%3;
    diffBtn.textContent=DIFF_NAMES[difficulty];
    newGame();
    diffBtn.blur();
  });
  const newWordBtn=mkBtn('New Word',ctrl);
  newWordBtn.addEventListener('click',()=>{ newGame(); newWordBtn.blur(); });
  mkInfo(ctrl).textContent='5-letter word game';

  requestAnimationFrame(draw2);
  return ()=>{ cancelAnimationFrame(raf2); ro.disconnect(); document.removeEventListener('keydown',onKey); };
}


