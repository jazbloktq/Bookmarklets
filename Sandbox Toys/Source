// TOY 29 — LORENZ ATTRACTOR
// ════════════════════════════════════════════════════════════════════════════
function initLorenz(body, ctrl) {
  const {c,ctx,ro} = mkCanvas(body);
  let W=c.width,H=c.height,raf;
  let points=[],paused=false,rotX=0.4,rotY=0,rotZ=0;
  let sigma=10,rho=28,beta=8/3,speed=6,trailLen=2000;
  let numAttractors=1,attractors=[];
  let isDragging=false,lastMX=0,lastMY=0;

  function mkAttractor(ox=0,oy=0,oz=0){
    return{x:ox,y:oy,z:oz,trail:[]};
  }

  function reset(){
    attractors=[];
    const cols=['#ff4488','#44aaff','#44ff88','#ffaa22'];
    for(let i=0;i<numAttractors;i++){
      const a=mkAttractor(rndf(-1,1),rndf(-1,1),rndf(20,30));
      a.col=cols[i%cols.length];
      a.trail=[];
      attractors.push(a);
    }
  }
  reset();

  function stepLorenz(a){
    const dt=0.008;
    const dx=sigma*(a.y-a.x)*dt;
    const dy=(a.x*(rho-a.z)-a.y)*dt;
    const dz=(a.x*a.y-beta*a.z)*dt;
    a.x+=dx;a.y+=dy;a.z+=dz;
    a.trail.push([a.x,a.y,a.z]);
    if(a.trail.length>trailLen)a.trail.shift();
  }

  // project 3D → 2D with rotation
  function project(px,py,pz){
    // rotate Y
    const cy=Math.cos(rotY),sy=Math.sin(rotY);
    const x1=px*cy+pz*sy,z1=-px*sy+pz*cy;
    // rotate X
    const cx=Math.cos(rotX),sx=Math.sin(rotX);
    const y2=py*cx-z1*sx,z2=py*sx+z1*cx;
    // rotate Z
    const cz=Math.cos(rotZ),sz2=Math.sin(rotZ);
    const x3=x1*cz-y2*sz2,y3=x1*sz2+y2*cz;
    // scale & center
    const scale=Math.min(W,H)*0.38/(30);
    return[W/2+x3*scale,H/2+y3*scale];
  }

  function draw(){
    raf=requestAnimationFrame(draw);
    W=c.width=body.clientWidth;H=c.height=body.clientHeight;
    if(!paused)for(let s=0;s<speed;s++)for(const a of attractors)stepLorenz(a);
    rotY+=0.002;

    ctx.fillStyle=bgFade(0.12);ctx.fillRect(0,0,W,H);

    for(const a of attractors){
      const trail=a.trail;if(trail.length<2)continue;
      for(let i=1;i<trail.length;i++){
        const t2=i/trail.length;
        const[x1,y1]=project(...trail[i-1]);
        const[x2,y2]=project(...trail[i]);
        const alpha=t2*t2*0.85;
        const paper=isPaper();
        if(paper){
          ctx.strokeStyle=a.col.replace(/^#/,'').match(/.{2}/g).reduce((s,h,idx)=>{
            const v=parseInt(h,16);return idx===0?`rgba(${v},`:s.replace(/,$/,`,${v},`);
          },'rgba(')+''+alpha+')';
        } else {
          const r2=parseInt(a.col.slice(1,3),16),g2=parseInt(a.col.slice(3,5),16),b2=parseInt(a.col.slice(5,7),16);
          ctx.strokeStyle=`rgba(${r2},${g2},${b2},${alpha})`;
        }
        ctx.lineWidth=0.8+t2*1.2;
        ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
      }
      // current head
      if(trail.length>0){
        const[hx,hy]=project(...trail[trail.length-1]);
        ctx.beginPath();ctx.arc(hx,hy,3,0,Math.PI*2);
        ctx.fillStyle=a.col;ctx.fill();
      }
    }

    // info
    const paper=isPaper();
    ctx.fillStyle=paper?'rgba(0,0,0,0.3)':'rgba(255,255,255,0.25)';
    ctx.font=`300 9px 'IBM Plex Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='top';
    ctx.fillText(`σ=${sigma.toFixed(1)} ρ=${rho.toFixed(1)} β=${beta.toFixed(2)}`,8,6);
    ctx.fillText('drag to rotate',8,18);
  }

  c.addEventListener('mousedown',e=>{isDragging=true;lastMX=e.clientX;lastMY=e.clientY;});
  c.addEventListener('mousemove',e=>{if(!isDragging)return;rotY+=(e.clientX-lastMX)*0.005;rotX+=(e.clientY-lastMY)*0.005;lastMX=e.clientX;lastMY=e.clientY;});
  c.addEventListener('mouseup',()=>isDragging=false);c.addEventListener('mouseleave',()=>isDragging=false);

  const pauseBtn=mkBtn('Pause',ctrl);
  pauseBtn.addEventListener('click',()=>{paused=!paused;pauseBtn.textContent=paused?'Resume':'Pause';setLit(pauseBtn,paused);});
  mkBtn('Reset',ctrl).addEventListener('click',reset);

  const rhoLbl=document.createElement('span');rhoLbl.className='sb-info sb-speed-lbl';rhoLbl.style.marginLeft='4px';rhoLbl.textContent='ρ';ctrl.appendChild(rhoLbl);
  const rhoSl=document.createElement('input');rhoSl.type='range';rhoSl.className='sb-slider';rhoSl.min=0.5;rhoSl.max=60;rhoSl.step=0.5;rhoSl.value=rho;ctrl.appendChild(rhoSl);styleSlider(rhoSl);
  rhoSl.addEventListener('input',()=>{rho=+rhoSl.value;reset();});

  const spdLbl=document.createElement('span');spdLbl.className='sb-info sb-speed-lbl';spdLbl.textContent='speed';ctrl.appendChild(spdLbl);
  const spdSl=document.createElement('input');spdSl.type='range';spdSl.className='sb-slider';spdSl.min=1;spdSl.max=20;spdSl.step=1;spdSl.value=speed;ctrl.appendChild(spdSl);styleSlider(spdSl);
  spdSl.addEventListener('input',()=>speed=+spdSl.value);

  const cntLbl2=document.createElement('span');cntLbl2.className='sb-info sb-speed-lbl';cntLbl2.textContent='paths';ctrl.appendChild(cntLbl2);
  const cntSl=document.createElement('input');cntSl.type='range';cntSl.className='sb-slider';cntSl.min=1;cntSl.max=4;cntSl.step=1;cntSl.value=numAttractors;ctrl.appendChild(cntSl);styleSlider(cntSl);
  cntSl.addEventListener('input',()=>{numAttractors=+cntSl.value;reset();});

  requestAnimationFrame(draw);
  return ()=>{cancelAnimationFrame(raf);ro.disconnect();};
}

