// ==========================================================================
//  VFX PLAYGROUND v3 — paste into browser console / run bookmark to activate
//  Run again to remove. Right-click ⚡ handle to remove entirely.
// ==========================================================================
(function () {
  if (document.getElementById('__vfx_root')) {
    document.getElementById('__vfx_root').remove();
    document.getElementById('__vfx_style')?.remove();
    console.log('[VFX] Removed. Paste again to restore.');
    return;
  }

  // ── FONTS ─────────────────────────────────────────────────────
  if (!document.getElementById('__vfx_font')) {
    const l = document.createElement('link');
    l.id = '__vfx_font'; l.rel = 'stylesheet';
    l.href = 'https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@800&display=swap';
    document.head.appendChild(l);
  }

  // ── CSS ───────────────────────────────────────────────────────
  const style = document.createElement('style');
  style.id = '__vfx_style';
  style.textContent = `
    #__vfx_root{position:fixed;inset:0;z-index:2147483647;pointer-events:none;}
    #__vfx_canvas{position:fixed;inset:0;pointer-events:none;z-index:2;}
    #__vfx_stage{position:fixed;inset:0;z-index:1;pointer-events:all;background:transparent;transition:background .4s;}
    #__vfx_stage.vfx-drawing{cursor:crosshair!important;}
    #__vfx_stage.vfx-erasing{cursor:cell!important;}
    #__vfx_panel{
      position:fixed;top:50%;right:20px;transform:translateY(-50%);
      width:224px;background:rgba(11,11,18,0.93);backdrop-filter:blur(14px);
      border:1px solid #252535;border-radius:14px;padding:15px 13px;
      box-shadow:0 0 50px rgba(0,0,0,.75),0 0 70px rgba(124,58,237,.07);
      pointer-events:all;z-index:10;user-select:none;
      transition:right .35s cubic-bezier(.4,0,.2,1);
    }
    #__vfx_panel.vfx-hidden{right:-248px;}
    #__vfx_toggle{
      position:fixed;right:0;top:50%;transform:translateY(-50%);
      width:27px;height:54px;background:rgba(11,11,18,0.93);backdrop-filter:blur(14px);
      border:1px solid #252535;border-right:none;border-radius:10px 0 0 10px;
      cursor:pointer;pointer-events:all;z-index:11;display:flex;align-items:center;
      justify-content:center;font-size:13px;color:#4a5568;
      transition:color .15s,background .15s;box-shadow:-4px 0 18px rgba(0,0,0,.55);
    }
    #__vfx_toggle:hover{color:#e2e8f0;background:rgba(22,22,34,.98);}
    .__vt{font-family:'Syne',sans-serif;font-size:10px;font-weight:800;letter-spacing:3px;
      text-transform:uppercase;color:#4a5568;padding-bottom:9px;border-bottom:1px solid #252535;margin-bottom:11px;}
    .__vs{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:#374151;margin:9px 0 5px;}
    .__vg{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
    .__vb{padding:7px 3px;border-radius:7px;border:1px solid #252535;background:rgba(255,255,255,.02);
      cursor:pointer;font-family:'Space Mono',monospace;font-size:9px;color:#4a5568;text-align:center;
      transition:all .12s;display:flex;flex-direction:column;align-items:center;gap:2px;outline:none;}
    .__vb .vi{font-size:15px;line-height:1;}
    .__vb:hover{border-color:#7c3aed;color:#e2e8f0;background:rgba(124,58,237,.12);transform:translateY(-1px);}
    .__vb.vfx-on{border-color:#7c3aed;background:rgba(124,58,237,.22);color:#a78bfa;box-shadow:0 0 9px rgba(124,58,237,.25);}
    .__vmr{display:flex;gap:4px;flex-wrap:wrap;}
    .__vm{flex:1;min-width:0;padding:6px 2px;border-radius:7px;border:1px solid #252535;
      background:rgba(255,255,255,.02);cursor:pointer;font-family:'Space Mono',monospace;
      font-size:8px;color:#4a5568;text-align:center;transition:all .12s;outline:none;
      letter-spacing:.3px;white-space:nowrap;}
    .__vm:hover{border-color:#06b6d4;color:#e2e8f0;}
    .__vm.vfx-on{border-color:#06b6d4;background:rgba(6,182,212,.15);color:#67e8f9;}
    .__vm.vfx-block-on{border-color:#f59e0b;background:rgba(245,158,11,.15);color:#fbbf24;}
    .__vm.vfx-erase-on{border-color:#ef4444;background:rgba(239,68,68,.15);color:#fca5a5;}
    .__vsr{display:flex;align-items:center;gap:5px;margin:4px 0;}
    .__vsl{font-size:8px;color:#374151;width:48px;flex-shrink:0;letter-spacing:.3px;}
    .__vri{-webkit-appearance:none;flex:1;height:3px;background:#252535;border-radius:2px;outline:none;cursor:pointer;}
