    #__vfx_pcap{position:fixed;bottom:16px;right:20px;pointer-events:none;z-index:10;
      font-size:8px;color:#1e293b;letter-spacing:.6px;font-family:'Space Mono',monospace;text-align:right;}
    #__vfx_pcap .pv{color:#4a5568;}
    .__vdp{position:fixed;pointer-events:none;z-index:8;
      border:2px dashed rgba(245,158,11,.7);background:rgba(245,158,11,.06);border-radius:3px;}
    .__vwz{position:fixed;pointer-events:none;z-index:7;
      border:2px dashed rgba(34,211,238,.6);background:rgba(34,211,238,.05);border-radius:3px;}
    .__vwz .wz-arrow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
      font-size:14px;color:rgba(34,211,238,.7);pointer-events:none;white-space:nowrap;}
